      { name: 'I (Bb)',  pressA: ['A5'],  resolveA: ['D5','Bb4'], pressB: ['Bb4'], resolveB: ['F5','A5'],  low: 'Bb3', walkBass: ['F3','D3'],   colorTone: 'C5' },
      { name: 'vi (Gm)', pressA: ['G5'],  resolveA: ['D5','Bb4'], pressB: ['G5'],  resolveB: ['D5','Bb4'], low: 'G3',  walkBass: ['D3','Bb3'],  colorTone: 'A5' },
      { name: 'IV (Eb)', pressA: ['Bb4'], resolveA: ['G5','Bb4'], pressB: ['Eb5'], resolveB: ['G5','Bb4'], low: 'Eb3', walkBass: ['Bb3','G3'],  colorTone: 'C5' },
      { name: 'I (Bb)',  pressA: ['F5'],  resolveA: ['D5','Bb4'], pressB: ['Bb4'], resolveB: ['D5','F5'],  low: 'Bb3', walkBass: ['F3','D3'],   colorTone: 'C5' },
      { name: 'V (F)',   pressA: ['C5'],  resolveA: ['F5','A5'],  pressB: ['F5'],  resolveB: ['C5','A5'],  low: 'F3',  walkBass: ['C3','A3'],   colorTone: 'G5' },
      { name: 'vi (Gm)', pressA: ['G5'],  resolveA: ['D5','Bb4'], pressB: ['Bb4'], resolveB: ['D5','G5'],  low: 'G3',  walkBass: ['D3','Bb3'],  colorTone: 'A5' },
      { name: 'I (Bb)',  pressA: ['Bb4'], resolveA: ['D5','F5'],  pressB: ['Bb4'], resolveB: ['F5','A5'],  low: 'Bb3', walkBass: ['F3','D3'],   colorTone: 'C5' }
    ];

    // ============================================================
    // Per-session randomization — seeded once at page load. Each visit
    // picks: which progression, density preset, and whether color tones
    // are on. Math.random() still drives per-loop jitter; this only
    // sets the session's "character."
    // ============================================================
    function mulberry32(seed) {
      return function() {
        let t = (seed += 0x6D2B79F5);
        t = Math.imul(t ^ (t >>> 15), t | 1);
        t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
      };
    }
    // Seed is sticky for the lifetime of a browser session (sessionStorage)
    // so the same combo plays across navigations. Fresh tab = fresh seed.
    let rabbitSeed;
    try {
      const stored = sessionStorage.getItem('rabbit.seed');
      if (stored) rabbitSeed = parseInt(stored, 10);
    } catch (e) {}
    if (!Number.isFinite(rabbitSeed)) {
      rabbitSeed = (Date.now() & 0xFFFFFFFF) ^
        ((screen.width || 1) * ((navigator.hardwareConcurrency || 4) + 17));
      try { sessionStorage.setItem('rabbit.seed', String(rabbitSeed)); } catch (e) {}
    }
    const rabbitRng = mulberry32(rabbitSeed);

    // Density profiles for the polyrhythm-event probability gates.
    const RABBIT_DENSITIES = {
      chill:  { ghost1: 0.25, ghost2: 0.30, shimmer: 0.20 },
      medium: { ghost1: 0.38, ghost2: 0.45, shimmer: 0.45 },
      dense:  { ghost1: 0.50, ghost2: 0.60, shimmer: 0.60 }
    };

    // Roll table — heavenly only. Density tiers + color toggle still vary
    // per session, but the progression is always heavenly father.
    const RABBIT_ROLL_TABLE = [
      { progKey: 'heavenly', presets: HEAVENLY_PRESETS, density: 'medium', color: false, weight: 13, label: 'vespers · medium' },
      { progKey: 'heavenly', presets: HEAVENLY_PRESETS, density: 'chill',  color: false, weight: 10, label: 'vespers · chill' },
      { progKey: 'heavenly', presets: HEAVENLY_PRESETS, density: 'dense',  color: false, weight: 6,  label: 'vespers · dense' },
      { progKey: 'heavenly', presets: HEAVENLY_PRESETS, density: 'medium', color: true,  weight: 3,  label: 'vespers · medium · color' },
      // Majestic: one combo, everything maxed.
      { progKey: 'heavenly', presets: HEAVENLY_PRESETS, density: 'dense',  color: true,  weight: 1,  label: 'lepus', majestic: true }
    ];

    function rabbitRollTier(weight) {
      if (weight <= 1) return 'majestic';
      if (weight <= 4) return 'rare';
      if (weight <= 9) return 'uncommon';
      return 'common';
    }

    // Weighted-random pick using rabbitRng (seeded once per page load).
    const RABBIT_ROLL_TOTAL = RABBIT_ROLL_TABLE.reduce((s, r) => s + r.weight, 0);
    const rabbitRollPick = (function() {
      let target = rabbitRng() * RABBIT_ROLL_TOTAL;
      for (let i = 0; i < RABBIT_ROLL_TABLE.length; i++) {
        target -= RABBIT_ROLL_TABLE[i].weight;
        if (target <= 0) return RABBIT_ROLL_TABLE[i];
      }
      return RABBIT_ROLL_TABLE[0];
    })();
    const rabbitDensity = RABBIT_DENSITIES[rabbitRollPick.density];
    const rabbitColorOn = rabbitRollPick.color;
    const rabbitRollPercent = (rabbitRollPick.weight / RABBIT_ROLL_TOTAL) * 100;
    const rabbitRollTierName = rabbitRollPick.majestic ? 'majestic' : rabbitRollTier(rabbitRollPick.weight);
    const PRETTY_PRESETS = rabbitRollPick.presets;

    // Catalog-style 10-digit signature — deterministic hash of the combo so
    // the same combination always yields the same number (return visitors
    // can recognize "got that one again"). djb2-style hash → 10 digits →
    // formatted XXXX·XXX·XXX like a stellar catalog identifier.
    function rabbitComboSignature(combo) {
      const key = combo.progKey + ':' + combo.density + ':' + (combo.color ? 'c' : 'd') + (combo.majestic ? ':*' : '');
      let h = 5381;
      for (let i = 0; i < key.length; i++) {
        h = (((h << 5) + h) + key.charCodeAt(i)) >>> 0;
      }
      const n = h % 1e10;
      const s = String(n).padStart(10, '0');
      return s.slice(0, 4) + '·' + s.slice(4, 7) + '·' + s.slice(7, 10);
    }
    const rabbitRollCode = rabbitComboSignature(rabbitRollPick);

    const PRETTY_WALK = [0, 1, 2, 3, 4, 5, 6];
    const PRETTY_WALK_MS = 5600;
    const PRETTY_WALK_SPREAD_MS = 1400;
    const PRETTY_DELAY_SETTLE_SECONDS = 240;
    const PRETTY_MASTER_GAIN = 1.55;
    const PRETTY_NOTE_LEVEL = 0.046;
    const PRETTY_LOW_LEVEL = 0.032;
    const PRETTY_DELAY_MIX_DEFAULT = 0.86;  // bumped from 0.72 — more wet
    let prettyDelayMix = PRETTY_DELAY_MIX_DEFAULT;

    function clamp01(value) {
      return Math.max(0, Math.min(1, value));
    }

    function syncPrettyDelayMixInput() {
      if (prettyDelayMixInput) {
        prettyDelayMixInput.value = Math.round(prettyDelayMix * 100);
        prettyDelayMixInput.style.setProperty('--delay-mix', prettyDelayMix);
      }
      // Promote to root so .note-star halo + paragraph blur can consume it
      if (document.documentElement) {
        document.documentElement.style.setProperty('--delay-mix', prettyDelayMix);
      }
    }

    // === Constellation art surface (lower-left, faded full-res plates) ===
    // Two stacked <img> elements alternating which is "active" via the
    // .is-active class. On switch, the inactive img's src loads the next
    // plate; once decoded, the active class swaps so CSS opacity transitions
    // crossfade old → new. Plates render at full source resolution (the
    // browser scales them to the container size) — preserves plate
    // detail rather than reducing to chunky pixels.
    const artContainer = document.querySelector('[data-constellation-art]');
    const artImgA = document.querySelector('[data-constellation-art-a]');
    const artImgB = document.querySelector('[data-constellation-art-b]');
    const ART_IMAGE_BASE = '/assets/constellations/';
    const ART_IMAGE_EXT = {
      lepus: 'webp', polaris: 'webp', bootes: 'jpg', crux: 'jpg',
      sirius: 'jpg', pleiades: 'webp', mizarAlcor: 'jpg', vega: 'jpg',
      reticulum: 'webp', epsilonEridani: 'jpg'
    };

    let artCurrentId = null;
    let artActiveSlot = 'a'; // which of the two imgs holds the visible plate
    function artUrlFor(id) {
      const ext = ART_IMAGE_EXT[id];
      if (!ext) return null;
      return ART_IMAGE_BASE + id + '.' + ext;
    }

    function initConstellationArt() {
      if (!artContainer || !artImgA || !artImgB) return;
      // Pre-decode all plates by setting src on hidden <img> instances. The
      // browser caches them so subsequent crossfades have zero loading delay.
      Object.keys(ART_IMAGE_EXT).forEach(function(id) {
        const pre = new Image();
        pre.decoding = 'async';
        pre.src = artUrlFor(id);
      });
    }

    function setConstellationArt(id) {
      if (!artContainer) return;
      if (id === artCurrentId) return;
      const url = artUrlFor(id);
      if (!url) return;
      const previousId = artCurrentId;
      artCurrentId = id;
      // Determine which img will host the new plate. If first-show, use A and
      // skip the crossfade; otherwise alternate slots.
      if (!previousId) {
        artImgA.src = url;
        artImgA.classList.add('is-active');
        artActiveSlot = 'a';
        return;
      }
      const incomingSlot = (artActiveSlot === 'a') ? 'b' : 'a';
      const incomingImg = (incomingSlot === 'a') ? artImgA : artImgB;
      const outgoingImg = (artActiveSlot === 'a') ? artImgA : artImgB;
      incomingImg.src = url;
      // Wait for the next plate to decode before swapping classes — avoids
      // a one-frame flash of the previous plate at the new src.
      const swap = function() {
        incomingImg.classList.add('is-active');
        outgoingImg.classList.remove('is-active');
        artActiveSlot = incomingSlot;
      };
      if (incomingImg.complete && incomingImg.naturalWidth > 0) {
        swap();
      } else {
        incomingImg.addEventListener('load', swap, { once: true });
      }
    }

    initConstellationArt();
    // Paint the initial active constellation (handled async via image onload).
    if (typeof activeConstellation !== 'undefined' && activeConstellation && activeConstellation.id) {
      setConstellationArt(activeConstellation.id);
    }

    // === Star tooltip data ===
    // Distance, apparent visual magnitude, spectral class for the 16 named
    // celestial bodies highlighted across the cycle + intro. Distances in
    // light-years (Sun in light-minutes for scale-grounding). Magnitudes are
    // apparent (what an unaided eye sees from Earth) — lower is brighter,
    // negative is brighter than Vega. Spectral class is the standard MK
    // (Morgan–Keenan) designation: O B A F G K M (hot to cool) + luminosity
    // class I-V (supergiant to main-sequence).
    const STAR_DATA = {
      'Sun':              { distance: '8.3 light-minutes', magnitude: '−26.74', class: 'G2V (yellow main-sequence)' },
      'Polaris':          { distance: '433 light-years',   magnitude: '1.98',   class: 'F7Ib (yellow supergiant, Cepheid variable)' },
      'Sirius':           { distance: '8.6 light-years',   magnitude: '−1.46',  class: 'A1V (white main-sequence; brightest star in the night sky)' },
      'R Leporis':        { distance: '~1,300 light-years', magnitude: '5.5–11.7 variable', class: 'C7 (carbon star; deepest red visible to the eye)' },
      'Acrux':            { distance: '320 light-years',   magnitude: '0.77',   class: 'B0.5IV+B1V (blue subgiant binary)' },
      'Vega':             { distance: '25 light-years',    magnitude: '0.03',   class: 'A0V (white main-sequence; magnitude reference)' },
      'Mizar':            { distance: '83 light-years',    magnitude: '2.04',   class: 'A1V (multiple star system)' },
      'Alcor':            { distance: '81 light-years',    magnitude: '4.0',    class: 'A5V (binary; eye-test companion to Mizar)' },
      'Alcyone':          { distance: '440 light-years',   magnitude: '2.85',   class: 'B7III (blue giant; brightest of the Pleiades)' },
      'Epsilon Eridani':  { distance: '10.5 light-years',  magnitude: '3.73',   class: 'K2V (orange dwarf; young Sun-like star)' },
      'Tau Ceti':         { distance: '11.9 light-years',  magnitude: '3.50',   class: 'G8V (Sun-like dwarf)' },
      'Thuban':           { distance: '303 light-years',   magnitude: '3.65',   class: 'A0III (white giant; pole star ~2700 BCE)' },
      'Achernar':         { distance: '139 light-years',   magnitude: '0.46',   class: 'B6Vpe (rapidly rotating blue main-sequence)' },
      'Canopus':          { distance: '310 light-years',   magnitude: '−0.74',  class: 'A9II (yellow-white supergiant; second-brightest night star)' },
      'Zeta Reticuli':    { distance: '39.4 light-years',  magnitude: '5.24 / 5.52', class: 'G3V + G2V (wide pair of Sun-like stars)' },
      'Alpha Reticuli':   { distance: '161 light-years',   magnitude: '3.33',   class: 'G8II–III (yellow giant)' }
    };

    let starTooltip = null;
    let starTooltipHideTimer = null;

    function buildStarTooltipRow(label, value) {
      const row = document.createElement('span');
      row.className = 'constellation-star-tooltip-row';
      const labelEl = document.createElement('span');
      labelEl.className = 'constellation-star-tooltip-label';
      labelEl.textContent = label;
      const valueEl = document.createElement('span');
      valueEl.className = 'constellation-star-tooltip-value';
      valueEl.textContent = value;
      row.appendChild(labelEl);
      row.appendChild(valueEl);
      return row;
    }

    function ensureStarTooltip() {
      if (starTooltip) return starTooltip;
      starTooltip = document.createElement('div');
      starTooltip.className = 'constellation-star-tooltip';
      starTooltip.setAttribute('role', 'tooltip');
      starTooltip.setAttribute('aria-hidden', 'true');
      document.body.appendChild(starTooltip);
      return starTooltip;
    }

    function showStarTooltip(targetEl, name) {
      const data = STAR_DATA[name];
      if (!data) return;
      const tip = ensureStarTooltip();
      if (starTooltipHideTimer) { clearTimeout(starTooltipHideTimer); starTooltipHideTimer = null; }
      // Rebuild contents via DOM API so values can never be parsed as HTML.
      while (tip.firstChild) tip.removeChild(tip.firstChild);
      const title = document.createElement('span');
      title.className = 'constellation-star-tooltip-title';
      title.textContent = name;
      tip.appendChild(title);
      tip.appendChild(buildStarTooltipRow('distance', data.distance));
      tip.appendChild(buildStarTooltipRow('apparent magnitude', data.magnitude));
      tip.appendChild(buildStarTooltipRow('spectral class', data.class));
      // Position relative to the hovered span; prefer below, flip above if no room.
      const rect = targetEl.getBoundingClientRect();
      tip.style.visibility = 'hidden';
      tip.classList.add('is-visible');
      const tipRect = tip.getBoundingClientRect();
      const margin = 8;
      let top = rect.bottom + margin;
      if (top + tipRect.height + margin > window.innerHeight) top = rect.top - tipRect.height - margin;
      let left = rect.left + (rect.width / 2) - (tipRect.width / 2);
      left = Math.max(margin, Math.min(window.innerWidth - tipRect.width - margin, left));
      tip.style.top = top + 'px';
      tip.style.left = left + 'px';
      tip.style.visibility = '';
      tip.setAttribute('aria-hidden', 'false');
    }

    function hideStarTooltip() {
      if (!starTooltip) return;
      if (starTooltipHideTimer) clearTimeout(starTooltipHideTimer);
      starTooltipHideTimer = setTimeout(function() {
        if (!starTooltip) return;
        starTooltip.classList.remove('is-visible');
        starTooltip.setAttribute('aria-hidden', 'true');
      }, 120);
    }

    function initStarTooltips() {
      // Delegate from document so dynamically-rendered note bodies also work.
      document.addEventListener('mouseover', function(event) {
        const target = event.target;
        if (!target || !target.classList || !target.classList.contains('note-star')) return;
        const name = (target.textContent || '').trim();
        if (!STAR_DATA[name]) return;
        showStarTooltip(target, name);
      });
      document.addEventListener('mouseout', function(event) {
        const target = event.target;
        if (!target || !target.classList || !target.classList.contains('note-star')) return;
        hideStarTooltip();
      });
    }

    initStarTooltips();

    // === Cursor tracker for constellation field interplay ===
    // Tracks cursor position so the constellation draw loop can apply
    // (1) differential parallax — stars shift less than lines shift less
    // than highlight points, giving a small depth illusion; (2) proximity
    // brightening — points within ~14 logical pixels of the mapped cursor
    // get an alpha bump. Mousemove writes module-level vars; the draw loop
    // reads them next frame. No CSS observers, no re-render trigger needed
    // (the rAF loop runs continuously while wave/rabbit is active).
    let cursorViewportX = -9999;
    let cursorViewportY = -9999;
    let cursorPresent = false;
    document.addEventListener('mousemove', function(event) {
      cursorViewportX = event.clientX;
      cursorViewportY = event.clientY;
      cursorPresent = true;
    }, { passive: true });
    document.addEventListener('mouseleave', function() {
      cursorPresent = false;
    });
    window.__getConstellationCursor = function() {
      return { x: cursorViewportX, y: cursorViewportY, present: cursorPresent };
    };

    // Loose audio→visual flare: each music step bumps --note-flare on root,
    // CSS interpolates filter:brightness back down. Not amplitude tracking;
    // a soft pulse synchronized with note onsets.
    let pendingFlareReset = 0;
    function pulseStarFlare() {
      const root = document.documentElement;
      if (!root) return;
      root.style.setProperty('--note-flare', '1');
      if (pendingFlareReset) cancelAnimationFrame(pendingFlareReset);
      pendingFlareReset = requestAnimationFrame(function() {
        pendingFlareReset = requestAnimationFrame(function() {
          root.style.setProperty('--note-flare', '0');
          pendingFlareReset = 0;
        });
      });
    }

    function getPrettyDelayProfileValues(age) {
      // Restored to original-live values 2026-05-11 — delay is the texture.
      // Warmth now comes from the in-loop lowpass dropped to 600Hz (see
      // getPrettyDelay below) rather than from cutting wet level.
      const mix = prettyDelayMix;
      const fadeAge = age * (1 - mix);
      return {
        feedback: Math.max(0.58, 0.72 + (0.14 * mix) - (0.13 * fadeAge)),
        wet: Math.max(0.12, 0.18 + (0.62 * mix) - ((0.08 + (0.12 * mix)) * fadeAge)),
        wetCeiling: Math.max(0.18, 0.26 + (0.58 * mix) - ((0.06 + (0.11 * mix)) * fadeAge))
      };
    }

    function getPrettySignalGainValue() {
      if (prettyDelayMix >= 1) return 0;
      if (prettyDelayMix <= 0) return 1;
      return Math.cos(prettyDelayMix * Math.PI * 0.5);
    }

    function setPrettyDelayMix(value, when) {
      prettyDelayMix = clamp01(Number.isFinite(value) ? value : PRETTY_DELAY_MIX_DEFAULT);
      syncPrettyDelayMixInput();
      if (audioCtx && audioCtx._prettyDelayControls) setPrettyDelayProfile(audioCtx, when);
      if (audioCtx && audioCtx._prettySignal) setPrettySignalProfile(audioCtx, when);
    }

    // Reverb — pre-delayed, dampened tail. Real rooms have a silent gap
    // before first reflections (the note speaks, THEN the room blooms), and
    // treble decays faster than bass (HF absorption by air/carpet/walls).
    // Per-channel decay rates differ slightly for stereo decorrelation.
    function getReverb(ctx) {
      if (ctx._reverbBus) return ctx._reverbBus;
      const seconds = 9.0;       // chapel-scale wash; notes bloom and bleed
      const preDelay = 0.035;    // 35ms silent intro — sense of space
      const sr = ctx.sampleRate;
      const len = Math.floor(sr * seconds);
      const preLen = Math.floor(sr * preDelay);
      const buf = ctx.createBuffer(2, len, sr);
      for (let ch = 0; ch < 2; ch++) {
        const d = buf.getChannelData(ch);
        const decayPower = ch === 0 ? 2.0 : 2.4;
        for (let i = 0; i < len; i++) {
          if (i < preLen) { d[i] = 0; continue; }
          const tailPos = (i - preLen) / (len - preLen);
          d[i] = (Math.random() * 2 - 1) * Math.pow(1 - tailPos, decayPower);
        }
      }
      const conv = ctx.createConvolver();
      conv.buffer = buf;
      // Heavy lowpass — removes white-noise-IR hash, leaves warm low-mid wash.
      // Music for Airports has little above ~4kHz in the wet signal.
      const damp = ctx.createBiquadFilter();
      damp.type = 'lowpass';
      damp.frequency.value = 1800;
      damp.Q.value = 0.5;
      conv.connect(damp).connect(ctx.destination);
      ctx._reverbBus = conv;
      return conv;
    }

    function getPrettyMaster(ctx) {
      if (ctx._prettyMaster) return ctx._prettyMaster;
      const master = ctx.createGain();
      master.gain.value = PRETTY_MASTER_GAIN;
      master.connect(ctx.destination);
      ctx._prettyMaster = master;
      return master;
    }

    function getPrettySignal(ctx) {
      if (ctx._prettySignal) return ctx._prettySignal;
      const signal = ctx.createGain();
      signal.gain.value = getPrettySignalGainValue();
      signal.connect(getPrettyMaster(ctx));
      ctx._prettySignal = signal;
      return signal;
    }

    function getPrettyReverb(ctx) {
      if (ctx._prettyReverbBus) return ctx._prettyReverbBus;
      const seconds = 9.0;
      const preDelay = 0.035;
      const sr = ctx.sampleRate;
      const len = Math.floor(sr * seconds);
      const preLen = Math.floor(sr * preDelay);
      const buf = ctx.createBuffer(2, len, sr);
      for (let ch = 0; ch < 2; ch++) {
        const d = buf.getChannelData(ch);
        const decayPower = ch === 0 ? 2.0 : 2.4;
        for (let i = 0; i < len; i++) {
          if (i < preLen) { d[i] = 0; continue; }
          const tailPos = (i - preLen) / (len - preLen);
          d[i] = (Math.random() * 2 - 1) * Math.pow(1 - tailPos, decayPower);
        }
      }
      const conv = ctx.createConvolver();
      conv.buffer = buf;
      const damp = ctx.createBiquadFilter();
      damp.type = 'lowpass';
      damp.frequency.value = 1800;
      damp.Q.value = 0.5;
      conv.connect(damp).connect(getPrettyMaster(ctx));
      ctx._prettyReverbBus = conv;
      ctx._prettyReverbNodes = [conv, damp];
      return conv;
    }

    function getPrettyDelay(ctx) {
      if (ctx._prettyDelay) return ctx._prettyDelay;
      const delay = ctx.createDelay(10.0);
      const filter = ctx.createBiquadFilter();
      const feedback = ctx.createGain();
      const wet = ctx.createGain();
      const limiter = ctx.createDynamicsCompressor();
      const wetCeiling = ctx.createGain();

      delay.delayTime.value = 0.52;
      filter.type = 'lowpass';
      filter.frequency.value = 600;  // warmer delay tail (was 820)
      filter.Q.value = 0.22;
      const initialDelayProfile = getPrettyDelayProfileValues(0);
      feedback.gain.value = initialDelayProfile.feedback;
      wet.gain.value = initialDelayProfile.wet;
      limiter.threshold.value = -16;
      limiter.knee.value = 4;
      limiter.ratio.value = 16;
      limiter.attack.value = 0.004;
      limiter.release.value = 0.34;
      wetCeiling.gain.value = initialDelayProfile.wetCeiling;

      delay.connect(filter);
      filter.connect(feedback);
      feedback.connect(delay);
      filter.connect(wet).connect(limiter).connect(wetCeiling).connect(getPrettyMaster(ctx));
      ctx._prettyDelay = delay;
      ctx._prettyDelayNodes = [delay, filter, feedback, wet, limiter, wetCeiling];
      ctx._prettyDelayControls = { feedback: feedback, wet: wet, wetCeiling: wetCeiling };
      return delay;
    }

    function getPrettyDelayAge(ctx, when) {
      if (!ctx || !prettyStartedAt) return 0;
      const t = when !== undefined ? when : ctx.currentTime;
      return Math.min(1, Math.max(0, (t - prettyStartedAt) / PRETTY_DELAY_SETTLE_SECONDS));
    }

    function setPrettyDelayProfile(ctx, when) {
      if (!ctx || !ctx._prettyDelayControls) return;
      const age = getPrettyDelayAge(ctx, when);
      const controls = ctx._prettyDelayControls;
      const t = when !== undefined ? when : ctx.currentTime;
      const profile = getPrettyDelayProfileValues(age);
      controls.feedback.gain.cancelScheduledValues(t);
      controls.wet.gain.cancelScheduledValues(t);
      controls.wetCeiling.gain.cancelScheduledValues(t);
      controls.feedback.gain.linearRampToValueAtTime(profile.feedback, t + 0.25);
      controls.wet.gain.linearRampToValueAtTime(profile.wet, t + 0.25);
      controls.wetCeiling.gain.linearRampToValueAtTime(profile.wetCeiling, t + 0.25);
    }

    function setPrettySignalProfile(ctx, when) {
      if (!ctx || !ctx._prettySignal) return;
      const t = when !== undefined ? when : ctx.currentTime;
      ctx._prettySignal.gain.cancelScheduledValues(t);
      ctx._prettySignal.gain.linearRampToValueAtTime(getPrettySignalGainValue(), t + 0.08);
    }

    function killPrettyAudio() {
      const ctx = audioCtx;
      if (!ctx) return;
      const now = ctx.currentTime;
      const master = ctx._prettyMaster;
      const signal = ctx._prettySignal;
      if (master) {
        try {
          master.gain.cancelScheduledValues(now);
          master.gain.setValueAtTime(0, now);
        } catch (e) {}
      }
      if (signal) {
        try {
          signal.gain.cancelScheduledValues(now);
          signal.gain.setValueAtTime(0, now);
        } catch (e) {}
      }

      const disconnectList = []
        .concat(signal ? [signal] : [])
        .concat(ctx._prettyDelayNodes || [])
        .concat(ctx._prettyReverbNodes || []);
      disconnectList.forEach(function(node) {
        try { node.disconnect(); } catch (e) {}
      });
      ctx._prettyDelay = null;
      ctx._prettyDelayNodes = null;
      ctx._prettyDelayControls = null;
      ctx._prettyReverbBus = null;
      ctx._prettyReverbNodes = null;
      ctx._prettySignal = null;

      if (master) {
        try { master.disconnect(); } catch (e) {}
        if (ctx._prettyMaster === master) ctx._prettyMaster = null;
      }
    }

    // Piano voice — one modeled key/body transient into the shared reverb bus.
    function playPianoNote(freq, when, sustain, levelOverride, withLowFloor, delayBus, outputBus) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = (when !== undefined) ? when : ctx.currentTime;
      const sus = sustain || 9.0;
      const level = levelOverride !== undefined ? levelOverride : 0.068;
      const output = outputBus || ctx.destination;
      const reverb = outputBus ? getPrettyReverb(ctx) : getReverb(ctx);
      playAcousticKey(freq, t, sus, level, reverb, delayBus, output);
      if (withLowFloor) playLowFloor(freq, t, sus, level * 0.28, reverb, output);
    }

    // Quiet acoustic-piano layer: a small modeled hammer/body event plus room.
    function playAcousticKey(freq, when, sustain, level, reverb, delayBus, outputBus) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = when !== undefined ? when : ctx.currentTime;
      const output = outputBus || ctx.destination;
      const dur = Math.min(4.8, Math.max(2.4, sustain * 0.56));
      const trebleMellow = freq >= 800 ? 0.74 : (freq >= 650 ? 0.88 : 1);
      const upperPartialScale = freq >= 800 ? 0.55 : (freq >= 650 ? 0.72 : 1);
      const hammerScale = freq >= 800 ? 0.24 : (freq >= 650 ? 0.48 : 1);
      const attackTime = freq >= 800 ? 0.032 : (freq >= 650 ? 0.022 : 0.012);
      const partialAttack = freq >= 800 ? 0.026 : (freq >= 650 ? 0.018 : 0.010);
      const bodyLevel = Math.max(0.003, level || 0.018) * trebleMellow;
      const pan = freq > 500 ? 0.18 : (freq < 320 ? -0.16 : 0.02);

      const body = ctx.createGain();
      body.gain.setValueAtTime(0.0001, t);
      body.gain.exponentialRampToValueAtTime(bodyLevel, t + attackTime);
      body.gain.exponentialRampToValueAtTime(bodyLevel * 0.22, t + 0.52);
      body.gain.exponentialRampToValueAtTime(0.0001, t + dur);

      const soundboard = ctx.createBiquadFilter();
      soundboard.type = 'lowpass';
      soundboard.frequency.value = freq >= 800 ? 2400 : (freq >= 650 ? 3200 : 4200);
      soundboard.Q.value = 0.35;

      const panner = ctx.createStereoPanner();
      panner.pan.value = pan;
      body.connect(soundboard).connect(panner).connect(output);

      const send = ctx.createGain();
      send.gain.value = 0.32;
      panner.connect(send).connect(reverb);
      if (delayBus) {
        const delaySend = ctx.createGain();
        const delayAge = getPrettyDelayAge(ctx, t);
        const delaySendScale = 1 - (0.24 * delayAge * (1 - prettyDelayMix));
        const delayMixScale = 0.62 + (0.72 * prettyDelayMix);
        delaySend.gain.value = (freq >= 650 ? 0.78 : 0.44) * delaySendScale * delayMixScale;
        panner.connect(delaySend).connect(delayBus);
      }

      [
        { ratio: 1.000, gain: 1.00, stop: dur },
        { ratio: 2.006, gain: 0.42, stop: dur * 0.76 },
        { ratio: 3.018, gain: 0.22, stop: dur * 0.50 },
        { ratio: 4.045, gain: 0.12, stop: dur * 0.36 }
      ].forEach(function(partial) {
        const osc = ctx.createOscillator();
        osc.type = 'triangle';
        osc.frequency.value = freq * partial.ratio;
        osc.detune.value = (Math.random() * 3) - 1.5;

        const partialGain = ctx.createGain();
        partialGain.gain.setValueAtTime(0.0001, t);
        partialGain.gain.exponentialRampToValueAtTime(
          partial.gain * (partial.ratio === 1.000 ? 1 : upperPartialScale),
          t + partialAttack
        );
        partialGain.gain.exponentialRampToValueAtTime(0.0001, t + partial.stop);

        osc.connect(partialGain).connect(body);
        osc.start(t);
        osc.stop(t + partial.stop + 0.08);
      });

      const hammer = ctx.createBufferSource();
      const hammerLen = Math.floor(ctx.sampleRate * (freq >= 650 ? 0.018 : 0.026));
      const hammerBuf = ctx.createBuffer(1, hammerLen, ctx.sampleRate);
      const data = hammerBuf.getChannelData(0);
      for (let i = 0; i < hammerLen; i++) {
        const decay = Math.pow(1 - (i / hammerLen), 2.8);
        data[i] = (Math.random() * 2 - 1) * decay;
      }
      hammer.buffer = hammerBuf;

      const hammerGain = ctx.createGain();
      hammerGain.gain.setValueAtTime(bodyLevel * 0.10 * hammerScale, t);
      hammerGain.gain.exponentialRampToValueAtTime(0.0001, t + 0.030);

      const hammerFilter = ctx.createBiquadFilter();
      hammerFilter.type = 'bandpass';
      hammerFilter.frequency.value = freq >= 800 ? 1050 : Math.min(1900, Math.max(800, freq * 3.0));
      hammerFilter.Q.value = freq >= 650 ? 0.8 : 1.2;

      hammer.connect(hammerGain).connect(hammerFilter).connect(panner);
      hammer.start(t);
      hammer.stop(t + 0.04);
    }

    function playLowFloor(freq, when, sustain, level, reverb, outputBus) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = when !== undefined ? when : ctx.currentTime;
      const output = outputBus || ctx.destination;
      const dur = Math.min(6.5, Math.max(3.2, sustain * 0.72));
      const base = freq / 2;
      const floorLevel = Math.max(0.0025, level || 0.014);

      const floorGain = ctx.createGain();
      floorGain.gain.setValueAtTime(0.0001, t);
      floorGain.gain.exponentialRampToValueAtTime(floorLevel, t + 0.055);
      floorGain.gain.exponentialRampToValueAtTime(floorLevel * 0.34, t + 1.1);
      floorGain.gain.exponentialRampToValueAtTime(0.0001, t + dur);

      const lowpass = ctx.createBiquadFilter();
      lowpass.type = 'lowpass';
      lowpass.frequency.value = 540;
      lowpass.Q.value = 0.6;

      const highpass = ctx.createBiquadFilter();
      highpass.type = 'highpass';
      highpass.frequency.value = 48;
      highpass.Q.value = 0.5;

      const panner = ctx.createStereoPanner();
      panner.pan.value = -0.04;
      floorGain.connect(lowpass).connect(highpass).connect(panner).connect(output);

      const send = ctx.createGain();
      send.gain.value = 0.18;
      panner.connect(send).connect(reverb);

      [
        { ratio: 1.000, gain: 1.00 },
        { ratio: 0.500, gain: 0.38 }
      ].forEach(function(layer) {
        const osc = ctx.createOscillator();
        osc.type = layer.ratio === 1.000 ? 'triangle' : 'sine';
        osc.frequency.value = base * layer.ratio;
        osc.detune.value = (Math.random() * 2) - 1;

        const layerGain = ctx.createGain();
        layerGain.gain.value = layer.gain;
        osc.connect(layerGain).connect(floorGain);
        osc.start(t);
        osc.stop(t + dur + 0.08);
      });
    }

    function playNoteName(note, when, sustain, level, withLowFloor, delayBus, outputBus) {
      const freq = NOTE_FREQ[note];
      if (!freq) return;
      playPianoNote(freq, when, sustain, level, withLowFloor, delayBus, outputBus);
    }

    function playNoteNames(notes, when, sustain, level, withLowFloor, delayBus, outputBus) {
      notes.forEach(function(note) {
        playNoteName(note, when, sustain, level, withLowFloor, delayBus, outputBus);
      });
    }

    function playPrettyGhost(notes, when, scale, outputBus) {
      const ctx = ensureAudio();
      if (!ctx || Math.random() > rabbitDensity.ghost1) return;
      const delay = getPrettyDelay(ctx);
      const echoScale = (scale === undefined ? 1 : scale) * (0.72 + (0.55 * prettyDelayMix));
      const offset = 0.72 + (Math.random() * 0.46);
      const note = notes[Math.floor(Math.random() * notes.length)];
      playLeadNote(note, when + offset, 6.2, 0.018 * echoScale, false, delay, outputBus);
      if (Math.random() < 0.28) {
        playLeadNote(note, when + offset + 0.52, 5.8, 0.011 * echoScale, false, delay, outputBus);
      }
    }

    // ============================================================
    // Rabbit-mode synthy voices + layered routing.
    // playPianoNote (used by dimmer) stays on playAcousticKey untouched.
    // Only playPrettyPreset routes through these layered voices below.
    // ============================================================
    const SYNTH_PRESETS_RABBIT = {
      rhodes: { wave: 'sine',     unison: 2, spread: 6, octaveMix: 0.18,
                vibRate: 4.0, vibDepth: 3, vibFadeIn: 0.25,
                attack: 0.025, decay: 0.55, shoulder: 0.28,
                cutoff: 2600, q: 0.7, levelMul: 1.1 },
      bell:   { wave: 'sine',     unison: 1, spread: 0, octaveMix: 0.3,
                vibRate: 3.4, vibDepth: 2, vibFadeIn: 0.3,
                attack: 0.02, decay: 0.8, shoulder: 0.18,
                cutoff: 3200, q: 0.6, levelMul: 0.95 },
      ondes:  { wave: 'sine',     unison: 1, spread: 0, octaveMix: 0,
                vibRate: 5.4, vibDepth: 8, vibFadeIn: 0.22,
                attack: 0.08, decay: 0.7, shoulder: 0.42,
                cutoff: 4000, q: 0.5, levelMul: 1.15 }
    };

    function playSynthVoice(presetKey, freq, when, sustain, level, reverb, delayBus, outputBus) {
      const ctx = ensureAudio();
      const p = SYNTH_PRESETS_RABBIT[presetKey];
      if (!ctx || !p) return;
      const t = when !== undefined ? when : ctx.currentTime;
      const output = outputBus || ctx.destination;
      const sus = sustain || 9.0;
      const lvl = (level !== undefined ? level : 0.046) * p.levelMul;
      const trebleMellow = freq >= 800 ? 0.74 : (freq >= 650 ? 0.88 : 1);
      const bodyLevel = Math.max(0.003, lvl) * trebleMellow;
      const pan = freq > 500 ? 0.18 : (freq < 320 ? -0.16 : 0.02);

      const body = ctx.createGain();
      body.gain.setValueAtTime(0.0001, t);
      body.gain.exponentialRampToValueAtTime(bodyLevel, t + p.attack);
      body.gain.exponentialRampToValueAtTime(Math.max(0.0002, bodyLevel * p.shoulder), t + p.attack + p.decay);
      body.gain.exponentialRampToValueAtTime(0.0001, t + sus);

      const filter = ctx.createBiquadFilter();
      filter.type = 'lowpass';
      filter.frequency.value = p.cutoff;
      filter.Q.value = p.q;

      const panner = ctx.createStereoPanner();
      panner.pan.value = pan;
      body.connect(filter).connect(panner).connect(output);

      const rSend = ctx.createGain();
      rSend.gain.value = 0.32;
      panner.connect(rSend).connect(reverb);

      if (delayBus) {
        const ds = ctx.createGain();
        const age = getPrettyDelayAge(ctx, t);
        const delaySendScale = 1 - (0.24 * age * (1 - prettyDelayMix));
        const delayMixScale = 0.62 + (0.72 * prettyDelayMix);
        ds.gain.value = (freq >= 650 ? 0.78 : 0.44) * delaySendScale * delayMixScale;
        panner.connect(ds).connect(delayBus);
      }

      let vibratoDepth = null;
      if (p.vibDepth > 0 && p.vibRate > 0) {
        const vib = ctx.createOscillator();
        vib.type = 'sine';
        vib.frequency.value = p.vibRate;
        vibratoDepth = ctx.createGain();
        vibratoDepth.gain.setValueAtTime(0.0001, t);
        vibratoDepth.gain.exponentialRampToValueAtTime(p.vibDepth, t + p.attack + p.vibFadeIn);
        vibratoDepth.gain.setValueAtTime(p.vibDepth, t + Math.max(p.attack + p.vibFadeIn, sus - 0.4));
        vibratoDepth.gain.exponentialRampToValueAtTime(0.0001, t + sus);
        vib.connect(vibratoDepth);
        vib.start(t);
        vib.stop(t + sus + 0.1);
      }

      const detunes = p.unison === 1 ? [0]
                    : p.unison === 2 ? [-p.spread, p.spread]
                    :                  [-p.spread, 0, p.spread];
      const perVoiceGain = 1 / Math.sqrt(p.unison);

      detunes.forEach(function(d) {
        const osc = ctx.createOscillator();
        osc.type = p.wave;
        osc.frequency.value = freq;
        osc.detune.value = d;
        if (vibratoDepth) vibratoDepth.connect(osc.detune);
        const g = ctx.createGain();
        g.gain.value = perVoiceGain;
        osc.connect(g).connect(body);
        osc.start(t);
        osc.stop(t + sus + 0.1);
      });

      if (p.octaveMix > 0) {
        const osc = ctx.createOscillator();
        osc.type = p.wave;
        osc.frequency.value = freq * 2;
        if (vibratoDepth) vibratoDepth.connect(osc.detune);
        const g = ctx.createGain();
        g.gain.value = p.octaveMix;
        osc.connect(g).connect(body);
        osc.start(t);
        osc.stop(t + sus + 0.1);
      }
    }

    // Layered lead voice — fires every voice in activeRabbitVoices, scaling
    // each level by 1/√N for equal-loudness summing. 'piano' routes to the
    // additive playAcousticKey; synth voices route to playSynthVoice.
    const activeRabbitVoices = new Set(['piano']);  // default: additive piano alone
    function playLeadVoice(freq, when, sustain, level, reverb, delayBus, outputBus) {
      const n = activeRabbitVoices.size || 1;
      const perVoiceLvl = level / Math.sqrt(n);
      activeRabbitVoices.forEach(function(name) {
        if (name === 'piano') {
          playAcousticKey(freq, when, sustain, perVoiceLvl, reverb, delayBus, outputBus);
        } else {
          playSynthVoice(name, freq, when, sustain, perVoiceLvl, reverb, delayBus, outputBus);
        }
      });
    }
    function playLeadNote(note, when, sustain, level, withLowFloor, delayBus, outputBus) {
      const freq = NOTE_FREQ[note];
      if (!freq) return;
      const ctx = ensureAudio();
      if (!ctx) return;
      const reverb = getPrettyReverb(ctx);
      playLeadVoice(freq, when, sustain, level, reverb, delayBus, outputBus);
      if (withLowFloor) playLowFloor(freq, when, sustain, level * 0.28, reverb, outputBus);
    }
    function playLeadNotes(notes, when, sustain, level, withLowFloor, delayBus, outputBus) {
      if (!notes) return;
      if (notes.length <= 1) {
        notes.forEach(function(n) { playLeadNote(n, when, sustain, level, withLowFloor, delayBus, outputBus); });
        return;
      }
      // ARP ONLY — no block, no strum. Random chord-tone picks at 150–250ms
      // intervals so each note is its own perceptual event. Different every
      // time: step rate, density, breath, gaps all re-roll. First note feeds
      // the delay bus (wet attack), rest dry to keep wash bounded.
      const stepSec     = 0.16 + Math.random() * 0.10;
      const startOffset = 0.04 + Math.random() * 0.18;
      const breathRate  = 0.5 + Math.random() * 0.9;
      const breathDepth = 0.4 + Math.random() * 0.4;
      const totalArpSec = Math.min(sustain * 0.78, 3.6);
      const stepCount = Math.min(22, Math.max(notes.length * 2, Math.floor(totalArpSec / stepSec)));
      for (let i = 0; i < stepCount; i++) {
        if (Math.random() < 0.10) continue;
        const note = notes[Math.floor(Math.random() * notes.length)];
        const breath = (1 - breathDepth) + (breathDepth * (0.5 + 0.5 * Math.sin(i * breathRate)));
        const fade = Math.max(0.18, 1 - (i / stepCount) * 0.82);
        const jitter = (Math.random() - 0.5) * 0.025;
        const noteSustain = Math.max(1.0, (sustain * 0.45) - (i * 0.02));
        const noteDelay = i === 0 ? delayBus : null;
        playLeadNote(note, when + startOffset + (i * stepSec) + jitter, noteSustain, level * fade * breath, withLowFloor && i === 0, noteDelay, outputBus);
      }
    }

    // Second ghost pass — later offset (1.6–2.4s), lower density.
    function playPrettyGhostLate(notes, when, scale, outputBus) {
      const ctx = ensureAudio();
      if (!ctx || Math.random() > rabbitDensity.ghost2) return;
      const delay = getPrettyDelay(ctx);
      const echoScale = (scale === undefined ? 1 : scale) * (0.55 + (0.45 * prettyDelayMix));
      const offset = 1.6 + (Math.random() * 0.8);
      const note = notes[Math.floor(Math.random() * notes.length)];
      playLeadNote(note, when + offset, 5.4, 0.013 * echoScale, false, delay, outputBus);
    }

    // Mid-phrase shimmer — single quiet note between resolveA and pressB.
    function playPrettyShimmer(preset, when, output) {
      const ctx = ensureAudio();
      if (!ctx || Math.random() > rabbitDensity.shimmer) return;
      const delay = getPrettyDelay(ctx);
      const pool = (Math.random() < 0.5 ? preset.resolveA : preset.resolveB) || [];
      if (pool.length === 0) return;
      const note = pool[Math.floor(Math.random() * pool.length)];
      const offset = 2.5 + (Math.random() * 0.7);
      playLeadNote(note, when + offset, 4.2, 0.011, false, delay, output);
    }

    // Walking-bass — quiet chord-tone bass between strikes. Three offsets
    // with ~35% skip chance each, varying dynamic per note. Stays loose,
    // re-rolls per phrase, doesn't lock into a grid.
    function playWalkBass(preset, when, output) {
      const ctx = ensureAudio();
      const walks = preset.walkBass;
      if (!ctx || !walks || walks.length === 0) return;
      const baseOffsets = [
        2.5 + Math.random() * 0.5,
        4.4 + Math.random() * 0.3,
        5.6 + Math.random() * 0.4
      ];
      baseOffsets.forEach(function(off, i) {
        if (Math.random() > 0.65) return;
        const note = walks[i % walks.length];
        if (!note) return;
        const dynamic = 0.45 + Math.random() * 0.20;
        playLeadNote(note, when + off, 2.8, PRETTY_LOW_LEVEL * dynamic, false, null, output);
      });
    }

    function playPrettyPreset(preset) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = ctx.currentTime + 0.035;
      const output = getPrettySignal(ctx);
      const delay = getPrettyDelay(ctx);
      const level = PRETTY_NOTE_LEVEL;
      setPrettyDelayProfile(ctx, t);
      setPrettySignalProfile(ctx, t);
      // If session rolled color-on, append phrase.colorTone to resolveB.
      const resolveB = (rabbitColorOn && preset.colorTone)
        ? preset.resolveB.concat([preset.colorTone])
        : preset.resolveB;
      playLeadNotes(preset.pressA,   t,                                                        4.0, level, false, null,  output);
      playLeadNotes(preset.resolveA, t + (PRESS_TO_HIT_MS / 1000),                             9.0, level, true,  delay, output);
      playPrettyGhost(preset.resolveA,     t + (PRESS_TO_HIT_MS / 1000), 0.95, output);
      playPrettyGhostLate(preset.resolveA, t + (PRESS_TO_HIT_MS / 1000), 0.90, output);
      playPrettyShimmer(preset,            t,                                  output);
      playWalkBass(preset,                 t,                                  output);
      playLeadNotes(preset.pressB,   t + (LOOP_BEAT_MS / 1000),                                5.0, level, false, null,  output);
      playLeadNotes(resolveB,        t + ((LOOP_BEAT_MS + PRESS_TO_HIT_MS) / 1000),            9.0, level, true,  delay, output);
      playPrettyGhost(resolveB,            t + ((LOOP_BEAT_MS + PRESS_TO_HIT_MS) / 1000), 1.08, output);
      playPrettyGhostLate(resolveB,        t + ((LOOP_BEAT_MS + PRESS_TO_HIT_MS) / 1000), 0.95, output);
      playLeadNote(preset.low,       t + ((LOOP_BEAT_MS + PRESS_TO_HIT_MS) / 1000),            9.0, PRETTY_LOW_LEVEL, true, null, output);
    }

    function playPressNote(goingDark) {
      if (goingDark) {
        playPianoNote(PIANO.N4, undefined, 4.0);
      } else {
        playPianoNote(PIANO.N1, undefined, 5.0);
      }
    }

    // Resolve — two notes at cat-paw impact.
    function playResolveChord(goingDark) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = ctx.currentTime;
      if (goingDark) {
        playPianoNote(PIANO.N2, t, 9.0, undefined, true);
        playPianoNote(PIANO.N1, t, 9.0, undefined, true);
      } else {
        playPianoNote(PIANO.N3, t, 9.0, undefined, true);
        playPianoNote(PIANO.N4, t, 9.0, undefined, true);
        // Final resolve gets a B-flat floor so the key reads as home.
        playPianoNote(PIANO.N1 / 2, t, 9.0, 0.034, true);
      }
    }

    // DOM-only theme flip (no audio). Used by both the manual click path
    // (via instantFlip) and the loop's deterministic timer chain.
    function applyThemeFlip() {
      const d = document.documentElement;
      const wasInDark = d.getAttribute('data-theme') === 'dark';
      const goingDark = !wasInDark;
      const next = goingDark ? 'dark' : 'light';
      d.setAttribute('data-theme', next);
      if (button) button.setAttribute('aria-pressed', goingDark ? 'true' : 'false');
      return goingDark;
    }

    function instantFlip() {
      const goingDark = applyThemeFlip();
      playResolveChord(goingDark);
    }

    // Loop cycle — JS-timer-driven audio rhythm, video plays in parallel for
    // visual only. The press-note fires now; the resolve-chord + theme-flip
    // fire at exactly +PRESS_TO_HIT_MS; the next cycle fires at +LOOP_BEAT_MS.
    // No video timing dependency = no per-cycle load-latency jitter.
    function fireCycle() {
      if (!loopArmed) return;

      // Direction: when unlocked, derives from current theme (so a manual
      // dimmer click between cycles re-syncs). When locked, alternates an
      // internal flag so the music still progresses without flipping theme.
      let goingDark;
      if (themeLocked) {
        if (loopDirection === null) {
          loopDirection = document.documentElement.getAttribute('data-theme') !== 'dark';
        } else {
          loopDirection = !loopDirection;
        }
        goingDark = loopDirection;
      } else {
        loopDirection = null;
        goingDark = document.documentElement.getAttribute('data-theme') !== 'dark';
      }

      // Audio: press immediately (this is beat zero of the cycle)
      playPressNote(goingDark);

      // Visual: cat clip keeps performing even when LOOP has pinned the page
      // theme. The lock is the room lighting; the cat/audio loop is the piece.
      catCtl.play(goingDark, 'loop');

      // Resolve chord + theme flip at deterministic +PRESS_TO_HIT_MS after press
      if (loopPressTimer) clearTimeout(loopPressTimer);
      loopPressTimer = setTimeout(function() {
        loopPressTimer = null;
        if (!loopArmed) return;
        if (!themeLocked) applyThemeFlip();
        playResolveChord(goingDark);
        // Schedule next cycle
        if (loopNextTimer) clearTimeout(loopNextTimer);
        loopNextTimer = setTimeout(function() {
          loopNextTimer = null;
          if (loopArmed) fireCycle();
        }, LOOP_BEAT_MS - PRESS_TO_HIT_MS);
      }, PRESS_TO_HIT_MS);
    }

    function playCatThenFlip() {
      if (reduced || !video || video.readyState < 3) return instantFlip();

      const goingDark = document.documentElement.getAttribute('data-theme') !== 'dark';
      const hitAt = goingDark ? HIT_SECONDS_FWD : HIT_SECONDS_REV;
      const seekFrom = goingDark ? 0 : (HIT_SECONDS_REV - HIT_SECONDS_FWD);
      const safetyMs = ((hitAt - seekFrom) / VIDEO_RATE) * 1000 + 500;

      catCtl.play(goingDark);

      let flipped = false;
      function doFlip() {
        if (flipped) return;
        flipped = true;
        instantFlip();
      }

      const safety = setTimeout(doFlip, safetyMs);
      function tick() {
