<!DOCTYPE html>
<!--
  You looked.
  The engraving in the margin is clickable.
-->
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or site.title }}</title>
  <meta name="description" content="Lee Wilkers – tools, judgment, and use.">
  <meta property="og:title" content="{{ title or site.title }}">
  <meta property="og:description" content="Tools, judgment, and use.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}/img/og-image.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title or site.title }}">
  <meta name="twitter:description" content="Tools, judgment, and use.">
  <meta name="twitter:image" content="{{ site.url }}/img/og-image.png">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <link rel="icon" href="/img/favicon.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Overpass:ital,wght@0,100..900;1,100..900&family=Source+Serif+4:ital,opsz,wght@0,8..60,300..900;1,8..60,300..900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="site-nav">
  <a href="/" class="nav-name">Lee Wilkers</a>
  <div class="nav-right">
    <div class="nav-links">
      <a href="/" {% if page.url == "/" %}class="active"{% endif %}>about</a>
      <a href="/shelf/" {% if page.url == "/shelf/" %}class="active"{% endif %}>shelf</a>
      {# stream temporarily hidden – coming back when populated #}
    </div>
    <button class="dimmer" aria-label="Toggle dark mode" onclick="toggleTheme()"></button>
  </div>
</nav>

<div class="cat-switch-frame" aria-hidden="true">
  <video class="cat-switch-video" muted playsinline preload="auto">
    <source src="/img/cat_light.mp4" type="video/mp4">
  </video>
</div>

<main class="page {{ pageClass }}">

  {{ content | safe }}

</main>

<script>
  // theme toggle – plays the cat-hitting-light clip and flips theme at impact
  (function() {
    const VIDEO_DURATION = 2.15;
    const VIDEO_FPS = 20;
    const HIT_SECONDS_FWD = 0.90;                          // frame 19 @ 20fps – paw pressed into light
    // Frame-accurate reverse: forward frame F appears in reverse at (duration - fwd_time - 1/fps)
    // because the first displayed frame sits at t=0, not t=1/fps. Gives 1.20s for this clip.
    const HIT_SECONDS_REV = VIDEO_DURATION - HIT_SECONDS_FWD - (1 / VIDEO_FPS);
    const VIDEO_FWD = '/img/cat_light.mp4';
    const VIDEO_REV = '/img/cat_light_rev.mp4';
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const frame  = document.querySelector('.cat-switch-frame');
    const video  = frame && frame.querySelector('video');
    const button = document.querySelector('.dimmer');

    function instantFlip() {
      const d = document.documentElement;
      const next = d.getAttribute('data-theme') === 'dark' ? '' : 'dark';
      d.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
    }

    function playCatThenFlip() {
      if (reduced || !video || video.readyState < 3) return instantFlip();

      const goingDark = document.documentElement.getAttribute('data-theme') !== 'dark';
      const hitAt = goingDark ? HIT_SECONDS_FWD : HIT_SECONDS_REV;
      const safetyMs = hitAt * 1000 + 500;
      if (button) button.disabled = true;

      video.src = goingDark ? VIDEO_FWD : VIDEO_REV;
      video.currentTime = 0;
      frame.classList.add('is-playing');

      let flipped = false;
      function doFlip() {
        if (flipped) return;
        flipped = true;
        instantFlip();
      }

      const safety = setTimeout(doFlip, safetyMs);

      function tick() {
        if (flipped) return;
        if (video.currentTime >= hitAt) {
          clearTimeout(safety);
          doFlip();
          return;
        }
        requestAnimationFrame(tick);
      }

      video.onended = function() {
        frame.classList.remove('is-playing');
        setTimeout(function() { if (button) button.disabled = false; }, 200);
      };

      const p = video.play();
      if (p && p.then) {
        p.then(function() { requestAnimationFrame(tick); })
         .catch(function() {
           clearTimeout(safety);
           frame.classList.remove('is-playing');
           if (button) button.disabled = false;
           instantFlip();
         });
      } else {
        requestAnimationFrame(tick);
      }
    }

    window.toggleTheme = playCatThenFlip;
  })();

  // FOUC restore – keep this untouched, runs as soon as parser hits it
  (function() {
    const saved = localStorage.getItem('theme');
    if (saved) document.documentElement.setAttribute('data-theme', saved);
  })();

  // margin ghost – detail card
  (function() {
    var img = document.getElementById('ghost-img');
    if (!img) return;
    var ghost = document.getElementById('margin-ghost');
    var defaultSrc = img.src;
    var gAuthor = document.getElementById('ghost-author');
    var gTitle = document.getElementById('ghost-title');
    var gDek = document.getElementById('ghost-dek');
    var gBlurb = document.getElementById('ghost-blurb');
    var gQuote = document.getElementById('ghost-quote');
    var gBadge = document.getElementById('ghost-type-badge');
    var leaveTimer = null;

    // type icons – minimal geometric (stroke only, 1.5px)
    var TYPE_ICONS = {
      book: '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2.5v11"/><path d="M3 3c0 0 2-.5 5-.5s5 .5 5 .5v10c0 0-2-.5-5-.5s-5 .5-5 .5z"/></svg>',
      essay: '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2h6l3 3v9H4z"/><path d="M10 2v3h3"/></svg>',
      site: '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="5.5"/><path d="M2.5 8h11"/><path d="M8 2.5c-1.5 1.5-2.2 3.5-2.2 5.5s.7 4 2.2 5.5"/><path d="M8 2.5c1.5 1.5 2.2 3.5 2.2 5.5s-.7 4-2.2 5.5"/></svg>',
      film: '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="12" height="10" rx="1"/><path d="M2 6h12M2 10h12"/><path d="M5 3v3M5 10v3M11 3v3M11 10v3"/></svg>',
      interview: '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h7a1 1 0 011 1v4a1 1 0 01-1 1H6l-2 2V9H3a1 1 0 01-1-1V4a1 1 0 011-1z"/><path d="M12 6h1a1 1 0 011 1v4a1 1 0 01-1 1h-1v2l-2-2h-3"/></svg>',
      slides: '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="12" height="9" rx="1"/><path d="M8 11v3M5 14h6"/></svg>',
      concept: '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 1.5l2.5 4.5h5L11 10l1.5 4.5L8 12l-4.5 2.5L5 10 .5 6h5z"/></svg>'
    };

    // preload covers
    document.querySelectorAll('[data-cover]').forEach(function(el) {
      new Image().src = el.getAttribute('data-cover');
    });

    // melancholia easter egg – clickable when at rest
    ghost.style.pointerEvents = 'auto';
    ghost.addEventListener('click', function() {
      if (!ghost.classList.contains('active')) {
        window.open('https://monoskop.org/images/e/eb/Lorusso_Silvio_What_Design_Cant_Do_Essays_on_Design_and_Disillusion_2023.pdf#page=67', '_blank');
      }
    });
    ghost.addEventListener('mouseenter', function() {
      if (!ghost.classList.contains('active')) {
        img.style.opacity = '1';
        img.style.filter = 'grayscale(0.6)';
        ghost.style.cursor = 'pointer';
      }
    });
    ghost.addEventListener('mouseleave', function() {
      if (!ghost.classList.contains('active')) {
        img.style.opacity = '';
        img.style.filter = '';
        ghost.style.cursor = '';
      }
    });

    function setGhost(cover, author, title, dek, blurb, quote, type) {
      img.src = cover || defaultSrc;
      gAuthor.textContent = author;
      gTitle.textContent = title;
      gDek.textContent = dek;
      gBlurb.textContent = blurb;
      gQuote.textContent = quote;
      gBadge.textContent = '';
      if (type && TYPE_ICONS[type]) {
        gBadge.insertAdjacentHTML('afterbegin', TYPE_ICONS[type]);
      }
    }

    document.querySelectorAll('.shelf li').forEach(function(el) {
      el.addEventListener('mouseenter', function() {
        if (leaveTimer) { clearTimeout(leaveTimer); leaveTimer = null; }
        var cover = el.getAttribute('data-cover');
        setGhost(
          cover,
          el.getAttribute('data-author') || '',
          el.getAttribute('data-item-title') || '',
          el.getAttribute('data-dek') || '',
          el.getAttribute('data-blurb') || '',
          el.getAttribute('data-quote') || '',
          el.getAttribute('data-type') || ''
        );
        ghost.classList.add('active');
        ghost.style.cursor = '';
        img.style.opacity = '';
        img.style.filter = '';
      });
      el.addEventListener('mouseleave', function() {
        ghost.classList.remove('active');
        leaveTimer = setTimeout(function() {
          if (!ghost.classList.contains('active')) {
            setGhost(null, '', '', '', '', '', '');
          }
        }, 600);
      });
    });
  })();

  // dust
  (function(){
    var el=document.querySelector('.dust');if(!el)return;
    var t='pardon the dust'.split(''),n=parseInt(localStorage.getItem('_d')||'0',10);
    localStorage.setItem('_d',++n);
    var d=Math.max(0,Math.min(n-2,t.length));if(!d)return;
    var r=t.map(function(_,i){return i}),s=42;
    for(var i=r.length-1;i>0;i--){s=(s*1103515245+12345)&0x7fffffff;var j=s%(i+1),tmp=r[i];r[i]=r[j];r[j]=tmp}
    for(var i=0;i<d;i++)t[r[i]]='\u2009';
    if(d>=15)el.style.visibility='hidden';else el.textContent=t.join('');
  })();

  // tab
  (function(){var t=document.title;document.addEventListener('visibilitychange',function(){document.title=document.hidden?'\u2013':t})})();

  // hover notes – cursor-follow tooltip, always on (ghost card shows blurb/quote)
  document.querySelectorAll('[data-note]').forEach(function(el) {
    if (el.querySelector('.entry-note')) return;
    var tip;
    el.addEventListener('mouseenter', function(e) {
      tip = document.createElement('div');
      tip.className = 'hover-note';
      tip.textContent = el.getAttribute('data-note');
      document.body.appendChild(tip);
      position(e);
    });
    el.addEventListener('mousemove', function(e) {
      if (tip) position(e);
    });
    el.addEventListener('mouseleave', function() {
      if (tip) { tip.remove(); tip = null; }
    });
    function position(e) {
      var x = e.clientX + 12;
      var y = e.clientY - 8;
      var w = tip.offsetWidth;
      if (x + w > window.innerWidth - 8) x = e.clientX - w - 12;
      tip.style.left = x + 'px';
      tip.style.top = y + 'px';
    }
  });
</script>
</body>
</html>
