          }
        }
      }
    }

    renderConstellationMeta(activeConstellation);

    function createPrettyConstellation(canvas, constellation) {
      if (!canvas || !canvas.getContext) {
        return { setActive: function(){}, setVisible: function(){}, setConstellation: function(){}, redraw: function(){} };
      }

      const ctx = canvas.getContext('2d');
      let points = constellation.points;
      let highlightIndex = constellation.highlightIndex;
      let edges = constellation.edges;
      let stars = constellation.stars;
      let lineColor = LINE_COLOR;
      let starColor = constellation.starColor;
      let pointColor = constellation.pointColor;
      let highlightColor = constellation.highlightColor;
      let highlightSparkColor = constellation.highlightSparkColor;
      let active = false;
      let exiting = false;
      let visible = true;
      let raf = null;
      let start = performance.now();
      let modeStart = start;
      const EXIT_SECONDS = 5.8;

      // Tighter x-mapping: previous 0.86×x + 9.1 left ~21% padding on each
      // canvas side, so shapes read small even when the field is large.
      // 1.08×x + 4 stretches typical x-range (8–55) closer to the canvas
      // edges (1.08×8+4 ≈ 12.6, 1.08×55+4 ≈ 63.4, ×2 = 25–127 of 136 ≈ 75%).
      function xPos(x) { return ((x * 1.08) + 4) * CONSTELLATION_PIXEL_SCALE; }
      function yPos(y) { return (y + 1.4) * CONSTELLATION_PIXEL_SCALE; }

      function pixel(x, y, size, alpha, color) {
        const px = xPos(x);
        const py = yPos(y);
        const scaledSize = Math.max(1, Math.round(size * 1.45));
        ctx.globalAlpha = alpha > 0 ? alpha : 0;
        ctx.fillStyle = color || '#cecdc3';
        ctx.fillRect(Math.round(px), Math.round(py), scaledSize, scaledSize);
      }

      function hash(seed) {
        const value = Math.sin(seed * 127.1) * 43758.5453;
        return value - Math.floor(value);
      }

      function lit(seed, t, threshold, hold) {
        if (reduced) return true;
        const step = Math.floor((t + (seed * 0.43)) / hold);
        return hash(seed + (step * 9.73)) > threshold;
      }

      function aliveOnExit(seed, modeT) {
        if (!exiting || reduced) return true;
        const death = 0.8 + (hash(seed + 31.7) * 4.8);
        if (modeT >= death) return false;
        if ((death - modeT) < 1.6) {
          return lit(seed + 61.2, modeT, 0.28, 1.15);
        }
        return true;
      }

      function drawLine(a, b, progress, alpha, time) {
        const ax = points[a][0];
        const ay = points[a][1];
        const bx = points[b][0];
        const by = points[b][1];
        const endX = ax + ((bx - ax) * progress);
        const endY = ay + ((by - ay) * progress);
        const steps = Math.max(3, Math.ceil(Math.hypot(endX - ax, endY - ay) * 0.92));
        for (let i = 0; i <= steps; i++) {
          const step = i / steps;
          const seed = (a * 7.1) + (b * 3.3) + i;
          if ((active || exiting) && !lit(seed, time, 0.08, 5.8)) continue;
          if (exiting && !aliveOnExit(seed, time)) continue;
          pixel(ax + ((endX - ax) * step), ay + ((endY - ay) * step), 1, alpha, lineColor);
        }
      }

      function draw(now) {
        if (!visible) return;
        const t = (now - start) / 1000;
        const modeT = (now - modeStart) / 1000;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        if (exiting && modeT > EXIT_SECONDS) {
          exiting = false;
          canvas.classList.remove('is-leaving');
          ctx.globalAlpha = 1;
          return;
        }
        const live = active || exiting;
        const settling = reduced ? 1 : Math.min(1, modeT / 2.4);
        const birthIndex = Math.floor(modeT * 4.9);
        const baseAlpha = live ? 0.62 : 0.18;
        // Slider semantic: max signal (mix=0) = stars only; max noise (mix=1) =
        // lines only. Use a 1.5x kink so the middle of the slider keeps both
        // visible (default mix=0.72 still shows stars, just dimmer).
        const mix = (typeof prettyDelayMix === 'number') ? prettyDelayMix : 0.72;
        const starMul = Math.max(0, Math.min(1, 1.5 * (1 - mix)));
        const lineMul = Math.max(0, Math.min(1, 1.5 * mix));
        // === Cursor interplay ===
        // Differential parallax: stars (far/background) shift LESS than lines
        // (mid-depth) shift LESS than named points (foreground). Mirrors how
        // closer objects appear to move more per observer head-shift. Magnitude
        // capped at ~1.5 logical px so the effect is felt, not jarring.
        // Proximity boost: stars + points within ~16 logical px of the mapped
        // cursor get an alpha multiplier up to 1.7×, giving the cursor a soft
        // "you're looking here" wake without visible halo geometry.
        const rect = canvas.getBoundingClientRect();
        const cursorInfo = (typeof window.__getConstellationCursor === 'function')
          ? window.__getConstellationCursor()
          : { present: false };
        let cursorCanvasX = canvas.width / 2;
        let cursorCanvasY = canvas.height / 2;
        let cursorOffsetX = 0;
        let cursorOffsetY = 0;
        const cursorPresent = !!(cursorInfo.present && rect.width > 0 && rect.height > 0 && !reduced);
        if (cursorPresent) {
          cursorCanvasX = (cursorInfo.x - rect.left) / rect.width * canvas.width;
          cursorCanvasY = (cursorInfo.y - rect.top) / rect.height * canvas.height;
          cursorOffsetX = (cursorInfo.x - (rect.left + rect.width / 2)) / (rect.width / 2);
          cursorOffsetY = (cursorInfo.y - (rect.top + rect.height / 2)) / (rect.height / 2);
          cursorOffsetX = Math.max(-1.5, Math.min(1.5, cursorOffsetX));
          cursorOffsetY = Math.max(-1.5, Math.min(1.5, cursorOffsetY));
        }
        const STAR_PARALLAX = 0.4;
        const LINE_PARALLAX = 0.95;
        const POINT_PARALLAX = 1.35;
        const PROX_RADIUS = 16;
        function proximityBoost(x, y) {
          if (!cursorPresent) return 1;
          const dx = x - cursorCanvasX;
          const dy = y - cursorCanvasY;
          const d = Math.sqrt(dx * dx + dy * dy);
          if (d > PROX_RADIUS) return 1;
          return 1 + (1 - d / PROX_RADIUS) * 0.7;
        }

        stars.forEach(function(star, index) {
          const seed = star[2] + index;
          const born = exiting
            ? aliveOnExit(seed, modeT)
            : (!active || reduced || index <= birthIndex || lit(seed, t, 0.22, 9.5));
          if (!born) return;
          if (active && !lit(seed, t, 0.12, 5.4)) return;
          const sx = star[0] + cursorOffsetX * STAR_PARALLAX;
          const sy = star[1] + cursorOffsetY * STAR_PARALLAX;
          pixel(sx, sy, index % 3 === 0 ? 2 : 1, baseAlpha * starMul * proximityBoost(sx, sy), starColor);
        });

        // Lines get parallax shift via temporary point displacement. Restore
        // points after both edge passes so geometry is clean for the next frame.
        const originalPoints = points;
        if (cursorPresent && (cursorOffsetX !== 0 || cursorOffsetY !== 0)) {
          points = points.map(function(p) {
            return [p[0] + cursorOffsetX * LINE_PARALLAX, p[1] + cursorOffsetY * LINE_PARALLAX];
          });
        }
        edges.forEach(function(edge) {
          drawLine(edge[0], edge[1], 1, (live ? 0.24 : 0.12) * lineMul, exiting ? modeT : t);
        });

        // Ease-out cascade: each line takes longer than the last, and later
        // lines overlap less. Snappier per-edge timing than the original
        // one-shot trace, because we now LOOP the whole cascade on a fixed
        // period (CASCADE_LOOP_S) so the constellation re-traces continuously
        // for as long as the field is live — the lines never sit visually
        // static. Per-edge `index * 0.34` phase offset within the loop gives
        // the wave the original "drawing in from one end" feel.
        const TRACE_BASE_DUR = 0.32;
        const TRACE_DUR_GROWTH = 0.05;
        const TRACE_OVERLAP = 0.55;
        const TRACE_FADE_DUR = 0.45;   // tail fade after each edge hits full
        const CASCADE_LOOP_S = 4.6;    // pulse repeat — feels like a heartbeat
        const traceStart = new Array(edges.length);
        const traceDur = new Array(edges.length);
        {
          let cum = 0;
          for (let i = 0; i < edges.length; i++) {
            traceDur[i] = TRACE_BASE_DUR + TRACE_DUR_GROWTH * i;
            traceStart[i] = cum;
            cum += traceDur[i] * (1 - TRACE_OVERLAP);
          }
        }
        edges.forEach(function(edge, index) {
          let progress;
          if (!active && !exiting) {
            // Static preview: first ~4 edges shown, the 4th partially drawn.
            progress = Math.max(0, Math.min(1, 3.4 - (index * 0.82)));
          } else if (exiting) {
            progress = 1;
          } else {
            // Looping cascade. Each edge has its own start offset within the
            // loop. While the edge is "drawing" we ramp 0→1, then hold at 1
            // for the rest of the loop, then fall back to 0 in a short fade
            // window before the next loop starts. The fade prevents a hard
            // snap when the loop wraps. The faint solid baseline (drawn just
            // above this block) keeps the line visible during the dip so the
            // constellation never disappears.
            const loopT = ((modeT % CASCADE_LOOP_S) + CASCADE_LOOP_S) % CASCADE_LOOP_S;
            const edgeStart = traceStart[index];
            const edgeDur = traceDur[index];
            const fadeStart = CASCADE_LOOP_S - TRACE_FADE_DUR;
            if (loopT < edgeStart) {
              progress = 0;
            } else if (loopT < edgeStart + edgeDur) {
              progress = (loopT - edgeStart) / edgeDur;
            } else if (loopT < fadeStart) {
              progress = 1;
            } else {
              progress = Math.max(0, 1 - (loopT - fadeStart) / TRACE_FADE_DUR);
            }
          }
          if (progress > 0) drawLine(edge[0], edge[1], progress, (live ? 0.7 : 0.22) * lineMul, exiting ? modeT + index : t + index);
        });
        points = originalPoints;

        points.forEach(function(point, index) {
          const seed = index + 11;
          const born = exiting
            ? aliveOnExit(seed, modeT)
            : (!active || reduced || index <= birthIndex || lit(seed, t, 0.18, 10.4));
          if (!born) return;
          const bright = live && lit(index + 19, t, 0.48, 5.6);
          const color = index === highlightIndex ? highlightColor : pointColor;
          // Highlight star (the named primary) keeps a small floor so it never
          // fully disappears at noise — it's the visual anchor.
          const pointMul = (index === highlightIndex)
            ? Math.max(0.35, starMul)
            : starMul;
          const px = point[0] + cursorOffsetX * POINT_PARALLAX;
          const py = point[1] + cursorOffsetY * POINT_PARALLAX;
          pixel(px - 1, py - 1, bright || index === highlightIndex ? 3 : 2, (live ? 0.88 : 0.36) * pointMul * proximityBoost(px, py), color);
          if (live && settling > 0.24 && lit(index + 23, t, 0.54, 6.8)) {
            pixel(px, py, 1, 0.68 * pointMul * proximityBoost(px, py), index === highlightIndex ? highlightSparkColor : lineColor);
          }
        });

        ctx.globalAlpha = 1;
        if (!reduced && (active || exiting)) raf = requestAnimationFrame(draw);
      }

      function run() {
        if (raf) cancelAnimationFrame(raf);
        raf = null;
        if (!visible) return;
        start = performance.now();
        if (reduced) {
          draw(start);
        } else {
          raf = requestAnimationFrame(draw);
        }
      }

      run();
      return {
        setActive: function(next) {
          const wasLive = active || exiting;
          active = !!next;
          exiting = !active && wasLive;
          modeStart = performance.now();
          canvas.classList.toggle('is-armed', active);
          canvas.classList.toggle('is-leaving', exiting);
          run();
        },
        setVisible: function(next) {
          visible = !!next;
          canvas.classList.toggle('is-hidden', !visible);
          if (visible) run();
        },
        setConstellation: function(nextConstellation) {
          if (!nextConstellation) return;
          points = nextConstellation.points;
          highlightIndex = nextConstellation.highlightIndex;
          edges = nextConstellation.edges;
          stars = nextConstellation.stars;
          lineColor = LINE_COLOR;
          starColor = nextConstellation.starColor;
          pointColor = nextConstellation.pointColor;
          highlightColor = nextConstellation.highlightColor;
          highlightSparkColor = nextConstellation.highlightSparkColor;
          modeStart = performance.now();
          run();
        },
        redraw: run
      };
    }

    const prettyConstellation = createPrettyConstellation(prettyCanvas, activeConstellation);

    function setActiveConstellation(id, twinkle) {
      const nextConstellation = CONSTELLATIONS[id];
      if (!nextConstellation || nextConstellation.id === activeConstellation.id) return;
      function commitSwitch() {
        activeConstellation = nextConstellation;
        renderConstellationMeta(activeConstellation);
        prettyConstellation.setConstellation(activeConstellation);
        if (typeof setConstellationArt === 'function') setConstellationArt(activeConstellation.id);
      }
      if (constellationSwitchTimer) {
        clearTimeout(constellationSwitchTimer);
        constellationSwitchTimer = null;
      }
      if (twinkle && prettyField && !reduced) {
        prettyField.classList.add('is-twinkling');
        constellationSwitchTimer = setTimeout(function() {
          constellationSwitchTimer = null;
          commitSwitch();
          setTimeout(function() {
            if (prettyField) prettyField.classList.remove('is-twinkling');
          }, 520);
        }, 420);
      } else {
        commitSwitch();
      }
    }

    function advanceConstellationCycle() {
      constellationCycleIndex = (constellationCycleIndex + 1) % CONSTELLATION_CYCLE.length;
      setActiveConstellation(CONSTELLATION_CYCLE[constellationCycleIndex], true);
    }

    function stepConstellationCycle(delta) {
      if (!CONSTELLATION_CYCLE.length) return;
      const len = CONSTELLATION_CYCLE.length;
      constellationCycleIndex = ((constellationCycleIndex + delta) % len + len) % len;
      setActiveConstellation(CONSTELLATION_CYCLE[constellationCycleIndex], true);
      // Restart the cycle timer so the manually-stepped record gets its full window
      if (constellationCycleTimer) {
        clearTimeout(constellationCycleTimer);
        constellationCycleTimer = null;
      }
      if (prettyArmed || constellationModeActive) startConstellationCycle();
    }

    function startConstellationCycle() {
      if (constellationCycleTimer || CONSTELLATION_CYCLE.length < 2) return;
      // Don't auto-advance while the rabbit-mode intro is playing.
      if (rabbitIntroState === 'playing') return;
      // setTimeout-recursion driven by the active constellation's reading time
      // (replaces fixed-interval cycle so long notes get full read window and
      // short ones don't over-dwell).
      function scheduleNext() {
        if (constellationCycleTimer) clearTimeout(constellationCycleTimer);
        const dwell = constellationDwellMs(activeConstellation);
        constellationCycleTimer = setTimeout(function() {
          advanceConstellationCycle();
          if (prettyArmed || constellationModeActive) scheduleNext();
        }, dwell);
      }
      scheduleNext();
    }

    // === Rabbit-mode intro state machine ===
    // Plays once per rabbit-mode entry: dim the constellation field, hide the
    // note + cluster, roll in 6 framing paragraphs over ~36s. Skippable on
    // any keypress, click, or by waiting for auto-end.
    let rabbitIntroState = 'inactive'; // 'inactive' | 'playing' | 'done'
    let rabbitIntroTimer = null;
    const REVEAL_ANIMATION_MS = 1600; // matches constellation-intro-roll keyframes
    const rabbitIntroOverlay = document.querySelector('[data-constellation-intro]');

    function startRabbitIntro() {
      // Intro removed 2026-05-11 — straight into constellations on rabbit-mode
      // entry. Mark as 'done' so the rest of the state machine treats it as
      // if the intro had already played and completed. The remote-added
      // constellation cycle-through-during-intro feature is also bypassed
      // (no intro means no intro-cycle window to fill).
      // Overlay HTML/CSS preserved for potential first-visit flow later.
      rabbitIntroState = 'done';
    }

    function endRabbitIntro() {
      if (rabbitIntroState !== 'playing') return;
      rabbitIntroState = 'done';
      if (rabbitIntroTimer) { clearTimeout(rabbitIntroTimer); rabbitIntroTimer = null; }
      document.documentElement.classList.remove('is-rabbit-intro');
      if (rabbitIntroOverlay) rabbitIntroOverlay.setAttribute('aria-hidden', 'true');
