<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or site.title }}</title>
  <meta name="description" content="Lee Wilkers – tools, judgment, and use.">
  <meta property="og:title" content="{{ title or site.title }}">
  <meta property="og:description" content="Tools, judgment, and use.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}/img/og-image.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title or site.title }}">
  <meta name="twitter:description" content="Tools, judgment, and use.">
  <meta name="twitter:image" content="{{ site.url }}/img/og-image.png">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <link rel="icon" href="/img/favicon.svg" type="image/svg+xml">
  <link rel="alternate" type="application/rss+xml" title="Shelf – Lee Wilkers" href="/shelf.xml">
  <link rel="alternate" type="application/rss+xml" title="Stream – Lee Wilkers" href="/stream.xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,300..900;1,8..60,300..900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<a href="#main" class="skip-link">Skip to content</a>

<nav class="site-nav" aria-label="Primary">
  <a href="/" class="nav-name">Lee Wilkers</a>
  <div class="nav-right">
    <div class="nav-links">
      <a href="/" {% if page.url == "/" %}class="active"{% endif %}>about</a>
      <span class="dead" aria-disabled="true" title="in progress – pardon the dust">consulting</span>
      <a href="/shelf/" {% if page.url == "/shelf/" %}class="active"{% endif %}>shelf</a>
      <span class="dead" aria-disabled="true" title="in progress – pardon the dust">stream</span>
    </div>
    <button class="dimmer" aria-label="Toggle dark mode" title="Toggle dark mode" aria-pressed="false" onclick="toggleTheme()"><span class="dimmer-icons"><span class="dimmer-sun" aria-hidden="true">☀</span><span class="dimmer-moon" aria-hidden="true">☾</span></span><span class="dimmer-track" aria-hidden="true"><span class="dimmer-knob"></span></span></button>
  </div>
</nav>

<div class="cat-switch-frame" aria-hidden="true">
  <video class="cat-switch-video" muted playsinline preload="auto">
    <source src="/img/cat_light.mp4" type="video/mp4">
  </video>
</div>

<main class="page {{ pageClass }}">

  {{ content | safe }}

</main>

<footer class="site-colophon" aria-label="Site colophon">
  <span class="colophon-dust">Pardon the dust – workin on it <span class="colophon-fleuron" aria-hidden="true">❧</span></span>
  <span>Generator Eleventy</span>
  <span>CMS Sveltia</span>
</footer>

<script>
  // theme toggle – plays the cat-hitting-light clip and flips theme at impact
  (function() {
    const VIDEO_DURATION = 2.15;
    const VIDEO_FPS = 20;
    const HIT_SECONDS_FWD = 0.90;                          // frame 19 @ 20fps – paw pressed into light
    // Frame-accurate reverse: forward frame F appears in reverse at (duration - fwd_time - 1/fps)
    // because the first displayed frame sits at t=0, not t=1/fps. Gives 1.20s for this clip.
    const HIT_SECONDS_REV = VIDEO_DURATION - HIT_SECONDS_FWD - (1 / VIDEO_FPS);
    const VIDEO_FWD = '/img/cat_light.mp4';
    const VIDEO_REV = '/img/cat_light_rev.mp4';
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const frame  = document.querySelector('.cat-switch-frame');
    const video  = frame && frame.querySelector('video');
    const button = document.querySelector('.dimmer');

    let audioCtx = null;
    function ensureAudio() {
      try {
        if (!audioCtx) {
          audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        }
        return audioCtx;
      } catch (e) { return null; }
    }

    // Synthesize a small reverb impulse response — exponentially decaying noise.
    // Cached on the ctx so the convolver buffer is built once per session.
    function getReverb(ctx) {
      if (ctx._reverbBus) return ctx._reverbBus;
      const seconds = 2.4;
      const sr = ctx.sampleRate;
      const len = Math.floor(sr * seconds);
      const buf = ctx.createBuffer(2, len, sr);
      for (let ch = 0; ch < 2; ch++) {
        const d = buf.getChannelData(ch);
        for (let i = 0; i < len; i++) {
          d[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / len, 2.6);
        }
      }
      const conv = ctx.createConvolver();
      conv.buffer = buf;
      const wet = ctx.createGain();
      wet.gain.value = 0.42;
      conv.connect(wet).connect(ctx.destination);
      ctx._reverbBus = conv;
      return conv;
    }

    // Antique-piano voice — sine harmonics with slight detune,
    // soft attack, long decay, lowpass + reverb. Brian-Eno-ish.
    function playPianoNote(freq, when, sustain) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = (when !== undefined) ? when : ctx.currentTime;
      const sus = sustain || 1.8;
      const reverb = getReverb(ctx);

      // Per-note bus: lowpass softens harshness for that antique feel.
      const lp = ctx.createBiquadFilter();
      lp.type = 'lowpass';
      lp.frequency.value = 2200;
      lp.Q.value = 0.6;

      // Harmonics with declining gain — fundamental + 2nd, 3rd, 4th.
      // Slight detune per harmonic gives chorusing warmth.
      const harmonics = [
        { mul: 1.0, gain: 0.16, detune: 0  },
        { mul: 2.0, gain: 0.06, detune: 4  },
        { mul: 3.0, gain: 0.03, detune: -3 },
        { mul: 4.0, gain: 0.014, detune: 6 }
      ];

      harmonics.forEach(function(h) {
        const osc = ctx.createOscillator();
        osc.type = 'sine';
        osc.frequency.value = freq * h.mul;
        osc.detune.value = h.detune;
        const g = ctx.createGain();
        // ADSR: ~30ms attack (soft swell), exponential decay over `sus` seconds
        g.gain.setValueAtTime(0.0001, t);
        g.gain.exponentialRampToValueAtTime(h.gain, t + 0.030);
        g.gain.exponentialRampToValueAtTime(0.0001, t + sus);
        osc.connect(g).connect(lp);
        osc.start(t);
        osc.stop(t + sus + 0.1);
      });

      // Send dry to destination AND wet to reverb bus — natural piano-in-room.
      lp.connect(ctx.destination);
      lp.connect(reverb);
    }

    // Press — single contemplative note. The pedal tone the arpeggio resolves to.
    //  going light: low D (D3) — pedal under the rising Dmaj9 arpeggio
    //  going dark:  high A (A5) — glimmer above the falling Bm9 arpeggio
    function playPressNote(goingDark) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const freq = goingDark ? 880.00 : 146.83;
      playPianoNote(freq, undefined, 2.4);
    }

    // Resolve — extended-chord arpeggio, ~650ms unfolding.
    // Voicings are American-Football / shoegaze: Dmaj9 (rising) ↔ Bm11 (falling).
    // Both share D, F#, A so they feel like the same harmonic space rotated.
    function playResolveChord(goingDark) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = ctx.currentTime;

      // Dark→light  (RISING):   Dmaj9 unfolding — D4 F#4 A4 C#5 E5
      //                         (root, 3, 5, maj7, 9)  bright, open, lifting
      // Light→dark  (FALLING):  Bm11 falling — F#5 C#5 A4 E4 B3
      //                         (5, 9, b3-of-relative, 11, root)  hangs, ambiguous, indie
      const notes = goingDark
        ? [739.99, 554.37, 440.00, 329.63, 246.94]   // F#5 C#5 A4 E4 B3
        : [293.66, 369.99, 440.00, 554.37, 659.25];  // D4 F#4 A4 C#5 E5

      const stagger = 0.115;
      notes.forEach(function(f, i) {
        // Top notes ring slightly longer for that shoegaze tail; bottom notes shorter.
        const sus = 1.6 + (i * 0.08);
        playPianoNote(f, t + i * stagger, sus);
      });
    }

    function instantFlip() {
      const d = document.documentElement;
      const wasInDark = d.getAttribute('data-theme') === 'dark';
      const goingDark = !wasInDark;
      const next = goingDark ? 'dark' : '';
      d.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      if (button) button.setAttribute('aria-pressed', goingDark ? 'true' : 'false');
      playResolveChord(goingDark);
    }

    function playCatThenFlip() {
      if (reduced || !video || video.readyState < 3) return instantFlip();

      const goingDark = document.documentElement.getAttribute('data-theme') !== 'dark';
      const hitAt = goingDark ? HIT_SECONDS_FWD : HIT_SECONDS_REV;
      const safetyMs = hitAt * 1000 + 500;
      if (button) button.disabled = true;

      video.src = goingDark ? VIDEO_FWD : VIDEO_REV;
      video.currentTime = 0;
      frame.classList.add('is-playing');

      let flipped = false;
      function doFlip() {
        if (flipped) return;
        flipped = true;
        instantFlip();
      }

      const safety = setTimeout(doFlip, safetyMs);

      function tick() {
        if (flipped) return;
        if (video.currentTime >= hitAt) {
          clearTimeout(safety);
          doFlip();
          return;
        }
        requestAnimationFrame(tick);
      }

      video.onended = function() {
        frame.classList.remove('is-playing');
        setTimeout(function() { if (button) button.disabled = false; }, 200);
      };

      const p = video.play();
      if (p && p.then) {
        p.then(function() { requestAnimationFrame(tick); })
         .catch(function() {
           clearTimeout(safety);
           frame.classList.remove('is-playing');
           if (button) button.disabled = false;
           instantFlip();
         });
      } else {
        requestAnimationFrame(tick);
      }
    }

    window.toggleTheme = playCatThenFlip;

    // Press feedback — fires the moment the pointer goes down, before onclick.
    // Pairs with CSS :active state on .dimmer for visual press-in.
    if (button) {
      button.addEventListener('pointerdown', function() {
        if (button.disabled) return;
        const goingDark = document.documentElement.getAttribute('data-theme') !== 'dark';
        playPressNote(goingDark);
      });
    }
  })();

  // FOUC restore – keep this untouched, runs as soon as parser hits it
  (function() {
    const saved = localStorage.getItem('theme');
    if (saved) document.documentElement.setAttribute('data-theme', saved);
    // sync aria-pressed on dimmer once DOM is ready
    document.addEventListener('DOMContentLoaded', function() {
      var btn = document.querySelector('.dimmer');
      if (btn) btn.setAttribute('aria-pressed', saved === 'dark' ? 'true' : 'false');
    });
  })();

  // tab
  (function(){var t=document.title;document.addEventListener('visibilitychange',function(){document.title=document.hidden?'\u2013':t})})();

  // scroll-spy — rAF-throttled scroll listener.  Robust for short sections
  // (IntersectionObserver with -60% bottom rootMargin skipped 1-item sections.)
  (function() {
    var sections = document.querySelectorAll('.topic-section');
    var links = document.querySelectorAll('.topic-index a');
    var index = document.getElementById('topic-index');
    if (!sections.length || !links.length) return;

    var linkMap = {};
    links.forEach(function(a) { linkMap[a.getAttribute('data-topic')] = a; });

    function navOffset() {
      var nav = document.querySelector('.site-nav');
      return nav ? Math.ceil(nav.getBoundingClientRect().height + 24) : 80;
    }

    function keepActiveLinkVisible(a) {
      if (!index || !a) return;
      var linkTop = a.offsetTop;
      var linkBottom = linkTop + a.offsetHeight;
      var viewTop = index.scrollTop;
      var viewBottom = viewTop + index.clientHeight;
      if (linkTop < viewTop) index.scrollTop = linkTop;
      else if (linkBottom > viewBottom) index.scrollTop = linkBottom - index.clientHeight;
    }

    function updateActive() {
      var referenceY = navOffset();
      var active = null;
      var best = Infinity;

      // Pick the section whose top has crossed the reference line most recently
      sections.forEach(function(s) {
        var r = s.getBoundingClientRect();
        if (r.top <= referenceY && r.bottom > referenceY) {
          var dist = referenceY - r.top;
          if (dist < best) { best = dist; active = s.dataset.topic; }
        }
      });

      // Fallback: first section fully visible, or first section if all below fold
      if (!active) {
        for (var i = 0; i < sections.length; i++) {
          var r = sections[i].getBoundingClientRect();
          if (r.top < window.innerHeight && r.bottom > 0) {
            active = sections[i].dataset.topic;
            break;
          }
        }
      }

      links.forEach(function(a) {
        var isActive = a.getAttribute('data-topic') === active;
        a.classList.toggle('active', isActive);
        if (isActive) {
          a.setAttribute('aria-current', 'true');
          keepActiveLinkVisible(a);
        } else {
          a.removeAttribute('aria-current');
        }
      });
    }

    var ticking = false;
    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(function() {
          updateActive();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    updateActive(); // initial paint

    // Click-nav: respect the section's CSS scroll-margin so the sticky
    // site nav and the topic highlight use the same reference point.
    links.forEach(function(a) {
      a.addEventListener('click', function(e) {
        var slug = a.getAttribute('data-topic');
        var section = document.getElementById(slug);
        if (section) {
          e.preventDefault();
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
          if (history.pushState) history.pushState(null, '', '#' + slug);
        }
        closeSidebar();
      });
    });
  })();

  // Mobile hamburger overlay: open/close with focus-trap + Escape + body scroll-lock
  function openSidebar() {
    var idx = document.getElementById('topic-index');
    var btn = document.querySelector('.sidebar-toggle');
    if (!idx) return;
    idx.classList.add('open');
    idx.removeAttribute('inert');
    document.body.classList.add('menu-open');
    if (btn) btn.setAttribute('aria-expanded', 'true');
    var firstLink = idx.querySelector('a');
    if (firstLink) firstLink.focus();
  }
  function closeSidebar() {
    var idx = document.getElementById('topic-index');
    var btn = document.querySelector('.sidebar-toggle');
    if (!idx) return;
    var wasOpen = idx.classList.contains('open');
    idx.classList.remove('open');
    document.body.classList.remove('menu-open');
    if (btn) {
      btn.setAttribute('aria-expanded', 'false');
      if (wasOpen) btn.focus();
    }
    // Keep off-canvas topic links out of the tab order whenever the overlay is hidden.
    if (window.matchMedia('(max-width: 1200px)').matches) {
      idx.setAttribute('inert', '');
    }
  }
  window.toggleSidebar = function() {
    var idx = document.getElementById('topic-index');
    if (!idx) return;
    if (idx.classList.contains('open')) closeSidebar();
    else openSidebar();
  };
  // Escape closes overlay when open
  document.addEventListener('keydown', function(e) {
    if (e.key !== 'Escape') return;
    var idx = document.getElementById('topic-index');
    if (idx && idx.classList.contains('open')) closeSidebar();
  });
  function syncSidebarMode() {
    var idx = document.getElementById('topic-index');
    var btn = document.querySelector('.sidebar-toggle');
    if (!idx) return;
    if (window.matchMedia('(max-width: 1200px)').matches) {
      if (!idx.classList.contains('open')) idx.setAttribute('inert', '');
    } else {
      idx.removeAttribute('inert');
      idx.classList.remove('open');
      document.body.classList.remove('menu-open');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    }
  }
  document.addEventListener('DOMContentLoaded', syncSidebarMode);
  window.addEventListener('resize', syncSidebarMode);
</script>
</body>
</html>
