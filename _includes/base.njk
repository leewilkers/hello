<script>
  // theme toggle – plays the cat-hitting-light clip and flips theme at impact
  (function() {
    const VIDEO_DURATION = 2.15;
    const VIDEO_FPS = 20;
    const HIT_SECONDS_FWD = 0.90;                          // frame 19 @ 20fps – paw pressed into light
    // Frame-accurate reverse: forward frame F appears in reverse at (duration - fwd_time - 1/fps)
    // because the first displayed frame sits at t=0, not t=1/fps. Gives 1.20s for this clip.
    const HIT_SECONDS_REV = VIDEO_DURATION - HIT_SECONDS_FWD - (1 / VIDEO_FPS);
    const VIDEO_FWD = '/img/cat_light.mp4';
    const VIDEO_REV = '/img/cat_light_rev.mp4';
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const frame  = document.querySelector('.cat-switch-frame');
    const video  = frame && frame.querySelector('video');
    const button = document.querySelector('.dimmer');
    const loopBtn = document.querySelector('.loop-tally');
    const lockBtn = document.querySelector('.theme-lock');

    // Loop mode — audio rhythm is driven by deterministic JS setTimeout chains,
    // NOT by video rendering. The video-detected hit moment has variable load/
    // decode latency per cycle (each src change re-loads the file), which made
    // the audio loop sound uneven even after we fixed the per-direction timing.
    // Two-timer architecture:
    //   loopPressTimer:  press-note → resolve-chord at +PRESS_TO_HIT_MS (900ms)
    //   loopNextTimer:   resolve-chord → next press-note at +(LOOP_BEAT_MS - 900)
    // The cat video plays in parallel for visual; if it's a few frames off, the
    // ear doesn't notice but the audio rhythm stays rock-solid.
    const VIDEO_RATE = 0.75;         // slow the cat-paw motion to a deliberate glide
    const LOOP_BEAT_MS = 4200;       // total time between press-notes
    const PRESS_TO_HIT_MS = (HIT_SECONDS_FWD * 1000) / VIDEO_RATE;  // 1200ms — matches slowed video hit
    let loopArmed = false;
    let loopPressTimer = null;
    let loopNextTimer = null;
    let themeLocked = false;
    let loopDirection = null;        // when locked, tracks alternating direction
    let droneOsc = null;             // sub-bass D2 drone — kept across fade cycles
    let droneGain = null;

    // Cat controller — single source of truth for video state. Onended handler
    // attached once at init so it always cleans up `is-playing` regardless of
    // whether the video was started via manual click (playCatThenFlip) or loop
    // (fireCycle). Eliminates the "cat sticky" class of bugs.
    // Button-disabled handling: only re-enables if loop is NOT armed (loop
    // owns the "always-disabled-while-armed" state).
    const catCtl = (function() {
      if (!video || !frame) return { play: function(){}, reset: function(){} };
      video.addEventListener('ended', function() {
        frame.classList.remove('is-playing');
        if (button && !loopArmed) {
          setTimeout(function() { button.disabled = false; }, 200);
        }
      });
      return {
        play: function(goingDark) {
          if (reduced || video.readyState < 3) return;
          if (button && !loopArmed) button.disabled = true;
          video.src = goingDark ? VIDEO_FWD : VIDEO_REV;
          video.currentTime = goingDark ? 0 : (HIT_SECONDS_REV - HIT_SECONDS_FWD);
          video.playbackRate = VIDEO_RATE;
          frame.classList.add('is-playing');
          const p = video.play();
          if (p && p.catch) p.catch(function() {});
        },
        reset: function() {
          frame.classList.remove('is-playing');
          try { video.pause(); } catch (e) {}
          if (button && !loopArmed) button.disabled = false;
        }
      };
    })();

    let audioCtx = null;
    function ensureAudio() {
      try {
        if (!audioCtx) {
          audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        }
        return audioCtx;
      } catch (e) { return null; }
    }

    // 4-note palette across Dmaj7 — numbered low to high.
    // Pattern (1→3, 4→2): toggling back-and-forth traces ↑↑↓↓ as a
    // looping melodic phrase: D4 A4 C#5 F#4 D4 A4 C#5 F#4...
    const PIANO = {
      N1: 293.66, // D4   (lowest — root, dark anchor)
      N2: 369.99, // F#4  (low-mid — major 3rd)
      N3: 440.00, // A4   (high-mid — perfect 5th)
      N4: 554.37  // C#5  (highest — maj7, treble bite)
    };

    // Reverb — pre-delayed, dampened tail. Real rooms have a silent gap
    // before first reflections (the note speaks, THEN the room blooms), and
    // treble decays faster than bass (HF absorption by air/carpet/walls).
    // Per-channel decay rates differ slightly for stereo decorrelation.
    function getReverb(ctx) {
      if (ctx._reverbBus) return ctx._reverbBus;
      const seconds = 9.0;       // chapel-scale wash; notes bloom and bleed
      const preDelay = 0.035;    // 35ms silent intro — sense of space
      const sr = ctx.sampleRate;
      const len = Math.floor(sr * seconds);
      const preLen = Math.floor(sr * preDelay);
      const buf = ctx.createBuffer(2, len, sr);
      for (let ch = 0; ch < 2; ch++) {
        const d = buf.getChannelData(ch);
        const decayPower = ch === 0 ? 2.0 : 2.4;
        for (let i = 0; i < len; i++) {
          if (i < preLen) { d[i] = 0; continue; }
          const tailPos = (i - preLen) / (len - preLen);
          d[i] = (Math.random() * 2 - 1) * Math.pow(1 - tailPos, decayPower);
        }
      }
      const conv = ctx.createConvolver();
      conv.buffer = buf;
      // Heavy lowpass — removes white-noise-IR hash, leaves warm low-mid wash.
      // Music for Airports has little above ~4kHz in the wet signal.
      const damp = ctx.createBiquadFilter();
      damp.type = 'lowpass';
      damp.frequency.value = 1800;
      damp.Q.value = 0.5;
      conv.connect(damp).connect(ctx.destination);
      ctx._reverbBus = conv;
      return conv;
    }

    // Pad voice — FM synthesis tuned for ambient bloom.
    // No hammer noise (pads don't strike). Slow attack (~110ms). Long sustain
    // so notes overlap into a harmonic cloud. Low mod-index peak keeps the
    // attack soft, no upper-partial sizzle. Stereo-panned per voice for the
    // watercolor spread. DX7 patch territory — Eno's Apollo, Music for Airports.
    function playPianoNote(freq, when, sustain, sendOverride) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = (when !== undefined) ? when : ctx.currentTime;
      const sus = sustain || 9.0;     // long enough that 3+ notes overlap
      const send = sendOverride !== undefined ? sendOverride : 0.65;
      const reverb = getReverb(ctx);

      // Two slightly-detuned voices for chorus shimmer; each panned to its
      // own stereo position so the chorus also spreads spatially.
      [-4, 4].forEach(function(detune, idx) {
        const carrier = ctx.createOscillator();
        carrier.type = 'sine';
        carrier.frequency.value = freq;
        carrier.detune.value = detune;

        const modulator = ctx.createOscillator();
        modulator.type = 'sine';
        modulator.frequency.value = freq;
        modulator.detune.value = detune;

        // Pad-like mod envelope: slow rise to a low peak, slow fall.
        // Index 0.7 → soft bell-pad (fundamental + 2nd partial mostly)
        // Index 0.2 → just the fundamental (pure sine sustain)
        const modDepth = ctx.createGain();
        modDepth.gain.setValueAtTime(0.0001, t);
        modDepth.gain.exponentialRampToValueAtTime(freq * 0.7, t + 0.110);
        modDepth.gain.exponentialRampToValueAtTime(freq * 0.2, t + 2.0);
        modDepth.gain.exponentialRampToValueAtTime(0.0001, t + sus);
        modulator.connect(modDepth).connect(carrier.frequency);

        // Slow attack (~110ms = pad), very long decay to silence.
        const carrierGain = ctx.createGain();
        carrierGain.gain.setValueAtTime(0.0001, t);
        carrierGain.gain.exponentialRampToValueAtTime(0.085, t + 0.110);
        carrierGain.gain.exponentialRampToValueAtTime(0.0001, t + sus);

        // Tremolo — AM at 4.5Hz (Wurlitzer-territory). LFO modulates a
        // dedicated gain stage AFTER the envelope so the wobble doesn't fight
        // the attack/decay shape. Per-voice phase offset (0 vs π) creates
        // stereo motion — left dips while right rises = Leslie cabinet feel.
        const tremoloGain = ctx.createGain();
        tremoloGain.gain.value = 1.0;  // base; LFO will swing around this
        const tremoloLfo = ctx.createOscillator();
        tremoloLfo.type = 'sine';
        tremoloLfo.frequency.value = 4.5;
        const tremoloDepth = ctx.createGain();
        tremoloDepth.gain.value = 0.22;  // ±22% amplitude swing
        tremoloLfo.connect(tremoloDepth).connect(tremoloGain.gain);
        // Phase offset between the two voices — start the second LFO half a
        // cycle later so they're inverse-phase.
        const lfoStart = t + (idx === 0 ? 0 : (1 / 4.5) / 2);
        tremoloLfo.start(lfoStart);
        tremoloLfo.stop(t + sus + 0.1);

        // Stereo pan per voice — chorus shimmer spreads spatially across L/R.
        const panner = ctx.createStereoPanner();
        panner.pan.value = idx === 0 ? -0.35 : 0.35;
        carrier.connect(carrierGain).connect(tremoloGain).connect(panner).connect(ctx.destination);

        // Reverb send — heavy wet bus by default; press-notes can override
        // (high C#5 press is dried because its tail bleeds into next chord).
        const sendGain = ctx.createGain();
        sendGain.gain.value = send;
        panner.connect(sendGain).connect(reverb);

        modulator.start(t);
        carrier.start(t);
        modulator.stop(t + sus + 0.1);
        carrier.stop(t + sus + 0.1);
      });
    }

    // Press — single first note. Direction-aware, conventional intuition:
    //   D→L (goingDark=false): going to LIGHT = rise. Press N1 (D4 — low).
    //   L→D (goingDark=true):  going to DARK  = fall. Press N4 (C#5 — high).
    // Shimmer — pure-sine bell octave-up, very slow attack + long sustain.
    // Sits as a halo above the main FM voice. Quiet enough that you don't
    // hear it as its own event, just as sparkle on top.
    function playShimmer(freq, when, sustain, sendOverride) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = (when !== undefined) ? when : ctx.currentTime;
      const sus = (sustain || 9.0) * 1.4;
      const send = sendOverride !== undefined ? sendOverride : 0.55;
      const reverb = getReverb(ctx);

      const osc = ctx.createOscillator();
      osc.type = 'sine';
      osc.frequency.value = freq * 2;  // octave up

      const gain = ctx.createGain();
      gain.gain.setValueAtTime(0.0001, t);
      gain.gain.exponentialRampToValueAtTime(0.045, t + 0.250);
      gain.gain.exponentialRampToValueAtTime(0.0001, t + sus);
      osc.connect(gain).connect(ctx.destination);

      const sendGain = ctx.createGain();
      sendGain.gain.value = send;
      gain.connect(sendGain).connect(reverb);

      osc.start(t);
      osc.stop(t + sus + 0.5);
    }

    function playPressNote(goingDark) {
      // C#5 press (going dark) is dried — its high register bleeds into the
      // next resolve chord otherwise. D4 press (going light) keeps full wash;
      // it's the bass root and its tail grounds the chord above it.
      if (goingDark) {
        playPianoNote(PIANO.N4, undefined, 4.0, 0.18);
        playShimmer(PIANO.N4, undefined, 4.0, 0.08);  // shimmer also dried
      } else {
        playPianoNote(PIANO.N1, undefined, 9.0);
        playShimmer(PIANO.N1, undefined, 9.0);
      }
    }

    // Resolve — TWO notes (a chord) at cat-paw impact. The "satisfying" beat.
    //   D→L (going light, RISING):  press N1 → resolve [N3 + N4] = A4 + C#5
    //   L→D (going dark, FALLING):  press N4 → resolve [N2 + N1] = F#4 + D4
    // Both directions complete a Dmaj7 voicing across press+resolve = full
    // 4-note chord arpeggiated in different orders. The two resolve notes
    // play with a 25ms stagger so the chord feels human-struck, not robotic.
    function playResolveChord(goingDark) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = ctx.currentTime;
      const pair = goingDark
        ? [PIANO.N2, PIANO.N1]   // F#4 + D4  (falling — major 3rd interval)
        : [PIANO.N3, PIANO.N4];  // A4 + C#5  (rising — major 3rd interval)
      pair.forEach(function(f) {
        playPianoNote(f, t, 9.0);
        playShimmer(f, t, 9.0);
      });
    }

    // DOM-only theme flip (no audio). Used by both the manual click path
    // (via instantFlip) and the loop's deterministic timer chain.
    function applyThemeFlip() {
      const d = document.documentElement;
      const wasInDark = d.getAttribute('data-theme') === 'dark';
      const goingDark = !wasInDark;
      const next = goingDark ? 'dark' : '';
      d.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      if (button) button.setAttribute('aria-pressed', goingDark ? 'true' : 'false');
      return goingDark;
    }

    function instantFlip() {
      const goingDark = applyThemeFlip();
      playResolveChord(goingDark);
    }

    // Loop cycle — JS-timer-driven audio rhythm, video plays in parallel for
    // visual only. The press-note fires now; the resolve-chord + theme-flip
    // fire at exactly +PRESS_TO_HIT_MS; the next cycle fires at +LOOP_BEAT_MS.
    // No video timing dependency = no per-cycle load-latency jitter.
    function fireCycle() {
      if (!loopArmed) return;

      // Direction: when unlocked, derives from current theme (so a manual
      // dimmer click between cycles re-syncs). When locked, alternates an
      // internal flag so the music still progresses without flipping theme.
      let goingDark;
      if (themeLocked) {
        if (loopDirection === null) {
          loopDirection = document.documentElement.getAttribute('data-theme') !== 'dark';
        } else {
          loopDirection = !loopDirection;
        }
        goingDark = loopDirection;
      } else {
        loopDirection = null;
        goingDark = document.documentElement.getAttribute('data-theme') !== 'dark';
      }

      // Audio: press immediately (this is beat zero of the cycle)
      playPressNote(goingDark);

      // Visual: cat clip plays in parallel — but only when NOT locked. With
      // theme locked, the paw motion would imply a theme change that won't
      // happen, so we leave the cat off-screen and just play music.
      if (!themeLocked) catCtl.play(goingDark);

      // Resolve chord + theme flip at deterministic +PRESS_TO_HIT_MS after press
      if (loopPressTimer) clearTimeout(loopPressTimer);
      loopPressTimer = setTimeout(function() {
        loopPressTimer = null;
        if (!loopArmed) return;
        if (!themeLocked) applyThemeFlip();
        playResolveChord(goingDark);
        // Schedule next cycle
        if (loopNextTimer) clearTimeout(loopNextTimer);
        loopNextTimer = setTimeout(function() {
          loopNextTimer = null;
          if (loopArmed) fireCycle();
        }, LOOP_BEAT_MS - PRESS_TO_HIT_MS);
      }, PRESS_TO_HIT_MS);
    }

    function playCatThenFlip() {
      if (reduced || !video || video.readyState < 3) return instantFlip();

      const goingDark = document.documentElement.getAttribute('data-theme') !== 'dark';
      const hitAt = goingDark ? HIT_SECONDS_FWD : HIT_SECONDS_REV;
      const seekFrom = goingDark ? 0 : (HIT_SECONDS_REV - HIT_SECONDS_FWD);
      const safetyMs = ((hitAt - seekFrom) / VIDEO_RATE) * 1000 + 500;

      catCtl.play(goingDark);

      let flipped = false;
      function doFlip() {
        if (flipped) return;
        flipped = true;
        instantFlip();
      }

      const safety = setTimeout(doFlip, safetyMs);
      function tick() {
        if (flipped) return;
        if (video.currentTime >= hitAt) {
          clearTimeout(safety);
          doFlip();
          return;
        }
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    window.toggleTheme = playCatThenFlip;

    // Press feedback — fires the moment the pointer goes down, before onclick.
    // Pairs with CSS :active state on .dimmer for visual press-in.
    if (button) {
      button.addEventListener('pointerdown', function() {
        if (button.disabled) return;
        const goingDark = document.documentElement.getAttribute('data-theme') !== 'dark';
        playPressNote(goingDark);
      });
    }

    function setLoopUI(armed) {
      if (!loopBtn) return;
      loopBtn.setAttribute('aria-pressed', armed ? 'true' : 'false');
      loopBtn.classList.toggle('is-armed', armed);
    }

    function setLockUI(locked) {
      if (!lockBtn) return;
      lockBtn.setAttribute('aria-pressed', locked ? 'true' : 'false');
      lockBtn.classList.toggle('is-locked', locked);
    }

    function toggleThemeLock() {
      themeLocked = !themeLocked;
      setLockUI(themeLocked);
      if (themeLocked) {
        // Hide any cat clip in flight from the pre-lock cycle
        catCtl.reset();
      } else {
        // Re-sync direction tracker to actual theme on next cycle
        loopDirection = null;
      }
    }
    window.toggleThemeLock = toggleThemeLock;

    // Drone — D2 + D3 layered (sub-bass + bass). D2 alone is below most laptop
    // speakers' rolloff (~150Hz), so we double it with D3 for audibility on any
    // playback. Eno's "On Land" trick — octave-doubled drone reads as a single
    // huge low tone but reproduces on small speakers.
    // Fades in 4s on arm, fades out 4s on disarm. Re-arming during fade-out
    // cancels the fade-out and ramps back up — no oscillator leak.
    function startDrone() {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = ctx.currentTime;
      const peak = 0.075;

      // Re-arm during fade-out: cancel scheduled stop, re-fade-in
      if (droneOsc && droneGain) {
        const g = droneGain.gain;
        g.cancelScheduledValues(t);
        g.setValueAtTime(g.value, t);
        g.exponentialRampToValueAtTime(peak, t + 3.0);
        return;
      }

      const reverb = getReverb(ctx);
      const gain = ctx.createGain();
      gain.gain.setValueAtTime(0.0001, t);
      gain.gain.exponentialRampToValueAtTime(peak, t + 4.0);
      gain.connect(ctx.destination);

      // Two oscillators — D2 (sub) and D3 (audible-on-laptops bass).
      // Slightly detuned for chorus shimmer at the low end.
      const oscD2 = ctx.createOscillator();
      oscD2.type = 'sine';
      oscD2.frequency.value = PIANO.N1 / 4;  // D2 = 73.4Hz
      oscD2.detune.value = -3;
      oscD2.connect(gain);

      const oscD3 = ctx.createOscillator();
      oscD3.type = 'sine';
      oscD3.frequency.value = PIANO.N1 / 2;  // D3 = 146.8Hz
      oscD3.detune.value = +3;
      oscD3.connect(gain);

      // Light reverb send for spatial weight
      const sendGain = ctx.createGain();
      sendGain.gain.value = 0.22;
      gain.connect(sendGain).connect(reverb);

      oscD2.start();
      oscD3.start();
      droneOsc = { sub: oscD2, bass: oscD3 };
      droneGain = gain;
    }

    function stopDrone() {
      if (!droneOsc || !droneGain) return;
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = ctx.currentTime;
      const oscRef = droneOsc;
      const gainRef = droneGain;
      droneOsc = null;
      droneGain = null;
      const g = gainRef.gain;
      g.cancelScheduledValues(t);
      g.setValueAtTime(g.value, t);
      g.exponentialRampToValueAtTime(0.0001, t + 4.0);
      try { oscRef.sub.stop(t + 4.5); } catch (e) {}
      try { oscRef.bass.stop(t + 4.5); } catch (e) {}
    }

    // fireCycle now self-drives via setTimeout chain — reduced-motion path is
    // handled inside fireCycle (skips video block when reduced is true).
    function startLoopCycle() {
      fireCycle();
    }

    function toggleLoop() {
      loopArmed = !loopArmed;
      try { sessionStorage.setItem('loop_armed', loopArmed ? '1' : '0'); } catch (e) {}
      setLoopUI(loopArmed);
      if (loopArmed) {
        // Loop owns the dimmer while running — manual clicks would conflict
        if (button) button.disabled = true;
        startLoopCycle();
      } else {
        if (loopPressTimer) { clearTimeout(loopPressTimer); loopPressTimer = null; }
        if (loopNextTimer) { clearTimeout(loopNextTimer); loopNextTimer = null; }
        // Clear lock state too — reset for next arming
        if (themeLocked) { themeLocked = false; setLockUI(false); }
        loopDirection = null;
        catCtl.reset();
        if (button) button.disabled = false;
      }
    }

    window.toggleLoop = toggleLoop;

    // Auto-resume across header page nav — sessionStorage survives full-page
    // loads within a tab. iOS Safari may require a user gesture before the
    // first AudioContext.resume(); the LED stays on either way and audio
    // engages on next interaction. Acceptable degradation.
    try {
      if (sessionStorage.getItem('loop_armed') === '1') {
        loopArmed = true;
        setLoopUI(true);
        if (button) button.disabled = true;  // loop owns dimmer while armed

        // Audio defer — if ctx is suspended (no user gesture on new page),
        // wait for first interaction before starting drone + cycle. Otherwise
        // events queue up on a frozen audio clock and slam together when
        // ctx finally resumes.
        function kickoff() {
          if (!loopArmed) return;
          if (reduced || !video || video.readyState >= 3) {
            fireCycle();
          } else {
            video.addEventListener('loadeddata', function once() {
              video.removeEventListener('loadeddata', once);
              if (loopArmed) fireCycle();
            });
          }
        }

        const ctx = ensureAudio();
        if (ctx && ctx.state === 'running') {
          kickoff();
        } else if (ctx) {
          // Try resume (some browsers honor cross-page gesture). If still
          // suspended, defer until first user interaction.
          const tryResume = ctx.resume();
          if (tryResume && tryResume.then) {
            tryResume.then(function() {
              if (ctx.state === 'running') kickoff();
              else deferKickoff();
            }).catch(deferKickoff);
          } else {
            deferKickoff();
          }
        }

        function deferKickoff() {
          const handler = function() {
            document.removeEventListener('pointerdown', handler);
            document.removeEventListener('keydown', handler);
            // Resume ctx now that we have a gesture
            const c = ensureAudio();
            if (c && c.state === 'suspended') c.resume();
            if (loopArmed) kickoff();
          };
          document.addEventListener('pointerdown', handler, { once: true });
          document.addEventListener('keydown', handler, { once: true });
        }
      }
    } catch (e) {}
  })();

  // FOUC restore – keep this untouched, runs as soon as parser hits it
  (function() {
    const saved = localStorage.getItem('theme');
    if (saved) document.documentElement.setAttribute('data-theme', saved);
    // sync aria-pressed on dimmer once DOM is ready
    document.addEventListener('DOMContentLoaded', function() {
      var btn = document.querySelector('.dimmer');
      if (btn) btn.setAttribute('aria-pressed', saved === 'dark' ? 'true' : 'false');
    });
  })();

  // tab
  (function(){var t=document.title;document.addEventListener('visibilitychange',function(){document.title=document.hidden?'\u2013':t})})();

  // scroll-spy — rAF-throttled scroll listener.  Robust for short sections
  // (IntersectionObserver with -60% bottom rootMargin skipped 1-item sections.)
  (function() {
    var sections = document.querySelectorAll('.topic-section');
    var links = document.querySelectorAll('.topic-index a');
    var index = document.getElementById('topic-index');
    if (!sections.length || !links.length) return;

    var linkMap = {};
    links.forEach(function(a) { linkMap[a.getAttribute('data-topic')] = a; });

    function navOffset() {
      var nav = document.querySelector('.site-nav');
      return nav ? Math.ceil(nav.getBoundingClientRect().height + 24) : 80;
    }

    function keepActiveLinkVisible(a) {
      if (!index || !a) return;
      var linkTop = a.offsetTop;
      var linkBottom = linkTop + a.offsetHeight;
      var viewTop = index.scrollTop;
      var viewBottom = viewTop + index.clientHeight;
      if (linkTop < viewTop) index.scrollTop = linkTop;
      else if (linkBottom > viewBottom) index.scrollTop = linkBottom - index.clientHeight;
    }

    function updateActive() {
      var referenceY = navOffset();
      var active = null;
      var best = Infinity;

      // Pick the section whose top has crossed the reference line most recently
      sections.forEach(function(s) {
        var r = s.getBoundingClientRect();
        if (r.top <= referenceY && r.bottom > referenceY) {
          var dist = referenceY - r.top;
          if (dist < best) { best = dist; active = s.dataset.topic; }
        }
      });

      // Fallback: first section fully visible, or first section if all below fold
      if (!active) {
        for (var i = 0; i < sections.length; i++) {
          var r = sections[i].getBoundingClientRect();
          if (r.top < window.innerHeight && r.bottom > 0) {
            active = sections[i].dataset.topic;
            break;
          }
        }
      }

      links.forEach(function(a) {
        var isActive = a.getAttribute('data-topic') === active;
        a.classList.toggle('active', isActive);
        if (isActive) {
          a.setAttribute('aria-current', 'true');
          keepActiveLinkVisible(a);
        } else {
          a.removeAttribute('aria-current');
        }
      });
    }

    var ticking = false;
    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(function() {
          updateActive();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    updateActive(); // initial paint

    // Click-nav: respect the section's CSS scroll-margin so the sticky
    // site nav and the topic highlight use the same reference point.
    links.forEach(function(a) {
      a.addEventListener('click', function(e) {
        var slug = a.getAttribute('data-topic');
        var section = document.getElementById(slug);
        if (section) {
          e.preventDefault();
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
          if (history.pushState) history.pushState(null, '', '#' + slug);
        }
        closeSidebar();
      });
    });
  })();

  // Mobile hamburger overlay: open/close with focus-trap + Escape + body scroll-lock
  function openSidebar() {
    var idx = document.getElementById('topic-index');
    var btn = document.querySelector('.sidebar-toggle');
    if (!idx) return;
    idx.classList.add('open');
    idx.removeAttribute('inert');
    document.body.classList.add('menu-open');
    if (btn) btn.setAttribute('aria-expanded', 'true');
    var firstLink = idx.querySelector('a');
    if (firstLink) firstLink.focus();
  }
  function closeSidebar() {
    var idx = document.getElementById('topic-index');
    var btn = document.querySelector('.sidebar-toggle');
    if (!idx) return;
    var wasOpen = idx.classList.contains('open');
    idx.classList.remove('open');
    document.body.classList.remove('menu-open');
    if (btn) {
      btn.setAttribute('aria-expanded', 'false');
      if (wasOpen) btn.focus();
    }
    // Keep off-canvas topic links out of the tab order whenever the overlay is hidden.
    if (window.matchMedia('(max-width: 1200px)').matches) {
      idx.setAttribute('inert', '');
    }
  }
  window.toggleSidebar = function() {
    var idx = document.getElementById('topic-index');
    if (!idx) return;
    if (idx.classList.contains('open')) closeSidebar();
    else openSidebar();
  };
  // Escape closes overlay when open
  document.addEventListener('keydown', function(e) {
    if (e.key !== 'Escape') return;
    var idx = document.getElementById('topic-index');
    if (idx && idx.classList.contains('open')) closeSidebar();
  });
  function syncSidebarMode() {
    var idx = document.getElementById('topic-index');
    var btn = document.querySelector('.sidebar-toggle');
    if (!idx) return;
    if (window.matchMedia('(max-width: 1200px)').matches) {
      if (!idx.classList.contains('open')) idx.setAttribute('inert', '');
    } else {
      idx.removeAttribute('inert');
      idx.classList.remove('open');
      document.body.classList.remove('menu-open');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    }
  }
  document.addEventListener('DOMContentLoaded', syncSidebarMode);
  window.addEventListener('resize', syncSidebarMode);
</script>
</body>
</html>
