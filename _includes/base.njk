<script>
  (function() {
    const ornaments = document.querySelector('.site-page-ornaments');
    const artNoteButton = document.querySelector('[data-art-note-toggle]');
    const artOriginal = document.querySelector('#site-sawyer-original');
    const artCaption = document.querySelector('.site-art-reveal-caption');
    if (!ornaments || !artNoteButton) return;

    function setArtReveal(active) {
      ornaments.classList.toggle('is-art-revealed', active);
      artNoteButton.setAttribute('aria-expanded', active ? 'true' : 'false');
      if (artOriginal) artOriginal.setAttribute('aria-hidden', active ? 'false' : 'true');
      if (artCaption) artCaption.setAttribute('aria-hidden', active ? 'false' : 'true');
    }

    artNoteButton.addEventListener('click', function() {
      const active = !ornaments.classList.contains('is-art-revealed');
      setArtReveal(active);
    });

    artNoteButton.addEventListener('keydown', function(event) {
      if (event.key !== 'Escape') return;
      setArtReveal(false);
      artNoteButton.blur();
    });
  })();
</script>

<script>
  // theme toggle – plays the cat-hitting-light clip and flips theme at impact
  (function() {
    const VIDEO_DURATION = 2.15;
    const VIDEO_FPS = 20;
    const HIT_SECONDS_FWD = 0.90;                          // frame 19 @ 20fps – paw pressed into light
    // Frame-accurate reverse: forward frame F appears in reverse at (duration - fwd_time - 1/fps)
    // because the first displayed frame sits at t=0, not t=1/fps. Gives 1.20s for this clip.
    const HIT_SECONDS_REV = VIDEO_DURATION - HIT_SECONDS_FWD - (1 / VIDEO_FPS);
    const VIDEO_FWD = '/img/cat_light.mp4';
    const VIDEO_REV = '/img/cat_light_rev.mp4';
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const frame  = document.querySelector('.cat-switch-frame');
    const video  = frame && frame.querySelector('video');
    const button = document.querySelector('.dimmer');
    const loopBtn = document.querySelector('.loop-tally');
    const rabbitModeBtn = document.querySelector('.pretty-loop');
    const waveModeBtn = document.querySelector('.constellation-mode-toggle');
    const prettyDelayMixControl = document.querySelector('.pretty-delay-control');
    const prettyDelayMixInput = document.querySelector('[data-pretty-delay-mix]');
    const prettyDelayCluster = document.querySelector('[data-pretty-cluster]');
    const constellationStepBtns = document.querySelectorAll('[data-constellation-step]');
    const prettyField = document.querySelector('.pretty-constellation-field');
    const prettyCanvas = document.querySelector('[data-pretty-constellation]');
    const constellationLabelNodes = document.querySelectorAll('[data-pretty-label]');
    const constellationNote = document.querySelector('[data-pretty-note]');
    const constellationNoteTitle = document.querySelector('[data-pretty-note-title]');
    const constellationNoteId = document.querySelector('[data-pretty-note-id]');
    const constellationNoteBody = document.querySelector('[data-pretty-note-body]');
    const lockBtn = document.querySelector('.theme-lock');
    if (!loopBtn) {
      try { sessionStorage.removeItem('loop_armed'); } catch (e) {}
    }

    // Loop mode — audio rhythm is driven by deterministic JS setTimeout chains,
    // NOT by video rendering. The video-detected hit moment has variable load/
    // decode latency per cycle (each src change re-loads the file), which made
    // the audio loop sound uneven even after we fixed the per-direction timing.
    // Two-timer architecture:
    //   loopPressTimer:  press-note → resolve-chord at +PRESS_TO_HIT_MS (1000ms)
    //   loopNextTimer:   resolve-chord → next press-note at +(LOOP_BEAT_MS - 1000)
    // The cat video plays in parallel for visual; if it's a few frames off, the
    // ear doesn't notice but the audio rhythm stays rock-solid.
    const VIDEO_RATE = 0.9;          // a little slower than source, but no longer syrupy
    const LOOP_BEAT_MS = 4000;       // total time between press-notes
    const PRESS_TO_HIT_MS = (HIT_SECONDS_FWD * 1000) / VIDEO_RATE;  // 1000ms — matches the paw hit
    const CAT_MANUAL_FADE_IN_MS = 130;
    const CAT_MANUAL_FADE_OUT_MS = 1050;
    const CAT_LOOP_FADE_IN_MS = 260;
    const CAT_LOOP_FADE_OUT_DELAY_MS = 1700;
    const CAT_LOOP_FADE_OUT_MS = 1950;
    let loopArmed = false;
    let loopPressTimer = null;
    let loopNextTimer = null;
    let themeLocked = false;
    let loopDirection = null;        // while locked, tracks alternating performance direction
    let prettyArmed = false;
    let constellationModeActive = false;
    let constellationVisualActive = false;
    let prettyTimer = null;
    let prettyFieldExitTimer = null;
    let prettyStep = 0;
    let prettyStartedAt = null;

    // Cat controller — manual clicks release on the video end; loop mode
    // releases from the music clock so the visual breath follows the note
    // attack and reverb tail instead of decode timing.
    const catCtl = (function() {
      if (!video || !frame) return { play: function(){}, reset: function(){} };
      let activeFadeOutMs = CAT_MANUAL_FADE_OUT_MS;
      let activeMode = 'manual';
      let fadeOutTimer = null;
      function clearFadeOutTimer() {
        if (fadeOutTimer) {
          clearTimeout(fadeOutTimer);
          fadeOutTimer = null;
        }
      }
      function beginFadeOut() {
        frame.style.setProperty('--cat-fade-ms', activeFadeOutMs + 'ms');
        frame.classList.remove('is-playing');
      }
      video.addEventListener('ended', function() {
        if (activeMode === 'loop') return;
        beginFadeOut();
        if (button && !loopArmed) {
          setTimeout(function() { button.disabled = false; }, activeFadeOutMs + 80);
        }
      });
      return {
        play: function(goingDark, mode) {
          if (reduced || video.readyState < 3) return;
          if (button && !loopArmed) button.disabled = true;
          const loopMode = mode === 'loop';
          clearFadeOutTimer();
          activeMode = loopMode ? 'loop' : 'manual';
          const fadeInMs = loopMode ? CAT_LOOP_FADE_IN_MS : CAT_MANUAL_FADE_IN_MS;
          activeFadeOutMs = loopMode ? CAT_LOOP_FADE_OUT_MS : CAT_MANUAL_FADE_OUT_MS;
          video.src = goingDark ? VIDEO_FWD : VIDEO_REV;
          video.currentTime = goingDark ? 0 : (HIT_SECONDS_REV - HIT_SECONDS_FWD);
          video.playbackRate = VIDEO_RATE;
          frame.style.setProperty('--cat-fade-ms', fadeInMs + 'ms');
          frame.classList.add('is-playing');
          const p = video.play();
          if (p && p.catch) p.catch(function() {});
          if (loopMode) {
            fadeOutTimer = setTimeout(function() {
              fadeOutTimer = null;
              beginFadeOut();
            }, CAT_LOOP_FADE_OUT_DELAY_MS);
          }
        },
        reset: function() {
          clearFadeOutTimer();
          activeMode = 'manual';
          beginFadeOut();
          try { video.pause(); } catch (e) {}
          if (button && !loopArmed) button.disabled = false;
        }
      };
    })();

    let audioCtx = null;
    function ensureAudio() {
      try {
        if (!audioCtx) {
          audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        }
        return audioCtx;
      } catch (e) { return null; }
    }

    function resumeAudio(ctx, onReady, onBlocked) {
      if (!ctx) {
        if (onBlocked) onBlocked();
        return;
      }
      if (ctx.state === 'running') {
        onReady();
        return;
      }
      if (!ctx.resume) {
        if (onBlocked) onBlocked();
        return;
      }
      const resumed = ctx.resume();
      if (resumed && resumed.then) {
        resumed.then(function() {
          if (ctx.state === 'running') onReady();
          else if (onBlocked) onBlocked();
        }).catch(function() {
          if (onBlocked) onBlocked();
        });
      } else if (ctx.state === 'running') {
        onReady();
      } else if (onBlocked) {
        onBlocked();
      }
    }

    const CONSTELLATION_CANVAS_WIDTH = 136;
    const CONSTELLATION_CANVAS_HEIGHT = 60;
    const CONSTELLATION_PIXEL_SCALE = 2;
    // Uniform line color across every constellation — the per-record
    // lineColor fields are kept in the data for reference but overridden
    // here so motion (pulse traversal) carries the visual identity instead
    // of color. Blue (#4385be) reads as drafting-ink on the dark field.
    const LINE_COLOR = '#4385be';

    function constellationXPercent(x) {
      // Mirrors xPos() inside createPrettyConstellation; kept in sync so
      // star-label DOM nodes (positioned by %) land where canvas pixels
      // are drawn. Update both together.
      return ((((x * 1.08) + 4) * CONSTELLATION_PIXEL_SCALE) / CONSTELLATION_CANVAS_WIDTH) * 100;
    }

    function constellationYPercent(y) {
      return (((y + 1.4) * CONSTELLATION_PIXEL_SCALE) / CONSTELLATION_CANVAS_HEIGHT) * 100;
    }

    const CONSTELLATIONS = {
      bootes: {
