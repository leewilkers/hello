        // Reverse — each char starts unsettled at its own random frame and
        // ends as noise, then clears. Random order, no directional dissolve.
        const unsettleFrames = phrase.split('').map(function(c) {
          if (c === ' ') return 0;
          return Math.floor(Math.random() * 14);
        });
        const clearFrames = unsettleFrames.map(function(s) { return s + 6 + Math.floor(Math.random() * 6); });
        const totalFrames = Math.max.apply(null, clearFrames) + 3;
        let frame = 0;
        function tick() {
          for (let i = 0; i < spans.length; i++) {
            if (phrase[i] === ' ') continue;
            if (frame < unsettleFrames[i]) {
              // still showing target letter
            } else if (frame < clearFrames[i]) {
              spans[i].textContent = pickNoise();
            } else {
