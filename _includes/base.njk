	    }

	    function getDropTarget(el) {
	      return el && el.closest('.topic-section, .topic-index a[data-topic]');
	    }

	    function getDropTopic(target) {
	      if (!target || target.dataset.curationDest) return '';
	      return target.dataset.topic || '';
	    }

	    function getDropDest(target) {
	      if (!target) return '';
	      return target.dataset.curationDest || '';
	    }

	    function createTopicSection(topic) {
	      if (!gridScroll) return null;
	      var section = document.createElement('section');
	      section.id = topic.slug;
	      section.dataset.topic = topic.slug;
	      section.dataset.topicName = topic.name;
	      section.dataset.topicCount = '0';
	      section.className = 'topic-section topic-section--custom';

	      var header = document.createElement('header');
	      header.className = 'section-label';
	      var title = document.createElement('h2');
	      title.className = 'section-label-name';
	      title.textContent = topic.name;
	      var count = document.createElement('span');
	      count.className = 'section-label-count';
	      count.dataset.sectionCount = '';
	      count.textContent = '0';
	      header.appendChild(title);
	      header.appendChild(count);

	      var grid = document.createElement('ul');
	      grid.className = 'grid';
	      var list = document.createElement('ul');
	      list.className = 'shelf-list is-empty';
	      list.setAttribute('aria-label', topic.name + ' list items');
	      section.appendChild(header);
	      section.appendChild(grid);
	      section.appendChild(list);

	      var firstCuration = gridScroll.querySelector('.topic-section[data-curation-dest]');
	      gridScroll.insertBefore(section, firstCuration || null);
	      return section;
	    }

	    function createTopicRailLink(topic) {
	      if (!topicIndex) return null;
	      var link = document.createElement('a');
	      link.href = '#' + topic.slug;
	      link.dataset.topic = topic.slug;
	      var label = document.createElement('span');
	      label.textContent = topic.name;
	      var count = document.createElement('b');
	      count.textContent = '0';
	      link.appendChild(label);
	      link.appendChild(count);
	      var firstCuration = topicIndex.querySelector('a[data-curation-dest]');
	      topicIndex.insertBefore(link, firstCuration || null);
	      link.addEventListener('click', topicRailClick);
	      return link;
	    }

	    function ensureCustomTopic(topic, persist) {
	      var rawName = topic && typeof topic === 'object' ? topic.name : topic;
	      var name = String(rawName || '').trim();
	      var slug = topic && typeof topic === 'object' && topic.slug ? topic.slug : slugifyTopic(name);
	      if (!name || !slug) return null;
	      var normalized = { name: name, slug: slug };
	      var existing = page.querySelector('.topic-section[data-topic="' + CSS.escape(slug) + '"]');
	      if (!existing) {
	        createTopicSection(normalized);
	        createTopicRailLink(normalized);
	      }
	      if (persist) {
	        var topics = readCustomTopics();
	        if (!topics.some(function(t) { return t.slug === slug; })) {
	          topics.push(normalized);
	          writeCustomTopics(topics);
	        }
	      }
	      return normalized;
	    }

	    function topicRailClick(e) {
	      var a = e.currentTarget || e.target.closest('a[data-topic]');
	      if (!a) return;
	      var slug = a.getAttribute('data-topic');
	      var section = document.getElementById(slug);
	      if (section) {
	        e.preventDefault();
	        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
	        if (history.pushState) history.pushState(null, '', '#' + slug);
	        closeSidebar();
	      }
	    }

	    function curationSnapshot() {
	      persistCurrentState();
	      return {
	        version: 1,
	        exportedAt: new Date().toISOString(),
	        source: location.href,
	        listItems: readListState(),
	        topicItems: readTopicState(),
	        destinationItems: readDestState(),
	        customTopics: readCustomTopics()
	      };
	    }

	    function copyText(text) {
	      if (navigator.clipboard && navigator.clipboard.writeText) {
	        return navigator.clipboard.writeText(text);
	      }
	      var textarea = document.createElement('textarea');
	      textarea.value = text;
	      textarea.setAttribute('readonly', '');
	      textarea.style.position = 'fixed';
	      textarea.style.left = '-9999px';
	      document.body.appendChild(textarea);
	      textarea.select();
	      try {
	        if (!document.execCommand('copy')) throw new Error('copy command failed');
	        return Promise.resolve();
	      } catch (e) {
	        return Promise.reject(e);
	      } finally {
	        textarea.remove();
	      }
	    }

	    function showExportFallback(text) {
	      var existing = document.querySelector('[data-shelf-export-fallback]');
	      if (existing) existing.remove();
	      var textarea = document.createElement('textarea');
	      textarea.className = 'shelf-export-fallback';
	      textarea.setAttribute('data-shelf-export-fallback', '');
	      textarea.setAttribute('aria-label', 'Shelf curation JSON');
	      textarea.value = text;
	      var controls = document.querySelector('.shelf-review-controls');
	      (controls || document.body).appendChild(textarea);
	      textarea.focus();
	      textarea.select();
	    }

	    function applyInitialState() {
	      readCustomTopics().forEach(function(topic) { ensureCustomTopic(topic, false); });
	      var topicMap = readTopicState();
	      Object.keys(topicMap).forEach(function(id) { moveItemToTopic(id, topicMap[id], false); });
	      readListState().forEach(function(id) { setListed(id, true, false); });
	      var destMap = readDestState();
	      Object.keys(destMap).forEach(function(id) { moveItemToDestination(id, destMap[id], false); });
	      page.querySelectorAll('.topic-section').forEach(function(section) {
	        updateListEmptyState(section);
	        updateTopicCount(section);
	      });
	    }

	    if (document.readyState === 'loading') {
	      document.addEventListener('DOMContentLoaded', applyInitialState);
	    } else {
	      applyInitialState();
	    }

	    if (topicForm) {
	      topicForm.addEventListener('submit', function(e) {
	        e.preventDefault();
	        var input = topicForm.querySelector('input[name="topic"]');
	        var topic = ensureCustomTopic(input && input.value, true);
	        if (!topic) return;
	        if (input) input.value = '';
	        setStatus('added ' + topic.name);
	        var section = document.getElementById(topic.slug);
	        if (section) {
	          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
	          if (history.pushState) history.pushState(null, '', '#' + topic.slug);
	        }
	      });
	    }

	    if (exportButton) {
	      exportButton.addEventListener('click', function() {
	        var text = JSON.stringify(curationSnapshot(), null, 2);
	        copyText(text).then(function() {
	          setStatus('curation JSON copied');
	        }).catch(function() {
	          showExportFallback(text);
	          setStatus('copy failed; select text below');
	        });
	      });
	    }

	    document.addEventListener('click', function(e) {
	      if (!armedItemId) return;
	      if (e.target.closest('[data-shelf-id]')) return;
	      var target = getDropTarget(e.target);
	      var topic = getDropTopic(target);
	      var dest = getDropDest(target);
	      if (!target || (!topic && !dest)) return;
	      e.preventDefault();
	      e.stopPropagation();
	      rememberState(armedItemId);
	      if (dest) moveItemToDestination(armedItemId, dest, false);
	      else moveItemToTopic(armedItemId, topic, false);
	      persistCurrentState();
	      clearArmedItem();
	      setStatus(dest ? (dest === 'remove' ? 'removed item' : 'moved to ' + dest) : 'moved topic');
	    }, true);

	    document.addEventListener('click', function(e) {
	      var armBtn = e.target.closest('[data-shelf-arm-topic]');
	      if (armBtn) {
	        if (!page.contains(armBtn)) return;
	        var armedItem = armBtn.closest('[data-shelf-id]');
	        if (!armedItem) return;
	        e.preventDefault();
	        armItem(armedItem.getAttribute('data-shelf-id'));
	        return;
	      }

	      var destBtn = e.target.closest('[data-shelf-dest]');
	      var actionBtn = e.target.closest('[data-shelf-action]');
	      var btn = destBtn || actionBtn;
	      if (!btn) return;
	      if (!page.contains(btn)) return;
	      var item = btn.closest('[data-shelf-id]');
	      if (!item) return;
	      e.preventDefault();
	      var id = item.getAttribute('data-shelf-id');
	      rememberState(id);

	      if (destBtn) {
	        var dest = destBtn.getAttribute('data-shelf-dest');
	        moveItemToDestination(id, dest, false);
	        setStatus(dest === 'remove' ? 'removed item' : 'moved to ' + dest);
	      } else {
	        var action = actionBtn.getAttribute('data-shelf-action');
	        if (action === 'cover') {
	          moveItemToDestination(id, 'shelf', false);
	          setListed(id, false, false);
	          setStatus('restored cover');
	        } else {
	          setListed(id, action === 'list', false);
	          setStatus(action === 'list' ? 'moved to list' : 'updated item');
	        }
	      }
	      persistCurrentState();
	    });

	    if (undoButton) {
	      undoButton.addEventListener('click', function() {
	        var state = undoStack.pop();
	        restoreState(state);
	      });
	      updateUndoButton();
	    }

	    page.addEventListener('dragstart', function(e) {
	      var item = e.target.closest('.shelf-card, .shelf-list-row');
	      if (!item || !item.dataset.shelfId) return;
	      page.classList.add('is-dragging-shelf-item');
	      item.classList.add('is-dragging');
	      e.dataTransfer.effectAllowed = 'move';
	      e.dataTransfer.setData('text/plain', item.dataset.shelfId);
	    });

	    page.addEventListener('dragend', function() {
	      page.classList.remove('is-dragging-shelf-item');
	      page.querySelectorAll('.is-dragging, .is-drop-target').forEach(function(el) {
	        el.classList.remove('is-dragging', 'is-drop-target');
	      });
	    });

	    page.addEventListener('dragover', function(e) {
	      var target = getDropTarget(e.target);
	      if (!target) return;
	      e.preventDefault();
	      e.dataTransfer.dropEffect = 'move';
	      target.classList.add('is-drop-target');
	    });

	    page.addEventListener('dragleave', function(e) {
	      var target = getDropTarget(e.target);
	      if (!target || target.contains(e.relatedTarget)) return;
	      target.classList.remove('is-drop-target');
	    });

	    page.addEventListener('drop', function(e) {
	      var target = getDropTarget(e.target);
	      var topic = getDropTopic(target);
	      var dest = getDropDest(target);
	      if (!target || (!topic && !dest)) return;
	      e.preventDefault();
	      var id = e.dataTransfer.getData('text/plain');
	      if (id) {
	        rememberState(id);
	        if (dest) moveItemToDestination(id, dest, false);
	        else moveItemToTopic(id, topic, false);
	        persistCurrentState();
	        clearArmedItem();
	      }
	      target.classList.remove('is-drop-target');
	    });
	  })();
{% endif %}

	  // Mobile hamburger overlay: open/close with focus-trap + Escape + body scroll-lock
	  function openSidebar() {
    var idx = document.getElementById('topic-index');
    var btn = document.querySelector('.sidebar-toggle');
    if (!idx) return;
    idx.classList.add('open');
    idx.removeAttribute('inert');
    document.body.classList.add('menu-open');
    if (btn) btn.setAttribute('aria-expanded', 'true');
    var firstLink = idx.querySelector('a');
    if (firstLink) firstLink.focus();
  }
  function closeSidebar() {
    var idx = document.getElementById('topic-index');
    var btn = document.querySelector('.sidebar-toggle');
    if (!idx) return;
    var wasOpen = idx.classList.contains('open');
    idx.classList.remove('open');
    document.body.classList.remove('menu-open');
    if (btn) {
      btn.setAttribute('aria-expanded', 'false');
      if (wasOpen) btn.focus();
    }
    // Keep off-canvas topic links out of the tab order whenever the overlay is hidden.
    if (window.matchMedia('(max-width: 1200px)').matches) {
      idx.setAttribute('inert', '');
    }
  }
  window.toggleSidebar = function() {
    var idx = document.getElementById('topic-index');
    if (!idx) return;
    if (idx.classList.contains('open')) closeSidebar();
    else openSidebar();
  };
  // Escape closes overlay when open
  document.addEventListener('keydown', function(e) {
    if (e.key !== 'Escape') return;
    var idx = document.getElementById('topic-index');
    if (idx && idx.classList.contains('open')) closeSidebar();
  });
  function syncSidebarMode() {
    var idx = document.getElementById('topic-index');
    var btn = document.querySelector('.sidebar-toggle');
    if (!idx) return;
    if (window.matchMedia('(max-width: 1200px)').matches) {
      if (!idx.classList.contains('open')) idx.setAttribute('inert', '');
    } else {
      idx.removeAttribute('inert');
      idx.classList.remove('open');
      document.body.classList.remove('menu-open');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    }
  }
  document.addEventListener('DOMContentLoaded', syncSidebarMode);
  window.addEventListener('resize', syncSidebarMode);
</script>

<script>
  (function() {
    var el = document.querySelector('[data-site-status]');
    if (!el) return;
    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    var now = new Date();
    var dateStr = now.getDate() + ' ' + months[now.getMonth()];
    var paint = function(weatherStr) {
      el.textContent = dateStr + (weatherStr ? ' · ' + weatherStr : '') + ' · Atlanta';
    };
    paint('');
    if (typeof fetch !== 'function') return;
    var url = 'https://api.open-meteo.com/v1/forecast?latitude=33.749&longitude=-84.388&current=temperature_2m&temperature_unit=fahrenheit';
    fetch(url)
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(data) {
        if (!data || !data.current || typeof data.current.temperature_2m !== 'number') return;
        paint(Math.round(data.current.temperature_2m) + '°F');
      })
      .catch(function() {});
  })();
</script>

<script>
  // Rail-hover: place-note content snaps into the right rail (anchored top).
  (function() {
    document.addEventListener('DOMContentLoaded', function() {
      var rail = document.getElementById('rail-hover');
      if (!rail) return;

      function activate(note) {
        rail.textContent = note;
        rail.classList.add('is-active');
      }

      function activateNode(sourceEl) {
        var clone = sourceEl.cloneNode(true);
        clone.removeAttribute('hidden');
        rail.replaceChildren.apply(rail, Array.prototype.slice.call(clone.childNodes));
        rail.classList.add('is-active');
      }

      function deactivate() {
        rail.classList.remove('is-active');
      }

      var notes = document.querySelectorAll('.home-place-note');
      notes.forEach(function(el) {
        var bodyEl = el.querySelector('.home-cite-note-body');
        var note = el.getAttribute('data-note') || '';
        function enter() { bodyEl ? activateNode(bodyEl) : activate(note); }
        el.addEventListener('mouseenter', enter);
        el.addEventListener('focus', enter);
        el.addEventListener('mouseleave', deactivate);
        el.addEventListener('blur', deactivate);
      });
    });
  })();
</script>
