<!DOCTYPE html>
<html lang="en" data-theme="dark"{% if fontPreview %} data-font="{{ fontPreview }}"{% endif %}{% if palettePreview %} data-palette="{{ palettePreview }}"{% endif %}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or site.title }}</title>
  <meta name="description" content="Lee Wilkers – tools, judgment, and use.">
  <meta property="og:title" content="{{ title or site.title }}">
  <meta property="og:description" content="Tools, judgment, and use.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}/img/og-image.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title or site.title }}">
  <meta name="twitter:description" content="Tools, judgment, and use.">
  <meta name="twitter:image" content="{{ site.url }}/img/og-image.png">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <link rel="icon" href="/img/favicon.svg" type="image/svg+xml">
  <link rel="alternate" type="application/rss+xml" title="Shelf – Lee Wilkers" href="/shelf.xml">
  <link rel="alternate" type="application/rss+xml" title="Stream – Lee Wilkers" href="/stream.xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,300..900;1,8..60,300..900&display=swap" rel="stylesheet">
  {% if fontPreview == "bricolage-eb" or fontPreview == "plex-pair" %}
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@10..96,400..800&family=EB+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Serif:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
  {% endif %}
  <script>
    (function() {
      try {
        var params = new URLSearchParams(window.location.search);
        var palette = params.get('palette');
        var theme = params.get('theme');
        var font = params.get('font');
        var fontPreview = {
          'current-eb': true,
          'source-serif': true,
          'literata': true,
          'newsreader': true,
          'spectral': true,
          'ibm-plex-serif': true,
          'charter-system': true,
          'lora': true,
          'crimson-pro': true,
          'alegreya': true,
          'source-atkinson': true,
          'plex-sans': true,
          'bricolage-eb': true,
          'plex-pair': true
        };
        var needsPreviewFontFile = {
          'literata': true,
          'newsreader': true,
          'spectral': true,
          'ibm-plex-serif': true,
          'lora': true,
          'crimson-pro': true,
          'alegreya': true,
          'source-atkinson': true,
          'bricolage-eb': true,
          'plex-pair': true
        };
        if (palette === 'default') {
          document.documentElement.removeAttribute('data-palette');
        } else if (palette) {
          document.documentElement.setAttribute('data-palette', palette);
        }
        if (font && fontPreview[font]) {
          document.documentElement.setAttribute('data-font', font);
          if (needsPreviewFontFile[font]) {
            var fontLink = document.createElement('link');
            fontLink.rel = 'stylesheet';
            fontLink.href = 'https://fonts.googleapis.com/css2?family=Alegreya:ital,wght@0,400;0,500;0,700;1,400&family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400&family=Bricolage+Grotesque:opsz,wght@10..96,400..800&family=Crimson+Pro:ital,wght@0,400..700;1,400..700&family=EB+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Serif:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Literata:ital,opsz,wght@0,7..72,400..700;1,7..72,400..700&family=Lora:ital,wght@0,400..700;1,400..700&family=Newsreader:ital,opsz,wght@0,6..72,400..700;1,6..72,400..700&family=Spectral:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap';
            document.head.appendChild(fontLink);
          }
        }
        if (theme === 'light' || theme === 'dark') {
          document.documentElement.setAttribute('data-theme', theme);
        }
      } catch (e) {}
    })();
  </script>
  <link rel="stylesheet" href="/css/style.css">
  {% if pageClass == "page-style-variations" %}
  <link rel="stylesheet" href="/css/style-variations.css">
  {% endif %}
  {% if pageClass == "page-color-lab" %}
  <link rel="stylesheet" href="/css/color-lab.css">
  {% endif %}
  {% if pageClass == "page-brico-colors" %}
  <link rel="stylesheet" href="/css/brico-colors.css">
  {% endif %}
</head>
