        // settle frame (within a window), so resolution is non-sequential —
        // the message emerges out of a noise field, not left-to-right.
        const settleFrames = phrase.split('').map(function(c) {
          if (c === ' ') return 0;
          return 6 + Math.floor(Math.random() * 16);  // settle anywhere from frame 6 to 22
        });
        const totalFrames = Math.max.apply(null, settleFrames) + 3;
        let frame = 0;
        function tick() {
          for (let i = 0; i < spans.length; i++) {
            if (phrase[i] === ' ') continue;
            if (frame < settleFrames[i]) {
              spans[i].textContent = pickNoise();
            } else {
              spans[i].textContent = phrase[i];
            }
          }
          frame++;
          if (frame >= totalFrames) { done(); return; }
          watermarkTimer = setTimeout(tick, FRAME_MS);
        }
        tick();
      }
