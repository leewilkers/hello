<script>
  // theme toggle – plays the cat-hitting-light clip and flips theme at impact
  (function() {
    const VIDEO_DURATION = 2.15;
    const VIDEO_FPS = 20;
    const HIT_SECONDS_FWD = 0.90;                          // frame 19 @ 20fps – paw pressed into light
    // Frame-accurate reverse: forward frame F appears in reverse at (duration - fwd_time - 1/fps)
    // because the first displayed frame sits at t=0, not t=1/fps. Gives 1.20s for this clip.
    const HIT_SECONDS_REV = VIDEO_DURATION - HIT_SECONDS_FWD - (1 / VIDEO_FPS);
    const VIDEO_FWD = '/img/cat_light.mp4';
    const VIDEO_REV = '/img/cat_light_rev.mp4';
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const frame  = document.querySelector('.cat-switch-frame');
    const video  = frame && frame.querySelector('video');
    const button = document.querySelector('.dimmer');
    const loopBtn = document.querySelector('.loop-tally');
    const lockBtn = document.querySelector('.theme-lock');

    // Loop mode — audio rhythm is driven by deterministic JS setTimeout chains,
    // NOT by video rendering. The video-detected hit moment has variable load/
    // decode latency per cycle (each src change re-loads the file), which made
    // the audio loop sound uneven even after we fixed the per-direction timing.
    // Two-timer architecture:
    //   loopPressTimer:  press-note → resolve-chord at +PRESS_TO_HIT_MS (1000ms)
    //   loopNextTimer:   resolve-chord → next press-note at +(LOOP_BEAT_MS - 1000)
    // The cat video plays in parallel for visual; if it's a few frames off, the
    // ear doesn't notice but the audio rhythm stays rock-solid.
    const VIDEO_RATE = 0.9;          // a little slower than source, but no longer syrupy
    const LOOP_BEAT_MS = 4000;       // total time between press-notes
    const PRESS_TO_HIT_MS = (HIT_SECONDS_FWD * 1000) / VIDEO_RATE;  // 1000ms — matches the paw hit
    const CAT_MANUAL_FADE_IN_MS = 130;
    const CAT_MANUAL_FADE_OUT_MS = 1050;
    const CAT_LOOP_FADE_IN_MS = 260;
    const CAT_LOOP_FADE_OUT_DELAY_MS = 1700;
    const CAT_LOOP_FADE_OUT_MS = 1950;
    let loopArmed = false;
    let loopPressTimer = null;
    let loopNextTimer = null;
    let themeLocked = false;
    let loopDirection = null;        // when locked, tracks alternating direction

    // Cat controller — manual clicks release on the video end; loop mode
    // releases from the music clock so the visual breath follows the note
    // attack and reverb tail instead of decode timing.
    const catCtl = (function() {
      if (!video || !frame) return { play: function(){}, reset: function(){} };
      let activeFadeOutMs = CAT_MANUAL_FADE_OUT_MS;
      let activeMode = 'manual';
      let fadeOutTimer = null;
      function clearFadeOutTimer() {
        if (fadeOutTimer) {
          clearTimeout(fadeOutTimer);
          fadeOutTimer = null;
        }
      }
      function beginFadeOut() {
        frame.style.setProperty('--cat-fade-ms', activeFadeOutMs + 'ms');
        frame.classList.remove('is-playing');
      }
      video.addEventListener('ended', function() {
        if (activeMode === 'loop') return;
        beginFadeOut();
        if (button && !loopArmed) {
          setTimeout(function() { button.disabled = false; }, activeFadeOutMs + 80);
        }
      });
      return {
        play: function(goingDark, mode) {
          if (reduced || video.readyState < 3) return;
          if (button && !loopArmed) button.disabled = true;
          const loopMode = mode === 'loop';
          clearFadeOutTimer();
          activeMode = loopMode ? 'loop' : 'manual';
          const fadeInMs = loopMode ? CAT_LOOP_FADE_IN_MS : CAT_MANUAL_FADE_IN_MS;
          activeFadeOutMs = loopMode ? CAT_LOOP_FADE_OUT_MS : CAT_MANUAL_FADE_OUT_MS;
          video.src = goingDark ? VIDEO_FWD : VIDEO_REV;
          video.currentTime = goingDark ? 0 : (HIT_SECONDS_REV - HIT_SECONDS_FWD);
          video.playbackRate = VIDEO_RATE;
          frame.style.setProperty('--cat-fade-ms', fadeInMs + 'ms');
          frame.classList.add('is-playing');
          const p = video.play();
          if (p && p.catch) p.catch(function() {});
          if (loopMode) {
            fadeOutTimer = setTimeout(function() {
              fadeOutTimer = null;
              beginFadeOut();
            }, CAT_LOOP_FADE_OUT_DELAY_MS);
          }
        },
        reset: function() {
          clearFadeOutTimer();
          activeMode = 'manual';
          beginFadeOut();
          try { video.pause(); } catch (e) {}
          if (button && !loopArmed) button.disabled = false;
        }
      };
    })();

    let audioCtx = null;
    function ensureAudio() {
      try {
        if (!audioCtx) {
          audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        }
        return audioCtx;
      } catch (e) { return null; }
    }

    // 4-note palette across Dmaj7 — numbered low to high.
    // Pattern (1→3, 4→2): toggling back-and-forth traces ↑↑↓↓ as a
    // looping melodic phrase: D4 A4 C#5 F#4 D4 A4 C#5 F#4...
    const PIANO = {
      N1: 293.66, // D4   (lowest — root, dark anchor)
      N2: 369.99, // F#4  (low-mid — major 3rd)
      N3: 440.00, // A4   (high-mid — perfect 5th)
      N4: 554.37  // C#5  (highest — maj7, treble bite)
    };

    // Reverb — pre-delayed, dampened tail. Real rooms have a silent gap
    // before first reflections (the note speaks, THEN the room blooms), and
    // treble decays faster than bass (HF absorption by air/carpet/walls).
    // Per-channel decay rates differ slightly for stereo decorrelation.
    function getReverb(ctx) {
      if (ctx._reverbBus) return ctx._reverbBus;
      const seconds = 9.0;       // chapel-scale wash; notes bloom and bleed
      const preDelay = 0.035;    // 35ms silent intro — sense of space
      const sr = ctx.sampleRate;
      const len = Math.floor(sr * seconds);
      const preLen = Math.floor(sr * preDelay);
      const buf = ctx.createBuffer(2, len, sr);
      for (let ch = 0; ch < 2; ch++) {
        const d = buf.getChannelData(ch);
        const decayPower = ch === 0 ? 2.0 : 2.4;
        for (let i = 0; i < len; i++) {
          if (i < preLen) { d[i] = 0; continue; }
          const tailPos = (i - preLen) / (len - preLen);
          d[i] = (Math.random() * 2 - 1) * Math.pow(1 - tailPos, decayPower);
        }
      }
      const conv = ctx.createConvolver();
      conv.buffer = buf;
      // Heavy lowpass — removes white-noise-IR hash, leaves warm low-mid wash.
      // Music for Airports has little above ~4kHz in the wet signal.
      const damp = ctx.createBiquadFilter();
      damp.type = 'lowpass';
      damp.frequency.value = 1800;
      damp.Q.value = 0.5;
      conv.connect(damp).connect(ctx.destination);
      ctx._reverbBus = conv;
      return conv;
    }

    // Pad voice — FM synthesis tuned for ambient bloom.
    // No hammer noise (pads don't strike). Slow attack (~110ms). Long sustain
    // so notes overlap into a harmonic cloud. Low mod-index peak keeps the
    // attack soft, no upper-partial sizzle. Stereo-panned per voice for the
    // watercolor spread. DX7 patch territory — Eno's Apollo, Music for Airports.
    function playPianoNote(freq, when, sustain, sendOverride, levelOverride, fadeProfile) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = (when !== undefined) ? when : ctx.currentTime;
      const sus = sustain || 9.0;     // long enough that 3+ notes overlap
      const send = sendOverride !== undefined ? sendOverride : 0.65;
      const level = levelOverride !== undefined ? levelOverride : 0.085;
      const reverb = getReverb(ctx);

      // Two slightly-detuned voices for chorus shimmer; each panned to its
      // own stereo position so the chorus also spreads spatially.
      [-4, 4].forEach(function(detune, idx) {
        const carrier = ctx.createOscillator();
        carrier.type = 'sine';
        carrier.frequency.value = freq;
        carrier.detune.value = detune;

        const modulator = ctx.createOscillator();
        modulator.type = 'sine';
        modulator.frequency.value = freq;
        modulator.detune.value = detune;

        // Pad-like mod envelope: slow rise to a low peak, slow fall.
        // Index 0.7 → soft bell-pad (fundamental + 2nd partial mostly)
        // Index 0.2 → just the fundamental (pure sine sustain)
        const modDepth = ctx.createGain();
        modDepth.gain.setValueAtTime(0.0001, t);
        modDepth.gain.exponentialRampToValueAtTime(freq * 0.7, t + 0.110);
        modDepth.gain.exponentialRampToValueAtTime(freq * 0.2, t + 2.0);
        modDepth.gain.exponentialRampToValueAtTime(0.0001, t + sus);
        modulator.connect(modDepth).connect(carrier.frequency);

        // Slow attack (~110ms = pad), very long decay to silence.
        const carrierGain = ctx.createGain();
        carrierGain.gain.setValueAtTime(0.0001, t);
        carrierGain.gain.exponentialRampToValueAtTime(level, t + 0.110);
        if (fadeProfile) {
          const holdUntil = t + (fadeProfile.hold || 0.75);
          const fadeUntil = t + (fadeProfile.fadeTo || 2.0);
          const tailLevel = Math.max(0.0001, level * (fadeProfile.tailRatio || 0.18));
          carrierGain.gain.setValueAtTime(level, holdUntil);
          carrierGain.gain.exponentialRampToValueAtTime(tailLevel, fadeUntil);
          carrierGain.gain.exponentialRampToValueAtTime(0.0001, t + sus);
        } else {
          carrierGain.gain.exponentialRampToValueAtTime(0.0001, t + sus);
        }

        // Warmth filter — gentle lowpass with slight resonance. Rolls off the
        // brittle highs the FM voice generates, giving the patch the warm,
        // physically-present quality of analog circuit filters (Moog/Juno).
        // Q ~0.7 = analog-sweet-spot resonance shelf.
        const warmth = ctx.createBiquadFilter();
        warmth.type = 'lowpass';
        warmth.frequency.value = 2800;
        warmth.Q.value = 0.7;

        // Stereo pan per voice — chorus shimmer spreads spatially across L/R.
        const panner = ctx.createStereoPanner();
        panner.pan.value = idx === 0 ? -0.35 : 0.35;
        carrier.connect(carrierGain).connect(warmth).connect(panner).connect(ctx.destination);

        // Reverb send — heavy wet bus by default; press-notes can override
        // (high C#5 press is dried because its tail bleeds into next chord).
        const sendGain = ctx.createGain();
        sendGain.gain.value = send;
        panner.connect(sendGain).connect(reverb);

        modulator.start(t);
        carrier.start(t);
        modulator.stop(t + sus + 0.1);
        carrier.stop(t + sus + 0.1);
      });
    }

    // Press — single first note. Direction-aware, conventional intuition:
    //   D→L (goingDark=false): going to LIGHT = rise. Press N1 (D4 — low).
    //   L→D (goingDark=true):  going to DARK  = fall. Press N4 (C#5 — high).
    // Shimmer — pure-sine bell octave-up, very slow attack + long sustain.
    // Sits as a halo above the main FM voice. Quiet enough that you don't
    // hear it as its own event, just as sparkle on top.
    function playShimmer(freq, when, sustain, sendOverride) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = (when !== undefined) ? when : ctx.currentTime;
      const sus = (sustain || 9.0) * 1.4;
      const send = sendOverride !== undefined ? sendOverride : 0.55;
      const reverb = getReverb(ctx);

      const osc = ctx.createOscillator();
      osc.type = 'sine';
      osc.frequency.value = freq * 2;  // octave up

      const gain = ctx.createGain();
      gain.gain.setValueAtTime(0.0001, t);
      gain.gain.exponentialRampToValueAtTime(0.045, t + 0.250);
      gain.gain.exponentialRampToValueAtTime(0.0001, t + sus);
      osc.connect(gain).connect(ctx.destination);

      const sendGain = ctx.createGain();
      sendGain.gain.value = send;
      gain.connect(sendGain).connect(reverb);

      osc.start(t);
      osc.stop(t + sus + 0.5);
    }

    function playPressNote(goingDark) {
      // Direction-aware press. The D4 press that starts dark→light blooms,
      // then ducks into a quiet tail so it doesn't cloud the next gesture.
      // C#5 press while going dark is dried a bit, but not clipped.
      if (goingDark) {
        playPianoNote(PIANO.N4, undefined, 4.0, 0.18);
        playShimmer(PIANO.N4, undefined, 4.0, 0.08);
      } else {
        playPianoNote(PIANO.N1, undefined, 5.0, 0.18, undefined, { hold: 0.75, fadeTo: 2.1, tailRatio: 0.16 });
        playShimmer(PIANO.N1, undefined, 3.2, 0.06);
      }
    }

    // Resolve — TWO notes (a chord) at cat-paw impact. The "satisfying" beat.
    // Keep the original music shapes here; dark/light assignment is inverted
    // only at the call sites via musicDirection().
    function playResolveChord(goingDark) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = ctx.currentTime;
      if (goingDark) {
        playPianoNote(PIANO.N2, t, 9.0);
        playShimmer(PIANO.N2, t, 9.0);
        playPianoNote(PIANO.N1, t, 9.0);
        playShimmer(PIANO.N1, t, 9.0);
      } else {
        [PIANO.N3, PIANO.N4].forEach(function(f) {
          playPianoNote(f, t, 9.0);
          playShimmer(f, t, 9.0);
        });
      }
    }

    // DOM-only theme flip (no audio). Used by both the manual click path
    // (via instantFlip) and the loop's deterministic timer chain.
    function applyThemeFlip() {
      const d = document.documentElement;
      const wasInDark = d.getAttribute('data-theme') === 'dark';
      const goingDark = !wasInDark;
      const next = goingDark ? 'dark' : 'light';
      d.setAttribute('data-theme', next);
      if (button) button.setAttribute('aria-pressed', goingDark ? 'true' : 'false');
      return goingDark;
    }

    function musicDirection(goingDark) {
      // Music treats dark/light as inverted now: same visual toggle, opposite
      // phrase direction.
      return !goingDark;
    }

    function instantFlip() {
      const goingDark = applyThemeFlip();
      playResolveChord(musicDirection(goingDark));
    }

    // Loop cycle — JS-timer-driven audio rhythm, video plays in parallel for
    // visual only. The press-note fires now; the resolve-chord + theme-flip
    // fire at exactly +PRESS_TO_HIT_MS; the next cycle fires at +LOOP_BEAT_MS.
    // No video timing dependency = no per-cycle load-latency jitter.
    function fireCycle() {
      if (!loopArmed) return;

      // Direction: when unlocked, derives from current theme (so a manual
      // dimmer click between cycles re-syncs). When locked, alternates an
      // internal flag so the music still progresses without flipping theme.
      let goingDark;
      if (themeLocked) {
        if (loopDirection === null) {
          loopDirection = document.documentElement.getAttribute('data-theme') !== 'dark';
        } else {
          loopDirection = !loopDirection;
        }
        goingDark = loopDirection;
      } else {
        loopDirection = null;
        goingDark = document.documentElement.getAttribute('data-theme') !== 'dark';
      }

      const musicGoingDark = musicDirection(goingDark);

      // Audio: press immediately (this is beat zero of the cycle)
      playPressNote(musicGoingDark);

      // Visual: cat clip plays in parallel — but only when NOT locked. With
      // theme locked, the paw motion would imply a theme change that won't
      // happen, so we leave the cat off-screen and just play music.
      if (!themeLocked) catCtl.play(musicGoingDark, 'loop');

