            constellationNoteId.textContent = constellation.note.id || '';
          }
          if (constellationNoteBody) {
            while (constellationNoteBody.firstChild) constellationNoteBody.removeChild(constellationNoteBody.firstChild);
            const noteParagraphs = Array.isArray(constellation.note.paragraphs) && constellation.note.paragraphs.length
              ? constellation.note.paragraphs
              : (constellation.note.text ? [constellation.note.text] : []);
            // Typewriter reveal: parse paragraph HTML via DOMParser (safe —
            // content is template-controlled), then walk and wrap every char
            // in a .tw-char span and queue it for the rAF reveal loop. The
            // loop (startTypewriterReveal) flips visibility per char by wall
            // clock — much more reliable than relying on hundreds of CSS
            // animation-delay timers, which can drop individual fires under
            // background throttling. TW_CHAR_MS + TW_PARA_GAP_MS pacing
            // matches the constellationDwellMs window.
            resetTypewriterReveal();
            let cursorMs = 0;
            noteParagraphs.forEach(function(paragraphText, pIdx) {
              const paragraphNode = document.createElement('span');
              paragraphNode.className = 'pretty-constellation-note-paragraph';
              const doc = new DOMParser().parseFromString('<div>' + paragraphText + '</div>', 'text/html');
              const sourceRoot = doc.body.firstChild;
              while (sourceRoot.firstChild) paragraphNode.appendChild(sourceRoot.firstChild);
              if (pIdx > 0) cursorMs += TW_PARA_GAP_MS;
              cursorMs = wrapTypewriter(paragraphNode, cursorMs, TW_CHAR_MS);
              constellationNoteBody.appendChild(paragraphNode);
            });
