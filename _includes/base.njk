      { name: 'light switch',  pressA: ['A5'],  resolveA: ['D5','Bb4'],  pressB: ['Bb4'], resolveB: ['F5','A5'],   low: 'Bb3', walkBass: ['F3','D3'],   colorTone: 'C5' },   // Bb add9
