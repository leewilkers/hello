      { name: 'vi (Gm) — verse turn', pressA: ['D5'],  resolveA: ['Bb4','D5','F5','A4'],pressB: ['Bb4'], resolveB: ['Bb4','D5','F5'],           low: 'G3',  walkBass: ['D3','Bb3'],  colorTone: 'A5' },
      { name: 'IV (Eb) — opening',    pressA: ['G5'],  resolveA: ['G4','Bb4','D5','F5'],pressB: ['Eb5'], resolveB: ['Eb5','G5','Bb4'],          low: 'Eb3', walkBass: ['Bb3','G3'],  colorTone: 'F5' },
