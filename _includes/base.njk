      void prettyField.offsetHeight;
      prettyField.classList.add('is-mode-twinkling');
      constellationModeTwinkleTimer = setTimeout(function() {
        if (prettyField) prettyField.classList.remove('is-mode-twinkling');
        constellationModeTwinkleTimer = null;
