      if (constellationModeActive) {
        constellationCycleIndex = 0;
        setActiveConstellation(CONSTELLATION_CYCLE[0], true);
        startConstellationCycle();
      }
    }

    function resetRabbitIntroForReentry() {
      // Allow the intro to play again next time rabbit mode is entered.
      rabbitIntroState = 'inactive';
      if (rabbitIntroTimer) { clearTimeout(rabbitIntroTimer); rabbitIntroTimer = null; }
      document.documentElement.classList.remove('is-rabbit-intro');
      if (rabbitIntroOverlay) rabbitIntroOverlay.setAttribute('aria-hidden', 'true');
    }

