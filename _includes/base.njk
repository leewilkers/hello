<script>
  // theme toggle – plays the cat-hitting-light clip and flips theme at impact
  (function() {
    const VIDEO_DURATION = 2.15;
    const VIDEO_FPS = 20;
    const HIT_SECONDS_FWD = 0.90;                          // frame 19 @ 20fps – paw pressed into light
    // Frame-accurate reverse: forward frame F appears in reverse at (duration - fwd_time - 1/fps)
    // because the first displayed frame sits at t=0, not t=1/fps. Gives 1.20s for this clip.
    const HIT_SECONDS_REV = VIDEO_DURATION - HIT_SECONDS_FWD - (1 / VIDEO_FPS);
    const VIDEO_FWD = '/img/cat_light.mp4';
    const VIDEO_REV = '/img/cat_light_rev.mp4';
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const frame  = document.querySelector('.cat-switch-frame');
    const video  = frame && frame.querySelector('video');
    const button = document.querySelector('.dimmer');
    const loopBtn = document.querySelector('.loop-tally');
    const prettyBtn = document.querySelector('.pretty-loop');
    const prettyField = document.querySelector('.pretty-constellation-field');
    const prettyCanvas = document.querySelector('[data-pretty-constellation]');
    const lockBtn = document.querySelector('.theme-lock');
    if (!loopBtn) {
      try { sessionStorage.removeItem('loop_armed'); } catch (e) {}
    }

    // Loop mode — audio rhythm is driven by deterministic JS setTimeout chains,
    // NOT by video rendering. The video-detected hit moment has variable load/
    // decode latency per cycle (each src change re-loads the file), which made
    // the audio loop sound uneven even after we fixed the per-direction timing.
    // Two-timer architecture:
    //   loopPressTimer:  press-note → resolve-chord at +PRESS_TO_HIT_MS (1000ms)
    //   loopNextTimer:   resolve-chord → next press-note at +(LOOP_BEAT_MS - 1000)
    // The cat video plays in parallel for visual; if it's a few frames off, the
    // ear doesn't notice but the audio rhythm stays rock-solid.
    const VIDEO_RATE = 0.9;          // a little slower than source, but no longer syrupy
    const LOOP_BEAT_MS = 4000;       // total time between press-notes
    const PRESS_TO_HIT_MS = (HIT_SECONDS_FWD * 1000) / VIDEO_RATE;  // 1000ms — matches the paw hit
    const CAT_MANUAL_FADE_IN_MS = 130;
    const CAT_MANUAL_FADE_OUT_MS = 1050;
    const CAT_LOOP_FADE_IN_MS = 260;
    const CAT_LOOP_FADE_OUT_DELAY_MS = 1700;
    const CAT_LOOP_FADE_OUT_MS = 1950;
    let loopArmed = false;
    let loopPressTimer = null;
    let loopNextTimer = null;
    let themeLocked = false;
    let loopDirection = null;        // while locked, tracks alternating performance direction
    let prettyArmed = false;
    let prettyTimer = null;
    let prettyFieldExitTimer = null;
    let prettyStep = 0;

    // Cat controller — manual clicks release on the video end; loop mode
    // releases from the music clock so the visual breath follows the note
    // attack and reverb tail instead of decode timing.
    const catCtl = (function() {
      if (!video || !frame) return { play: function(){}, reset: function(){} };
      let activeFadeOutMs = CAT_MANUAL_FADE_OUT_MS;
      let activeMode = 'manual';
      let fadeOutTimer = null;
      function clearFadeOutTimer() {
        if (fadeOutTimer) {
          clearTimeout(fadeOutTimer);
          fadeOutTimer = null;
        }
      }
      function beginFadeOut() {
        frame.style.setProperty('--cat-fade-ms', activeFadeOutMs + 'ms');
        frame.classList.remove('is-playing');
      }
      video.addEventListener('ended', function() {
        if (activeMode === 'loop') return;
        beginFadeOut();
        if (button && !loopArmed) {
          setTimeout(function() { button.disabled = false; }, activeFadeOutMs + 80);
        }
      });
      return {
        play: function(goingDark, mode) {
          if (reduced || video.readyState < 3) return;
          if (button && !loopArmed) button.disabled = true;
          const loopMode = mode === 'loop';
          clearFadeOutTimer();
          activeMode = loopMode ? 'loop' : 'manual';
          const fadeInMs = loopMode ? CAT_LOOP_FADE_IN_MS : CAT_MANUAL_FADE_IN_MS;
          activeFadeOutMs = loopMode ? CAT_LOOP_FADE_OUT_MS : CAT_MANUAL_FADE_OUT_MS;
          video.src = goingDark ? VIDEO_FWD : VIDEO_REV;
          video.currentTime = goingDark ? 0 : (HIT_SECONDS_REV - HIT_SECONDS_FWD);
          video.playbackRate = VIDEO_RATE;
          frame.style.setProperty('--cat-fade-ms', fadeInMs + 'ms');
          frame.classList.add('is-playing');
          const p = video.play();
          if (p && p.catch) p.catch(function() {});
          if (loopMode) {
            fadeOutTimer = setTimeout(function() {
              fadeOutTimer = null;
              beginFadeOut();
            }, CAT_LOOP_FADE_OUT_DELAY_MS);
          }
        },
        reset: function() {
          clearFadeOutTimer();
          activeMode = 'manual';
          beginFadeOut();
          try { video.pause(); } catch (e) {}
          if (button && !loopArmed) button.disabled = false;
        }
      };
    })();

    let audioCtx = null;
    function ensureAudio() {
      try {
        if (!audioCtx) {
          audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        }
        return audioCtx;
      } catch (e) { return null; }
    }

    function createPrettyConstellation(canvas) {
      if (!canvas || !canvas.getContext) {
        return { setActive: function(){}, setVisible: function(){}, redraw: function(){} };
      }

      const ctx = canvas.getContext('2d');
      const points = [
        [3, 10], [11, 7], [19, 8], [29, 13], [42, 10], [38, 3],
        [47, 2], [52, 21], [32, 18], [21, 22], [15, 18]
      ];
      const edges = [[0, 1], [1, 2], [2, 3], [3, 4], [4, 5], [4, 6], [4, 7], [3, 8], [8, 7], [8, 9], [9, 10], [10, 3], [10, 0]];
      const stars = [
        [6, 3, 0.2], [14, 13, 1.3], [24, 5, 2.4], [34, 2, 1.1], [50, 7, 2.1],
        [56, 16, 0.9], [8, 21, 2.8], [27, 19, 0.5], [44, 22, 1.7]
      ];
      let active = false;
      let exiting = false;
      let visible = true;
      let raf = null;
      let start = performance.now();
      let modeStart = start;
      const PIXEL_SCALE = 2;
      const EXIT_SECONDS = 5.8;

      function xPos(x) { return ((x * 0.86) + 9.1) * PIXEL_SCALE; }
      function yPos(y) { return (y + 1.4) * PIXEL_SCALE; }

      function pixel(x, y, size, alpha, color) {
        const px = xPos(x);
        const py = yPos(y);
        const scaledSize = Math.max(1, Math.round(size * 1.45));
        ctx.globalAlpha = alpha > 0 ? alpha : 0;
        ctx.fillStyle = color || '#cecdc3';
        ctx.fillRect(Math.round(px), Math.round(py), scaledSize, scaledSize);
      }

      function hash(seed) {
        const value = Math.sin(seed * 127.1) * 43758.5453;
        return value - Math.floor(value);
      }

      function lit(seed, t, threshold, hold) {
        if (reduced) return true;
        const step = Math.floor((t + (seed * 0.43)) / hold);
        return hash(seed + (step * 9.73)) > threshold;
      }

      function aliveOnExit(seed, modeT) {
        if (!exiting || reduced) return true;
        const death = 0.8 + (hash(seed + 31.7) * 4.8);
        if (modeT >= death) return false;
        if ((death - modeT) < 1.6) {
          return lit(seed + 61.2, modeT, 0.28, 1.15);
        }
        return true;
      }

      function drawLine(a, b, progress, alpha, time) {
        const ax = points[a][0];
        const ay = points[a][1];
        const bx = points[b][0];
        const by = points[b][1];
        const endX = ax + ((bx - ax) * progress);
        const endY = ay + ((by - ay) * progress);
        const steps = Math.max(3, Math.ceil(Math.hypot(endX - ax, endY - ay) * 0.92));
        for (let i = 0; i <= steps; i++) {
          const step = i / steps;
          const seed = (a * 7.1) + (b * 3.3) + i;
          if ((active || exiting) && !lit(seed, time, 0.08, 5.8)) continue;
          if (exiting && !aliveOnExit(seed, time)) continue;
          pixel(ax + ((endX - ax) * step), ay + ((endY - ay) * step), 1, alpha, '#3aa99f');
        }
      }

      function draw(now) {
        if (!visible) return;
        const t = (now - start) / 1000;
        const modeT = (now - modeStart) / 1000;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        if (exiting && modeT > EXIT_SECONDS) {
          exiting = false;
          canvas.classList.remove('is-leaving');
          ctx.globalAlpha = 1;
          return;
        }
        const live = active || exiting;
        const settling = reduced ? 1 : Math.min(1, modeT / 2.8);
        const birthIndex = Math.floor(modeT * 3.8);
        const baseAlpha = live ? 0.52 : 0.18;
        stars.forEach(function(star, index) {
          const seed = star[2] + index;
          const born = exiting
            ? aliveOnExit(seed, modeT)
            : (!active || reduced || index <= birthIndex || lit(seed, t, 0.22, 9.5));
          if (!born) return;
          if (active && !lit(seed, t, 0.16, 6.6)) return;
          pixel(star[0], star[1], index % 3 === 0 ? 2 : 1, baseAlpha, '#cecdc3');
        });

        edges.forEach(function(edge) {
          drawLine(edge[0], edge[1], 1, live ? 0.18 : 0.12, exiting ? modeT : t);
        });

        const sweep = active
          ? Math.min(edges.length + 1.2, modeT * 1.55)
          : (exiting ? edges.length + 1.2 : 3.4);
        edges.forEach(function(edge, index) {
          const progress = Math.max(0, Math.min(1, sweep - (index * 0.82)));
          if (progress > 0) drawLine(edge[0], edge[1], progress, live ? 0.62 : 0.22, exiting ? modeT + index : t + index);
        });

        points.forEach(function(point, index) {
          const seed = index + 11;
          const born = exiting
            ? aliveOnExit(seed, modeT)
            : (!active || reduced || index <= birthIndex || lit(seed, t, 0.18, 10.4));
          if (!born) return;
          const bright = live && lit(index + 19, t, 0.56, 6.2);
          pixel(point[0] - 1, point[1] - 1, bright ? 3 : 2, live ? 0.82 : 0.36, '#fffcf0');
          if (live && settling > 0.35 && lit(index + 23, t, 0.62, 8.2)) {
            pixel(point[0], point[1], 1, 0.62, '#3aa99f');
          }
        });

        ctx.globalAlpha = 1;
        if (!reduced && (active || exiting)) raf = requestAnimationFrame(draw);
      }

      function run() {
        if (raf) cancelAnimationFrame(raf);
        raf = null;
        if (!visible) return;
        start = performance.now();
        if (reduced) {
          draw(start);
        } else {
          raf = requestAnimationFrame(draw);
        }
      }

      run();
      return {
        setActive: function(next) {
          const wasLive = active || exiting;
          active = !!next;
          exiting = !active && wasLive;
          modeStart = performance.now();
          canvas.classList.toggle('is-armed', active);
          canvas.classList.toggle('is-leaving', exiting);
          run();
        },
        setVisible: function(next) {
          visible = !!next;
          canvas.classList.toggle('is-hidden', !visible);
          if (visible) run();
        },
        redraw: run
      };
    }

    const prettyConstellation = createPrettyConstellation(prettyCanvas);

    // B-flat major 7 color across four tones: Bb4, D5, F5, A5.
    const PIANO = {
      N1: 466.16,
      N2: 587.33,
      N3: 698.46,
      N4: 880.00
    };

    const NOTE_FREQ = {
      Bb3: 233.08,
      Bb4: 466.16,
      C5: 523.25,
      D5: 587.33,
      Eb5: 622.25,
      F5: 698.46,
      G5: 783.99,
      A5: 880.00,
      Bb5: 932.33
    };

    const PRETTY_PRESETS = [
      { name: 'current shelf', pressA: ['A5'], resolveA: ['D5', 'Bb4'], pressB: ['Bb4'], resolveB: ['F5', 'A5'], low: 'Bb3' },
      { name: 'G top', pressA: ['G5'], resolveA: ['D5', 'Bb4'], pressB: ['Bb4'], resolveB: ['F5', 'G5'], low: 'Bb3' },
      { name: 'ninth air', pressA: ['C5'], resolveA: ['D5', 'Bb4'], pressB: ['Bb4'], resolveB: ['F5', 'C5'], low: 'Bb3' },
      { name: 'Eb shimmer', pressA: ['Eb5'], resolveA: ['D5', 'Bb4'], pressB: ['Bb4'], resolveB: ['F5', 'Eb5'], low: 'Bb3' },
      { name: 'plain fifth', pressA: ['F5'], resolveA: ['D5', 'Bb4'], pressB: ['Bb4'], resolveB: ['F5', 'Bb4'], low: 'Bb3' }
    ];

    const PRETTY_WALK = [0, 1, 2, 4, 3, 1, 0];
    const PRETTY_WALK_MS = 5600;
    const PRETTY_WALK_SPREAD_MS = 1400;

    // Reverb — pre-delayed, dampened tail. Real rooms have a silent gap
    // before first reflections (the note speaks, THEN the room blooms), and
    // treble decays faster than bass (HF absorption by air/carpet/walls).
    // Per-channel decay rates differ slightly for stereo decorrelation.
    function getReverb(ctx) {
      if (ctx._reverbBus) return ctx._reverbBus;
      const seconds = 9.0;       // chapel-scale wash; notes bloom and bleed
      const preDelay = 0.035;    // 35ms silent intro — sense of space
      const sr = ctx.sampleRate;
      const len = Math.floor(sr * seconds);
      const preLen = Math.floor(sr * preDelay);
      const buf = ctx.createBuffer(2, len, sr);
      for (let ch = 0; ch < 2; ch++) {
        const d = buf.getChannelData(ch);
        const decayPower = ch === 0 ? 2.0 : 2.4;
        for (let i = 0; i < len; i++) {
          if (i < preLen) { d[i] = 0; continue; }
          const tailPos = (i - preLen) / (len - preLen);
          d[i] = (Math.random() * 2 - 1) * Math.pow(1 - tailPos, decayPower);
        }
      }
      const conv = ctx.createConvolver();
      conv.buffer = buf;
      // Heavy lowpass — removes white-noise-IR hash, leaves warm low-mid wash.
      // Music for Airports has little above ~4kHz in the wet signal.
      const damp = ctx.createBiquadFilter();
      damp.type = 'lowpass';
      damp.frequency.value = 1800;
      damp.Q.value = 0.5;
      conv.connect(damp).connect(ctx.destination);
      ctx._reverbBus = conv;
      return conv;
    }

    function getPrettyMaster(ctx) {
      if (ctx._prettyMaster) return ctx._prettyMaster;
      const master = ctx.createGain();
      master.gain.value = 1;
      master.connect(ctx.destination);
      ctx._prettyMaster = master;
      return master;
    }

    function getPrettyReverb(ctx) {
      if (ctx._prettyReverbBus) return ctx._prettyReverbBus;
      const seconds = 9.0;
      const preDelay = 0.035;
      const sr = ctx.sampleRate;
      const len = Math.floor(sr * seconds);
      const preLen = Math.floor(sr * preDelay);
      const buf = ctx.createBuffer(2, len, sr);
      for (let ch = 0; ch < 2; ch++) {
        const d = buf.getChannelData(ch);
        const decayPower = ch === 0 ? 2.0 : 2.4;
        for (let i = 0; i < len; i++) {
          if (i < preLen) { d[i] = 0; continue; }
          const tailPos = (i - preLen) / (len - preLen);
          d[i] = (Math.random() * 2 - 1) * Math.pow(1 - tailPos, decayPower);
        }
      }
      const conv = ctx.createConvolver();
      conv.buffer = buf;
      const damp = ctx.createBiquadFilter();
      damp.type = 'lowpass';
      damp.frequency.value = 1800;
      damp.Q.value = 0.5;
      conv.connect(damp).connect(getPrettyMaster(ctx));
      ctx._prettyReverbBus = conv;
      ctx._prettyReverbNodes = [conv, damp];
      return conv;
    }

    function getPrettyDelay(ctx) {
      if (ctx._prettyDelay) return ctx._prettyDelay;
      const delay = ctx.createDelay(10.0);
      const filter = ctx.createBiquadFilter();
      const feedback = ctx.createGain();
      const wet = ctx.createGain();
      const limiter = ctx.createDynamicsCompressor();
      const wetCeiling = ctx.createGain();

      delay.delayTime.value = 0.52;
      filter.type = 'lowpass';
      filter.frequency.value = 820;
      filter.Q.value = 0.22;
      feedback.gain.value = 0.86;
      wet.gain.value = 0.52;
      limiter.threshold.value = -16;
      limiter.knee.value = 4;
      limiter.ratio.value = 16;
      limiter.attack.value = 0.004;
      limiter.release.value = 0.34;
      wetCeiling.gain.value = 0.64;

      delay.connect(filter);
      filter.connect(feedback);
      feedback.connect(delay);
      filter.connect(wet).connect(limiter).connect(wetCeiling).connect(getPrettyMaster(ctx));
      ctx._prettyDelay = delay;
      ctx._prettyDelayNodes = [delay, filter, feedback, wet, limiter, wetCeiling];
      return delay;
    }

    function killPrettyAudio() {
      const ctx = audioCtx;
      if (!ctx) return;
      const now = ctx.currentTime;
      const master = ctx._prettyMaster;
      if (master) {
        try {
          master.gain.cancelScheduledValues(now);
          master.gain.setValueAtTime(0, now);
        } catch (e) {}
      }

      const disconnectList = []
        .concat(ctx._prettyDelayNodes || [])
        .concat(ctx._prettyReverbNodes || []);
      disconnectList.forEach(function(node) {
        try { node.disconnect(); } catch (e) {}
      });
      ctx._prettyDelay = null;
      ctx._prettyDelayNodes = null;
      ctx._prettyReverbBus = null;
      ctx._prettyReverbNodes = null;

      if (master) {
        try { master.disconnect(); } catch (e) {}
        if (ctx._prettyMaster === master) ctx._prettyMaster = null;
      }
    }

    // Piano voice — one modeled key/body transient into the shared reverb bus.
    function playPianoNote(freq, when, sustain, levelOverride, withLowFloor, delayBus, outputBus) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = (when !== undefined) ? when : ctx.currentTime;
      const sus = sustain || 9.0;
      const level = levelOverride !== undefined ? levelOverride : 0.068;
      const output = outputBus || ctx.destination;
      const reverb = outputBus ? getPrettyReverb(ctx) : getReverb(ctx);
      playAcousticKey(freq, t, sus, level, reverb, delayBus, output);
      if (withLowFloor) playLowFloor(freq, t, sus, level * 0.28, reverb, output);
    }

    // Quiet acoustic-piano layer: a small modeled hammer/body event plus room.
    function playAcousticKey(freq, when, sustain, level, reverb, delayBus, outputBus) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = when !== undefined ? when : ctx.currentTime;
      const output = outputBus || ctx.destination;
      const dur = Math.min(4.8, Math.max(2.4, sustain * 0.56));
      const trebleMellow = freq >= 800 ? 0.74 : (freq >= 650 ? 0.88 : 1);
      const upperPartialScale = freq >= 800 ? 0.55 : (freq >= 650 ? 0.72 : 1);
      const hammerScale = freq >= 800 ? 0.24 : (freq >= 650 ? 0.48 : 1);
      const attackTime = freq >= 800 ? 0.032 : (freq >= 650 ? 0.022 : 0.012);
      const partialAttack = freq >= 800 ? 0.026 : (freq >= 650 ? 0.018 : 0.010);
      const bodyLevel = Math.max(0.003, level || 0.018) * trebleMellow;
      const pan = freq > 500 ? 0.18 : (freq < 320 ? -0.16 : 0.02);

      const body = ctx.createGain();
      body.gain.setValueAtTime(0.0001, t);
      body.gain.exponentialRampToValueAtTime(bodyLevel, t + attackTime);
      body.gain.exponentialRampToValueAtTime(bodyLevel * 0.22, t + 0.52);
      body.gain.exponentialRampToValueAtTime(0.0001, t + dur);

      const soundboard = ctx.createBiquadFilter();
      soundboard.type = 'lowpass';
      soundboard.frequency.value = freq >= 800 ? 2400 : (freq >= 650 ? 3200 : 4200);
      soundboard.Q.value = 0.35;

      const panner = ctx.createStereoPanner();
      panner.pan.value = pan;
      body.connect(soundboard).connect(panner).connect(output);

      const send = ctx.createGain();
      send.gain.value = 0.32;
      panner.connect(send).connect(reverb);
      if (delayBus) {
        const delaySend = ctx.createGain();
        delaySend.gain.value = freq >= 650 ? 0.72 : 0.38;
        panner.connect(delaySend).connect(delayBus);
      }

      [
        { ratio: 1.000, gain: 1.00, stop: dur },
        { ratio: 2.006, gain: 0.42, stop: dur * 0.76 },
        { ratio: 3.018, gain: 0.22, stop: dur * 0.50 },
        { ratio: 4.045, gain: 0.12, stop: dur * 0.36 }
      ].forEach(function(partial) {
        const osc = ctx.createOscillator();
        osc.type = 'triangle';
        osc.frequency.value = freq * partial.ratio;
        osc.detune.value = (Math.random() * 3) - 1.5;

        const partialGain = ctx.createGain();
        partialGain.gain.setValueAtTime(0.0001, t);
        partialGain.gain.exponentialRampToValueAtTime(
          partial.gain * (partial.ratio === 1.000 ? 1 : upperPartialScale),
          t + partialAttack
        );
        partialGain.gain.exponentialRampToValueAtTime(0.0001, t + partial.stop);

        osc.connect(partialGain).connect(body);
        osc.start(t);
        osc.stop(t + partial.stop + 0.08);
      });

      const hammer = ctx.createBufferSource();
      const hammerLen = Math.floor(ctx.sampleRate * (freq >= 650 ? 0.018 : 0.026));
      const hammerBuf = ctx.createBuffer(1, hammerLen, ctx.sampleRate);
      const data = hammerBuf.getChannelData(0);
      for (let i = 0; i < hammerLen; i++) {
        const decay = Math.pow(1 - (i / hammerLen), 2.8);
        data[i] = (Math.random() * 2 - 1) * decay;
      }
      hammer.buffer = hammerBuf;

      const hammerGain = ctx.createGain();
      hammerGain.gain.setValueAtTime(bodyLevel * 0.10 * hammerScale, t);
      hammerGain.gain.exponentialRampToValueAtTime(0.0001, t + 0.030);

      const hammerFilter = ctx.createBiquadFilter();
      hammerFilter.type = 'bandpass';
      hammerFilter.frequency.value = freq >= 800 ? 1050 : Math.min(1900, Math.max(800, freq * 3.0));
      hammerFilter.Q.value = freq >= 650 ? 0.8 : 1.2;

      hammer.connect(hammerGain).connect(hammerFilter).connect(panner);
      hammer.start(t);
      hammer.stop(t + 0.04);
    }

    function playLowFloor(freq, when, sustain, level, reverb, outputBus) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = when !== undefined ? when : ctx.currentTime;
      const output = outputBus || ctx.destination;
      const dur = Math.min(6.5, Math.max(3.2, sustain * 0.72));
      const base = freq / 2;
      const floorLevel = Math.max(0.0025, level || 0.014);

      const floorGain = ctx.createGain();
      floorGain.gain.setValueAtTime(0.0001, t);
      floorGain.gain.exponentialRampToValueAtTime(floorLevel, t + 0.055);
      floorGain.gain.exponentialRampToValueAtTime(floorLevel * 0.34, t + 1.1);
      floorGain.gain.exponentialRampToValueAtTime(0.0001, t + dur);

      const lowpass = ctx.createBiquadFilter();
      lowpass.type = 'lowpass';
      lowpass.frequency.value = 540;
      lowpass.Q.value = 0.6;

      const highpass = ctx.createBiquadFilter();
      highpass.type = 'highpass';
      highpass.frequency.value = 48;
      highpass.Q.value = 0.5;

      const panner = ctx.createStereoPanner();
      panner.pan.value = -0.04;
      floorGain.connect(lowpass).connect(highpass).connect(panner).connect(output);

      const send = ctx.createGain();
      send.gain.value = 0.18;
      panner.connect(send).connect(reverb);

      [
        { ratio: 1.000, gain: 1.00 },
        { ratio: 0.500, gain: 0.38 }
      ].forEach(function(layer) {
        const osc = ctx.createOscillator();
        osc.type = layer.ratio === 1.000 ? 'triangle' : 'sine';
        osc.frequency.value = base * layer.ratio;
        osc.detune.value = (Math.random() * 2) - 1;

        const layerGain = ctx.createGain();
        layerGain.gain.value = layer.gain;
        osc.connect(layerGain).connect(floorGain);
        osc.start(t);
        osc.stop(t + dur + 0.08);
      });
    }

    function playNoteName(note, when, sustain, level, withLowFloor, delayBus, outputBus) {
      const freq = NOTE_FREQ[note];
      if (!freq) return;
      playPianoNote(freq, when, sustain, level, withLowFloor, delayBus, outputBus);
    }

    function playNoteNames(notes, when, sustain, level, withLowFloor, delayBus, outputBus) {
      notes.forEach(function(note) {
        playNoteName(note, when, sustain, level, withLowFloor, delayBus, outputBus);
      });
    }

    function playPrettyGhost(notes, when, scale, outputBus) {
      const ctx = ensureAudio();
      if (!ctx || Math.random() > 0.38) return;
      const delay = getPrettyDelay(ctx);
      const echoScale = scale === undefined ? 1 : scale;
      const offset = 0.72 + (Math.random() * 0.46);
      const note = notes[Math.floor(Math.random() * notes.length)];
      playNoteName(note, when + offset, 6.2, 0.012 * echoScale, false, delay, outputBus);
      if (Math.random() < 0.28) {
        playNoteName(note, when + offset + 0.52, 5.8, 0.007 * echoScale, false, delay, outputBus);
      }
    }

    function playPrettyPreset(preset) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = ctx.currentTime + 0.035;
      const output = getPrettyMaster(ctx);
      const delay = getPrettyDelay(ctx);
      const level = 0.028;
      playNoteNames(preset.pressA, t, 4.0, level, false, null, output);
      playNoteNames(preset.resolveA, t + (PRESS_TO_HIT_MS / 1000), 9.0, level, true, delay, output);
      playPrettyGhost(preset.resolveA, t + (PRESS_TO_HIT_MS / 1000), 0.95, output);
      playNoteNames(preset.pressB, t + (LOOP_BEAT_MS / 1000), 5.0, level, false, null, output);
      playNoteNames(preset.resolveB, t + ((LOOP_BEAT_MS + PRESS_TO_HIT_MS) / 1000), 9.0, level, true, delay, output);
      playPrettyGhost(preset.resolveB, t + ((LOOP_BEAT_MS + PRESS_TO_HIT_MS) / 1000), 1.08, output);
      playNoteName(preset.low, t + ((LOOP_BEAT_MS + PRESS_TO_HIT_MS) / 1000), 9.0, 0.018, true, null, output);
    }

    function playPressNote(goingDark) {
      if (goingDark) {
        playPianoNote(PIANO.N4, undefined, 4.0);
      } else {
        playPianoNote(PIANO.N1, undefined, 5.0);
      }
    }

    // Resolve — two notes at cat-paw impact.
    function playResolveChord(goingDark) {
      const ctx = ensureAudio();
      if (!ctx) return;
      const t = ctx.currentTime;
      if (goingDark) {
        playPianoNote(PIANO.N2, t, 9.0, undefined, true);
        playPianoNote(PIANO.N1, t, 9.0, undefined, true);
      } else {
        playPianoNote(PIANO.N3, t, 9.0, undefined, true);
        playPianoNote(PIANO.N4, t, 9.0, undefined, true);
        // Final resolve gets a B-flat floor so the key reads as home.
        playPianoNote(PIANO.N1 / 2, t, 9.0, 0.034, true);
      }
    }

    // DOM-only theme flip (no audio). Used by both the manual click path
    // (via instantFlip) and the loop's deterministic timer chain.
    function applyThemeFlip() {
      const d = document.documentElement;
      const wasInDark = d.getAttribute('data-theme') === 'dark';
      const goingDark = !wasInDark;
      const next = goingDark ? 'dark' : 'light';
      d.setAttribute('data-theme', next);
      if (button) button.setAttribute('aria-pressed', goingDark ? 'true' : 'false');
      return goingDark;
    }

    function instantFlip() {
      const goingDark = applyThemeFlip();
      playResolveChord(goingDark);
    }

    // Loop cycle — JS-timer-driven audio rhythm, video plays in parallel for
    // visual only. The press-note fires now; the resolve-chord + theme-flip
    // fire at exactly +PRESS_TO_HIT_MS; the next cycle fires at +LOOP_BEAT_MS.
    // No video timing dependency = no per-cycle load-latency jitter.
    function fireCycle() {
      if (!loopArmed) return;

      // Direction: when unlocked, derives from current theme (so a manual
      // dimmer click between cycles re-syncs). When locked, alternates an
      // internal flag so the music still progresses without flipping theme.
      let goingDark;
      if (themeLocked) {
        if (loopDirection === null) {
          loopDirection = document.documentElement.getAttribute('data-theme') !== 'dark';
        } else {
          loopDirection = !loopDirection;
        }
        goingDark = loopDirection;
      } else {
        loopDirection = null;
        goingDark = document.documentElement.getAttribute('data-theme') !== 'dark';
      }

      // Audio: press immediately (this is beat zero of the cycle)
      playPressNote(goingDark);

      // Visual: cat clip keeps performing even when LOOP has pinned the page
      // theme. The lock is the room lighting; the cat/audio loop is the piece.
      catCtl.play(goingDark, 'loop');

      // Resolve chord + theme flip at deterministic +PRESS_TO_HIT_MS after press
      if (loopPressTimer) clearTimeout(loopPressTimer);
      loopPressTimer = setTimeout(function() {
        loopPressTimer = null;
        if (!loopArmed) return;
        if (!themeLocked) applyThemeFlip();
        playResolveChord(goingDark);
        // Schedule next cycle
        if (loopNextTimer) clearTimeout(loopNextTimer);
        loopNextTimer = setTimeout(function() {
          loopNextTimer = null;
          if (loopArmed) fireCycle();
        }, LOOP_BEAT_MS - PRESS_TO_HIT_MS);
      }, PRESS_TO_HIT_MS);
    }

    function playCatThenFlip() {
      if (reduced || !video || video.readyState < 3) return instantFlip();

      const goingDark = document.documentElement.getAttribute('data-theme') !== 'dark';
      const hitAt = goingDark ? HIT_SECONDS_FWD : HIT_SECONDS_REV;
      const seekFrom = goingDark ? 0 : (HIT_SECONDS_REV - HIT_SECONDS_FWD);
      const safetyMs = ((hitAt - seekFrom) / VIDEO_RATE) * 1000 + 500;

      catCtl.play(goingDark);

      let flipped = false;
      function doFlip() {
        if (flipped) return;
        flipped = true;
        instantFlip();
      }

      const safety = setTimeout(doFlip, safetyMs);
      function tick() {
        if (flipped) return;
        if (video.currentTime >= hitAt) {
          clearTimeout(safety);
          doFlip();
          return;
        }
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    window.toggleTheme = playCatThenFlip;

    // Press feedback — fires the moment the pointer goes down, before onclick.
    // Pairs with CSS :active state on .dimmer for visual press-in.
    if (button) {
      button.addEventListener('pointerdown', function() {
        if (button.disabled) return;
        const goingDark = document.documentElement.getAttribute('data-theme') !== 'dark';
        playPressNote(goingDark);
      });
    }

    function setLoopUI(armed) {
      if (!loopBtn) return;
      const action = armed ? 'Stop dimmer loop' : 'Start dimmer loop';
      loopBtn.setAttribute('aria-pressed', armed ? 'true' : 'false');
      loopBtn.setAttribute('aria-label', action);
      loopBtn.setAttribute('title', action);
      loopBtn.classList.toggle('is-armed', armed);
    }

    function setPrettyUI(armed) {
      if (!prettyBtn) return;
      const action = armed ? 'Stop pretty progression walk' : 'Start pretty progression walk';
      prettyBtn.setAttribute('aria-pressed', armed ? 'true' : 'false');
      prettyBtn.setAttribute('aria-label', action);
      prettyBtn.setAttribute('title', action);
      prettyBtn.classList.toggle('is-armed', armed);
      if (prettyField) {
        if (prettyFieldExitTimer) {
          clearTimeout(prettyFieldExitTimer);
          prettyFieldExitTimer = null;
        }
        const wasLive = prettyField.classList.contains('is-armed') || prettyField.classList.contains('is-leaving');
        prettyField.classList.toggle('is-armed', armed);
        prettyField.classList.toggle('is-leaving', !armed && wasLive);
        if (!armed && wasLive) {
          prettyFieldExitTimer = setTimeout(function() {
            prettyField.classList.remove('is-leaving');
            prettyFieldExitTimer = null;
          }, 5900);
        }
      }
      prettyConstellation.setActive(armed);
    }

    function setPrettyVisible(visible) {
      if (!prettyBtn) return;
      prettyBtn.hidden = false;
      prettyBtn.disabled = false;
      prettyBtn.classList.remove('is-hidden');
      if (prettyField) prettyField.classList.remove('is-hidden');
      prettyConstellation.setVisible(true);
    }

    function setLockUI(locked) {
      if (!lockBtn) return;
      lockBtn.setAttribute('aria-pressed', locked ? 'true' : 'false');
      lockBtn.classList.toggle('is-locked', locked);
    }

    function toggleThemeLock() {
      if (loopArmed) return;
      themeLocked = !themeLocked;
      setLockUI(themeLocked);
      if (themeLocked) {
        // Hide any cat clip in flight from the pre-lock cycle
        catCtl.reset();
      } else {
        // Re-sync direction tracker to actual theme on next cycle
        loopDirection = null;
      }
    }
    window.toggleThemeLock = toggleThemeLock;

    // fireCycle now self-drives via setTimeout chain — reduced-motion path is
    // handled inside fireCycle (skips video block when reduced is true).
    function startLoopCycle() {
      fireCycle();
    }

    function stopPrettyWalk() {
      if (prettyTimer) {
        clearTimeout(prettyTimer);
        prettyTimer = null;
      }
      prettyArmed = false;
      setPrettyUI(false);
      killPrettyAudio();
    }

    function schedulePrettyWalk() {
      prettyTimer = setTimeout(function() {
        playPrettyStep();
      }, PRETTY_WALK_MS + Math.floor(Math.random() * PRETTY_WALK_SPREAD_MS));
    }

    function playPrettyStep() {
      if (!prettyArmed) return;
      const presetIndex = PRETTY_WALK[prettyStep % PRETTY_WALK.length];
      playPrettyPreset(PRETTY_PRESETS[presetIndex]);
      prettyStep += 1;
      schedulePrettyWalk();
    }

    function togglePrettyLoop() {
      if (!prettyBtn || prettyBtn.hidden) return;
      prettyArmed = !prettyArmed;
      if (prettyArmed) {
        prettyStep = 0;
        setPrettyUI(true);
        playPrettyStep();
      } else {
        stopPrettyWalk();
      }
    }

    window.togglePrettyLoop = togglePrettyLoop;

    function toggleLoop() {
      loopArmed = !loopArmed;
      try { sessionStorage.setItem('loop_armed', loopArmed ? '1' : '0'); } catch (e) {}
      setLoopUI(loopArmed);
      if (loopArmed) {
        themeLocked = true;
        setLockUI(true);
        setPrettyVisible(true);
        loopDirection = null;
        // Loop owns the dimmer while running — manual clicks would conflict
        if (button) button.disabled = true;
        startLoopCycle();
      } else {
        stopPrettyWalk();
        setPrettyVisible(false);
        if (loopPressTimer) { clearTimeout(loopPressTimer); loopPressTimer = null; }
        if (loopNextTimer) { clearTimeout(loopNextTimer); loopNextTimer = null; }
        // Clear lock state too — reset for next arming
        if (themeLocked) { themeLocked = false; setLockUI(false); }
        loopDirection = null;
        catCtl.reset();
        if (button) button.disabled = false;
      }
    }

    window.toggleLoop = toggleLoop;
    window.siteMusicIsActive = function() {
      return loopArmed || prettyArmed;
    };

    // Auto-resume across header page nav — sessionStorage survives full-page
    // loads within a tab. iOS Safari may require a user gesture before the
    // first AudioContext.resume(); the LED stays on either way and audio
    // engages on next interaction. Acceptable degradation.
    try {
      if (sessionStorage.getItem('loop_armed') === '1') {
        loopArmed = true;
        themeLocked = true;
        loopDirection = null;
        setLoopUI(true);
        setLockUI(true);
        setPrettyVisible(true);
        if (button) button.disabled = true;  // loop owns dimmer while armed

        // Audio defer — if ctx is suspended (no user gesture on new page),
        // wait for first interaction before starting the cycle. Otherwise
        // events queue up on a frozen audio clock and slam together when
        // ctx finally resumes.
        function kickoff() {
          if (!loopArmed) return;
          if (reduced || !video || video.readyState >= 3) {
            fireCycle();
          } else {
            video.addEventListener('loadeddata', function once() {
              video.removeEventListener('loadeddata', once);
              if (loopArmed) fireCycle();
            });
          }
        }

        const ctx = ensureAudio();
        if (ctx && ctx.state === 'running') {
          kickoff();
        } else if (ctx) {
          // Try resume (some browsers honor cross-page gesture). If still
          // suspended, defer until first user interaction.
          const tryResume = ctx.resume();
          if (tryResume && tryResume.then) {
            tryResume.then(function() {
              if (ctx.state === 'running') kickoff();
              else deferKickoff();
            }).catch(deferKickoff);
          } else {
            deferKickoff();
          }
        }

        function deferKickoff() {
          const handler = function() {
            document.removeEventListener('pointerdown', handler);
            document.removeEventListener('keydown', handler);
            // Resume ctx now that we have a gesture
            const c = ensureAudio();
            if (c && c.state === 'suspended') c.resume();
            if (loopArmed) kickoff();
          };
          document.addEventListener('pointerdown', handler, { once: true });
          document.addEventListener('keydown', handler, { once: true });
        }
      }
    } catch (e) {}
  })();

  // Theme control state. The HTML opens dark by default; URL ?theme=light/dark
  // may override for previews, but regular opens intentionally do not persist
  // a prior light-mode test.
  (function() {
    document.addEventListener('DOMContentLoaded', function() {
      var btn = document.querySelector('.dimmer');
      var theme = document.documentElement.getAttribute('data-theme');
      if (btn) btn.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
    });
  })();

  // tab
  (function(){var t=document.title;document.addEventListener('visibilitychange',function(){document.title=document.hidden?'\u2013':t})})();

  function initHomePage() {
    var toggle = document.querySelector('[data-home-work-toggle]');
    if (!toggle || toggle.dataset.homeWorkInit === '1') return;
    var list = document.getElementById(toggle.getAttribute('aria-controls'));
    if (!list) return;
    toggle.dataset.homeWorkInit = '1';
    toggle.addEventListener('click', function() {
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      list.hidden = expanded;
    });
  }
  window.initHomePage = initHomePage;

  // scroll-spy — rAF-throttled scroll listener. Highlight the topic that
  // occupies at least half the usable viewport; fall back to the most visible
  // section for short or between-section states.
