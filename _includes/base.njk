      const phrase = "it's different every time";
      const NOISE = "!@#$%&*+=/\\|<>?~^`:;.,'\"-_";
      const FRAME_MS = 50;
      const SCRAMBLE_FRAMES = 12;  // each char scrambles ~600ms before settling
