  <script>
  (function () {
    var modal = document.getElementById('syllabus-modal');
    if (!modal || typeof modal.showModal !== 'function') return;
    var f = modal.querySelector('.syllabus-modal-field'),
        t = modal.querySelector('.syllabus-modal-title'),
        m = modal.querySelector('.syllabus-modal-meta'),
        n = modal.querySelector('.syllabus-modal-note'),
        lw = modal.querySelector('.syllabus-modal-link'),
        la = lw.querySelector('a');
    document.querySelectorAll('.syllabus-cover').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var d = btn.dataset;
        f.textContent = d.field || '';
        t.textContent = d.title || '';
        m.textContent = [d.author, d.year].filter(Boolean).join(' · ');
        n.textContent = d.note || '';
        if (d.url) { la.href = d.url; lw.hidden = false; } else { lw.hidden = true; }
        modal.showModal();
      });
    });
    modal.addEventListener('click', function (e) {
      var b = modal.querySelector('.syllabus-modal-body').getBoundingClientRect();
      if (e.clientX < b.left || e.clientX > b.right || e.clientY < b.top || e.clientY > b.bottom) modal.close();
    });
  })();
