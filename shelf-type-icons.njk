<title>Shelf Type Icons</title>
<style>
@font-face {
  font-family: 'EB Garamond';
  src: url('/fonts/EB-Garamond/EBGaramond.woff2') format('woff2');
  font-weight: 400 700;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'EB Garamond';
  src: url('/fonts/EB-Garamond/EBGaramond-Italic.woff2') format('woff2');
  font-weight: 400 700;
  font-style: italic;
  font-display: swap;
}

:root {
  color-scheme: dark;
  --bg: #100f0f;
  --surface: #1c1b1a;
  --surface-soft: #242321;
  --ink: #cecdc3;
  --ink-light: #b7b5ac;
  --ink-faint: #878580;
  --ink-muted: #575653;
  --rule: #343331;
  --rule-strong: #575653;
  --accent: #3aa99f;
  --yellow: #d0a215;
  --green: #879a39;
  --red: #d14d41;
  --serif: 'EB Garamond', Georgia, "Times New Roman", serif;
  --mono: "IBM Plex Sans", ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  --sans: "IBM Plex Sans", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-family: var(--sans);
}

* { box-sizing: border-box; }
html { background: var(--bg); color: var(--ink); scroll-behavior: smooth; }
body { margin: 0; min-height: 100vh; background: var(--bg); line-height: 1.38; }
a { color: inherit; text-decoration: none; }
button,
input,
select {
  font: inherit;
}

.app-header {
  position: sticky;
  top: 0;
  z-index: 40;
  border-bottom: 1px solid var(--rule);
  background: color-mix(in srgb, var(--bg) 92%, transparent);
  backdrop-filter: blur(18px);
}

.header-inner {
  max-width: 1540px;
  margin: 0 auto;
  padding: 1rem;
}

.title-row {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: flex-start;
}

h1 {
  margin: 0;
  font-family: var(--serif);
  font-size: clamp(1.58rem, 1.18rem + 1.22vw, 2.42rem);
  font-weight: 700;
  line-height: 0.98;
  letter-spacing: 0;
}

.subtitle {
  max-width: 58rem;
  margin: 0.32rem 0 0;
  color: var(--ink-faint);
  font-family: var(--serif);
  font-size: 0.92rem;
  font-style: italic;
}

.badge,
.status-line,
.filter-button,
.quiet-actions,
.control-label,
.item-meta,
.type-chip,
.path-line {
  font-family: var(--mono);
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.badge {
  display: inline-flex;
  align-items: center;
  border: 1px solid var(--rule-strong);
  border-radius: 999px;
  padding: 0.32rem 0.62rem;
  color: var(--yellow);
  white-space: nowrap;
}

.status-line {
  display: flex;
  flex-wrap: wrap;
  gap: 0.46rem 0.8rem;
  margin-top: 0.82rem;
  color: var(--ink-muted);
}
.status-line b { color: var(--ink-light); }
.status-line .changed b { color: var(--accent); }
.status-line .type b { color: var(--yellow); }
.status-line .icon b { color: var(--green); }

.toolbar {
  display: grid;
  grid-template-columns: minmax(14rem, 1fr) auto;
  gap: 0.72rem 1rem;
  align-items: center;
  margin-top: 0.86rem;
}

.search-input {
  width: 100%;
  min-height: 2rem;
  border: 1px solid var(--rule);
  border-radius: 3px;
  background: color-mix(in srgb, var(--bg) 84%, var(--surface-soft));
  color: var(--ink);
  padding: 0.42rem 0.58rem;
}
.search-input:focus {
  outline: 1px solid var(--accent);
  outline-offset: 2px;
}

.filters,
.quiet-actions {
  display: flex;
  flex-wrap: wrap;
}

.filters {
  justify-content: flex-end;
  gap: 0.34rem;
}

.filter-button {
  border: 1px solid var(--rule);
  border-radius: 999px;
  background: transparent;
  color: var(--ink-faint);
  padding: 0.34rem 0.58rem;
  cursor: pointer;
}
.filter-button:hover,
.filter-button:focus-visible,
.filter-button[aria-pressed="true"] {
  border-color: var(--accent);
  color: var(--accent);
  outline: 0;
}

.quiet-actions {
  gap: 0.42rem 0.8rem;
  margin-top: 0.58rem;
}
.quiet-actions a,
.row-action {
  color: var(--ink-faint);
  text-underline-offset: 0.16em;
}
.quiet-actions a:hover,
.quiet-actions a:focus-visible,
.row-action:hover,
.row-action:focus-visible {
  color: var(--accent);
  outline: 0;
  text-decoration: underline;
}
.quiet-actions a[aria-disabled="true"],
.row-action[aria-disabled="true"] {
  color: var(--ink-muted);
  pointer-events: none;
  opacity: 0.48;
}

.library {
  max-width: 1540px;
  margin: 0 auto;
  padding: 1rem 1.25rem 3rem;
}

.topic-section {
  margin: 0 0 1.2rem;
  border-top: 1px solid var(--rule-strong);
}

.topic-heading {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: baseline;
  padding: 0.52rem 0 0.64rem;
}

.topic-label {
  margin: 0;
  color: var(--yellow);
  font-family: var(--mono);
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.topic-count {
  color: var(--ink-muted);
  font-family: var(--mono);
  font-size: 0.68rem;
  font-weight: 700;
}

.item-stack {
  display: grid;
  gap: 0.42rem;
}

.item-row {
  display: grid;
  grid-template-columns: 3rem minmax(0, 1fr) minmax(13rem, 0.66fr) minmax(12rem, 0.62fr) auto;
  gap: 0.74rem;
  align-items: center;
  min-width: 0;
  border-top: 1px solid var(--rule);
  padding: 0.58rem 0;
  color: var(--ink-faint);
}
.item-row:first-child {
  border-top: 0;
}
.item-row.is-changed {
  color: var(--ink-light);
}

.icon-preview {
  display: grid;
  place-items: center;
  width: 2.48rem;
  height: 2.48rem;
  border: 1px solid var(--rule);
  background: color-mix(in srgb, var(--surface) 76%, var(--bg));
}

.item-type-symbol {
  --shelf-type-symbol-default: color-mix(in srgb, var(--ink-light) 74%, var(--ink-muted));
  --shelf-type-symbol-size: 1.35rem;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: var(--shelf-type-symbol-size);
  height: var(--shelf-type-symbol-size);
  color: var(--shelf-type-symbol-color, var(--shelf-type-symbol-default));
}
.icon-preview.item-type-symbol {
  width: 2.48rem;
  height: 2.48rem;
}
.item-type-symbol__icon {
  width: var(--shelf-type-symbol-size);
  height: var(--shelf-type-symbol-size);
  fill: none;
  stroke: currentColor;
  stroke-width: 1.75;
  stroke-linecap: round;
  stroke-linejoin: round;
}
.icon-preview .item-type-symbol__icon {
  width: 1.38rem;
  height: 1.38rem;
}

.item-type-symbol[data-type="book"],
.item-type-symbol[data-type="chapter"],
.item-type-symbol[data-type="archive"] {
  --shelf-type-symbol-color: #4385be;
}
.item-type-symbol[data-type="essay"] {
  --shelf-type-symbol-color: #a699d0;
}
.item-type-symbol[data-type="site"] {
  --shelf-type-symbol-color: #3aa99f;
}
.item-type-symbol[data-type="paper"],
.item-type-symbol[data-type="journal article"],
.item-type-symbol[data-type="report"],
.item-type-symbol[data-type="working paper"] {
  --shelf-type-symbol-color: #d0a215;
}
.item-type-symbol[data-type="film"],
.item-type-symbol[data-type="video"],
.item-type-symbol[data-type="slides"],
.item-type-symbol[data-type="magazine"] {
  --shelf-type-symbol-color: #ce5d97;
}
.item-type-symbol[data-type="vr"],
.item-type-symbol[data-type="game"],
.item-type-symbol[data-type="installation"],
.item-type-symbol[data-type="project"] {
  --shelf-type-symbol-color: #ec8b49;
}
.item-type-symbol[data-type="tool"] {
  --shelf-type-symbol-color: #879a39;
}
.item-type-symbol[data-type="interview"] {
  --shelf-type-symbol-color: #d0a215;
}
.item-type-symbol[data-type="concept"] {
  --shelf-type-symbol-color: #a0af54;
}
.item-type-symbol[data-symbol="hand-finger"] {
  --shelf-type-symbol-color: #ec8b49;
}

.item-copy {
  display: grid;
  gap: 0.2rem;
  min-width: 0;
}

.item-title {
  color: var(--ink);
  font-family: var(--serif);
  font-size: 1rem;
  line-height: 1.12;
}

.item-meta,
.path-line {
  color: var(--ink-muted);
  line-height: 1.24;
}

.item-dek {
  color: var(--ink-faint);
  font-family: var(--serif);
  font-size: 0.82rem;
  font-style: italic;
  line-height: 1.18;
}

.type-chip {
  color: var(--ink-muted);
}
.type-chip b {
  color: var(--ink-light);
  font-weight: 700;
}
.item-row.is-changed .type-chip b {
  color: var(--accent);
}

.control-field {
  display: grid;
  gap: 0.24rem;
  min-width: 0;
}

.control-label {
  color: var(--ink-muted);
}

.select-input {
  width: 100%;
  min-height: 2rem;
  border: 1px solid var(--rule);
  border-radius: 3px;
  background: color-mix(in srgb, var(--bg) 84%, var(--surface-soft));
  color: var(--ink);
  padding: 0.32rem 0.46rem;
}
.select-input:focus {
  outline: 1px solid var(--accent);
  outline-offset: 2px;
}

.row-action {
  border: 0;
  background: transparent;
  padding: 0;
  cursor: pointer;
  font-family: var(--mono);
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.empty {
  border: 1px dashed var(--rule);
  padding: 2rem;
  color: var(--ink-faint);
  font-family: var(--serif);
  font-style: italic;
}

.export-panel {
  position: fixed;
  left: max(1rem, 4vw);
  right: max(1rem, 4vw);
  bottom: 1rem;
  z-index: 80;
  max-width: 980px;
  margin: 0 auto;
  border: 1px solid var(--rule-strong);
  background: color-mix(in srgb, var(--bg) 94%, var(--surface-soft));
  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.52);
  padding: 1rem;
}

.export-panel.hidden {
  display: none;
}

.export-head {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: start;
  margin-bottom: 0.72rem;
}

.export-head h2 {
  margin: 0;
  font-family: var(--serif);
  font-size: 1.24rem;
  line-height: 1;
}

.export-head p {
  margin: 0.28rem 0 0;
  color: var(--ink-faint);
  font-family: var(--serif);
  font-size: 0.88rem;
  font-style: italic;
}

.export-output {
  width: 100%;
  min-height: min(46vh, 30rem);
  max-height: min(58vh, 34rem);
  overflow: auto;
  border: 1px solid var(--rule);
  background: color-mix(in srgb, var(--bg) 88%, var(--surface-soft));
  color: var(--ink);
  border-radius: 3px;
  padding: 0.72rem;
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  font-size: 0.82rem;
  line-height: 1.45;
  white-space: pre-wrap;
}

.shelf-type-symbols {
  position: absolute;
  width: 0;
  height: 0;
  overflow: hidden;
}

@media (max-width: 900px) {
  .title-row,
  .toolbar,
  .topic-heading {
    display: block;
  }
  .badge,
  .filters {
    margin-top: 0.58rem;
    justify-content: flex-start;
  }
  .item-row {
    grid-template-columns: 2.8rem minmax(0, 1fr);
  }
  .control-field,
  .row-action {
    grid-column: 2;
  }
}

/* WYSIWYG Shelf review layer. These rules intentionally override the
   utilitarian row pass above without changing the export/state model. */
.library {
  max-width: 1680px;
  padding: 1.1rem clamp(0.78rem, 2.2vw, 1.8rem) 3rem;
}

.topic-section {
  margin-bottom: 1.6rem;
  border-top: 1px solid color-mix(in srgb, var(--rule-strong) 82%, transparent);
}

.topic-heading {
  padding: 0.62rem 0 0.78rem;
}

.preview-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(218px, 1fr));
  gap: 1.1rem 0.88rem;
  align-items: start;
}

.review-item {
  min-width: 0;
  position: relative;
  display: grid;
  gap: 0.5rem;
  padding: 0.14rem;
}

.review-item.is-changed::before {
  content: "";
  position: absolute;
  inset: -0.36rem -0.28rem;
  border: 1px solid color-mix(in srgb, var(--accent) 62%, transparent);
  background: color-mix(in srgb, var(--accent) 5%, transparent);
  pointer-events: none;
}

.review-item > * {
  position: relative;
  z-index: 1;
}

.shelf-preview {
  min-width: 0;
}

.shelf-preview--cover {
  display: grid;
  gap: 0.26rem;
}

.preview-cover {
  position: relative;
  display: grid;
  place-items: start center;
  width: 100%;
  aspect-ratio: 4 / 5.4;
  overflow: hidden;
  background: transparent;
}

.preview-cover img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: top center;
  display: block;
  box-shadow: 0 1px 0 0 color-mix(in srgb, var(--rule) 76%, transparent);
}

.preview-cover:hover img,
.preview-cover:focus-visible img {
  filter: brightness(0.68) saturate(0.9);
}

.preview-cover:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: -2px;
}

.preview-text-card {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  padding: clamp(0.58rem, 0.48rem + 0.26vw, 0.78rem);
  color: var(--ink);
  background:
    linear-gradient(
      160deg,
      color-mix(in srgb, var(--bg) 90%, #fff 6%) 0%,
      color-mix(in srgb, var(--bg) 76%, #fff 13%) 100%
    );
  border: 1px solid color-mix(in srgb, var(--rule) 82%, transparent);
  box-shadow:
    inset 0 1px 0 color-mix(in srgb, #fff 8%, transparent),
    0 1px 0 color-mix(in srgb, #000 72%, transparent);
}

.preview-text-top {
  display: flex;
  align-items: center;
  gap: 0.28rem;
  min-width: 0;
  margin-bottom: 0.44rem;
}

.preview-kind {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-family: var(--mono);
  font-size: clamp(0.54rem, 0.49rem + 0.11vw, 0.63rem);
  font-weight: 650;
  letter-spacing: 0.08em;
  line-height: 1.1;
  text-transform: uppercase;
  color: var(--ink-muted);
}

.preview-text-title {
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 6;
  -webkit-box-orient: vertical;
  font-family: var(--serif);
  font-size: clamp(1.02rem, 0.92rem + 0.24vw, 1.2rem);
  font-weight: 620;
  line-height: 1.05;
  color: var(--ink);
  text-wrap: balance;
}

.preview-text-meta,
.preview-text-dek {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  font-family: var(--mono);
  letter-spacing: 0.02em;
  line-height: 1.3;
}

.preview-text-meta {
  -webkit-line-clamp: 2;
  margin-top: 0.38rem;
  color: var(--ink-light);
  font-size: 0.61rem;
}

.preview-text-dek {
  -webkit-line-clamp: 3;
  margin-top: 0.38rem;
  color: var(--ink-faint);
  font-size: 0.58rem;
}

.preview-cover-stamp {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 0.16rem;
  justify-content: flex-end;
  padding: clamp(2.4rem, 18%, 4rem) 0.44rem 0.4rem;
  color: #fff9ed;
  pointer-events: none;
}

.preview-cover-stamp::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 0;
  background:
    linear-gradient(
      to top,
      color-mix(in srgb, #050505 78%, transparent) 0%,
      color-mix(in srgb, #050505 42%, transparent) 44%,
      transparent 100%
    );
}

.preview-cover-stamp > * {
  position: relative;
  z-index: 1;
}

.preview-cover-stamp-title {
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  font-family: var(--serif);
  font-size: clamp(0.94rem, 0.86rem + 0.22vw, 1.14rem);
  font-weight: 650;
  line-height: 1.06;
  text-wrap: balance;
  text-shadow: 0 1px 0 #050505, 0 0.12rem 0.38rem color-mix(in srgb, #050505 86%, transparent);
}

.preview-cover-stamp-meta {
  font-family: var(--mono);
  font-size: clamp(0.58rem, 0.52rem + 0.14vw, 0.68rem);
  font-weight: 600;
  letter-spacing: 0.04em;
  line-height: 1.2;
  color: color-mix(in srgb, #fff9ed 84%, transparent);
}

.preview-cover:hover .preview-cover-stamp,
.preview-cover:focus-visible .preview-cover-stamp {
  opacity: 0;
}

.preview-caption {
  display: grid;
  gap: 0.08rem;
  min-width: 0;
}

.preview-title-row {
  --shelf-type-symbol-size: 0.88rem;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  align-items: start;
  column-gap: 0.32rem;
  line-height: 1.2;
}

.preview-title {
  display: -webkit-box;
  min-width: 0;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  font-family: var(--serif);
  font-size: 0.78rem;
  font-weight: 540;
  line-height: 1.18;
  color: var(--ink);
}

.preview-meta,
.preview-dek {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  font-family: var(--mono);
  letter-spacing: 0.02em;
  line-height: 1.3;
}

.preview-meta {
  -webkit-line-clamp: 2;
  color: var(--ink-light);
  font-size: 0.64rem;
}

.preview-dek {
  -webkit-line-clamp: 2;
  color: var(--ink-faint);
  font-size: 0.61rem;
}

.shelf-preview--list {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  min-height: 4.5rem;
  align-content: center;
  padding: 0.62rem 0;
  border-top: 1px solid color-mix(in srgb, var(--rule) 78%, transparent);
  border-bottom: 1px solid color-mix(in srgb, var(--rule) 48%, transparent);
}

.preview-list-main {
  --shelf-type-symbol-size: 1rem;
  display: block;
  min-width: 0;
  line-height: 1.22;
}

.preview-list-main .item-type-symbol {
  margin: 0 0.34rem 0 0;
  vertical-align: -0.16em;
}

.preview-list-title {
  display: inline;
  font-family: var(--serif);
  font-size: 0.9rem;
  font-weight: 520;
  line-height: 1.22;
  color: var(--ink);
  margin-right: 0.45rem;
}

.preview-list-meta,
.preview-list-dek {
  font-family: var(--mono);
  font-size: 0.62rem;
  letter-spacing: 0.02em;
  line-height: 1.3;
  margin-right: 0.45rem;
}

.preview-list-meta {
  color: var(--ink-light);
}

.preview-list-dek {
  color: var(--ink-faint);
}

.review-controls {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) auto;
  gap: 0.42rem;
  align-items: end;
  padding-top: 0.16rem;
}

.review-item.is-list .review-controls {
  padding-top: 0;
}

.control-field {
  gap: 0.18rem;
}

.control-label {
  font-size: 0.58rem;
  color: var(--ink-muted);
}

.select-input {
  min-height: 1.82rem;
  border-color: color-mix(in srgb, var(--rule) 82%, transparent);
  background: color-mix(in srgb, var(--bg) 90%, var(--surface-soft));
  font-family: var(--mono);
  font-size: 0.68rem;
  font-weight: 650;
  letter-spacing: 0.02em;
}

.row-action {
  min-height: 1.82rem;
  align-self: end;
  font-size: 0.6rem;
}

.path-line,
.item-copy,
.icon-preview {
  display: none;
}

@media (max-width: 780px) {
  .preview-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .review-controls {
    grid-template-columns: minmax(0, 1fr);
  }

  .row-action {
    justify-self: start;
  }
}

@media (max-width: 460px) {
  .preview-grid {
    grid-template-columns: minmax(0, 1fr);
  }
}
</style>
</head>
<body>
{% include "type-symbols.njk" %}
{%- set shelfItems = collections.items | where("dest", "shelf") -%}
<header class="app-header">
  <div class="header-inner">
    <div class="title-row">
      <div>
        <h1>Shelf Type Icons</h1>
        <p class="subtitle">Review type and symbol decisions in the shape they take on the Shelf. Browser-local until export.</p>
      </div>
      <span class="badge">{{ shelfItems | length }} Shelf items</span>
    </div>
    <div class="status-line" id="stats"></div>
    <div class="toolbar">
      <input class="search-input" id="searchInput" type="search" autocomplete="off" placeholder="Search title, author, topic, type">
      <nav class="filters" aria-label="Type review filters">
        <button class="filter-button" type="button" data-filter="all" aria-pressed="false">All</button>
        <button class="filter-button" type="button" data-filter="writing-scholar" aria-pressed="true">Essays / papers</button>
        <button class="filter-button" type="button" data-filter="essay" aria-pressed="false">Essay</button>
        <button class="filter-button" type="button" data-filter="scholar" aria-pressed="false">Paper-ish</button>
        <button class="filter-button" type="button" data-filter="custom-icon" aria-pressed="false">Icon override</button>
        <button class="filter-button" type="button" data-filter="changed" aria-pressed="false">Changed</button>
      </nav>
    </div>
    <nav class="quiet-actions" aria-label="Type icon actions">
      <a href="#export" id="exportLink">Export changes</a>
      <a href="#copy" id="copyLink" aria-disabled="true">Copy export</a>
      <a href="#reset" id="resetLink">Clear local changes</a>
    </nav>
  </div>
</header>

<main class="library" id="board" aria-label="Shelf type icon board"></main>

<section id="exportPanel" class="export-panel hidden" aria-live="polite">
  <div class="export-head">
    <div>
      <h2>Export Type Icon Changes</h2>
      <p>Paste this back when you want the decisions applied to item frontmatter.</p>
    </div>
    <a href="#close" id="closeExportLink">Close</a>
  </div>
  <pre id="exportText" class="export-output" tabindex="0"></pre>
  <nav class="quiet-actions" aria-label="Export actions">
    <a href="#copy-export" id="copyExportLink">Copy export</a>
  </nav>
</section>

<script>
const STORAGE_KEY = "shelfTypeIcons.v2";
const LEGACY_STORAGE_KEY = "shelfTypeIcons.v1";
const DEFAULT_FILTER = "writing-scholar";
const TOPICS = {{ topics | toJson | safe }};
const TYPE_OPTIONS = [
  { value: "book", label: "Book", symbol: "book" },
  { value: "case study", label: "Case study", symbol: "file-text" },
  { value: "chapter", label: "Chapter", symbol: "book" },
  { value: "essay", label: "Essay", symbol: "article" },
  { value: "journal article", label: "Journal article", symbol: "microscope" },
  { value: "paper", label: "Paper", symbol: "microscope" },
  { value: "working paper", label: "Working paper", symbol: "microscope" },
  { value: "report", label: "Report", symbol: "file-text" },
  { value: "site", label: "Site", symbol: "browser" },
  { value: "archive", label: "Archive", symbol: "archive" },
  { value: "tool", label: "Tool", symbol: "terminal-2" },
  { value: "project", label: "Project", symbol: "cube" },
  { value: "game", label: "Game", symbol: "hand-finger" },
  { value: "film", label: "Film", symbol: "movie" },
  { value: "video", label: "Video", symbol: "video" },
  { value: "vr", label: "VR", symbol: "hand-finger" },
  { value: "installation", label: "Installation", symbol: "cube" },
  { value: "interview", label: "Interview", symbol: "messages" },
  { value: "magazine", label: "Magazine", symbol: "article" },
  { value: "slides", label: "Slides", symbol: "presentation" },
  { value: "concept", label: "Concept", symbol: "bulb" }
];
const ICON_OPTIONS = [
  { value: "", label: "Default" },
  { value: "book", label: "Book" },
  { value: "article", label: "Article" },
  { value: "browser", label: "Browser" },
  { value: "file-text", label: "File text" },
  { value: "news", label: "News" },
  { value: "microscope", label: "Microscope" },
  { value: "movie", label: "Movie" },
  { value: "video", label: "Video" },
  { value: "wave-sine", label: "Audio wave" },
  { value: "photo", label: "Photo" },
  { value: "notes", label: "Notes" },
  { value: "database", label: "Database" },
  { value: "map-2", label: "Map" },
  { value: "terminal-2", label: "Terminal" },
  { value: "badge-vr", label: "VR badge" },
  { value: "messages", label: "Messages" },
  { value: "presentation", label: "Presentation" },
  { value: "archive", label: "Archive" },
  { value: "device-gamepad-2", label: "Gamepad" },
  { value: "hand-finger", label: "Hand" },
  { value: "cube", label: "Cube" },
  { value: "podium", label: "Podium" },
  { value: "bulb", label: "Bulb" }
];
const ITEMS = [
{%- for topic in topics %}
  {%- set bucket = collections.items | where("dest", "shelf") | where("topic", topic) | sortForShelf %}
  {%- for item in bucket %}
  {
    path: {{ item.inputPath | replace("./", "") | toJson | safe }},
    title: {{ item.data.title | toJson | safe }},
    author: {{ item.data.author | toJson | safe }},
    topic: {{ topic | toJson | safe }},
    type: {{ item.data.type | toJson | safe }},
    typeSymbol: {{ (item.data.type_symbol or "") | toJson | safe }},
    year: {{ item.data | shelfIdentityYear | toJson | safe }},
    dek: {{ (item.data.dek or "") | toJson | safe }},
    note: {{ (item.data.note or "") | toJson | safe }},
    blurb: {{ (item.data.blurb or "") | toJson | safe }},
    quote: {{ (item.data.quote or "") | toJson | safe }},
    image: {{ (item.data.image or "") | toJson | safe }},
    url: {{ (item.data.url or "") | toJson | safe }},
    shelfList: {{ (item.data.shelf_list or false) | toJson | safe }},
    coverLabel: {{ ((item.data.cover_label or item.data.cover_label_text) and true or false) | toJson | safe }},
    coverLabelText: {{ (item.data.cover_label_text or "") | toJson | safe }}
  },
  {%- endfor %}
{%- endfor %}
];

const typeValues = new Set(TYPE_OPTIONS.map((type) => type.value));
const iconValues = new Set(ICON_OPTIONS.map((icon) => icon.value));
const typeByValue = new Map(TYPE_OPTIONS.map((type) => [type.value, type]));
const iconByValue = new Map(ICON_OPTIONS.map((icon) => [icon.value, icon]));
const itemByPath = new Map(ITEMS.map((item) => [item.path, item]));

const state = {
  typeByPath: {},
  iconByPath: {},
  filter: DEFAULT_FILTER,
  search: ""
};

const els = {
  board: document.getElementById("board"),
  stats: document.getElementById("stats"),
  searchInput: document.getElementById("searchInput"),
  exportPanel: document.getElementById("exportPanel"),
  exportText: document.getElementById("exportText"),
  copyLink: document.getElementById("copyLink")
};

function loadState() {
  try {
    const stored = localStorage.getItem(STORAGE_KEY);
    const legacy = stored ? null : localStorage.getItem(LEGACY_STORAGE_KEY);
    const parsed = JSON.parse(stored || legacy || "{}");
    state.typeByPath = parsed && parsed.typeByPath ? parsed.typeByPath : {};
    state.iconByPath = parsed && parsed.iconByPath ? parsed.iconByPath : {};
    state.filter = stored && parsed && parsed.filter ? parsed.filter : DEFAULT_FILTER;
    state.search = stored && parsed && parsed.search ? parsed.search : "";
  } catch (error) {
    state.typeByPath = {};
    state.iconByPath = {};
    state.filter = DEFAULT_FILTER;
    state.search = "";
  }
  sanitizeState();
  writeState();
}

function sanitizeState() {
  const cleanTypes = {};
  for (const [path, value] of Object.entries(state.typeByPath || {})) {
    const item = itemByPath.get(path);
    const cleanValue = String(value || "").trim();
    if (!item || !typeValues.has(cleanValue)) continue;
    if (cleanValue !== item.type) cleanTypes[path] = cleanValue;
  }
  const cleanIcons = {};
  for (const [path, value] of Object.entries(state.iconByPath || {})) {
    const item = itemByPath.get(path);
    const cleanValue = String(value || "").trim();
    if (!item || !iconValues.has(cleanValue)) continue;
    if (cleanValue !== String(item.typeSymbol || "")) cleanIcons[path] = cleanValue;
  }
  state.typeByPath = cleanTypes;
  state.iconByPath = cleanIcons;
  if (!["all", "writing-scholar", "essay", "scholar", "custom-icon", "changed"].includes(state.filter)) state.filter = DEFAULT_FILTER;
  state.search = String(state.search || "");
}

function saveState() {
  sanitizeState();
  writeState();
}

function writeState() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify({
    typeByPath: state.typeByPath,
    iconByPath: state.iconByPath,
    filter: state.filter,
    search: state.search,
    updatedAt: new Date().toISOString()
  }));
}

function hasTypeOverride(item) {
  return Object.prototype.hasOwnProperty.call(state.typeByPath, item.path);
}

function hasIconOverride(item) {
  return Object.prototype.hasOwnProperty.call(state.iconByPath, item.path);
}

function currentType(item) {
  if (!item) return "";
  return hasTypeOverride(item) ? state.typeByPath[item.path] : item.type;
}

function currentIconOverride(item) {
  if (!item) return "";
  return hasIconOverride(item) ? state.iconByPath[item.path] : String(item.typeSymbol || "");
}

function defaultSymbolForType(type) {
  const option = typeByValue.get(type);
  return option ? option.symbol : "notes";
}

function effectiveSymbol(item) {
  return currentIconOverride(item) || defaultSymbolForType(currentType(item));
}

function isChanged(item) {
  return hasTypeOverride(item) || hasIconOverride(item);
}

function setType(path, value) {
  const item = itemByPath.get(path);
  const cleanValue = String(value || "").trim();
  if (!item || !typeValues.has(cleanValue)) return;
  if (cleanValue === item.type) delete state.typeByPath[path];
  else state.typeByPath[path] = cleanValue;
  saveState();
  render();
}

function setIcon(path, value) {
  const item = itemByPath.get(path);
  const cleanValue = String(value || "").trim();
  if (!item || !iconValues.has(cleanValue)) return;
  if (cleanValue === String(item.typeSymbol || "")) delete state.iconByPath[path];
  else state.iconByPath[path] = cleanValue;
  saveState();
  render();
}

function clearItem(path) {
  delete state.typeByPath[path];
  delete state.iconByPath[path];
  saveState();
  render();
}

function visibleItems() {
  const query = state.search.trim().toLowerCase();
  return ITEMS.filter((item) => {
    const nextType = currentType(item);
    const changed = isChanged(item);
    const scholarTypes = ["chapter", "paper", "journal article", "working paper", "report"];
    if (state.filter === "writing-scholar" && !["essay", ...scholarTypes].includes(nextType)) return false;
    if (state.filter === "essay" && nextType !== "essay") return false;
    if (state.filter === "scholar" && !scholarTypes.includes(nextType)) return false;
    if (state.filter === "custom-icon" && !currentIconOverride(item)) return false;
    if (state.filter === "changed" && !changed) return false;
    if (!query) return true;
    return [item.title, item.author, item.topic, item.type, nextType, item.dek, item.path].join(" ").toLowerCase().includes(query);
  });
}

function render() {
  renderStats();
  renderFilters();
  els.searchInput.value = state.search;
  const items = visibleItems();
  const grouped = TOPICS.map((topic) => ({
    topic,
    items: items.filter((item) => item.topic === topic)
  })).filter((group) => group.items.length);
  els.board.innerHTML = grouped.length
    ? grouped.map(topicMarkup).join("")
    : `<p class="empty">No Shelf items match this view.</p>`;
  bindRows();
}

function renderStats() {
  const decisions = exportDecisions();
  const typeChanged = decisions.filter((item) => item.typeChanged).length;
  const iconChanged = decisions.filter((item) => item.symbolChanged).length;
  const customIcons = ITEMS.filter((item) => currentIconOverride(item)).length;
  els.stats.innerHTML = [
    `<span><b>${ITEMS.length}</b> total shelf</span>`,
    `<span class="changed"><b>${decisions.length}</b> changed</span>`,
    `<span class="type"><b>${typeChanged}</b> type</span>`,
    `<span class="icon"><b>${iconChanged}</b> icon</span>`,
    `<span><b>${customIcons}</b> custom icon</span>`
  ].join("");
  els.copyLink.setAttribute("aria-disabled", decisions.length ? "false" : "true");
}

function renderFilters() {
  document.querySelectorAll("[data-filter]").forEach((button) => {
    button.setAttribute("aria-pressed", button.dataset.filter === state.filter ? "true" : "false");
  });
}

function topicMarkup(group) {
  return `
    <section class="topic-section" id="${topicSlug(group.topic)}">
      <header class="topic-heading">
        <h2 class="topic-label">${escapeHtml(group.topic)}</h2>
        <span class="topic-count">${group.items.length}</span>
      </header>
      <div class="preview-grid">
        ${group.items.map(itemMarkup).join("")}
      </div>
    </section>
  `;
}

function itemMarkup(item) {
  const nextType = currentType(item);
  const nextSymbol = effectiveSymbol(item);
  const iconValue = currentIconOverride(item);
  const changed = isChanged(item);
  const defaultSymbol = defaultSymbolForType(nextType);
  const defaultLabel = iconLabel(defaultSymbol);
  const oldTypeText = item.type === nextType ? item.type : `${item.type} -> ${nextType}`;
  const oldIcon = String(item.typeSymbol || "") || "default";
  const nextIcon = iconValue || "default";
  const iconText = oldIcon === nextIcon ? nextIcon : `${oldIcon} -> ${nextIcon}`;
  return `
    <article class="review-item${item.shelfList ? " is-list" : " is-cover"}${changed ? " is-changed" : ""}" data-path="${escapeAttr(item.path)}">
      ${item.shelfList ? listPreviewMarkup(item) : coverPreviewMarkup(item)}
      <div class="review-controls">
        <label class="control-field">
          <span class="control-label">Type <span class="type-chip"><b>${escapeHtml(oldTypeText)}</b></span></span>
          <select class="select-input" data-type-select aria-label="Type for ${escapeAttr(item.title || "Untitled")}">
            ${TYPE_OPTIONS.map((option) => `<option value="${escapeAttr(option.value)}"${option.value === nextType ? " selected" : ""}>${escapeHtml(option.label)}</option>`).join("")}
          </select>
        </label>
        <label class="control-field">
          <span class="control-label">Icon <span class="type-chip"><b>${escapeHtml(iconText)}</b></span></span>
          <select class="select-input" data-icon-select aria-label="Icon for ${escapeAttr(item.title || "Untitled")}">
            ${ICON_OPTIONS.map((option) => {
              const label = option.value ? option.label : `Default (${defaultLabel})`;
              return `<option value="${escapeAttr(option.value)}"${option.value === iconValue ? " selected" : ""}>${escapeHtml(label)}</option>`;
            }).join("")}
          </select>
        </label>
        <button class="row-action" type="button" data-clear-item aria-disabled="${changed ? "false" : "true"}">Clear</button>
      </div>
    </article>
  `;
}

function coverPreviewMarkup(item) {
  const nextType = currentType(item);
  const nextSymbol = effectiveSymbol(item);
  const text = item.quote || item.note || item.blurb || item.dek || "";
  const labelText = item.coverLabelText || item.title || "Untitled";
  const content = item.image
    ? `<img src="${escapeAttr(item.image)}" alt="">`
    : textPreviewMarkup(item, nextType, nextSymbol);
  return `
    <div class="shelf-preview shelf-preview--cover">
      <a class="preview-cover" href="${escapeAttr(item.url || "#")}" target="_blank" rel="noopener" aria-label="Open ${escapeAttr(item.title || "Untitled")}">
        ${content}
        ${item.coverLabel ? `
        <span class="preview-cover-stamp" aria-hidden="true">
          <span class="preview-cover-stamp-title">${escapeHtml(labelText)}</span>
          <span class="preview-cover-stamp-meta">${escapeHtml([item.author, item.year].filter(Boolean).join(" / "))}</span>
        </span>` : ""}
      </a>
      <span class="preview-caption">
        <span class="preview-title-row">
          ${typeIconMarkup(nextType, nextSymbol, "cell-type")}
          <span class="preview-title">${escapeHtml(item.title || "Untitled")}</span>
        </span>
        <span class="preview-meta">${escapeHtml([item.author, item.year].filter(Boolean).join(" / "))}</span>
        ${item.dek ? `<span class="preview-dek">${escapeHtml(item.dek)}</span>` : ""}
      </span>
    </div>
  `;
}

function textPreviewMarkup(item, nextType, nextSymbol) {
  return `
    <span class="preview-text-card">
      <span class="preview-text-top">
        ${typeIconMarkup(nextType, nextSymbol, "cell-text-type")}
        <span class="preview-kind">${escapeHtml(typeLabel(nextType))}</span>
      </span>
      <span class="preview-text-title">${escapeHtml(item.title || "Untitled")}</span>
      <span class="preview-text-meta">${escapeHtml([item.author, item.year].filter(Boolean).join(" / "))}</span>
      ${item.dek ? `<span class="preview-text-dek">${escapeHtml(item.dek)}</span>` : ""}
    </span>
  `;
}

function listPreviewMarkup(item) {
  const nextType = currentType(item);
  const nextSymbol = effectiveSymbol(item);
  return `
    <div class="shelf-preview shelf-preview--list">
      <span class="preview-list-main">
        ${typeIconMarkup(nextType, nextSymbol, "shelf-list-type")}
        <span class="preview-list-title">${escapeHtml(item.title || "Untitled")}</span>
        <span class="preview-list-meta">${escapeHtml([item.author, item.year].filter(Boolean).join(", "))}</span>
        ${item.dek ? `<span class="preview-list-dek">${escapeHtml(item.dek)}</span>` : ""}
      </span>
    </div>
  `;
}

function typeIconMarkup(type, symbol, className) {
  return `
    <span class="${escapeAttr(className)} item-type-symbol" data-type="${escapeAttr(type)}" data-symbol="${escapeAttr(symbol)}" role="img" aria-label="${escapeAttr(typeLabel(type))}">
      <svg class="item-type-symbol__icon" aria-hidden="true" focusable="false">
        <use href="#item-type-${escapeAttr(symbol)}"></use>
      </svg>
    </span>
  `;
}

function bindRows() {
  document.querySelectorAll("[data-type-select]").forEach((select) => {
    select.addEventListener("change", () => {
      const row = select.closest("[data-path]");
      if (!row) return;
      setType(row.dataset.path, select.value);
    });
  });
  document.querySelectorAll("[data-icon-select]").forEach((select) => {
    select.addEventListener("change", () => {
      const row = select.closest("[data-path]");
      if (!row) return;
      setIcon(row.dataset.path, select.value);
    });
  });
  document.querySelectorAll("[data-clear-item]").forEach((button) => {
    button.addEventListener("click", () => {
      if (button.getAttribute("aria-disabled") === "true") return;
      const row = button.closest("[data-path]");
      if (!row) return;
      clearItem(row.dataset.path);
    });
  });
}

function exportDecisions() {
  return ITEMS.filter(isChanged).map((item) => {
    const nextType = currentType(item);
    const nextSymbolOverride = currentIconOverride(item);
    return {
      path: item.path,
      title: item.title,
      author: item.author,
      topic: item.topic,
      oldType: item.type,
      newType: nextType,
      oldTypeSymbol: String(item.typeSymbol || ""),
      newTypeSymbol: nextSymbolOverride,
      effectiveSymbol: effectiveSymbol(item),
      typeChanged: item.type !== nextType,
      symbolChanged: String(item.typeSymbol || "") !== nextSymbolOverride,
      removeTypeSymbol: Boolean(item.typeSymbol) && !nextSymbolOverride,
      setTypeSymbol: nextSymbolOverride || null
    };
  });
}

function exportPayload() {
  const decisions = exportDecisions();
  return {
    exportedAt: new Date().toISOString(),
    source: "shelf-type-icons",
    localStorageKey: STORAGE_KEY,
    counts: {
      totalShelfItems: ITEMS.length,
      changedItems: decisions.length,
      typeChanged: decisions.filter((item) => item.typeChanged).length,
      symbolChanged: decisions.filter((item) => item.symbolChanged).length
    },
    decisions
  };
}

function showExport() {
  els.exportText.textContent = JSON.stringify(exportPayload(), null, 2);
  els.exportPanel.classList.remove("hidden");
  els.exportText.focus();
}

async function copyExport() {
  const text = JSON.stringify(exportPayload(), null, 2);
  try {
    await navigator.clipboard.writeText(text);
  } catch (error) {
    showExport();
    els.exportText.textContent = text;
    els.exportText.focus();
  }
}

function resetChanges() {
  if (!window.confirm("Clear local type/icon decisions? This only resets browser state.")) return;
  state.typeByPath = {};
  state.iconByPath = {};
  state.filter = DEFAULT_FILTER;
  state.search = "";
  saveState();
  render();
}

function typeLabel(type) {
  const option = typeByValue.get(type);
  return option ? option.label : type || "Item";
}

function iconLabel(symbol) {
  const option = iconByValue.get(symbol);
  return option ? option.label : symbol || "Default";
}

function topicSlug(topic) {
  return topic.toLowerCase().replace(/&/g, "and").replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
}

function escapeHtml(value) {
  return String(value || "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function escapeAttr(value) {
  return escapeHtml(value).replace(/'/g, "&#39;");
}

function stopLink(event) {
  event.preventDefault();
}

loadState();
render();

els.searchInput.addEventListener("input", (event) => {
  state.search = event.currentTarget.value;
  saveState();
  render();
});

document.querySelectorAll("[data-filter]").forEach((button) => {
  button.addEventListener("click", () => {
    state.filter = button.dataset.filter;
    saveState();
    render();
  });
});

document.getElementById("exportLink").addEventListener("click", (event) => {
  stopLink(event);
  showExport();
});
document.getElementById("copyLink").addEventListener("click", (event) => {
  stopLink(event);
  if (event.currentTarget.getAttribute("aria-disabled") !== "true") copyExport();
});
document.getElementById("resetLink").addEventListener("click", (event) => {
  stopLink(event);
  resetChanges();
});
document.getElementById("closeExportLink").addEventListener("click", (event) => {
  stopLink(event);
  els.exportPanel.classList.add("hidden");
});
document.getElementById("copyExportLink").addEventListener("click", (event) => {
  stopLink(event);
  copyExport();
});
document.addEventListener("keydown", (event) => {
  if (event.key === "Escape") els.exportPanel.classList.add("hidden");
});
</script>
</body>
</html>
