<article class="ascii-lab" id="main" data-ascii-lab>
  <header class="al-head">
    <h1>ASCII constellation lab</h1>
    <p>Full-frame luminance-raster ASCII. The constellation geometry drives an offscreen luminance scene (star halos, edge glows, drifting nebula); each character cell samples that scene and picks a glyph from a brightness ramp. Should look like it's dancing.</p>
    <nav class="al-cyclenav" aria-label="Constellation cycle">
      <button type="button" data-cyc="prev" aria-label="Previous">&lt;</button>
      <span data-cyc-label class="al-cyc-label"></span>
      <button type="button" data-cyc="next" aria-label="Next">&gt;</button>
      <button type="button" data-cyc="pause" class="al-cyc-pause">pause</button>
    </nav>
  </header>

  <div class="al-frame-stack" aria-hidden="true">
    <pre class="al-frame al-layer-nebula" data-frame-n></pre>
    <pre class="al-frame al-layer-lines" data-frame-l></pre>
    <pre class="al-frame al-layer-stars" data-frame-s></pre>
  </div>

  <section class="al-note" data-note aria-live="polite"></section>

  <details class="al-controls">
    <summary>tuning</summary>
    <div class="al-controls-grid">
      <label>cols <input type="range" min="60" max="180" step="2" value="120" data-tune="cols"><output data-out="cols">120</output></label>
      <label>rows <input type="range" min="24" max="80" step="1" value="40" data-tune="rows"><output data-out="rows">40</output></label>
      <label>ramp <select data-tune="ramp">
        <option value=" .:-=+*#%@">10 short</option>
        <option value=" .,:;i!lI+*?xX#%@" selected>17 ascii</option>
        <option value=" .'`^&quot;,:;Il!i&gt;&lt;~+_-?][}{1)(|/tfjrxnuvczXYUJCLQ0OZmwqpdbkhao*#MW&amp;8%B@$">70 long</option>
      </select></label>
      <label>twinkle <input type="range" min="0" max="100" step="1" value="55" data-tune="twinkle"><output data-out="twinkle">55</output></label>
      <label>nebula <input type="range" min="0" max="60" step="1" value="22" data-tune="nebula"><output data-out="nebula">22</output></label>
      <label>line pulse <input type="range" min="0" max="100" step="1" value="65" data-tune="pulse"><output data-out="pulse">65</output></label>
      <label>sway <input type="range" min="0" max="50" step="1" value="18" data-tune="sway"><output data-out="sway">18</output></label>
      <label>dither <input type="range" min="0" max="40" step="1" value="14" data-tune="dither"><output data-out="dither">14</output></label>
      <label>fps cap <input type="range" min="12" max="60" step="1" value="30" data-tune="fps"><output data-out="fps">30</output></label>
    </div>
  </details>
</article>

