        { name: '♭VI (Eb)',     pressA: ['Eb5'], resolveA: ['G5','Bb4'],  pressB: ['Bb4'], resolveB: ['Eb5','G5'],  low: 'Eb3', walkBass: ['Bb3','G3'] },
        { name: 'v (Dm)',       pressA: ['D5'],  resolveA: ['F5','A5'],   pressB: ['A5'],  resolveB: ['D5','F5'],   low: 'D3',  walkBass: ['A3','F3'] },
        { name: 'iv (Cm)',      pressA: ['C5'],  resolveA: ['Eb5','G5'],  pressB: ['G5'],  resolveB: ['Eb5','C5'],  low: 'C3',  walkBass: ['G3','Eb3'] },
        { name: 'i (Gm)',       pressA: ['G5'],  resolveA: ['Bb4','D5'],  pressB: ['Bb4'], resolveB: ['F5','D5'],   low: 'G3',  walkBass: ['D3','Bb3'] },
        { name: '♭VII (F)',     pressA: ['F5'],  resolveA: ['A5','C5'],   pressB: ['C5'],  resolveB: ['F5','A5'],   low: 'F3',  walkBass: ['C3','A3'] },
        { name: 'i cadence',    pressA: ['Bb4'], resolveA: ['D5','F5'],   pressB: ['G5'],  resolveB: ['Bb4','D5','G5'], low: 'G3', walkBass: ['D3','Bb3'] }
      ]
    }
  };

  // ============================================================
  // Transport.
  // ============================================================
  const playBtn = document.querySelector('[data-play]');
  const stopBtn = document.querySelector('[data-stop]');
  const statusEl = document.querySelector('[data-status]');
  const progressionEl = document.querySelector('[data-progression]');
  const songButtons = document.querySelectorAll('.song-btn[data-song]');

  let armed = false;
  let step = 0;
  let walkTimer = null;
  let activeSongKey = 'heavenly';
  let activePhrases = PROGRESSIONS[activeSongKey].phrases;

  function renderProgression() {
    while (progressionEl.firstChild) progressionEl.removeChild(progressionEl.firstChild);
    activePhrases.forEach((p, i) => {
      const row = document.createElement('div');
      row.className = 'phrase';
      row.dataset.phrase = String(i);

      const stepEl = document.createElement('span');
      stepEl.className = 'step';
      stepEl.textContent = 'P' + i;

      const body = document.createElement('span');
      const label = document.createElement('span');
      label.className = 'label';
      label.textContent = p.name;
      body.appendChild(label);
      body.appendChild(document.createTextNode(' · '));

      // Build flashable note groups: pressA → resolveA → pressB → resolveB · low
      appendNoteGroup(body, p.pressA,   'pressA');
      body.appendChild(document.createTextNode(' → '));
      appendNoteGroup(body, p.resolveA, 'resolveA');
      body.appendChild(document.createTextNode(' → '));
      appendNoteGroup(body, p.pressB,   'pressB');
      body.appendChild(document.createTextNode(' → '));
      appendNoteGroup(body, p.resolveB, 'resolveB');
      body.appendChild(document.createTextNode(' · '));
      // Low note as a single flashable span.
      const lowSpan = document.createElement('span');
      lowSpan.className = 'n';
      lowSpan.dataset.evt = 'low';
      lowSpan.textContent = p.low;
      body.appendChild(lowSpan);

      if (p.walkBass && p.walkBass.length) {
        const wb = document.createElement('span');
        wb.className = 'walk';
        wb.appendChild(document.createTextNode('↳ walk '));
        p.walkBass.forEach((note, wi) => {
          if (wi > 0) wb.appendChild(document.createTextNode(' · '));
          const wn = document.createElement('span');
          wn.className = 'n';
          wn.dataset.walkIdx = String(wi);
          wn.textContent = note;
          wb.appendChild(wn);
        });
        body.appendChild(wb);
      }
      row.appendChild(stepEl);
      row.appendChild(body);
      progressionEl.appendChild(row);
    });
  }

  // Build a "+"-joined note group with each note as a flashable .n span.
  function appendNoteGroup(parent, notes, eventName) {
    if (!notes || notes.length === 0) return;
    notes.forEach((note, i) => {
      if (i > 0) parent.appendChild(document.createTextNode('+'));
      const span = document.createElement('span');
      span.className = 'n';
      span.dataset.evt = eventName;
      span.textContent = note;
      parent.appendChild(span);
    });
  }

  // Flash all notes within one event-group on the active phrase row.
  // delayMs is wall-clock offset from now; holdMs is the lit duration.
  const FLASH_HOLD_MS = 280;
  function flashEvent(phraseIdx, eventName, delayMs) {
    setTimeout(() => {
      const row = progressionEl.querySelector('[data-phrase="' + phraseIdx + '"]');
      if (!row) return;
      const targets = row.querySelectorAll('.n[data-evt="' + eventName + '"]');
      targets.forEach(el => el.classList.add('is-firing'));
      setTimeout(() => targets.forEach(el => el.classList.remove('is-firing')), FLASH_HOLD_MS);
    }, Math.max(0, delayMs));
  }
  function flashWalk(phraseIdx, walkIdx, delayMs) {
    setTimeout(() => {
      const row = progressionEl.querySelector('[data-phrase="' + phraseIdx + '"]');
      if (!row) return;
      const el = row.querySelector('.n[data-walk-idx="' + walkIdx + '"]');
      if (!el) return;
      el.classList.add('is-firing');
      setTimeout(() => el.classList.remove('is-firing'), FLASH_HOLD_MS);
    }, Math.max(0, delayMs));
  }

  function setActivePhrase(idx) {
    progressionEl.querySelectorAll('.phrase').forEach(el => {
      el.classList.toggle('active', parseInt(el.dataset.phrase, 10) === idx);
    });
  }

  function setStatus(prefix, label) {
    while (statusEl.firstChild) statusEl.removeChild(statusEl.firstChild);
    if (!label) { statusEl.appendChild(document.createTextNode(prefix)); return; }
    statusEl.appendChild(document.createTextNode(prefix));
    const strong = document.createElement('strong');
    strong.textContent = label;
    statusEl.appendChild(strong);
  }

  function pickSong(key) {
    activeSongKey = key;
    activePhrases = PROGRESSIONS[key].phrases;
    songButtons.forEach(b => b.classList.toggle('on', b.dataset.song === key));
    renderProgression();
    if (!armed) setStatus('cued · ', PROGRESSIONS[key].name);
    // step stays — next scheduled phrase will pull from new phrases. If we're
    // mid-walk, the rest of this loop iteration plays the OLD preset; the next
    // playStep tick picks up the new one. That's the right hand-off behavior:
    // no audible glitch, no double-trigger.
  }

  function playStep() {
    if (!armed) return;
    const idx = step % activePhrases.length;
    const preset = activePhrases[idx];
    playPrettyPreset(preset);
    setActivePhrase(idx);
    setStatus('playing · ', PROGRESSIONS[activeSongKey].name + ' · P' + idx + ' (' + preset.name + ')');
    // Visual flashes — wall-clock setTimeout, aligned to audio event offsets.
    // Audio schedules from c.currentTime+0.035, so add 35ms head start to match.
    flashEvent(idx, 'pressA',   35);
    flashEvent(idx, 'resolveA', 35 + PRESS_TO_HIT_MS);
    flashWalk(idx,  0,          35 + 2750);   // center of 2.5–3.0s window
    flashEvent(idx, 'pressB',   35 + LOOP_BEAT_MS);
    flashWalk(idx,  1,          35 + 4550);   // center of 4.4–4.7s window
    flashEvent(idx, 'resolveB', 35 + LOOP_BEAT_MS + PRESS_TO_HIT_MS);
    flashEvent(idx, 'low',      35 + LOOP_BEAT_MS + PRESS_TO_HIT_MS);
    step += 1;
    walkTimer = setTimeout(playStep, PRETTY_WALK_MS + Math.floor(Math.random() * PRETTY_WALK_SPREAD_MS));
  }

  function start() {
    if (armed) return;
    const c = ensureAudio();
    if (c.state === 'suspended') c.resume();
    armed = true;
    step = 0;
    prettyStartedAt = c.currentTime;
    playBtn.classList.add('on');
    playBtn.textContent = '❚❚ pause';
    playStep();
  }

  function stop() {
    armed = false;
    if (walkTimer) { clearTimeout(walkTimer); walkTimer = null; }
    playBtn.classList.remove('on');
    playBtn.textContent = '▶ play';
    setActivePhrase(-1);
    setStatus('stopped · ', PROGRESSIONS[activeSongKey].name);
  }

  songButtons.forEach(b => b.addEventListener('click', () => pickSong(b.dataset.song)));
  playBtn.addEventListener('click', () => { if (armed) stop(); else start(); });
  stopBtn.addEventListener('click', stop);

  // Voice picker — multi-select toggle. Tapping adds/removes a voice from
  // the active set; next scheduled note layers all active voices.
  // Safety: if user de-selects the last voice, re-add it so we always have ≥1 source.
  document.querySelectorAll('[data-voice]').forEach(btn => {
    btn.addEventListener('click', () => {
      const name = btn.dataset.voice;
      if (activeVoices.has(name)) {
        activeVoices.delete(name);
        if (activeVoices.size === 0) activeVoices.add(name);  // can't have zero
      } else {
        activeVoices.add(name);
      }
      document.querySelectorAll('[data-voice]').forEach(b => {
        b.classList.toggle('on', activeVoices.has(b.dataset.voice));
      });
    });
  });

  renderProgression();
})();
</script>
</body>
</html>
