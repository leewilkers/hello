  <script>
    // ============================================================
    // Editor mode: activate by appending ?edit=1 to the URL.
    // Makes the essay contenteditable + adds flag/comment/export.
    // Auto-saves to localStorage; export copies updated HTML.
    // ============================================================
    (function() {
      const params = new URLSearchParams(location.search);
      if (!params.has('edit')) return;
      const article = document.querySelector('article.essay');
      if (!article) return;
      const STORAGE_KEY = 'essay-edits:' + location.pathname;

      // Restore saved edits via DOMParser (safer than innerHTML)
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        try {
          const data = JSON.parse(saved);
          if (data && data.html) {
            const parser = new DOMParser();
            const doc = parser.parseFromString(
              '<div>' + data.html + '</div>',
              'text/html'
            );
            const container = doc.body.firstChild;
            // Remove any scripts the parser may have included (paranoia)
            container.querySelectorAll('script').forEach(s => s.remove());
            // Replace article children with parsed nodes
            while (article.firstChild) article.removeChild(article.firstChild);
            while (container.firstChild) article.appendChild(container.firstChild);
          }
        } catch (e) { console.warn('Restore failed:', e); }
      }

      // Make text editable
      const EDITABLE = 'p, h1, h2, h3, h4, li, figcaption, dt, dd, blockquote';
      article.querySelectorAll(EDITABLE).forEach(el => {
        el.setAttribute('contenteditable', 'true');
        el.setAttribute('spellcheck', 'true');
      });

      // Auto-save on edit (debounced)
      let saveTimer = null;
      article.addEventListener('input', () => {
        clearTimeout(saveTimer);
        saveTimer = setTimeout(() => {
          // Serialize via outerHTML of cloned content (read-only operation)
          const clone = article.cloneNode(true);
          clone.querySelectorAll('[contenteditable]').forEach(el =>
            el.removeAttribute('contenteditable')
          );
          clone.querySelectorAll('[spellcheck]').forEach(el =>
            el.removeAttribute('spellcheck')
          );
          localStorage.setItem(STORAGE_KEY, JSON.stringify({
            html: clone.innerHTML,
            ts: Date.now()
          }));
          status('Saved ' + new Date().toLocaleTimeString());
        }, 400);
      });

      // Build toolbar via DOM API (no innerHTML)
      function el(tag, attrs, text) {
        const e = document.createElement(tag);
        if (attrs) for (const k in attrs) {
          if (k === 'dataset') for (const dk in attrs.dataset) e.dataset[dk] = attrs.dataset[dk];
          else e.setAttribute(k, attrs[k]);
        }
        if (text != null) e.textContent = text;
        return e;
      }

      const toolbar = el('div', { class: 'essay-editor-toolbar' });
      toolbar.appendChild(el('div', { class: 'essay-editor-title' }, 'Editor mode'));

      const buttons = [
        ['flag', '⚑ Flag', 'Highlight selected text (yellow)'],
        ['comment', '💬 Comment', 'Add a note on selection'],
        ['unmark', '⌫ Clear flag', 'Remove flag/comment from selection'],
        ['export', '↓ Copy HTML', 'Copy edited HTML to clipboard'],
        ['json', '⤴ Copy JSON', 'Copy edits as structured JSON'],
        ['reset', '↺ Reset', 'Discard all edits'],
      ];
      buttons.forEach(([action, label, title]) => {
        const b = el('button', { type: 'button', title, dataset: { action } }, label);
        toolbar.appendChild(b);
      });
      const statusEl = el('div', { class: 'essay-editor-status' });
      toolbar.appendChild(statusEl);
      document.body.appendChild(toolbar);

      function status(msg) {
        statusEl.textContent = msg;
        if (msg) setTimeout(() => { if (statusEl.textContent === msg) statusEl.textContent = ''; }, 3000);
      }

      function wrapSelection(className, comment) {
        const sel = window.getSelection();
        if (!sel || sel.rangeCount === 0) { status('Select text first'); return; }
        const range = sel.getRangeAt(0);
        if (range.collapsed) { status('Select text first'); return; }
        try {
          const mark = el('mark', { class: className });
          if (comment) {
            mark.title = comment;
            mark.dataset.comment = comment;
          }
          range.surroundContents(mark);
          sel.removeAllRanges();
          article.dispatchEvent(new Event('input'));
        } catch (e) { status('Cannot flag across elements'); }
      }

      function unmarkSelection() {
        const sel = window.getSelection();
        if (!sel || sel.rangeCount === 0) { status('Select text first'); return; }
        let node = sel.anchorNode;
        while (node && node !== article) {
          if (node.nodeType === 1 && node.tagName === 'MARK' &&
              (node.classList.contains('essay-flag') || node.classList.contains('essay-flag-comment'))) {
            const parent = node.parentNode;
            while (node.firstChild) parent.insertBefore(node.firstChild, node);
            parent.removeChild(node);
            article.dispatchEvent(new Event('input'));
            return;
          }
          node = node.parentNode;
        }
        status('No flag found in selection');
      }

      function exportHTML() {
        const clone = article.cloneNode(true);
        clone.querySelectorAll('[contenteditable]').forEach(el => el.removeAttribute('contenteditable'));
        clone.querySelectorAll('[spellcheck]').forEach(el => el.removeAttribute('spellcheck'));
        navigator.clipboard.writeText(clone.outerHTML).then(() => status('HTML copied'));
      }

      function exportJSON() {
        const flags = [];
        article.querySelectorAll('mark.essay-flag, mark.essay-flag-comment').forEach(m => {
          flags.push({
            text: m.textContent,
            comment: m.dataset.comment || null,
            type: m.classList.contains('essay-flag-comment') ? 'comment' : 'flag'
          });
        });
        const data = { page: location.pathname, ts: new Date().toISOString(), flagCount: flags.length, flags };
        navigator.clipboard.writeText(JSON.stringify(data, null, 2)).then(() => {
          status('JSON copied (' + flags.length + ' flags)');
        });
      }

      function resetEdits() {
        if (!confirm('Discard all edits and flags? This cannot be undone.')) return;
        localStorage.removeItem(STORAGE_KEY);
        location.reload();
      }

      toolbar.addEventListener('click', e => {
        const btn = e.target.closest('button');
        if (!btn) return;
        const action = btn.dataset.action;
        if (action === 'flag') wrapSelection('essay-flag');
        else if (action === 'comment') {
          const note = prompt('Comment for this selection:');
          if (note && note.trim()) wrapSelection('essay-flag-comment', note.trim());
        } else if (action === 'unmark') unmarkSelection();
        else if (action === 'export') exportHTML();
        else if (action === 'json') exportJSON();
        else if (action === 'reset') resetEdits();
      });

      document.addEventListener('keydown', e => {
        if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key.toLowerCase() === 'f') {
          e.preventDefault();
          wrapSelection('essay-flag');
        }
      });

      status('Editor active — click any text to edit');
    })();
  </script>

