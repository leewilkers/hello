          { at: 6.77, notes: ['A4'], sustain: 5.4, level: 0.014, send: 0.62 },
          { at: 12.18, notes: ['G3', 'D4'], sustain: 8.2, level: 0.020, send: 0.48 }
        ]
      }
    ];

    function ensureAudio() {
      try {
        if (!audioCtx) {
          audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        }
        if (audioCtx.state === 'suspended') audioCtx.resume();
        return audioCtx;
      } catch (e) {
        return null;
      }
    }

    function getMaster(ctx) {
      if (ctx._bbMaster) return ctx._bbMaster;
      const master = ctx.createGain();
      master.gain.value = 0.72;
      master.connect(ctx.destination);
      ctx._bbMaster = master;
      return master;
    }

    function getReverb(ctx) {
      if (ctx._bbReverb) return ctx._bbReverb;
      const seconds = 8.0;
      const preDelay = 0.045;
      const sr = ctx.sampleRate;
      const len = Math.floor(sr * seconds);
      const preLen = Math.floor(sr * preDelay);
      const buffer = ctx.createBuffer(2, len, sr);
      for (let ch = 0; ch < 2; ch += 1) {
        const data = buffer.getChannelData(ch);
        const decayPower = ch === 0 ? 2.15 : 2.55;
        for (let i = 0; i < len; i += 1) {
          if (i < preLen) {
            data[i] = 0;
          } else {
            const pos = (i - preLen) / (len - preLen);
            data[i] = (Math.random() * 2 - 1) * Math.pow(1 - pos, decayPower);
          }
        }
      }

      const convolver = ctx.createConvolver();
      const damp = ctx.createBiquadFilter();
      convolver.buffer = buffer;
      damp.type = 'lowpass';
      damp.frequency.value = 1700;
      damp.Q.value = 0.45;
      convolver.connect(damp).connect(getMaster(ctx));
      ctx._bbReverb = convolver;
      return convolver;
    }

    function clearProgress() {
      if (progressTimer) {
        clearInterval(progressTimer);
        progressTimer = null;
      }
      root.querySelectorAll('.bb-card').forEach(function(card) {
        card.classList.remove('is-playing');
        card.style.setProperty('--bb-progress', '0%');
        const play = card.querySelector('[data-bb-play]');
        const loop = card.querySelector('[data-bb-loop]');
        const switchButton = card.querySelector('[data-bb-switch]');
        if (play) play.setAttribute('aria-pressed', 'false');
        if (loop) loop.setAttribute('aria-pressed', 'false');
        if (switchButton) switchButton.setAttribute('aria-pressed', 'false');
      });
    }

    function clearSwitchTimers() {
      switchTimers.forEach(function(timer) {
        clearTimeout(timer);
      });
      switchTimers = [];
      if (catFadeTimer) {
        clearTimeout(catFadeTimer);
        catFadeTimer = null;
      }
    }

    function flipThemeOnly() {
      const doc = document.documentElement;
      const goingDark = doc.getAttribute('data-theme') !== 'dark';
      doc.setAttribute('data-theme', goingDark ? 'dark' : 'light');
      if (dimmerButton) {
        dimmerButton.setAttribute('aria-pressed', goingDark ? 'true' : 'false');
      }
    }

    function playCatSwitchVisual() {
      if (reducedMotion || !catFrame || !catVideo) return;
      const goingDark = document.documentElement.getAttribute('data-theme') !== 'dark';
      const visualGoingDark = !goingDark;
      if (catFadeTimer) {
        clearTimeout(catFadeTimer);
        catFadeTimer = null;
      }
      catVideo.src = visualGoingDark ? CAT_VIDEO_FWD : CAT_VIDEO_REV;
      catVideo.currentTime = visualGoingDark ? 0 : (CAT_HIT_SECONDS_REV - CAT_HIT_SECONDS_FWD);
      catVideo.playbackRate = CAT_VIDEO_RATE;
      catFrame.style.setProperty('--cat-fade-ms', '180ms');
      catFrame.classList.add('is-playing');
      const playPromise = catVideo.play();
      if (playPromise && playPromise.catch) playPromise.catch(function() {});
      catFadeTimer = setTimeout(function() {
        catFadeTimer = null;
        catFrame.style.setProperty('--cat-fade-ms', '1050ms');
        catFrame.classList.remove('is-playing');
      }, 1700);
    }

    function runSwitchHit() {
      playCatSwitchVisual();
      switchTimers.push(setTimeout(flipThemeOnly, CAT_PRESS_TO_HIT_MS));
    }

    function scheduleSwitchHit() {
      runSwitchHit();
    }

    function rand(min, max) {
      return min + Math.random() * (max - min);
    }

    function pick(items) {
      return items[Math.floor(Math.random() * items.length)];
    }

    function clearOrganicTimer() {
      if (organicTimer) {
        clearTimeout(organicTimer);
        organicTimer = null;
      }
    }

    function setOrganicUI(active, label) {
      if (fieldButton) {
        fieldButton.setAttribute('aria-pressed', active ? 'true' : 'false');
        fieldButton.classList.toggle('is-active', active);
      }
      if (fieldStatus) {
        fieldStatus.textContent = label || (active ? 'organic field running' : 'organic loop idle');
      }
    }

    function stopAll() {
      if (loopTimer) {
        clearTimeout(loopTimer);
        loopTimer = null;
      }
      clearSwitchTimers();
      clearOrganicTimer();
      organicActive = false;
      setOrganicUI(false, 'organic loop idle');
      clearProgress();
      activeId = null;
      activeNodes.forEach(function(node) {
        try { node.stop(); } catch (e) {}
      });
      activeNodes = [];
    }

    function playPad(noteName, when, sustain, level, send) {
      const ctx = ensureAudio();
      const freq = NOTE_FREQ[noteName];
      if (!ctx || !freq) return;
      const reverb = getReverb(ctx);
      const master = getMaster(ctx);
      const duration = sustain || 7.5;
      const gainLevel = level || 0.052;
      const wet = send === undefined ? 0.58 : send;

      [-3, 3].forEach(function(detune, idx) {
        const carrier = ctx.createOscillator();
        const modulator = ctx.createOscillator();
        const modDepth = ctx.createGain();
        const gain = ctx.createGain();
        const warmth = ctx.createBiquadFilter();
        const panner = ctx.createStereoPanner();
        const sendGain = ctx.createGain();

        carrier.type = 'sine';
        carrier.frequency.value = freq;
        carrier.detune.value = detune;
        modulator.type = 'sine';
        modulator.frequency.value = freq;
        modulator.detune.value = detune;

        modDepth.gain.setValueAtTime(0.0001, when);
        modDepth.gain.exponentialRampToValueAtTime(freq * 0.42, when + 0.18);
        modDepth.gain.exponentialRampToValueAtTime(freq * 0.13, when + 1.8);
        modDepth.gain.exponentialRampToValueAtTime(0.0001, when + duration);
        modulator.connect(modDepth).connect(carrier.frequency);

        gain.gain.setValueAtTime(0.0001, when);
        gain.gain.exponentialRampToValueAtTime(gainLevel, when + 0.18);
        gain.gain.exponentialRampToValueAtTime(Math.max(0.0001, gainLevel * 0.18), when + 2.8);
        gain.gain.exponentialRampToValueAtTime(0.0001, when + duration);

        warmth.type = 'lowpass';
        warmth.frequency.value = 2550;
        warmth.Q.value = 0.55;
        panner.pan.value = idx === 0 ? -0.28 : 0.28;
        sendGain.gain.value = wet;

        carrier.connect(gain).connect(warmth).connect(panner).connect(master);
        panner.connect(sendGain).connect(reverb);

        modulator.start(when);
        carrier.start(when);
        modulator.stop(when + duration + 0.2);
        carrier.stop(when + duration + 0.2);
        activeNodes.push(modulator, carrier);
      });
    }

    function scheduleOrganicGesture() {
      if (!organicActive) return;
      const ctx = ensureAudio();
      if (!ctx) return;

      const gesture = pick(FIELD_GESTURES);
      const now = ctx.currentTime + 0.08;
      let lastAt = 0;
      setOrganicUI(true, 'organic field: ' + gesture.name);

      gesture.events.forEach(function(event) {
        const jitter = rand(-0.42, 0.52);
        const at = Math.max(0, event.at + jitter);
        lastAt = Math.max(lastAt, at + event.sustain);
        event.notes.forEach(function(note) {
          playPad(note, now + at, event.sustain + rand(-0.6, 1.2), event.level * rand(0.82, 1.08), event.send);
        });
      });

      const rest = rand(gesture.rest[0], gesture.rest[1]);
      organicTimer = setTimeout(scheduleOrganicGesture, Math.max(5, lastAt + rest) * 1000);
    }

    function toggleOrganicField() {
      if (organicActive) {
        stopAll();
        return;
      }
      stopAll();
      organicActive = true;
      activeId = 'organic-field';
      setOrganicUI(true, 'organic field: listening');
      scheduleOrganicGesture();
    }

    function getProgressionEvents(progression, cycleIndex) {
      if (progression.cycles && progression.cycles.length) {
        return progression.cycles[cycleIndex % progression.cycles.length];
      }
      if (progression.events && progression.events.length) {
        return progression.events;
      }
      const n = progression.notes;
      const finalNotes = progression.finalNotes || [n[1], n[0]];
      return [
        { at: 0.0, notes: [n[0]], sustain: 5.0, level: 0.044, send: 0.22 },
        { at: 1.15, notes: [n[2], n[3]], sustain: 7.6, level: 0.038, send: 0.62 },
        { at: 4.75, notes: [n[3]], sustain: 4.7, level: 0.036, send: 0.22 },
        { at: 5.90, notes: finalNotes, sustain: 7.8, level: 0.038, send: 0.62 }
      ];
    }

    function getProgressionDuration(progression, events) {
      if (progression.duration) return progression.duration;
      const end = events.reduce(function(max, event) {
        return Math.max(max, event.at + (event.sustain || 7.5));
      }, 0);
      return Math.max(12, end + 3.5);
    }

    function getSwitchHalfEvents(events, half) {
      const start = half === 1 ? SWITCH_HALF_SECONDS : 0;
      const end = start + SWITCH_HALF_SECONDS;
      return events.filter(function(event) {
        return event.at >= start && event.at < end;
      }).map(function(event) {
        const copy = Object.assign({}, event);
        copy.notes = event.notes.slice();
        copy.at = event.at - start;
        return copy;
      });
    }

    function scheduleProgression(progression, loop, cycleIndex, switchMode, switchHalf) {
      stopAll();
      const ctx = ensureAudio();
      if (!ctx) return;
      const now = ctx.currentTime + 0.07;
      const cycle = cycleIndex || 0;
      const sourceEvents = getProgressionEvents(progression, cycle);
      const events = switchMode ? getSwitchHalfEvents(sourceEvents, switchHalf || 0) : sourceEvents;
      const duration = switchMode ? SWITCH_HALF_SECONDS : getProgressionDuration(progression, events);
      const looseness = progression.looseness === undefined ? 0.22 : progression.looseness;

      events.forEach(function(event) {
        const eventLooseness = event.looseness === undefined ? looseness : event.looseness;
        const at = event.locked ? event.at : Math.max(0, event.at + rand(-eventLooseness, eventLooseness));
        const sustain = event.locked ? (event.sustain || 7.5) : Math.max(1.2, (event.sustain || 7.5) + rand(-0.45, 0.9));
        const level = event.locked ? (event.level || 0.026) : (event.level || 0.026) * rand(0.88, 1.06);
        event.notes.forEach(function(note) {
          playPad(note, now + at, sustain, level, event.send);
        });
      });

      activeId = progression.id;
      const card = root.querySelector('[data-progression-id="' + progression.id + '"]');
      if (card) {
        card.classList.add('is-playing');
        const control = card.querySelector(switchMode ? '[data-bb-switch]' : (loop ? '[data-bb-loop]' : '[data-bb-play]'));
        if (control) control.setAttribute('aria-pressed', 'true');
      }

      if (switchMode) {
        scheduleSwitchHit();
      }

      const startedAt = Date.now();
      progressTimer = setInterval(function() {
        const pct = Math.min(100, ((Date.now() - startedAt) / (duration * 1000)) * 100);
        if (card) card.style.setProperty('--bb-progress', pct.toFixed(2) + '%');
      }, 80);

      loopTimer = setTimeout(function() {
        loopTimer = null;
        clearProgress();
        if (loop && activeId === progression.id) {
          scheduleProgression(progression, true, cycle + 1);
        } else {
          activeId = null;
        }
      }, duration * 1000);
    }

    function render() {
      grid.innerHTML = PROGRESSIONS.map(function(progression, index) {
        const finalNotes = progression.finalNotes || [progression.notes[1], progression.notes[0]];
        const notePath = progression.path || (progression.notes[0] + ' -> ' + progression.notes[2] + '+' + progression.notes[3] + ' / ' + progression.notes[3] + ' -> ' + finalNotes.join('+'));
        return '' +
          '<section class="bb-card" data-progression-id="' + progression.id + '">' +
            '<div class="bb-card-progress" aria-hidden="true"></div>' +
            '<div class="bb-card-top">' +
              '<span class="bb-index">' + String(index + 1).padStart(2, '0') + '</span>' +
              '<h2>' + progression.name + '</h2>' +
            '</div>' +
            '<p class="bb-notes">' + progression.notes.join('  ') + '</p>' +
            '<p class="bb-path">' + notePath + '</p>' +
            '<p class="bb-mood">' + progression.mood + '</p>' +
            '<div class="bb-actions">' +
              '<button type="button" data-bb-play="' + progression.id + '" aria-pressed="false">play</button>' +
              '<button type="button" data-bb-switch="' + progression.id + '" aria-pressed="false">switch</button>' +
            '</div>' +
          '</section>';
      }).join('');
    }

    render();

    grid.addEventListener('click', function(event) {
      const play = event.target.closest('[data-bb-play]');
      const loop = event.target.closest('[data-bb-loop]');
      const switchButton = event.target.closest('[data-bb-switch]');
      const button = play || loop || switchButton;
      if (!button) return;
      const id = button.getAttribute(play ? 'data-bb-play' : (loop ? 'data-bb-loop' : 'data-bb-switch'));
      const progression = PROGRESSIONS.find(function(item) { return item.id === id; });
      if (progression) {
        const isSwitch = Boolean(switchButton);
        const half = isSwitch ? (switchHalfById[id] || 0) : 0;
        scheduleProgression(progression, Boolean(loop), 0, isSwitch, half);
        if (isSwitch) {
          switchHalfById[id] = half === 0 ? 1 : 0;
        }
      }
    });

    if (stopButton) {
      stopButton.addEventListener('click', stopAll);
    }

    if (fieldButton) {
      fieldButton.addEventListener('click', toggleOrganicField);
    }

    window.addEventListener('pagehide', stopAll);
  })();
</script>
