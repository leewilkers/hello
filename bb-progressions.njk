    function uniqueNotes(events) {
      const seen = {};
      return events.reduce(function(notes, event) {
        event.notes.forEach(function(note) {
          if (!seen[note]) {
            seen[note] = true;
            notes.push(note);
          }
        });
        return notes;
      }, []);
    }

    function mainEvent(at, notes, sustain, level, send) {
      return { at: at, notes: notes, sustain: sustain, level: level, send: send, locked: true };
