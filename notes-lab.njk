      paragraphs: [
        'Eridanus, <span class="note-name">the River</span>, is the sixth-largest constellation by area — a long sinuous river that winds south from <span class="note-name">Orion</span>’s foot to end at <span class="note-star">Achernar</span>. In Greek myth, it is the river into which <span class="note-person">Phaeton</span> fell after losing the reins of the <span class="note-star">Sun</span>’s chariot.',
        '<span class="note-star">Epsilon Eridani</span> is a young Sun-like star, only 10.5 light-years away and among the closest visible to the naked eye. It hosts a confirmed Jupiter-mass planet and two dust rings that echo our own asteroid belt and Kuiper belt.',
        'On 8 April 1960, <span class="note-person">Frank Drake</span> aimed the 26-metre <span class="note-tool">Tatel radio telescope</span> at <span class="note-star">Tau Ceti</span> and Epsilon Eridani and listened — the first deliberate search for radio signals from another star, called Project Ozma.'
      ]
    }
  };

  const INITIAL_STYLES = {
    'note-star': {
      label: '.note-star · cream / celestial',
      color: '#fffcf0',
      layers: [
        { blur: 0.4, opacity: 55 },
        { blur: 0.93, opacity: 58 },
        { blur: 1.85, opacity: 26 }
      ]
    },
    'note-name': {
      label: '.note-name · teal / constellations only',
      color: '#3aa99f',
      layers: [
        { blur: 0.5, opacity: 40 },
        { blur: 1.2, opacity: 20 }
      ]
    },
    'note-tool': {
      label: '.note-tool · brass / instruments',
      color: '#d4a017',
      layers: [
        { blur: 0.69, opacity: 46 },
        { blur: 1.35, opacity: 22 }
      ]
    },
    'note-person': {
      label: '.note-person · dusty lilac / persons + mythic',
      color: '#b794c7',
      layers: [
        { blur: 0.5, opacity: 40 },
        { blur: 1.2, opacity: 20 }
      ]
    }
  };

  let records = loadRecords();
  let styles = loadStyles();
  let activeId = Object.keys(records)[0];

  function loadRecords() {
    try { const stored = localStorage.getItem(STORAGE_RECORDS); if (stored) return JSON.parse(stored); } catch (e) {}
    return JSON.parse(JSON.stringify(INITIAL_RECORDS));
  }
  function loadStyles() {
    try { const stored = localStorage.getItem(STORAGE_STYLES); if (stored) return JSON.parse(stored); } catch (e) {}
    return JSON.parse(JSON.stringify(INITIAL_STYLES));
  }
  function saveRecords() { localStorage.setItem(STORAGE_RECORDS, JSON.stringify(records)); }
  function saveStyles() { localStorage.setItem(STORAGE_STYLES, JSON.stringify(styles)); }

  // ===== Reading-time math (mirrors base.njk readingMs + cycle constants) =====
  const READ_WPM_CYCLE = 250;
  const READ_BUFFER = 1.3;
  const READ_FLOOR_MS = 4000;
  const READ_CEILING_MS = 22000;
  const CYCLE_TAIL_MS = 1500;
  function paragraphReadingMs(html) {
    const text = String(html || '').replace(/<[^>]+>/g, ' ');
    const words = text.trim().split(/\s+/).filter(Boolean).length;
    if (!words) return { words: 0, ms: READ_FLOOR_MS };
    const ms = (words / READ_WPM_CYCLE) * 60000 * READ_BUFFER;
    return { words, ms: Math.min(READ_CEILING_MS, Math.max(READ_FLOOR_MS, Math.round(ms))) };
  }
  function fmtMs(ms) { return (ms / 1000).toFixed(1) + 's'; }

  // ===== DOM helpers (no innerHTML) =====
  function el(tag, attrs, children) {
    const node = document.createElement(tag);
    if (attrs) for (const k in attrs) {
      if (k === 'class') node.className = attrs[k];
      else if (k === 'text') node.textContent = attrs[k];
      else if (k === 'dataset') Object.assign(node.dataset, attrs[k]);
      else if (k.startsWith('on')) node.addEventListener(k.slice(2), attrs[k]);
      else node.setAttribute(k, attrs[k]);
    }
    if (children) (Array.isArray(children) ? children : [children]).forEach(c => {
      if (c == null) return;
      node.appendChild(typeof c === 'string' ? document.createTextNode(c) : c);
    });
    return node;
  }

  // Render Lee's typed HTML (which contains his own intentional <span> markup)
  // into the preview pane via DOMParser — sanitized of scripts at parse time
  // (DOMParser does not execute), and stripped to body children before insertion.
  function renderHtmlInto(target, html) {
    const doc = new DOMParser().parseFromString('<!doctype html><html><body>' + html + '</body></html>', 'text/html');
    // Strip any script/style nodes for safety even though this is local-only.
    doc.querySelectorAll('script, style, iframe, object, embed, link').forEach(n => n.remove());
    target.replaceChildren(...doc.body.childNodes);
  }

  // Live CSS injection
  const liveStyleEl = document.createElement('style');
  liveStyleEl.id = 'notes-lab-live-styles';
  document.head.appendChild(liveStyleEl);

  function buildLiveCss() {
    let css = '';
    for (const cls in styles) {
      const def = styles[cls];
      const shadow = def.layers.map(L =>
        `0 0 ${L.blur}rem color-mix(in srgb, ${def.color} ${L.opacity}%, transparent)`
      ).join(', ');
      css += `.notes-lab-preview .${cls} { color: ${def.color}; text-shadow: ${shadow}; }\n`;
    }
    return css;
  }
  function applyLiveStyles() { liveStyleEl.textContent = buildLiveCss(); }

  // ===== Render =====
  function renderRecordList() {
    const list = document.querySelector('[data-record-list]');
    list.replaceChildren();
    for (const id in records) {
      const btn = el('button', {
        type: 'button',
        class: 'notes-lab-record-btn' + (id === activeId ? ' is-active' : ''),
        text: id,
        onclick: () => { activeId = id; render(); }
      });
      list.appendChild(el('li', null, btn));
    }
  }

  function renderEditor() {
    const editor = document.querySelector('[data-editor]');
    editor.replaceChildren();
    if (!activeId || !records[activeId]) {
      editor.appendChild(el('p', { class: 'notes-lab-empty', text: 'pick a record on the left' }));
      return;
    }
    const rec = records[activeId];
    const totalBadge = el('div', { class: 'notes-lab-total-badge' });
    function updateTotal() {
      const sum = rec.paragraphs.reduce((acc, p) => acc + paragraphReadingMs(p).ms, 0);
      const total = sum + CYCLE_TAIL_MS;
      totalBadge.textContent = 'cycle dwell: ' + fmtMs(total) + ' (' + rec.paragraphs.length + ' paragraphs + 1.5s tail)';
    }
    updateTotal();
    editor.appendChild(buildMeta(rec, totalBadge));
    rec.paragraphs.forEach((para, idx) => editor.appendChild(buildParagraphEditor(rec, idx, updateTotal)));
  }

  function buildMeta(rec, totalBadge) {
    const wrap = el('div', { class: 'notes-lab-meta-wrap' });
    const meta = el('div', { class: 'notes-lab-meta' });
    [['title', 'title'], ['id', 'id'], ['href', 'href']].forEach(([key, label]) => {
      const id = 'nl-' + key;
      meta.appendChild(el('label', { for: id, text: label }));
      const input = el('input', {
        id, type: 'text', value: rec[key] || '',
        oninput: (e) => { rec[key] = e.target.value; saveRecords(); }
      });
      meta.appendChild(input);
    });
    wrap.appendChild(meta);
    wrap.appendChild(totalBadge);
    return wrap;
  }

  function buildParagraphEditor(rec, idx, updateTotal) {
    const wrap = el('div', { class: 'notes-lab-paragraph' });

    const head = el('div', { class: 'notes-lab-paragraph-head' });
    const labelGroup = el('span', { class: 'notes-lab-paragraph-label-group' });
    labelGroup.appendChild(el('span', { class: 'notes-lab-paragraph-label', text: 'paragraph ' + (idx + 1) }));
    const badge = el('span', { class: 'notes-lab-reading-badge' });
    labelGroup.appendChild(badge);
    head.appendChild(labelGroup);
    function updateBadge(html) {
      const { words, ms } = paragraphReadingMs(html);
      badge.textContent = words + ' words · ' + fmtMs(ms) + ' (250 wpm × 1.3)';
      badge.classList.toggle('is-floor', ms === READ_FLOOR_MS);
      badge.classList.toggle('is-ceiling', ms === READ_CEILING_MS);
      if (updateTotal) updateTotal();
    }

    const chips = el('div', { class: 'notes-lab-tag-chips' });
    [
      { tag: 'note-star', label: '+star' },
      { tag: 'note-name', label: '+name' },
      { tag: 'note-tool', label: '+tool' },
      { tag: 'note-person', label: '+person' },
      { tag: 'unwrap', label: '× unwrap' }
    ].forEach(({ tag, label }) => {
      chips.appendChild(el('button', {
        type: 'button',
        class: 'notes-lab-tag-chip',
        dataset: { tag },
        text: label,
        onclick: () => applyTag(rec, idx, tag)
      }));
    });
    head.appendChild(chips);
    wrap.appendChild(head);

    const split = el('div', { class: 'notes-lab-split' });
    const ta = el('textarea', { class: 'notes-lab-textarea', dataset: { paraIdx: String(idx) } });
    ta.value = rec.paragraphs[idx];
    const preview = el('div', { class: 'notes-lab-preview' });
    renderHtmlInto(preview, ta.value);
    updateBadge(ta.value);
    ta.addEventListener('input', () => {
      rec.paragraphs[idx] = ta.value;
      renderHtmlInto(preview, ta.value);
      updateBadge(ta.value);
      saveRecords();
    });
    split.appendChild(ta);
    split.appendChild(preview);
    wrap.appendChild(split);
    return wrap;
  }

  function applyTag(rec, idx, tag) {
    const ta = document.querySelector('textarea.notes-lab-textarea[data-para-idx="' + idx + '"]');
    if (!ta) return;
    const start = ta.selectionStart;
    const end = ta.selectionEnd;
    const value = ta.value;
    if (tag === 'unwrap') {
      const before = value.slice(0, start);
      const selected = value.slice(start, end);
      const after = value.slice(end);
      const stripped = selected.replace(/<span class="note-(?:star|name|tool|person)">([\s\S]*?)<\/span>/g, '$1');
      ta.value = before + stripped + after;
      rec.paragraphs[idx] = ta.value;
      ta.dispatchEvent(new Event('input'));
      return;
    }
    if (start === end) { status('select some text first, then click a chip'); return; }
    const selected = value.slice(start, end);
    const wrapped = '<span class="' + tag + '">' + selected + '</span>';
    const newVal = value.slice(0, start) + wrapped + value.slice(end);
    ta.value = newVal;
    rec.paragraphs[idx] = newVal;
    ta.dispatchEvent(new Event('input'));
    ta.focus();
    ta.setSelectionRange(start, start + wrapped.length);
  }

  function renderStyles() {
    const grid = document.querySelector('[data-style-grid]');
    grid.replaceChildren();
    for (const cls in styles) grid.appendChild(buildStyleCard(cls));
    applyLiveStyles();
  }

  function buildStyleCard(cls) {
    const def = styles[cls];
    const card = el('div', { class: 'notes-lab-style-card' });

    const head = el('div', { class: 'notes-lab-style-card-head' });
    head.appendChild(el('span', { class: 'notes-lab-style-card-title', text: def.label }));
    const sample = el('span', { class: 'notes-lab-style-card-sample notes-lab-preview' });
    sample.appendChild(el('span', { class: cls, text: 'Aa' }));
    head.appendChild(sample);
    card.appendChild(head);

    // Color
    const colorRow = el('div', { class: 'notes-lab-style-row' });
    colorRow.appendChild(el('label', { text: 'color' }));
    const colorInput = el('input', { type: 'color', value: def.color });
    const colorOut = el('output', { text: def.color });
    colorInput.addEventListener('input', () => {
      def.color = colorInput.value;
      colorOut.textContent = colorInput.value;
      saveStyles(); applyLiveStyles();
    });
    colorRow.appendChild(colorInput);
    colorRow.appendChild(colorOut);
    card.appendChild(colorRow);

    // Halo layer rows
    def.layers.forEach((layer, lidx) => {
      const blurRow = el('div', { class: 'notes-lab-style-row' });
      blurRow.appendChild(el('label', { text: 'blur ' + (lidx + 1) }));
      const blurInput = el('input', { type: 'range', min: '0', max: '3', step: '0.05', value: String(layer.blur) });
      const blurOut = el('output', { text: layer.blur.toFixed(2) + 'rem' });
      blurInput.addEventListener('input', () => {
        layer.blur = parseFloat(blurInput.value);
        blurOut.textContent = layer.blur.toFixed(2) + 'rem';
        saveStyles(); applyLiveStyles();
      });
      blurRow.appendChild(blurInput);
      blurRow.appendChild(blurOut);
      card.appendChild(blurRow);

      const opRow = el('div', { class: 'notes-lab-style-row' });
      opRow.appendChild(el('label', { text: 'opacity ' + (lidx + 1) }));
      const opInput = el('input', { type: 'range', min: '0', max: '100', step: '1', value: String(layer.opacity) });
      const opOut = el('output', { text: layer.opacity + '%' });
      opInput.addEventListener('input', () => {
        layer.opacity = parseInt(opInput.value, 10);
        opOut.textContent = layer.opacity + '%';
        saveStyles(); applyLiveStyles();
      });
      opRow.appendChild(opInput);
      opRow.appendChild(opOut);
      card.appendChild(opRow);
    });

    return card;
  }

  // ===== Exports =====
  function exportRecords() {
    copy(JSON.stringify(records, null, 2), 'records JSON copied to clipboard');
  }
  function exportCss() {
    let css = '/* === Notes-lab CSS overrides — paste into css/style.css === */\n\n';
    for (const cls in styles) {
      const def = styles[cls];
      const shadow = def.layers.map(L =>
        `\n    0 0 ${L.blur}rem color-mix(in srgb, ${def.color} ${L.opacity}%, transparent)`
      ).join(',');
      css += `.pretty-constellation-note-paragraph .${cls},\n.constellation-intro-paragraph .${cls} {\n  color: ${def.color};\n  text-shadow:${shadow};\n}\n\n`;
    }
    copy(css, 'CSS overrides copied to clipboard');
  }
  function copy(text, msg) {
    navigator.clipboard.writeText(text).then(() => status(msg), () => status('clipboard write failed'));
    console.log(text);
  }

  function resetRecords() {
    if (!confirm('reset records to current shipped state? unsaved edits will be lost.')) return;
    records = JSON.parse(JSON.stringify(INITIAL_RECORDS));
    saveRecords(); render(); status('records reset');
  }
  function resetStyles() {
    if (!confirm('reset class styles to current shipped values?')) return;
    styles = JSON.parse(JSON.stringify(INITIAL_STYLES));
    saveStyles(); renderStyles(); status('styles reset');
  }

  let statusTimer = null;
  function status(msg) {
    const elt = document.querySelector('[data-status]');
    elt.textContent = msg;
    elt.hidden = false;
    if (statusTimer) clearTimeout(statusTimer);
    statusTimer = setTimeout(() => { elt.hidden = true; }, 2400);
  }

  function render() { renderRecordList(); renderEditor(); }

  document.querySelector('[data-action="export-records"]').addEventListener('click', exportRecords);
  document.querySelector('[data-action="export-css"]').addEventListener('click', exportCss);
  document.querySelector('[data-action="reset-records"]').addEventListener('click', resetRecords);
  document.querySelector('[data-action="reset-styles"]').addEventListener('click', resetStyles);

  render();
  renderStyles();

  // ===== Auto-fetch live style.css and parse .note-* values =====
  // Replaces INITIAL_STYLES in-place so reset-to-defaults uses live values
  // instead of the hardcoded snapshot. If localStorage has no user-edited
  // styles yet, also updates the working `styles` and re-renders.
  // Silent on failure — the snapshot is the fallback.
  function evalCalcRem(expr) {
    // Handles "0.4rem" or "calc(0.5rem + var(--delay-mix, 0.72) * 0.6rem)".
    const plain = expr.match(/^\s*([\d.]+)rem\s*$/);
    if (plain) return parseFloat(plain[1]);
    const calc = expr.match(/calc\(\s*([\d.]+)rem\s*\+\s*var\(--delay-mix,\s*([\d.]+)\)\s*\*\s*([\d.]+)rem\s*\)/);
    if (calc) {
      const base = parseFloat(calc[1]);
      const mix = parseFloat(calc[2]);
      const factor = parseFloat(calc[3]);
      return base + mix * factor;
    }
    return null;
  }
  function parseClassRule(css, cls) {
    // Match the exact selector pair we ship.
    const re = new RegExp(
      '\\.pretty-constellation-note-paragraph \\.' + cls + ',\\s*' +
      '\\.constellation-intro-paragraph \\.' + cls + '\\s*\\{([\\s\\S]*?)\\}',
      'm'
    );
    const block = css.match(re);
    if (!block) return null;
    const body = block[1];
    // Color: grab first hex anywhere in `color: ...;` (handles plain hex and color-mix forms).
    const colorLine = body.match(/color:\s*([^;]+);/);
    if (!colorLine) return null;
    const hexMatch = colorLine[1].match(/#([0-9a-fA-F]{6})/);
    if (!hexMatch) return null;
    const color = '#' + hexMatch[1].toLowerCase();
    // text-shadow: capture the whole value, split into top-level commas, parse each layer.
    const shadowLine = body.match(/text-shadow:\s*([\s\S]+?);/);
    if (!shadowLine) return null;
    const layers = [];
    // Split by comma at paren-depth 0.
    const value = shadowLine[1];
    let depth = 0, start = 0;
    for (let i = 0; i < value.length; i++) {
      const c = value[i];
      if (c === '(') depth++;
      else if (c === ')') depth--;
      else if (c === ',' && depth === 0) {
        layers.push(value.slice(start, i).trim());
        start = i + 1;
      }
    }
    layers.push(value.slice(start).trim());
    const parsedLayers = [];
    for (const layer of layers) {
      // Pattern: "0 0 <blur> color-mix(in srgb, #xxx N%, transparent)"
      const m = layer.match(/0\s+0\s+(.+?)\s+color-mix\([^)]*?#[0-9a-fA-F]+\s+(\d+)%/);
      if (!m) continue;
      const blur = evalCalcRem(m[1]);
      const opacity = parseInt(m[2], 10);
      if (blur == null) continue;
      parsedLayers.push({ blur: parseFloat(blur.toFixed(3)), opacity });
    }
    if (!parsedLayers.length) return null;
    return { color, layers: parsedLayers };
  }
  async function autoFetchLiveCss() {
    try {
      const res = await fetch('/css/style.css', { cache: 'no-store' });
      if (!res.ok) throw new Error('fetch failed: ' + res.status);
      const css = await res.text();
      const fetched = {};
      for (const cls of ['note-star', 'note-name', 'note-tool', 'note-person']) {
        const parsed = parseClassRule(css, cls);
        if (parsed) fetched[cls] = parsed;
      }
      if (!Object.keys(fetched).length) throw new Error('no rules parsed');
      // Replace INITIAL_STYLES values (preserve labels).
      for (const cls in fetched) {
        if (INITIAL_STYLES[cls]) {
          INITIAL_STYLES[cls].color = fetched[cls].color;
          INITIAL_STYLES[cls].layers = fetched[cls].layers;
        }
      }
      // If user hasn't edited styles in this session (no localStorage), refresh working styles too.
      if (!localStorage.getItem(STORAGE_STYLES)) {
        styles = JSON.parse(JSON.stringify(INITIAL_STYLES));
        renderStyles();
      }
      status('synced styles from live css/style.css');
    } catch (err) {
      console.warn('notes-lab: auto-fetch failed, using snapshot defaults', err);
      // No status message — silent fallback.
    }
  }
  autoFetchLiveCss();
})();
</script>
