{% macro open_link(variant, theme) -%}
/type/bricolage/?palette={{ variant.query }}&amp;theme={{ theme }}
{%- endmacro %}

{% macro specimen(variant, mode, theme) %}
  <article class="brico-specimen brico-specimen--{{ theme }}" style="--sample-bg: {{ mode.bg }}; --sample-ink: {{ mode.ink }}; --sample-body: {{ mode.body }}; --sample-muted: {{ mode.muted }}; --sample-rule: {{ mode.rule }}; --sample-label: {{ mode.label }}; --sample-link: {{ mode.link }}; --sample-trail: {{ mode.trail }}; --sample-subtitle: {{ mode.subtitle }}; --sample-aside: {{ mode.aside }}; --sample-surface: {{ mode.surface }};">
    <p class="brico-specimen-mode">{{ theme }}</p>
    <h3>Lee Wilkers</h3>
    <p class="brico-specimen-subtitle">Research, strategy, and sensemaking for health, science, and public-interest work.</p>
    <div class="brico-specimen-body">
      <p>As an independent consultant, I help people and organizations make sense of evidence, context, and competing priorities.</p>
      <p>I&rsquo;ve spent 10+ years in and around global health ethics, after earlier work in humanitarian relief, ecology, and other formative detours.</p>
      <p class="brico-specimen-aside">Social scientist by training. Generalist by practice.</p>
    </div>
    <section class="brico-mini-section">
      <h4>Most recently</h4>
      <ul>
        <li><strong>Focus Area on Compassion &amp; Ethics</strong><br>The Task Force for Global Health</li>
        <li><strong>Human Engagement Learning Platform</strong><br>Rollins School of Public Health, Emory University</li>
      </ul>
    </section>
    <p class="brico-specimen-aside">Raised in the DC area. Based in Atlanta.</p>
    <div class="brico-specimen-trail" aria-hidden="true"></div>
    <section class="brico-mini-pages">
      <h4>Pages</h4>
      <p><a href="#">Shelf</a>: things on my desk, informing current work and thinking.</p>
      <p><a href="#">Contact</a>: lee@leewilkers.com</p>
    </section>
  </article>
{% endmacro %}

<article class="brico-colors" id="main">
  <header class="brico-colors-head">
    <p class="brico-colors-kicker">Brico color lab</p>
    <h1>Ink, paper, prose, code, with a little living edge.</h1>
    <p>Preview-only color directions for the Brico homepage. The full-page links open the real Brico route with the palette applied; the default homepage stays unchanged until one earns it.</p>
  </header>

  <section class="brico-green-studies" id="green-studies" aria-labelledby="green-studies-title">
    <div class="brico-green-head">
      <p class="brico-colors-kicker">Green studies</p>
      <h2 id="green-studies-title">Same palette, different living edge.</h2>
      <p>These hold Sand Moss Blue constant and vary only the rabbit/trail green. The useful range is narrow: too yellow gets sickly; too saturated starts looking like a UI success state.</p>
    </div>

    <div class="brico-green-grid" aria-label="Green trail color studies">
      {% for green in greenStudies %}
      <article class="brico-green-card" style="--green-study: {{ green.hex }}">
        <div class="brico-green-surface brico-green-surface--light">
          <span class="brico-green-trail" aria-hidden="true"></span>
        </div>
        <div class="brico-green-surface brico-green-surface--dark">
          <span class="brico-green-trail" aria-hidden="true"></span>
        </div>
        <div class="brico-green-meta">
          <h3>{{ green.name }}</h3>
          <p><span>{{ green.hex }}</span>{{ green.note }}</p>
        </div>
      </article>
      {% endfor %}
    </div>
  </section>

  <div class="brico-color-stack" aria-label="Brico color candidates">
    {% for variant in variants %}
    <section class="brico-color-card{% if variant.selected %} is-selected{% endif %}" id="{{ variant.id }}">
      <div class="brico-color-card-copy">
        <p class="brico-color-card-kicker">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}{% if variant.selected %} / selected{% endif %}</p>
        <h2>{{ variant.name }}</h2>
        <p>{{ variant.note }}</p>
        <div class="brico-swatches" aria-hidden="true">
          {% for swatch in variant.swatches %}
          <span style="background: {{ swatch }}"></span>
          {% endfor %}
        </div>
        <p class="brico-open-links">
          <a href="{{ open_link(variant, "light") }}">open light</a>
          <a href="{{ open_link(variant, "dark") }}">open dark</a>
        </p>
      </div>
      <div class="brico-specimen-pair">
        {{ specimen(variant, variant.light, "light") }}
        {{ specimen(variant, variant.dark, "dark") }}
      </div>
    </section>
    {% endfor %}
  </div>
</article>
