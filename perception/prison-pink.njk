<script>
(function () {
  /* The reveal: flip the page background from Baker-Miller pink to neutral
   * mid-gray. The previously-staring user's red-channel cells, fatigued from
   * the pink, paint a cyan-green afterimage onto the gray field. The hidden
   * "gray-stage" prose fades in to name what they're seeing.
   *
   * The reveal is user-triggered (the CTA button) rather than timer-driven,
   * so the reader controls when they want to see the trick. A soft auto-cue
   * appears after 25s in case the reader is lost. */

  /* the live exposure clock: ticks while the reader is on the pink stage;
   * freezes the second the reveal fires (because exposure-to-pink has ended).
   * the gesture is dosimeter / clinical observation log / paint procurement spec —
   * the reader can watch their own "dose" accrue and then become an object in the
   * archive once the experiment ends. */
  const startedAt = Date.now();
  const clockEl = document.querySelector('[data-pp-exposure-clock]');
  let frozen = false;
  function fmt (ms) {
    const s = Math.floor(ms / 1000);
    return String(Math.floor(s / 60)).padStart(2, '0') + ':' + String(s % 60).padStart(2, '0');
  }
  function tick () {
    if (frozen || !clockEl) return;
    clockEl.textContent = fmt(Date.now() - startedAt);
  }
  tick();
  const tickId = setInterval(tick, 1000);

  function reveal () {
    if (document.body.classList.contains('is-gray')) return;
    document.documentElement.classList.add('is-gray');
    document.body.classList.add('is-gray');
    /* freeze the exposure clock — the dose is whatever the reader chose to take */
    frozen = true;
    clearInterval(tickId);
    /* the new spec-sheet row appears: the reader has just produced a datum */
    const afterimageRow = document.querySelector('[data-pp-afterimage]');
    if (afterimageRow) afterimageRow.removeAttribute('hidden');
    const grayProse = document.querySelector('.pp-prose-gray');
    if (grayProse) {
      grayProse.removeAttribute('hidden');
      grayProse.style.opacity = '0';
      requestAnimationFrame(() => {
        grayProse.style.transition = 'opacity 1.4s ease';
        grayProse.style.opacity = '1';
      });
    }
    /* scroll the freshly-revealed prose into view, not abruptly */
    if (grayProse) {
      setTimeout(() => grayProse.scrollIntoView({ behavior: 'smooth', block: 'center' }), 200);
    }
  }

  const btn = document.querySelector('[data-pp-reveal]');
  if (btn) btn.addEventListener('click', reveal);

  /* gentle nudge: if the reader is still on the pink stage after ~25s,
   * pulse the reveal button so they know it's an actionable affordance.
   * Many readers won't realize the page has a trick. */
  setTimeout(() => {
    if (document.body.classList.contains('is-gray')) return;
    if (!btn) return;
    btn.style.transition = 'opacity 0.6s ease';
    let on = true;
    const id = setInterval(() => {
      if (document.body.classList.contains('is-gray')) { clearInterval(id); return; }
      btn.style.opacity = on ? '0.55' : '1';
      on = !on;
    }, 700);
  }, 25000);
})();
</script>
