<script>
(function(){
  const stage = document.querySelector('[data-tm-stage]');
  if (!stage) return;
  stage.querySelectorAll('.tm-node').forEach(node => {
    const id = node.getAttribute('data-node');
    const url = node.getAttribute('data-url');
    const enter = () => stage.setAttribute('data-hover', id);
    const leave = () => { if (stage.getAttribute('data-hover') === id) stage.removeAttribute('data-hover'); };
    node.addEventListener('mouseenter', enter);
    node.addEventListener('mouseleave', leave);
    node.addEventListener('focus', enter);
    node.addEventListener('blur', leave);
    node.addEventListener('click', () => { if (url) location.href = url; });
    node.addEventListener('keydown', (e) => { if ((e.key === 'Enter' || e.key === ' ') && url){ e.preventDefault(); location.href = url; } });
  });
})();
</script>
