      <path class="tm-mycelium tm-mycelium-fine" d="M 670 680 Q 696 690 720 696"/>
      <path class="tm-mycelium tm-mycelium-fine" d="M 410 640 Q 392 658 374 668"/>
      <path class="tm-mycelium tm-mycelium-fine" d="M 540 642 Q 558 656 578 666"/>

      <circle class="tm-mycelium-node" cx="320" cy="656" r="0.9"/>
      <circle class="tm-mycelium-node" cx="614" cy="656" r="0.9"/>
