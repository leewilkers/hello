    {# water — arc from stream into stacks #}
    <path class="tm-river" data-related="stream stacks" d="M 818 590 Q 660 596 492 590"/>

    {# === nodes === #}
    <g class="tm-node" data-node="consulting" data-url="/consulting/" tabindex="0"
