{# V5 — after Alexander. V4 palette + V2 curved geometry, low-amplitude tremor on tree shapes,
   soil horizon breaking before the river, faint unlabeled mycelium beneath (inputs that aren't
   on the site). EB Garamond upright, no mono-caps subs, no koan. No physics — click + keyboard. #}

<style>
  main.page.page-site-tree{
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 1rem 0;
    /* no min-height — let the page size to its content so the site's nav + footer
       remain in their natural flow without pushing total past the viewport. */
  }

  /* title sits on the canvas, top-right of the tree — like an inset caption */
  .tm-title{
    position: absolute;
    top: 6%; right: 4%;
    max-width: 20em;
    text-align: right;
    z-index: 2;
    line-height: 1.4;
  }
  .tm-title-eyebrow{
    display: block;
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 0.74rem; font-weight: 600; letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink); line-height: 1;
    text-decoration: none;
    margin-bottom: 0.5rem;
  }
  .tm-title-def{
    font-family: "EB Garamond", "Source Serif 4", Georgia, serif;
    font-style: italic; font-size: 1.02rem; line-height: 1.45;
    color: color-mix(in srgb, var(--ink) 82%, transparent);
  }

  .tm-stage{
    position: relative;
    width: 100%; max-width: 1080px;
    /* cap stage so it never exceeds viewport-minus-chrome regardless of nav/footer height.
       14rem reserve covers typical site nav + footer + comfortable padding. */
    max-height: calc(100dvh - 18rem);
    aspect-ratio: 1000 / 720;
    margin: 0 auto;
    color: var(--ink);
    --tm-bark:   oklch(34% 0.065 42);
    --tm-canopy: oklch(48% 0.115 152);
    --tm-soil:   oklch(36% 0.06  45);
    --tm-water:  oklch(46% 0.115 228);
    --tm-paper:  var(--bg);
    --tm-hair:   oklch(32% 0.055 55);
  }
  [data-theme="dark"] .tm-stage{
    --tm-bark:   oklch(76% 0.055 55);
    --tm-canopy: oklch(78% 0.115 152);
    --tm-soil:   oklch(74% 0.05  50);
    --tm-water:  oklch(78% 0.12  225);
    --tm-paper:  var(--bg);
    --tm-hair:   oklch(78% 0.055 65);
  }
  .tm-stage svg{ display:block; width:100%; height:100%; overflow: visible; user-select: none; }

  /* tree parts — V2 curved geometry, V3's low-amplitude tremor */
  .tm-trunk{
    fill: var(--tm-bark); fill-opacity: 0.62;
    filter: url(#tm-tremor);
    transition: fill-opacity 280ms ease;
  }
  .tm-branch{
    fill: var(--tm-canopy); fill-opacity: 0.66;
    filter: url(#tm-tremor);
    transition: fill-opacity 280ms ease;
  }
  .tm-edge{ fill:none; stroke-linecap:round; }
  .tm-edge-bark{
    stroke: var(--tm-bark); stroke-width: 1.5; opacity: 0.36;
    filter: url(#tm-tremor);
    transition: opacity 280ms ease;
  }

  /* soil horizon — anchors the tree, breaks before the water */
  .tm-horizon{
    stroke: var(--tm-soil); stroke-width: 0.9; opacity: 0.35;
    fill:none;
    filter: url(#tm-tremor);
  }

  /* mycelium — unlabeled inputs that aren't on the site.
     Dashed strokes drift toward the trunk base (positive stroke-dashoffset = flow inward).
     Two cadences plus a few reverse strands, so the network reads as breathing, not pulsing. */
  .tm-mycelium{
    stroke: var(--tm-hair); fill: none;
    stroke-width: 0.7; stroke-linecap: round;
    opacity: 0.42;
    stroke-dasharray: 2 9;
    animation: tm-mycelium-flow 11s linear infinite;
    filter: url(#tm-tremor);
  }
  .tm-mycelium-fine{
    stroke-width: 0.5; opacity: 0.30;
    stroke-dasharray: 1 11;
    animation-duration: 16s;
  }
  .tm-mycelium-weave{
    stroke-width: 0.55; opacity: 0.34;
    stroke-dasharray: 1.5 14;
    animation-duration: 22s;
    animation-direction: reverse;
  }
  .tm-mycelium-node{ fill: var(--tm-hair); fill-opacity: 0.55; }
  .tm-twinkle{
    fill: var(--tm-hair);
    fill-opacity: 0.08;
    animation: tm-twinkle 4.6s ease-in-out infinite;
  }
  @keyframes tm-twinkle{
    0%, 100% { fill-opacity: 0.06; }
    50%      { fill-opacity: 0.55; }
  }
  @media (prefers-reduced-motion: reduce){
    .tm-twinkle{ animation: none; fill-opacity: 0.22; }
  }
  @keyframes tm-mycelium-flow{
    from { stroke-dashoffset: 0; }
    to   { stroke-dashoffset: 60; }
  }
  @media (prefers-reduced-motion: reduce){
    .tm-mycelium{ animation: none; stroke-dasharray: 0; opacity: 0.16; }
  }

  /* river — keeps the animated dashed flow */
  .tm-river{
    fill:none; stroke: var(--tm-water); stroke-linecap: round;
    stroke-width: 4; stroke-dasharray: 8 7;
    animation: tm-flow 2.6s linear infinite;
  }
  @keyframes tm-flow{ from { stroke-dashoffset: 0; } to { stroke-dashoffset: -22; } }
  @media (prefers-reduced-motion: reduce){ .tm-river { animation: none; } }

  /* hover-probe — dim unrelated, brighten related */
  .tm-stage[data-hover] [data-related]{ opacity: 0.18; fill-opacity: 0.18; }
  .tm-stage[data-hover="consulting"] [data-related~="consulting"],
  .tm-stage[data-hover="writing"]    [data-related~="writing"],
  .tm-stage[data-hover="stacks"]     [data-related~="stacks"],
  .tm-stage[data-hover="stream"]     [data-related~="stream"],
  .tm-stage[data-hover="about"]      [data-related~="about"]{ opacity: 1; fill-opacity: 0.9; }
  .tm-stage[data-hover="about"] .tm-edge-bark[data-related~="about"]{ opacity: 0.82; }
  .tm-stage[data-hover] .tm-node{ transition: opacity 280ms ease; }
  .tm-stage[data-hover="consulting"] .tm-node:not([data-node="consulting"]),
  .tm-stage[data-hover="writing"]    .tm-node:not([data-node="writing"]),
  .tm-stage[data-hover="stacks"]     .tm-node:not([data-node="stacks"]),
  .tm-stage[data-hover="stream"]     .tm-node:not([data-node="stream"]),
  .tm-stage[data-hover="about"]      .tm-node:not([data-node="about"]){ opacity: 0.42; }

  /* nodes */
  .tm-node{ cursor: pointer; }
  .tm-hit{ fill: transparent; }
  .tm-mark{
    fill: var(--tm-paper);
    stroke: var(--node-stroke, var(--ink));
    stroke-width: 1.4;
    transition: r 180ms ease, stroke-width 180ms ease;
  }
  .tm-node:hover .tm-mark, .tm-node:focus-visible .tm-mark{ r: 6; stroke-width: 1.6; }

  .tm-node-label{
    font-family: "EB Garamond", "Source Serif 4", Georgia, serif;
    font-size: 28px; font-weight: 400; font-style: normal;
    fill: var(--ink); pointer-events: none;
    transition: fill 200ms ease;
  }
  .tm-node:hover .tm-node-label, .tm-node:focus-visible .tm-node-label{ fill: var(--node-stroke); }

</style>

<div class="tm-stage" data-tm-stage>
