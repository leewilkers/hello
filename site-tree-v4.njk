{# V4 — variation on baseline: parchment-warm stage background, EB Garamond labels (not Source Serif),
   sub-labels dropped, koan dropped. Same geometry, same trunk/branch fills, same animated river.
   Pulls the page register from "design system" toward "book page". #}

<style>
  main.page.page-site-tree{ min-height: 100dvh; display: flex; flex-direction: column; padding: 1rem 0; }
  .st-header{ display:flex; align-items:baseline; gap: 0.9rem; padding: 0 0 0.9rem; margin: 0 0 0.6rem; border-bottom: 1px solid color-mix(in srgb, var(--ink) 12%, transparent); }
  .st-eyebrow{ font-family: "IBM Plex Mono", ui-monospace, monospace; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink); line-height: 1; text-decoration: none; }
  .st-variant{ font-family: "EB Garamond", "Source Serif 4", Georgia, serif; font-style: italic; font-size: 0.85rem; color: color-mix(in srgb, var(--ink) 55%, transparent); }

  .tm-stage{
    position: relative; width: 100%; max-width: 980px; max-height: 64dvh;
    aspect-ratio: 1000 / 720; margin: auto; color: var(--ink);
    /* warm parchment cast, very subtle */
    background: oklch(96% 0.018 80);
    border-radius: 2px;
    --tm-bark:   oklch(36% 0.06  45);
    --tm-canopy: oklch(40% 0.075 135);
    --tm-soil:   oklch(38% 0.055 45);
    --tm-water:  oklch(48% 0.115 228);
  }
  [data-theme="dark"] .tm-stage{
    background: oklch(22% 0.012 60);
    --tm-bark:   oklch(74% 0.05  55);
    --tm-canopy: oklch(76% 0.085 145);
    --tm-soil:   oklch(72% 0.05  50);
    --tm-water:  oklch(76% 0.12  225);
  }
  .tm-stage svg{ display:block; width:100%; height:100%; overflow: visible; user-select: none; }

  .tm-trunk{ fill: var(--tm-bark); fill-opacity: 0.82; transition: fill-opacity 280ms ease; }
  .tm-branch{ fill: var(--tm-canopy); fill-opacity: 0.85; transition: fill-opacity 280ms ease; }
  .tm-edge{ fill:none; stroke-linecap:round; }
  .tm-edge-bark{ stroke: var(--tm-bark); stroke-width: 1.6; opacity: 0.45; transition: opacity 280ms ease; }
  .tm-river{ fill:none; stroke: var(--tm-water); stroke-linecap: round; stroke-width: 4.5; stroke-dasharray: 9 7; animation: tm-flow 2.4s linear infinite; }
  @keyframes tm-flow{ from { stroke-dashoffset: 0; } to { stroke-dashoffset: -22; } }
  @media (prefers-reduced-motion: reduce){ .tm-river { animation: none; } }

  .tm-stage[data-hover] [data-related]{ opacity: 0.18; fill-opacity: 0.18; }
  .tm-stage[data-hover="consulting"] [data-related~="consulting"],
  .tm-stage[data-hover="writing"] [data-related~="writing"],
  .tm-stage[data-hover="stacks"] [data-related~="stacks"],
  .tm-stage[data-hover="stream"] [data-related~="stream"],
  .tm-stage[data-hover="about"] [data-related~="about"]{ opacity: 1; fill-opacity: 0.9; }
  .tm-stage[data-hover="about"] .tm-edge-bark[data-related~="about"]{ opacity: 0.82; }
  .tm-stage[data-hover] .tm-node{ transition: opacity 280ms ease; }
  .tm-stage[data-hover="consulting"] .tm-node:not([data-node="consulting"]),
  .tm-stage[data-hover="writing"] .tm-node:not([data-node="writing"]),
  .tm-stage[data-hover="stacks"] .tm-node:not([data-node="stacks"]),
  .tm-stage[data-hover="stream"] .tm-node:not([data-node="stream"]),
  .tm-stage[data-hover="about"] .tm-node:not([data-node="about"]){ opacity: 0.42; }

  .tm-node{ cursor: pointer; }
  .tm-hit{ fill: transparent; }
  .tm-mark{ fill: oklch(96% 0.018 80); stroke: var(--node-stroke, var(--ink)); stroke-width: 1.4; transition: r 180ms ease, stroke-width 180ms ease; }
  [data-theme="dark"] .tm-stage .tm-mark{ fill: oklch(22% 0.012 60); }
  .tm-node:hover .tm-mark, .tm-node:focus-visible .tm-mark{ r: 6; stroke-width: 1.6; }

  /* EB Garamond, no italic, no caps-mono subs */
  .tm-node-label{
    font-family: "EB Garamond", "Source Serif 4", Georgia, serif;
    font-size: 28px; font-weight: 400; font-style: normal;
    fill: var(--ink); pointer-events: none;
    transition: fill 200ms ease;
  }
  .tm-node:hover .tm-node-label, .tm-node:focus-visible .tm-node-label{ fill: var(--node-stroke); }

  .st-colophon{ margin: 0.8rem auto 0; max-width: 36rem; text-align: center; font-family: "EB Garamond", "Source Serif 4", Georgia, serif; font-style: italic; font-size: 14px; line-height: 1.5; color: color-mix(in srgb, var(--ink) 50%, transparent); }
</style>

<header class="st-header">
  <a class="st-eyebrow" href="/site-tree-labs/">site tree</a>
  <span class="st-variant">V4 — warm paper, EB Garamond, no subs</span>
</header>

<div class="tm-stage" data-tm-stage>
  <svg viewBox="0 0 1000 720" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Site tree, warm paper variant">
    <path class="tm-trunk" data-related="stacks consulting writing" d="M 464 590 L 486 590 L 478 342 L 472 342 Z"/>
    <path class="tm-branch" data-related="consulting" d="M 474.33 343.44 L 472.67 344.56 L 326.68 132.23 L 333.32 127.77 Z"/>
    <path class="tm-branch" data-related="writing" d="M 477.48 344.21 L 475.52 343.79 L 516.09 144.15 L 523.91 145.85 Z"/>
    <path class="tm-edge tm-edge-bark" data-related="about" d="M 182 350 L 468 350"/>
    <path class="tm-river" data-related="stream stacks" d="M 818 590 L 492 590"/>

    <g class="tm-node" data-node="consulting" data-url="/consulting/" tabindex="0" style="--node-stroke: var(--tm-canopy)">
      <rect class="tm-hit" x="230" y="86" width="200" height="56"/>
      <text class="tm-node-label" x="330" y="110" text-anchor="middle">Consulting</text>
      <circle class="tm-mark" cx="330" cy="130" r="4.5"/>
    </g>
    <g class="tm-node" data-node="writing" data-url="/writing/" tabindex="0" style="--node-stroke: var(--tm-canopy)">
      <rect class="tm-hit" x="420" y="102" width="200" height="56"/>
      <text class="tm-node-label" x="520" y="126" text-anchor="middle">Writing</text>
      <circle class="tm-mark" cx="520" cy="145" r="4.5"/>
    </g>
    <g class="tm-node" data-node="about" data-url="/" tabindex="0" style="--node-stroke: var(--tm-bark)">
      <rect class="tm-hit" x="40" y="330" width="145" height="44"/>
      <text class="tm-node-label" x="158" y="356" text-anchor="end">About</text>
      <circle class="tm-mark" cx="170" cy="350" r="4.5"/>
    </g>
    <g class="tm-node" data-node="stacks" data-url="/shelf/" tabindex="0" style="--node-stroke: var(--tm-soil)">
