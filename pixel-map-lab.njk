<p class="pml-welcome">here's how to get around my website</p>

<div class="pml-stage" data-stage>
  <canvas data-canvas></canvas>
  <div class="pml-labels" data-labels></div>
  <div class="pml-status">you are here <b data-here-label>home</b></div>
</div>

<script type="module">
'use strict';

// pixel-map-lab - Phase 0 v3
// A flat tube-map prototype: home -> about -> consulting / stacks -> stream.

const RW = 480;
const RH = 300;

const NODES = [
  { id:'about',      label:'About',       sub:'bio',      url:'/',            x:120, y:156, glyph:'disc',     color:'about' },
  { id:'consulting', label:'Consulting',  sub:'advisory', url:'/consulting/', x:240, y:94,  glyph:'square',   color:'consulting' },
  { id:'stacks',     label:'Stacks',      sub:'shelf',    url:'/shelf/',      x:240, y:218, glyph:'bars',     color:'stacks' },
  { id:'stream',     label:'Stream',      sub:'feed',     url:'/stream/',     x:360, y:218, glyph:'waves',    color:'stream' },
  { id:'writing',    label:'Writing',     sub:'output',   url:'/writing/',    x:360, y:94,  glyph:'page',     color:'writing', terminus:true },
];

// edges + flow semantics — the site as a tree:
//   stream → stacks         : water flowing into the roots (steady, SOLID)
//   stacks → consulting     : sap rising from roots to near leaf (animated, SLOW)
//   about  → consulting     : trunk extending up to near leaf (SOLID)
//   about  → writing        : canopy radiating to far leaf (animated, MEDIUM)
const LINKS = [
  { from:'stream', to:'stacks',     color:'stream' },
  { from:'stacks', to:'consulting', color:'stacks' },
  { from:'about',  to:'consulting', color:'about'  },
  { from:'about',  to:'writing',    color:'writing' },
];

// tree-coded palette — each node is an arboreal anatomy.
//   about      = trunk bark (saddle-leather brown, structural core)
//   consulting = deep canopy (lexington green, established foliage)
//   stacks     = root soil (mouse's back brown, underground accumulation)
//   stream     = water (newburyport blue, flowing in)
//   writing    = younger-leaf canopy (fresher green, newer growth at the edge)
const NODE_FILL = {
  about:      '#5a3a24',  // saddle-leather / tanner's brown — trunk
  consulting: '#3f5347',  // lexington green — deep canopy
  stacks:     '#7c6852',  // mouse's back / drab — root soil
  stream:     '#3d5972',  // newburyport blue — water
  writing:    '#5c7e54',  // sage-leaf green — younger canopy
};

// palette is built around the site's --ink and --bg so the canvas reads as
// part of the page rather than a self-contained game UI.
//   routeInk   = muted neutral, all routes use this when inactive
//   routeActive = warm accent, only highlighted route
//   here       = same accent as routeActive, so "you are here" and "this is the live path" rhyme
const PAL_LIGHT = {
  sky:'#faf3e6',         // overridden at runtime to site --bg if available
  skyBand:'#faf3e6',
  ink:'#2a1a14',
  paper:'#fff8e8',
  shadow:'rgba(58,32,24,0.22)',
  star:'rgba(58,32,24,0.42)',
  node:'#fff8e8',
  nodeDark:'#d8c8a8',
  here:'#b04020',
  routeInk:'#8a7868',
  routeActive:'#b04020',
  lineShadow:'rgba(58,32,24,0.18)',
  tiny:'#6a4a30',
};

const PAL_DARK = {
  sky:'#1a1830',
  skyBand:'#1a1830',
  ink:'#f5e0c0',
  paper:'#2a1a30',
  shadow:'rgba(0,0,0,0.45)',
  star:'rgba(255,248,192,0.65)',
  node:'#3e2818',
  nodeDark:'#604030',
  here:'#e9b048',
  routeInk:'#7a6850',
  routeActive:'#e9b048',
  lineShadow:'rgba(0,0,0,0.35)',
  tiny:'#b89870',
};

let PAL = PAL_LIGHT;
function refreshPalette(){
  const dark = (document.documentElement.getAttribute('data-theme') === 'dark') ||
               (document.body.getAttribute('data-theme') === 'dark');
  PAL = dark ? Object.assign({}, PAL_DARK) : Object.assign({}, PAL_LIGHT);

  // read site palette so the canvas dovetails with the page
  const cs = getComputedStyle(document.body);
  const siteBg  = (cs.getPropertyValue('--bg')  || '').trim();
  const siteInk = (cs.getPropertyValue('--ink') || '').trim();
  if (siteBg){
    PAL.sky     = siteBg;
    PAL.skyBand = siteBg;
  }
  if (siteInk){
    PAL.ink = siteInk;
  }
}
refreshPalette();

function roomFromPath(){
  const q = new URLSearchParams(location.search).get('room');
  if (q && NODES.some(node => node.id === q)) return q;
  const p = location.pathname;
  if (p.startsWith('/consulting')) return 'consulting';
  if (p.startsWith('/shelf'))      return 'stacks';
  if (p.startsWith('/stream'))     return 'stream';
  if (p.startsWith('/writing'))    return 'writing';
  return 'about';
}

let here = roomFromPath();
let hoveredNode = null;

const stage = document.querySelector('[data-stage]');
const canvas = stage.querySelector('[data-canvas]');
const labelLayer = stage.querySelector('[data-labels]');
const hereLabel = stage.querySelector('[data-here-label]');

canvas.width = RW;
canvas.height = RH;
const ctx = canvas.getContext('2d');
ctx.imageSmoothingEnabled = false;

function nodeById(id){
  return NODES.find(node => node.id === id);
}

hereLabel.textContent = nodeById(here)?.label.toLowerCase() || 'home';

const stars = [];
(function makeStars(){
  for (let i = 0; i < 54; i++){
    stars.push({
      x: Math.floor(Math.random() * RW),
      y: Math.floor(Math.random() * RH * 0.54),
      phase: Math.random() * Math.PI * 2,
    });
  }
})();

function px(v){
  return Math.round(v) + 0.5;
}

function drawSky(){
  const grd = ctx.createLinearGradient(0, 0, 0, RH * 0.8);
  grd.addColorStop(0, PAL.skyBand);
  grd.addColorStop(1, PAL.sky);
  ctx.fillStyle = grd;
  ctx.fillRect(0, 0, RW, RH);

  ctx.fillStyle = 'rgba(0,0,0,0.08)';
  for (let y = 0; y < RH; y += 4){
    ctx.fillRect(0, y, RW, 1);
  }
}

// soft atmospheric tints behind the two regions — interior (warm) and feed (cool)
// gives the canvas a felt sense of place beyond what nodes-and-edges can carry alone
function drawRegions(){
  // interior cluster centroid ≈ between about and the consulting/stacks column
  const interiorCx = 220, interiorCy = 156;
  const grd1 = ctx.createRadialGradient(interiorCx, interiorCy, 20, interiorCx, interiorCy, 170);
  grd1.addColorStop(0, hexAlpha(NODE_FILL.about, 0.12));
  grd1.addColorStop(1, hexAlpha(NODE_FILL.about, 0));
  ctx.fillStyle = grd1;
  ctx.fillRect(0, 0, RW, RH);

  // feed region — radial behind the stream node
  const feedCx = 400, feedCy = 218;
  const grd2 = ctx.createRadialGradient(feedCx, feedCy, 12, feedCx, feedCy, 130);
  grd2.addColorStop(0, hexAlpha(NODE_FILL.stream, 0.18));
  grd2.addColorStop(1, hexAlpha(NODE_FILL.stream, 0));
  ctx.fillStyle = grd2;
  ctx.fillRect(0, 0, RW, RH);
}

// convert a hex color + alpha into rgba string for use in gradient stops
function hexAlpha(hex, alpha){
  const n = parseInt(hex.replace('#', ''), 16);
  const r = (n >> 16) & 0xff;
  const g = (n >> 8)  & 0xff;
  const b =  n        & 0xff;
  return `rgba(${r}, ${g}, ${b}, ${alpha})`;
}

function drawStars(t){
  for (const star of stars){
    const alpha = 0.16 + 0.5 * (0.5 + 0.5 * Math.sin(t * 0.6 + star.phase));
    ctx.fillStyle = PAL.star.replace(/[\d.]+\)$/, `${alpha.toFixed(3)})`);
    ctx.fillRect(star.x, star.y, 1, 1);
    if (alpha > 0.48) ctx.fillRect(star.x + 1, star.y, 1, 1);
  }
}

function drawLineSegment(a, b, color, active){
  // elbow on A's column — vertical first, then horizontal.
  const elbowed = Math.abs(a.y - b.y) > 16;
  const points = elbowed
    ? [a, { x: a.x, y: b.y }, b]
    : [a, b];

  ctx.lineCap = 'butt';
  ctx.lineJoin = 'miter';

  ctx.strokeStyle = PAL.lineShadow;
  ctx.lineWidth = active ? 7 : 5;
  ctx.beginPath();
  points.forEach((point, index) => {
    if (index === 0) ctx.moveTo(px(point.x), px(point.y + 2));
    else ctx.lineTo(px(point.x), px(point.y + 2));
  });
  ctx.stroke();

  ctx.strokeStyle = color;
  ctx.lineWidth = active ? 4 : 2.5;
  ctx.beginPath();
  points.forEach((point, index) => {
    if (index === 0) ctx.moveTo(px(point.x), px(point.y));
    else ctx.lineTo(px(point.x), px(point.y));
  });
  ctx.stroke();

  // arrowhead at the destination end — direction comes from the last segment
  const last  = points[points.length - 1];
  const prev  = points[points.length - 2];
  drawArrow(prev, last, color, active);
}

// pixel-art arrowhead — small triangle pulled back from the destination node
function drawArrow(from, to, color, active){
  const dx = to.x - from.x;
  const dy = to.y - from.y;
  const len = Math.hypot(dx, dy);
  if (len < 4) return;
  const ux = dx / len;
  const uy = dy / len;
  // pull back so the tip lands at the edge of the destination node (not its center)
  const inset = 17;
  const tipX = to.x - ux * inset;
  const tipY = to.y - uy * inset;
  const size = active ? 5 : 4;
  const perpX = -uy;
  const perpY =  ux;
  ctx.fillStyle = color;
  ctx.beginPath();
  ctx.moveTo(tipX, tipY);
  ctx.lineTo(tipX - ux * size + perpX * size, tipY - uy * size + perpY * size);
  ctx.lineTo(tipX - ux * size - perpX * size, tipY - uy * size - perpY * size);
  ctx.closePath();
  ctx.fill();
}

// compute the set of edges that form the narrative chain through a node:
// everything upstream that flows into it, everything downstream it flows toward.
// hovering reveals the full epistemic story of that node, not just adjacent neighbors.
function relatedEdges(nodeId){
  if (!nodeId) return new Set();
  const upstream = new Set([nodeId]);
  let changed = true;
  while (changed){
    changed = false;
    for (const link of LINKS){
      if (upstream.has(link.to) && !upstream.has(link.from)){
        upstream.add(link.from);
        changed = true;
      }
    }
  }
  const downstream = new Set([nodeId]);
  changed = true;
  while (changed){
    changed = false;
    for (const link of LINKS){
      if (downstream.has(link.from) && !downstream.has(link.to)){
        downstream.add(link.to);
        changed = true;
      }
    }
  }
  return new Set(LINKS.filter(l =>
    (upstream.has(l.from) && upstream.has(l.to)) ||
    (downstream.has(l.from) && downstream.has(l.to))
  ));
}

function drawNetwork(t){
  const active = hoveredNode || here;
  const story = relatedEdges(active);
  // inactive routes draw first, active route draws last so it sits on top
  const ordered = LINKS.map(link => ({
    link,
    isActive: story.has(link),
  })).sort((x, y) => Number(x.isActive) - Number(y.isActive));
  for (const { link, isActive } of ordered){
    const a = nodeById(link.from);
    const b = nodeById(link.to);
    const color = isActive ? PAL.routeActive : NODE_FILL[link.color];
    // three living flows (tree-as-organism — each tempo carries its own felt-rate):
    //   stream → stacks     : water flowing into roots (fast, 14 px/s)
    //   stacks → consulting : sap rising from roots to near leaf (slow, 6 px/s)
    //   about  → writing    : canopy radiating to far leaf (medium, 4 px/s)
    // about → consulting is the only structural edge — the trunk-to-leaf spine, solid
    if (link.from === 'stream'){
      drawFlowingLine(a, b, color, isActive, t, 14);
    } else if (link.from === 'stacks' && link.to === 'consulting'){
      drawFlowingLine(a, b, color, isActive, t, 6);
    } else if (link.from === 'about' && link.to === 'writing'){
      drawFlowingLine(a, b, color, isActive, t, 4);
    } else {
      drawLineSegment(a, b, color, isActive);
    }
  }
}

// animated dashed line — dashes march from source toward destination, conveying flow.
// speed = px/sec the dashes appear to travel.
function drawFlowingLine(a, b, color, active, t, speed){
  const elbowed = Math.abs(a.y - b.y) > 16;
  const points = elbowed
    ? [a, { x: a.x, y: b.y }, b]
    : [a, b];

  ctx.lineCap = 'butt';
  ctx.lineJoin = 'miter';

  // soft shadow (static, gives the flowing dashes a "ghost" trail to read against)
  ctx.strokeStyle = PAL.lineShadow;
  ctx.lineWidth = active ? 7 : 5;
  ctx.setLineDash([]);
  ctx.beginPath();
  points.forEach((p, i) => {
    if (i === 0) ctx.moveTo(px(p.x), px(p.y + 2));
    else ctx.lineTo(px(p.x), px(p.y + 2));
  });
  ctx.stroke();

  // flowing dashes — dashOffset decrements over time so dashes move toward destination
  ctx.strokeStyle = color;
  ctx.lineWidth = active ? 4 : 2.5;
  ctx.setLineDash([5, 4]);
  ctx.lineDashOffset = -t * (speed || 16);
  ctx.beginPath();
  points.forEach((p, i) => {
    if (i === 0) ctx.moveTo(px(p.x), px(p.y));
    else ctx.lineTo(px(p.x), px(p.y));
  });
  ctx.stroke();
  ctx.setLineDash([]);

  // arrowhead at destination, same as static edges
  const last = points[points.length - 1];
  const prev = points[points.length - 2];
  drawArrow(prev, last, color, active);
}

// abstract pixel-rune glyphs — geometric marks rather than literal pictograms.
// reads as marginalia / heraldic symbol, not RPG sprite. outline = ink, fill = heritage paint.
function drawDisc(cx, cy, fill, outline){
  // chunky pixel disc (approximated 18-wide circle)
  ctx.fillStyle = outline;
  ctx.fillRect(cx - 7, cy - 9, 14, 18);
  ctx.fillRect(cx - 9, cy - 7, 18, 14);
  ctx.fillStyle = fill;
  ctx.fillRect(cx - 6, cy - 8, 12, 16);
  ctx.fillRect(cx - 8, cy - 6, 16, 12);
}

function drawSquare(cx, cy, fill, outline){
  // chunky 18×18 filled square
  const s = 9;
  ctx.fillStyle = outline;
  ctx.fillRect(cx - s, cy - s, s * 2, s * 2);
  ctx.fillStyle = fill;
  ctx.fillRect(cx - s + 1, cy - s + 1, s * 2 - 2, s * 2 - 2);
}

function drawBars(cx, cy, fill, outline){
  // three stacked horizontal bars (≡ mark)
  const w = 20, h = 4;
  for (let i = 0; i < 3; i++){
    const y = cy - 9 + i * 7;
    ctx.fillStyle = outline;
    ctx.fillRect(cx - w/2, y, w, h);
    ctx.fillStyle = fill;
    ctx.fillRect(cx - w/2 + 1, y + 1, w - 2, h - 2);
  }
}

function drawWaves(cx, cy, fill, outline){
  // two horizontal wavy bands with offset (~ mark, water/inflow signifier)
  const w = 20;
  const bands = [
    { y: -5, off: 0 },
    { y:  3, off: 2 },
  ];
  for (const b of bands){
    ctx.fillStyle = outline;
    ctx.fillRect(cx - w/2 + b.off, cy + b.y, w, 5);
    ctx.fillStyle = fill;
    ctx.fillRect(cx - w/2 + 1 + b.off, cy + b.y + 1, w - 2, 3);
  }
}

function drawPage(cx, cy, fill, outline){
  // page with folded corner — output / publication mark
  const w = 14, h = 18;
  const x = cx - w/2, y = cy - h/2;
  // page body
  ctx.fillStyle = outline;
  ctx.fillRect(x, y, w, h);
  ctx.fillStyle = fill;
  ctx.fillRect(x + 1, y + 1, w - 2, h - 2);
  // folded corner — outline + dark notch
  ctx.fillStyle = outline;
  ctx.fillRect(x + w - 5, y, 5, 1);
  ctx.fillRect(x + w - 4, y + 1, 4, 1);
  ctx.fillRect(x + w - 3, y + 2, 3, 1);
  ctx.fillRect(x + w - 5, y + 1, 1, 4);
  ctx.fillRect(x + w - 4, y + 2, 1, 3);
  ctx.fillRect(x + w - 3, y + 3, 1, 2);
}

const ICONS = {
  disc:   drawDisc,
  square: drawSquare,
  bars:   drawBars,
  waves:  drawWaves,
  page:   drawPage,
};

function drawNode(node){
  const isHere   = node.id === here;
  const isHover  = node.id === hoveredNode;
  const isActive = isHere || isHover;
  const fill     = NODE_FILL[node.color] || PAL.node;
  const drawIcon = ICONS[node.glyph];
  if (!drawIcon) return;

  // soft ground shadow at the base of the icon
  ctx.fillStyle = PAL.shadow;
  ctx.fillRect(node.x - 9, node.y + 12, 18, 2);
  ctx.fillRect(node.x - 7, node.y + 14, 14, 1);

  // the icon
  drawIcon(node.x, node.y, fill, PAL.ink);

  // here / hover pin marker — small warm-rust dot above the icon
  if (isActive){
    ctx.fillStyle = PAL.routeActive;
    ctx.fillRect(node.x - 1, node.y - 19, 3, 5);
    ctx.fillRect(node.x - 2, node.y - 18, 5, 3);
  }

  // terminus pennant — small triangle off the right side of the icon,
  // signaling "this points outward, beyond what's drawn"
  if (node.terminus){
    const tx = node.x + 13;
    const ty = node.y;
    ctx.fillStyle = fill;
    ctx.beginPath();
    ctx.moveTo(tx,     ty - 5);
    ctx.lineTo(tx + 8, ty);
    ctx.lineTo(tx,     ty + 5);
    ctx.closePath();
    ctx.fill();
    ctx.strokeStyle = PAL.ink;
    ctx.lineWidth = 1;
    ctx.stroke();
  }
}

function render(t){
  drawSky();
  drawRegions();        // atmospheric region tints — interior vs feed (felt, not named)
  drawBoundary();       // soft stippled threshold between interior and the right-side output column
  drawHoverTint();      // faint canvas wash in the hovered node's color
  drawStars(t);
  drawNetwork(t);
  for (const node of NODES) drawNode(node);
}

// Lynchian boundary — a stippled threshold between the interior cluster and the right column.
// not a partition (hard line) but a threshold (permeable, atmospheric).
function drawBoundary(){
  ctx.fillStyle = hexAlpha(PAL.ink, 0.10);
  const x0 = 305;
  for (let y = 36; y < RH - 36; y += 5){
    const xoff = Math.sin(y * 0.06) * 3;
    ctx.fillRect(x0 + xoff, y, 1, 2);
  }
}

// when hovering a node, wash the whole canvas in a faint tint of that node's color —
// reinforces the felt sense of "you are entering this region" without explicit boundary.
function drawHoverTint(){
  if (!hoveredNode) return;
  const node = nodeById(hoveredNode);
  if (!node) return;
  ctx.fillStyle = hexAlpha(NODE_FILL[node.color], 0.06);
  ctx.fillRect(0, 0, RW, RH);
}

const pinEls = new Map();
NODES.forEach(node => {
  const el = document.createElement('div');
  el.className = 'pml-pin' + (node.id === here ? ' is-here' : '');
  const main = document.createElement('span');
  main.textContent = node.label;
  el.appendChild(main);
  const sub = document.createElement('span');
  sub.className = 'pin-sub';
  sub.textContent = node.sub;
  el.appendChild(sub);
  el.addEventListener('click', () => { location.href = node.url; });
  el.addEventListener('mouseenter', () => { hoveredNode = node.id; });
  el.addEventListener('mouseleave', () => { if (hoveredNode === node.id) hoveredNode = null; });
  labelLayer.appendChild(el);
  pinEls.set(node.id, el);
});

function updateLabels(){
  const rect = stage.getBoundingClientRect();
  const sxr = rect.width / RW;
  const syr = rect.height / RH;
  NODES.forEach(node => {
    const el = pinEls.get(node.id);
    if (!el) return;
    el.style.left = (node.x * sxr) + 'px';
    el.style.top = (node.y * syr) + 'px';
  });
}

function pickNode(clientX, clientY){
  const rect = canvas.getBoundingClientRect();
  const cx = ((clientX - rect.left) / rect.width) * RW;
  const cy = ((clientY - rect.top) / rect.height) * RH;
  let best = null;
  let bestD = 20;
  for (const node of NODES){
    const d = Math.hypot(node.x - cx, node.y - cy);
    if (d < bestD){
      best = node;
      bestD = d;
    }
  }
  return best;
}

canvas.addEventListener('click', event => {
  const node = pickNode(event.clientX, event.clientY);
  if (node) location.href = node.url;
});
canvas.addEventListener('pointermove', event => {
  const node = pickNode(event.clientX, event.clientY);
  hoveredNode = node ? node.id : null;
  canvas.style.cursor = node ? 'pointer' : '';
});
canvas.addEventListener('pointerleave', () => {
  hoveredNode = null;
  canvas.style.cursor = '';
});

new MutationObserver(refreshPalette).observe(document.documentElement, { attributes:true, attributeFilter:['data-theme'] });
new MutationObserver(refreshPalette).observe(document.body, { attributes:true, attributeFilter:['data-theme'] });

const t0 = performance.now();
function frame(){
  const t = (performance.now() - t0) / 1000;
  render(t);
  updateLabels();
  requestAnimationFrame(frame);
}
frame();
</script>
