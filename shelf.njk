---
layout: base.njk
title: Shelf – Lee Wilkers
permalink: /shelf/
pageClass: page-shelf
---

{% set typeSymbols = {
  "archive": { label: "Archive", symbol: "archive" },
  "audio": { label: "Audio", symbol: "wave-sine" },
  "book": { label: "Book", symbol: "book" },
  "case study": { label: "Case study", symbol: "file-text" },
  "concept": { label: "Concept", symbol: "bulb" },
  "dataset": { label: "Dataset", symbol: "database" },
  "essay": { label: "Essay", symbol: "article" },
  "film": { label: "Film", symbol: "movie" },
  "game": { label: "Game", symbol: "hand-finger" },
  "image": { label: "Image", symbol: "photo" },
  "installation": { label: "Installation", symbol: "cube" },
  "interview": { label: "Interview", symbol: "messages" },
  "journal article": { label: "Journal article", symbol: "microscope" },
  "lecture": { label: "Lecture", symbol: "podium" },
  "magazine": { label: "Magazine", symbol: "article" },
  "map": { label: "Map", symbol: "map-2" },
  "note": { label: "Note", symbol: "notes" },
  "paper": { label: "Paper", symbol: "microscope" },
  "photo": { label: "Photo", symbol: "photo" },
  "project": { label: "Project", symbol: "cube" },
  "report": { label: "Report", symbol: "file-text" },
  "site": { label: "Website", symbol: "browser" },
  "slides": { label: "Slides", symbol: "presentation" },
  "software": { label: "Software", symbol: "terminal-2" },
  "talk": { label: "Talk", symbol: "podium" },
  "tool": { label: "Tool", symbol: "terminal-2" },
  "video": { label: "Video", symbol: "video" },
  "vr": { label: "VR", symbol: "hand-finger" },
  "working paper": { label: "Working paper", symbol: "microscope" },
  "unknown": { label: "Item type", symbol: "notes" }
} %}

{% macro typeSymbol(item, className) %}
  {%- set rawType = item.data.type or "unknown" -%}
  {%- set key = rawType | lower -%}
  {%- set isInteractive = item.data.interactive or key == "vr" or key == "game" -%}
  {%- if typeSymbols[key] -%}
    {%- set label = typeSymbols[key].label -%}
    {%- set symbol = item.data.type_symbol or typeSymbols[key].symbol -%}
  {%- else -%}
    {%- set label = rawType -%}
    {%- set symbol = item.data.type_symbol or typeSymbols.unknown.symbol -%}
  {%- endif -%}
  {%- if isInteractive -%}
    {%- set symbol = item.data.type_symbol or "hand-finger" -%}
    {%- if label == "VR" -%}
      {%- set label = "Interactive VR" -%}
    {%- else -%}
      {%- set label = "Interactive " ~ (label | lower) -%}
    {%- endif -%}
  {%- endif -%}
        <span class="{{ className }} item-type-symbol" data-type="{{ rawType | escape }}" data-symbol="{{ symbol | escape }}" role="img" aria-label="{{ label | escape }}" title="{{ label | escape }}">
          <svg class="item-type-symbol__icon" aria-hidden="true" focusable="false">
            <use href="#item-type-{{ symbol }}"></use>
          </svg>
        </span>
{% endmacro %}

{% macro cell(item, topic) %}
      {%- set primaryUrl = item.data.url %}
      {%- set hoverVoice = item.data | shelfHoverVoice %}
      {%- set identityYear = item.data | shelfIdentityYear %}
      {%- set showCoverLabel = item.data.cover_label or item.data.cover_label_text %}
      <li class="shelf-card{% if showCoverLabel %} shelf-card--cover-label{% endif %}">
        <span class="cell-cover">
          <span class="cell-cover-panel">
          {%- if item.data.image %}
            {% shelfCover item.data.image, "" %}
          {%- endif %}
          </span>
          {%- if showCoverLabel %}
          <span class="cell-cover-stamp" aria-hidden="true">
            <span class="cell-cover-stamp-title">{{ item.data.cover_label_text or item.data.title }}</span>
            {%- if item.data.author or identityYear %}
            <span class="cell-cover-stamp-meta">
              {%- if item.data.author %}<span>{{ item.data.author }}</span>{% endif -%}
              {%- if identityYear %}<span>{{ identityYear }}</span>{% endif -%}
            </span>
            {%- endif %}
          </span>
          {%- endif %}
          {%- if primaryUrl %}
          <a class="cell-cover-primary" href="{{ primaryUrl }}" target="_blank" rel="noopener" aria-label="Open {{ item.data.title | escape }}"></a>
          {%- endif %}
          <span class="cell-cover-overlay">
            <span class="cell-cover-identity" aria-hidden="true">
              <span class="cell-cover-title">{{ item.data.title }}</span>
              {%- if item.data.author or identityYear %}
              <span class="cell-cover-meta">
                {%- if item.data.author %}<span>{{ item.data.author }}</span>{% endif -%}
                {%- if identityYear %}<span>{{ identityYear }}</span>{% endif -%}
              </span>
              {%- endif %}
            </span>
            {%- if hoverVoice %}
            <span class="cell-hover-note cell-hover-note--{{ hoverVoice.kind }}" aria-hidden="true">{{ hoverVoice.text }}</span>
            {%- endif %}
            <ul class="cell-links" aria-label="Links">
            {%- if item.data.url %}
              <li><a href="{{ item.data.url }}" target="_blank" rel="noopener">{{ item.data.url | linkLabel(item.data.source_label) }}</a></li>
            {%- endif %}
            {%- if item.data.links %}{%- for link in item.data.links %}
              <li><a href="{{ link.url }}" target="_blank" rel="noopener">{{ link.url | linkLabel(link.label) }}</a></li>
            {%- endfor %}{%- endif %}
            </ul>
          </span>
        </span>
        <span class="cell-heading">
        {{ typeSymbol(item, "cell-type") }}
        {%- if item.data.title %}
          {%- set tip = item.data.tooltip %}
          {%- if primaryUrl %}
        <a class="cell-title" href="{{ primaryUrl }}" target="_blank" rel="noopener"{% if tip %} title="{{ tip }}"{% endif %}>{{ item.data.title }}</a>
          {%- else %}
        <span class="cell-title"{% if tip %} title="{{ tip }}"{% endif %}>{{ item.data.title }}</span>
          {%- endif %}
        {%- endif %}
        </span>
        <span class="cell-author">{{ item.data.author }}</span>
        {%- if item.data.dek %}<span class="cell-dek">{{ item.data.dek }}</span>{% endif %}
      </li>
{% endmacro %}

<button class="sidebar-toggle" aria-label="Topics" aria-expanded="false" onclick="toggleSidebar()">☰</button>

<h1 class="sr-only">Shelf</h1>

{% include "type-symbols.njk" %}


<header class="shelf-console-head" id="main">
  <div class="shelf-console-head__title">
    <img class="shelf-head-mark" src="/img/rabbits/sitter.png" alt="" aria-hidden="true">
    <p class="console-kicker">Shelf</p>
    <p class="shelf-subtitle">Things on my desk.</p>
  </div>
  <p class="console-status">
    {{ collections.items | where("dest", "shelf") | length }} entries ·
    {{ topics | length }} topics
  </p>
</header>

<div class="library">

  <nav class="topic-index" id="topic-index" aria-label="Topics">
    <p class="rail-label">Topics</p>
    {%- for topic in topics %}
      {%- set sidebarBucket = collections.items | where("dest", "shelf") | where("topic", topic) %}
    <a href="#{{ topic | slug }}" data-topic="{{ topic | slug }}"><span>{{ topic }}</span><b>{{ sidebarBucket.length }}</b></a>
    {%- endfor %}
  </nav>

  <section class="grid-scroll" aria-label="Items">
    {%- for topic in topics %}
      {%- set bucket = collections.items | where("dest", "shelf") | where("topic", topic) | sortByAuthor %}
    <section id="{{ topic | slug }}" data-topic="{{ topic | slug }}" data-topic-name="{{ topic }}" data-topic-count="{{ bucket.length }}" class="topic-section">
      <header class="section-label">
        <img class="section-label-mark" src="/img/rabbits/runner-lg.png" alt="" aria-hidden="true">
        <h2 class="section-label-name">{{ topic }}</h2>
        <span class="section-label-count" data-section-count>{{ bucket.length }}</span>
      </header>
      <ul class="grid">
        {%- for item in bucket %}{{ cell(item, topic) }}{%- endfor %}
      </ul>
    </section>
    {%- endfor %}
  </section>

</div>
