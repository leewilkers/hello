---
layout: base.njk
title: Shelf – Lee Wilkers
permalink: /shelf/
pageClass: page-shelf
---

{% macro cell(item, topic) %}
      {%- set primaryUrl = item.data.url %}
      {%- set hoverVoice = item.data | shelfHoverVoice %}
      <li class="shelf-card" data-shelf-id="{{ item.fileSlug }}" data-shelf-origin="{{ topic | slug }}">
        <span class="cell-cover">
          <span class="cell-cover-panel">
          {%- if item.data.image %}
            {% shelfCover item.data.image, "" %}
          {%- endif %}
          </span>
          <span class="cell-cover-overlay">
            {%- if hoverVoice %}
            <span class="cell-hover-text cell-hover-text--{{ hoverVoice.kind }}">{{ hoverVoice.text }}</span>
            {%- endif %}
            <ul class="cell-links" aria-label="Links">
            {%- if item.data.url %}
              <li><a href="{{ item.data.url }}" target="_blank" rel="noopener">{{ item.data.url | linkLabel(item.data.source_label) }}</a></li>
            {%- endif %}
            {%- if item.data.links %}{%- for link in item.data.links %}
              <li><a href="{{ link.url }}" target="_blank" rel="noopener">{{ link.url | linkLabel(link.label) }}</a></li>
            {%- endfor %}{%- endif %}
            </ul>
          </span>
        </span>
        <span class="cell-type">{{ item.data.type }}</span>
        {%- if item.data.title %}
          {%- set tip = item.data.tooltip %}
          {%- if primaryUrl %}
        <a class="cell-title" href="{{ primaryUrl }}" target="_blank" rel="noopener"{% if tip %} title="{{ tip }}"{% endif %}>{{ item.data.title }}</a>
          {%- else %}
        <span class="cell-title"{% if tip %} title="{{ tip }}"{% endif %}>{{ item.data.title }}</span>
          {%- endif %}
        {%- endif %}
        <span class="cell-author">{{ item.data.author }}</span>
        {%- if item.data.dek %}<span class="cell-dek">{{ item.data.dek }}</span>{% endif %}
        <div class="shelf-card-controls">
          <button class="shelf-card-action" type="button" data-shelf-action="list" aria-label="Move only {{ item.data.title or item.data.author }} to the compact list">move this to list</button>
          <button class="shelf-card-action" type="button" data-shelf-dest="stream" aria-label="Move {{ item.data.title or item.data.author }} to stream review">stream</button>
          <button class="shelf-card-action" type="button" data-shelf-dest="remove" aria-label="Remove {{ item.data.title or item.data.author }} from shelf review">remove</button>
          <button class="shelf-drag-hint" type="button" data-shelf-arm-topic draggable="true" aria-label="Choose a topic for {{ item.data.title or item.data.author }}">drag topic</button>
        </div>
      </li>
{% endmacro %}

{% macro listCell(item, topic) %}
      {%- set primaryUrl = item.data.url %}
      <li class="shelf-list-row" data-shelf-id="{{ item.fileSlug }}" data-shelf-origin="{{ topic | slug }}" hidden>
        <span class="shelf-list-type">{{ item.data.type }}</span>
        <span class="shelf-list-main">
          {%- if item.data.title %}
            {%- set tip = item.data.tooltip %}
            {%- if primaryUrl %}
          <a class="shelf-list-title" href="{{ primaryUrl }}" target="_blank" rel="noopener"{% if tip %} title="{{ tip }}"{% endif %}>{{ item.data.title }}</a>
            {%- else %}
          <span class="shelf-list-title"{% if tip %} title="{{ tip }}"{% endif %}>{{ item.data.title }}</span>
            {%- endif %}
          {%- endif %}
          <span class="shelf-list-author">{{ item.data.author }}</span>
          {%- if item.data.dek %}<span class="shelf-list-dek">{{ item.data.dek }}</span>{% endif %}
        </span>
        <ul class="shelf-list-links" aria-label="Links">
          {%- if item.data.url %}
          <li><a href="{{ item.data.url }}" target="_blank" rel="noopener">{{ item.data.url | linkLabel(item.data.source_label) }}</a></li>
          {%- endif %}
          {%- if item.data.links %}{%- for link in item.data.links %}
          <li><a href="{{ link.url }}" target="_blank" rel="noopener">{{ link.url | linkLabel(link.label) }}</a></li>
          {%- endfor %}{%- endif %}
          <li><button class="shelf-list-action" type="button" data-shelf-action="cover" aria-label="Restore {{ item.data.title or item.data.author }} to covers">restore this cover</button></li>
          <li><button class="shelf-list-action" type="button" data-shelf-dest="stream" aria-label="Move {{ item.data.title or item.data.author }} to stream review">stream</button></li>
          <li><button class="shelf-list-action" type="button" data-shelf-dest="remove" aria-label="Remove {{ item.data.title or item.data.author }} from shelf review">remove</button></li>
          <li><button class="shelf-drag-hint" type="button" data-shelf-arm-topic draggable="true" aria-label="Choose a topic for {{ item.data.title or item.data.author }}">drag topic</button></li>
        </ul>
      </li>
{% endmacro %}

<button class="sidebar-toggle" aria-label="Topics" aria-expanded="false" onclick="toggleSidebar()">☰</button>

<h1 class="sr-only">Shelf</h1>

<header class="shelf-console-head" id="main">
  <div class="shelf-console-head__title">
    <img class="shelf-head-mark" src="/img/rabbits/sitter.png" alt="" aria-hidden="true">
    <p class="console-kicker">Shelf</p>
    <p class="shelf-subtitle">Things on my desk.</p>
  </div>
  <p class="console-status">
    {{ collections.items | where("dest", "shelf") | length }} entries ·
    {{ topics | length }} topics
  </p>
  <div class="shelf-review-controls" aria-label="Shelf review controls">
    <form class="shelf-new-topic" data-shelf-topic-form>
      <label class="sr-only" for="shelf-new-topic">New topic</label>
      <input id="shelf-new-topic" name="topic" type="text" autocomplete="off" placeholder="new topic">
      <button type="submit">add topic</button>
    </form>
    <button class="shelf-export" type="button" data-shelf-export>copy curation JSON</button>
    <button class="shelf-undo" type="button" data-shelf-undo disabled>Undo</button>
    <span class="shelf-review-status" data-shelf-status aria-live="polite"></span>
  </div>
</header>

<div class="library">

  <nav class="topic-index" id="topic-index" aria-label="Topics">
    <p class="rail-label">Topics</p>
    {%- for topic in topics %}
      {%- set sidebarBucket = collections.items | where("dest", "shelf") | where("topic", topic) %}
    <a href="#{{ topic | slug }}" data-topic="{{ topic | slug }}"><span>{{ topic }}</span><b>{{ sidebarBucket.length }}</b></a>
    {%- endfor %}
    <a href="#stream" data-topic="stream" data-curation-dest="stream"><span>Stream</span><b>0</b></a>
    <a href="#removed" data-topic="removed" data-curation-dest="remove"><span>Removed</span><b>0</b></a>
  </nav>

  <section class="grid-scroll" aria-label="Items">
    {%- for topic in topics %}
      {%- set bucket = collections.items | where("dest", "shelf") | where("topic", topic) | sortByAuthor %}
    <section id="{{ topic | slug }}" data-topic="{{ topic | slug }}" data-topic-name="{{ topic }}" data-topic-count="{{ bucket.length }}" class="topic-section">
      <header class="section-label">
        <img class="section-label-mark" src="/img/rabbits/runner-lg.png" alt="" aria-hidden="true">
        <h2 class="section-label-name">{{ topic }}</h2>
        <span class="section-label-count" data-section-count>{{ bucket.length }}</span>
      </header>
      <ul class="grid">
        {%- for item in bucket %}{{ cell(item, topic) }}{%- endfor %}
      </ul>
      <ul class="shelf-list is-empty" aria-label="{{ topic }} list items">
        {%- for item in bucket %}{{ listCell(item, topic) }}{%- endfor %}
      </ul>
    </section>
    {%- endfor %}

    <section id="stream" data-topic="stream" data-topic-name="Stream" data-topic-count="0" data-curation-dest="stream" class="topic-section topic-section--curation">
      <header class="section-label">
        <img class="section-label-mark" src="/img/rabbits/runner-lg.png" alt="" aria-hidden="true">
        <h2 class="section-label-name">Stream</h2>
        <span class="section-label-count" data-section-count>0</span>
      </header>
      <ul class="grid"></ul>
      <ul class="shelf-list is-empty" aria-label="Stream review items"></ul>
    </section>

    <section id="removed" data-topic="removed" data-topic-name="Removed" data-topic-count="0" data-curation-dest="remove" class="topic-section topic-section--curation">
      <header class="section-label">
        <img class="section-label-mark" src="/img/rabbits/runner-lg.png" alt="" aria-hidden="true">
        <h2 class="section-label-name">Removed</h2>
        <span class="section-label-count" data-section-count>0</span>
      </header>
      <ul class="grid"></ul>
      <ul class="shelf-list is-empty" aria-label="Removed review items"></ul>
    </section>
  </section>

</div>
