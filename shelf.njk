---
layout: base.njk
title: Shelf – Lee Wilkers
permalink: /shelf/
pageClass: page-shelf
---

{% macro cell(item) %}
      <li>
        <a href="{{ item.data.url }}" class="cell-link">
          <div class="cell-cover">
            {% if item.data.image %}<img src="{{ item.data.image }}" alt="" loading="lazy">{% endif %}
          </div>
          {%- if item.data.title %}<span class="cell-title">{{ item.data.title }}</span>{% endif %}
          <span class="cell-author">{{ item.data.author }}</span>
          {%- if item.data.dek %}<span class="cell-dek">{{ item.data.dek }}</span>{% endif %}
          {%- if item.data.blurb %}<span class="cell-blurb">{{ item.data.blurb }}</span>{% endif %}
          {%- if item.data.quote %}<span class="cell-quote">{{ item.data.quote }}</span>{% endif %}
          {%- if item.data.note %}<span class="cell-note">{{ item.data.note }}</span>{% endif %}
        </a>
      </li>
{% endmacro %}

<button class="sidebar-toggle" aria-label="Topics" aria-expanded="false" onclick="toggleSidebar()">☰</button>

<h1 class="sr-only">Shelf</h1>

<div class="library">

  <nav class="topic-index" id="topic-index" aria-label="Topics">
    {%- for topic in topics %}
      {%- set sidebarBucket = collections.items | where("dest", "shelf") | where("topic", topic) %}
      {%- if sidebarBucket.length %}
    <a href="#{{ topic | slug }}" data-topic="{{ topic | slug }}">{{ topic }}</a>
      {%- endif %}
    {%- endfor %}
  </nav>

  <section class="grid-scroll" id="main" aria-label="Items">
    <p class="shelf-subtitle">Things on my desk.</p>
    {%- for topic in topics %}
      {%- set bucket = collections.items | where("dest", "shelf") | where("topic", topic) | sortByAuthor %}
      {%- if bucket.length %}
    <section id="{{ topic | slug }}" data-topic="{{ topic | slug }}" class="topic-section">
      <header class="section-label">
        <h2 class="section-label-name">{{ topic }}</h2>
        <span class="section-label-count">{{ bucket.length }}</span>
      </header>
      <ul class="grid">
        {%- for item in bucket %}{{ cell(item) }}{%- endfor %}
      </ul>
    </section>
      {%- endif %}
    {%- endfor %}
  </section>

</div>

<footer class="colophon">
  {{ collections.items | where("dest", "shelf") | length }} entries across {{ topics | length }} topics · updated 2026-04
</footer>
