---
layout: base.njk
title: Shelf – Lee Wilkers
permalink: /shelf/
pageClass: page-shelf
---

{% macro cell(item) %}
      <li data-type="{{ item.data.type }}"{% if item.data.note %} data-note="{{ item.data.note }}"{% endif %}{% if item.data.blurb %} data-blurb="{{ item.data.blurb }}"{% endif %}{% if item.data.quote %} data-quote="{{ item.data.quote }}"{% endif %}{% if item.data.image %} data-cover="{{ item.data.image }}"{% endif %} data-author="{{ item.data.author }}" data-item-title="{{ item.data.title }}"{% if item.data.dek %} data-dek="{{ item.data.dek }}"{% endif %}>
        <a href="{{ item.data.url }}" class="cell-link">
          <div class="cell-cover">
            {% if item.data.image %}<img src="{{ item.data.image }}" alt="" loading="lazy">{% endif %}
          </div>
          {%- if item.data.title %}<span class="cell-title">{{ item.data.title }}</span>{% endif %}
          <span class="cell-author">{{ item.data.author }}</span>
          {%- if item.data.blurb %}<span class="cell-blurb">{{ item.data.blurb }}</span>{% endif %}
        </a>
      </li>
{% endmacro %}

<button class="sidebar-toggle" aria-label="Topics" aria-expanded="false" onclick="toggleSidebar()">☰</button>

<div class="library">

  <aside class="topic-index" id="topic-index">
    {%- for topic in topics %}
      {%- set sidebarBucket = collections.items | where("dest", "shelf") | where("topic", topic) %}
      {%- if sidebarBucket.length %}
    <a href="#{{ topic | slug }}" data-topic="{{ topic | slug }}">{{ topic }}</a>
      {%- endif %}
    {%- endfor %}
  </aside>

  <main class="grid-scroll">
    <div class="shelf-subtitle">Things on my desk.</div>
    {%- for topic in topics %}
      {%- set bucket = collections.items | where("dest", "shelf") | where("topic", topic) | sortByAuthor %}
      {%- if bucket.length %}
    <section id="{{ topic | slug }}" data-topic="{{ topic | slug }}" class="topic-section">
      <header class="section-label">
        <span class="section-label-name">{{ topic }}</span>
        <span class="section-label-count">{{ bucket.length }}</span>
      </header>
      <ul class="grid">
        {%- for item in bucket %}{{ cell(item) }}{%- endfor %}
      </ul>
    </section>
      {%- endif %}
    {%- endfor %}
  </main>

</div>

<div class="margin-ghost" id="margin-ghost">
  <div class="ghost-image">
    <img src="/img/melancholia.jpg" alt="" id="ghost-img">
  </div>
  <div class="ghost-meta" id="ghost-meta">
    <div class="ghost-header">
      <span class="ghost-type-badge" id="ghost-type-badge"></span>
      <div class="ghost-title-block">
        <span class="ghost-author" id="ghost-author"></span>
        <span class="ghost-title" id="ghost-title"></span>
      </div>
    </div>
    <span class="ghost-dek" id="ghost-dek"></span>
    <span class="ghost-blurb" id="ghost-blurb"></span>
    <span class="ghost-quote" id="ghost-quote"></span>
  </div>
</div>
