---
layout: base.njk
title: Shelf – Lee Wilkers
permalink: /shelf/
pageClass: page-shelf
---

{% macro cell(item) %}
      {%- set primaryUrl = item.data.url %}
      <li>
        <span class="cell-cover">
          {%- if item.data.image %}
            {%- if primaryUrl %}
          <a href="{{ primaryUrl }}" target="_blank" rel="noopener" aria-label="Open source for {{ item.data.title or item.data.author }}">{% shelfCover item.data.image, "" %}</a>
            {%- else %}
          {% shelfCover item.data.image, "" %}
            {%- endif %}
          {%- endif %}
        </span>
        <span class="cell-type">{{ item.data.type }}</span>
        {%- if item.data.title %}
          {%- if primaryUrl %}
        <a class="cell-title" href="{{ primaryUrl }}" target="_blank" rel="noopener">{{ item.data.title }}</a>
          {%- else %}
        <span class="cell-title">{{ item.data.title }}</span>
          {%- endif %}
        {%- endif %}
        <span class="cell-author">{{ item.data.author }}</span>
        {%- if item.data.dek %}<span class="cell-dek">{{ item.data.dek }}</span>{% endif %}
        {%- if item.data.note or item.data.quote or item.data.blurb %}
        <div class="cell-voice">
          {%- if item.data.note %}<p class="cell-note">{{ item.data.note }}</p>{% endif %}
          {%- if item.data.quote %}<blockquote class="cell-quote">{{ item.data.quote }}</blockquote>{% endif %}
          {%- if item.data.blurb %}<p class="cell-blurb">{{ item.data.blurb }}</p>{% endif %}
        </div>
        {%- endif %}
        <ul class="cell-links" aria-label="Links">
          {%- if item.data.url %}
          <li><a href="{{ item.data.url }}" target="_blank" rel="noopener">source</a></li>
          {%- endif %}
          {%- if item.data.links %}{%- for link in item.data.links %}
          <li><a href="{{ link.url }}" target="_blank" rel="noopener">{{ link.label }}</a></li>
          {%- endfor %}{%- endif %}
        </ul>
      </li>
{% endmacro %}

<button class="sidebar-toggle" aria-label="Topics" aria-expanded="false" onclick="toggleSidebar()">☰</button>

<h1 class="sr-only">Shelf</h1>

<header class="shelf-console-head" id="main">
  <div class="shelf-console-head__title">
    <p class="console-kicker">Shelf</p>
    <p class="shelf-subtitle">Things on my desk.</p>
  </div>
  <div class="shelf-view-toggle" role="group" aria-label="View">
    <button type="button" class="view-toggle-btn" data-view="grid" aria-pressed="true" title="Grid view"><span aria-hidden="true">▦</span><span class="sr-only">Grid view</span></button>
    <button type="button" class="view-toggle-btn" data-view="list" aria-pressed="false" title="List view"><span aria-hidden="true">≡</span><span class="sr-only">List view</span></button>
  </div>
  <p class="console-status">
    {{ collections.items | where("dest", "shelf") | length }} entries ·
    {{ topics | length }} topics
  </p>
</header>

<div class="library">

  <nav class="topic-index" id="topic-index" aria-label="Topics">
    <p class="rail-label">Topics</p>
    {%- for topic in topics %}
      {%- set sidebarBucket = collections.items | where("dest", "shelf") | where("topic", topic) %}
      {%- if sidebarBucket.length %}
    <a href="#{{ topic | slug }}" data-topic="{{ topic | slug }}"><span>{{ topic }}</span><b>{{ sidebarBucket.length }}</b></a>
      {%- endif %}
    {%- endfor %}
  </nav>

  <section class="grid-scroll" aria-label="Items">
    {%- for topic in topics %}
      {%- set bucket = collections.items | where("dest", "shelf") | where("topic", topic) | sortByAuthor %}
      {%- if bucket.length %}
    <section id="{{ topic | slug }}" data-topic="{{ topic | slug }}" data-topic-count="{{ bucket.length }}" class="topic-section">
      <header class="section-label">
        <h2 class="section-label-name">{{ topic }}</h2>
        <span class="section-label-count" data-section-count>{{ bucket.length }}</span>
      </header>
      <ul class="grid">
        {%- for item in bucket %}{{ cell(item) }}{%- endfor %}
      </ul>
    </section>
      {%- endif %}
    {%- endfor %}
  </section>

</div>

<script>
// View toggle — grid (cover-first) vs list (reading-log). Persists to localStorage.
(function() {
  var scroll = document.querySelector('.grid-scroll');
  var buttons = document.querySelectorAll('.view-toggle-btn');
  if (!scroll || !buttons.length) return;

  function apply(view) {
    scroll.classList.toggle('view-list', view === 'list');
    buttons.forEach(function(b) {
      b.setAttribute('aria-pressed', b.getAttribute('data-view') === view ? 'true' : 'false');
    });
    try { localStorage.setItem('shelf-view', view); } catch (e) {}
  }

  var saved = 'grid';
  try { saved = localStorage.getItem('shelf-view') || 'grid'; } catch (e) {}
  apply(saved);

  buttons.forEach(function(b) {
    b.addEventListener('click', function() { apply(b.getAttribute('data-view')); });
  });
})();
</script>
