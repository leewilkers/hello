      border-bottom: 1px solid color-mix(in srgb, var(--ink, #cecdc3) 12%, transparent);
      margin-bottom: 4px;
    }
    .essay-editor-toolbar button {
      background: transparent;
      color: inherit;
      border: 1px solid color-mix(in srgb, var(--ink, #cecdc3) 14%, transparent);
      padding: 7px 10px;
      cursor: pointer;
      border-radius: 3px;
      text-align: left;
      font-family: inherit;
      font-size: inherit;
      transition: border-color 120ms, background 120ms;
    }
    .essay-editor-toolbar button:hover {
      border-color: var(--accent, #d14f3a);
      background: rgba(255, 255, 255, 0.03);
    }
    .essay-editor-status {
      font-size: 0.66rem;
      color: color-mix(in srgb, var(--ink, #cecdc3) 55%, transparent);
      padding-top: 6px;
      border-top: 1px solid color-mix(in srgb, var(--ink, #cecdc3) 12%, transparent);
      margin-top: 4px;
      min-height: 1em;
    }
    mark.essay-flag {
      background-color: rgba(255, 215, 0, 0.32);
      color: inherit;
      border-bottom: 1px dashed rgba(255, 215, 0, 0.7);
      padding: 0 1px;
    }
    mark.essay-flag-comment {
      background-color: rgba(255, 110, 110, 0.28);
      color: inherit;
      border-bottom: 1px dashed rgba(255, 110, 110, 0.7);
      padding: 0 1px;
      cursor: help;
    }
    [contenteditable="true"] { outline: none; }
    [contenteditable="true"]:hover {
      outline: 1px dashed color-mix(in srgb, var(--accent, #d14f3a) 25%, transparent);
      outline-offset: 6px;
    }
    [contenteditable="true"]:focus {
      outline: 1px solid color-mix(in srgb, var(--accent, #d14f3a) 50%, transparent);
      outline-offset: 6px;
      background: rgba(255, 255, 255, 0.015);
    }
  </style>

  <script>
    (function() {
      const links = document.querySelectorAll('.essay-toc-list a');
      if (!links.length || !('IntersectionObserver' in window)) return;
      const sections = Array.from(links).map(link => {
        const id = link.getAttribute('href').slice(1);
        return document.getElementById(id);
      }).filter(Boolean);
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            links.forEach(link => {
              link.classList.toggle('active', link.getAttribute('href') === '#' + id);
            });
          }
        });
      }, { rootMargin: '-20% 0px -70% 0px' });
      sections.forEach(section => observer.observe(section));
    })();
  </script>

</article>
