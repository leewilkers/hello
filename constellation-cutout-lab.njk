<script>document.documentElement.classList.add('page-cutout-lab'); document.body && document.body.classList.add('page-cutout-lab');</script>

<div class="ccl-stage" data-stage>
  <pre class="ccl-bg"    data-bg    aria-hidden="true"></pre>
  <pre class="ccl-edges" data-edges aria-hidden="true"></pre>
  <pre class="ccl-stars" data-stars aria-hidden="true"></pre>
  <pre class="ccl-highlight" data-highlight aria-hidden="true"></pre>
  <div class="ccl-watermark" data-watermark aria-live="polite"></div>
  <section class="ccl-essay" data-essay aria-live="polite" hidden>
    <div class="ccl-essay-card" data-essay-card>
      <div class="ccl-essay-kicker" data-essay-kicker></div>
      <p class="ccl-essay-body" data-essay-body></p>
      <div class="ccl-essay-progress" data-essay-progress></div>
    </div>
    <div class="ccl-essay-hint" data-essay-hint></div>
  </section>

  <nav class="ccl-cycle" aria-label="Constellation cycle">
    <button type="button" data-prev aria-label="Previous page">&lt;</button>
    <span class="ccl-cycle-label" data-cycle-label></span>
    <button type="button" data-next aria-label="Next page">&gt;</button>
    <button type="button" data-autoplay class="ccl-cycle-autoplay">autoplay</button>
  </nav>

  <details class="ccl-knobs" data-knobs>
    <summary>tune</summary>
    <div class="ccl-knobs-grid">

      <h3>pattern</h3>
      <label>wave sources <select data-knob="sources">
        <option value="labeled" selected>labeled stars only</option>
        <option value="highlight">highlight star only</option>
        <option value="main">all main points</option>
        <option value="all">all stars + scatter</option>
        <option value="edges">constellation edges</option>
        <option value="centroid">centroid (1 point)</option>
      </select></label>
      <label>pattern <select data-knob="pattern">
        <option value="motif">motif (per-constellation ascii)</option>
        <option value="field" selected>field (waves from stars) ★</option>
        <option value="orbit">orbit (rotating shells)</option>
        <option value="lensing">lensing (negative space)</option>
        <option value="ripple">ripple (drop pulses)</option>
        <option value="schwarz">schwarzschild (gravitational lensing)</option>
        <option value="geodesic">geodesic (null path curvature)</option>
        <option value="doppler">doppler (radial frequency shift)</option>
        <option value="metric">metric (curvature density)</option>
        <option value="lightcone">lightcone (past/future)</option>
        <option value="agc">AGC code (Apollo 11)</option>
        <option value="agc-jitter">AGC + line jitter</option>
        <option value="waves">waves (sinusoidal)</option>
        <option value="topo">topo (contour bands)</option>
        <option value="rain">rain (matrix columns)</option>
        <option value="noise">noise (value splatter)</option>
        <option value="void">void (none)</option>
      </select></label>
      <label>speed <input type="range" min="0" max="100" step="1" value="22" data-knob="speed"><output data-out="speed">22</output></label>
      <label>amp / density <input type="range" min="0" max="100" step="1" value="55" data-knob="density"><output data-out="density">55</output></label>
      <label>scale / λ <input type="range" min="20" max="200" step="1" value="100" data-knob="scale"><output data-out="scale">100</output></label>
      <label>ring falloff <input type="range" min="20" max="200" step="1" value="50" data-knob="falloff"><output data-out="falloff">50</output></label>
      <label>highlight gravity <input type="range" min="0" max="400" step="1" value="180" data-knob="hgrav"><output data-out="hgrav">180</output></label>
      <label>wash α <input type="range" min="10" max="100" step="1" value="65" data-knob="wash"><output data-out="wash">65</output></label>

      <h3>sizing (independent layers)</h3>
      <label>bg cell px <input type="range" min="7" max="22" step="1" value="11" data-knob="cellBg"><output data-out="cellBg">11</output></label>
      <label>star cell px <input type="range" min="12" max="44" step="1" value="22" data-knob="cellStar"><output data-out="cellStar">22</output></label>
      <label>note cell px <input type="range" min="10" max="22" step="1" value="14" data-knob="cellNote"><output data-out="cellNote">14</output></label>
      <label>constellation scale <input type="range" min="30" max="200" step="1" value="100" data-knob="conScale"><output data-out="conScale">100</output></label>
      <label>constellation x% <input type="range" min="10" max="90" step="1" value="55" data-knob="conX"><output data-out="conX">55</output></label>
      <label>constellation y% <input type="range" min="10" max="90" step="1" value="40" data-knob="conY"><output data-out="conY">40</output></label>

      <h3>color</h3>
      <label>palette <select data-knob="palette">
        <option value="cool" selected>cool slate</option>
        <option value="xalt">xaltgeist (cyan/violet)</option>
        <option value="terraforms">terraforms (peach/sage)</option>
        <option value="lagoon">lagoon (teal/blue)</option>
        <option value="dusk">dusk (mauve/amber)</option>
        <option value="ember">ember (warm rust)</option>
        <option value="mono">mono (slate)</option>
      </select></label>
      <label>hue cycle s <input type="range" min="0" max="180" step="2" value="50" data-knob="hue"><output data-out="hue">50</output></label>
      <label>bg color <select data-knob="bgcolor">
        <option value="palette" selected>(palette default)</option>
        <option value="cream">cream</option>
        <option value="teal">teal</option>
        <option value="amber">amber</option>
        <option value="violet">violet</option>
      </select></label>
      <label>star color <select data-knob="starcolor">
        <option value="cream" selected>cream</option>
        <option value="amber">amber</option>
        <option value="cyan">cyan</option>
        <option value="white">white</option>
        <option value="red">red (salmon)</option>
        <option value="signal">red (signal)</option>
        <option value="ember">red (ember)</option>
        <option value="deep">red (deep)</option>
      </select></label>
      <label>star glow <input type="range" min="0" max="100" step="1" value="0" data-knob="starGlow"><output data-out="starGlow">0</output></label>

      <h3>stars + edges</h3>
      <label>star glyph <select data-knob="star">
        <option value="dot" selected>· dot</option>
        <option value="ast">* asterisk</option>
        <option value="filled">● filled</option>
        <option value="cross">+ cross</option>
        <option value="diamond">◆ diamond</option>
      </select></label>
      <label>highlight <select data-knob="highlight">
        <option value="star" selected>★ filled star</option>
        <option value="circ">◉ circle</option>
        <option value="at">@ at-sign</option>
        <option value="o">O letter o</option>
      </select></label>
      <label>twinkle <input type="range" min="0" max="100" step="1" value="55" data-knob="twinkle"><output data-out="twinkle">55</output></label>
      <label>star pulse <input type="range" min="0" max="100" step="1" value="55" data-knob="pulse"><output data-out="pulse">55</output></label>
      <label>scatter stars <input type="range" min="0" max="100" step="1" value="55" data-knob="scatter"><output data-out="scatter">55</output></label>
      <label>labels <select data-knob="labels">
        <option value="all">all star names</option>
        <option value="primary">primary only</option>
        <option value="none" selected>hidden</option>
      </select></label>
      <label>edges <select data-knob="edge">
        <option value="dot" selected>· dots</option>
        <option value="hyphen">- hyphens</option>
        <option value="dash">─ box-draw</option>
        <option value="trace">running trace ✦</option>
        <option value="none">(none)</option>
      </select></label>
      <label>edge α <input type="range" min="0" max="100" step="1" value="55" data-knob="edgeA"><output data-out="edgeA">55</output></label>
      <label>star α <input type="range" min="20" max="100" step="1" value="92" data-knob="starA"><output data-out="starA">92</output></label>
      <label>star weight <select data-knob="starWeight">
        <option value="bold" selected>bold</option>
        <option value="black">black</option>
        <option value="medium">medium</option>
        <option value="light">light</option>
      </select></label>

      <h3>notes</h3>
      <label>position <select data-knob="notepos">
        <option value="bl" selected>bottom-left</option>
        <option value="br">bottom-right</option>
        <option value="tl">top-left</option>
        <option value="tr">top-right</option>
        <option value="cc">centered</option>
        <option value="bc">bottom-center</option>
      </select></label>
      <label>width cells <input type="range" min="32" max="100" step="1" value="58" data-knob="notew"><output data-out="notew">58</output></label>
      <label>note red <select data-knob="red">
        <option value="salmon" selected>salmon (#f6a19a)</option>
        <option value="signal">signal (#d14d41)</option>
        <option value="ember">ember (#ff5a3c)</option>
        <option value="deep">deep (#b03028)</option>
      </select></label>
      <label>note α <input type="range" min="40" max="100" step="1" value="100" data-knob="noteA"><output data-out="noteA">100</output></label>
      <label>note glow <input type="range" min="0" max="100" step="1" value="0" data-knob="noteGlow"><output data-out="noteGlow">0</output></label>
      <label>note font <select data-knob="noteFont">
        <option value="typewriter" selected>typewriter (Courier Prime)</option>
        <option value="plex">IBM Plex Mono</option>
        <option value="jet">JetBrains Mono</option>
        <option value="iosevka">Iosevka (humanist mono)</option>
        <option value="sysmono">system mono</option>
        <option value="cursive">cursive mono</option>
      </select></label>
      <label>letter spacing <input type="range" min="-10" max="20" step="1" value="0" data-knob="noteLS"><output data-out="noteLS">0</output></label>
      <label>line height <input type="range" min="90" max="180" step="2" value="110" data-knob="noteLH"><output data-out="noteLH">110</output></label>
      <label>glitch jitter <input type="range" min="0" max="100" step="1" value="38" data-knob="jitter"><output data-out="jitter">38</output></label>
      <label>reveal speed <input type="range" min="20" max="200" step="1" value="80" data-knob="reveal"><output data-out="reveal">80</output></label>
      <label>persistent flicker <input type="range" min="0" max="100" step="1" value="22" data-knob="flicker"><output data-out="flicker">22</output></label>
      <label>dwell s <input type="range" min="6" max="60" step="1" value="22" data-knob="dwell"><output data-out="dwell">22</output></label>
      <label>panel bg <select data-knob="panelbg">
        <option value="none" selected>none</option>
        <option value="dim">dim cell veil</option>
        <option value="block">solid block</option>
      </select></label>
    </div>
    <p class="ccl-hud"><span data-hud></span></p>
  </details>
</div>

<style>
  html.page-cutout-lab,
  body.page-cutout-lab {
    margin: 0; padding: 0; background: #06080b; color: #cecdc3;
    height: 100%; overflow: hidden;
  }
  body.page-cutout-lab .site-nav,
  body.page-cutout-lab .site-colophon,
  body.page-cutout-lab .site-page-ornaments,
  body.page-cutout-lab .site-art-note,
  body.page-cutout-lab .site-art-reveal-caption,
  body.page-cutout-lab .site-sawyer-original,
  body.page-cutout-lab .site-sawyer-motif,
  body.page-cutout-lab .site-dust-motif { display: none !important; }
  body.page-cutout-lab #main { margin: 0 !important; padding: 0 !important; max-width: none !important; width: 100% !important; }

  body.page-cutout-lab .ccl-stage {
    position: fixed; inset: 0; overflow: hidden; background: #06080b;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", "JetBrains Mono", "IBM Plex Mono", Menlo, Consolas, monospace;
  }

  .ccl-bg, .ccl-edges, .ccl-stars, .ccl-highlight {
    position: absolute; inset: 0; margin: 0; padding: 0;
    line-height: 1; letter-spacing: 0; white-space: pre;
    pointer-events: none; user-select: none; will-change: filter, opacity;
  }
  .ccl-highlight {
    color: #f6a19a; opacity: 1.0; font-weight: 900;
    text-shadow:
      0 0 2px #06080b, 0 0 4px #06080b, 0 0 10px #06080b,
      1px 0 #06080b, -1px 0 #06080b, 0 1px #06080b, 0 -1px #06080b;
  }
  /* constellation watermark — a single small-caps label that names the
   * current constellation. Unobtrusive, anchored bottom-center above the
   * cycle nav. The art is the field + stars + labels; this is the only
   * prose anywhere in the lab. */
  .ccl-watermark {
    position: absolute;
    left: 50%;
    bottom: clamp(80px, 11vh, 140px);
    transform: translateX(-50%);
    z-index: 4;
    font-family: "Source Serif 4", "Source Serif Pro", Georgia, serif;
    color: rgba(255, 252, 240, 0.82);
    font-size: clamp(0.7rem, 1.2vw, 0.9rem);
    letter-spacing: 0.34em;
    text-transform: uppercase;
    font-variant: small-caps;
    text-align: center;
    opacity: 0;
    transition: opacity 1400ms ease-out;
    pointer-events: none;
    text-shadow: 0 0 6px #06080b, 0 0 14px #06080b, 0 0 28px #06080b;
  }
  .ccl-watermark.is-visible { opacity: 1; }
  .ccl-watermark .id {
    display: block;
    margin-top: 0.3em;
    font-size: 0.78em;
    letter-spacing: 0.18em;
    color: rgba(255, 252, 240, 0.42);
    font-variant: normal;
    text-transform: none;
  }
  .ccl-watermark .id .star {
    /* main star name — recoloured via JS to the active note-red */
    color: var(--ccl-watermark-star, #f6a19a);
  }

  /* Tap-essay layer — kept in DOM but hidden. The constellation cycle
   * IS the art now; no paragraphs, no progress dots. */
  .ccl-essay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    /* anchor essay to the bottom third so the constellation owns the top
     * two thirds and the prose doesn't block its stars */
    justify-content: flex-end;
    padding: clamp(20px, 4vh, 56px) clamp(20px, 4vh, 56px) clamp(80px, 12vh, 160px);
    pointer-events: auto;
    cursor: pointer;
    z-index: 3;
  }
  .ccl-essay-card {
    max-width: min(60ch, 88vw);
    width: 100%;
    text-align: center;
    color: #f6a19a;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 280ms ease-out, transform 280ms ease-out;
    will-change: opacity, transform;
  }
  .ccl-essay-card.is-visible { opacity: 1; transform: translateY(0); }
  .ccl-essay-card.is-visible { opacity: 1; }
  .ccl-essay-kicker {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: clamp(0.62rem, 1.2vw, 0.8rem);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(246, 161, 154, 0.65);
    margin-bottom: clamp(1.4rem, 4vh, 3rem);
    font-variant: small-caps;
  }
  .ccl-essay-kicker .id {
    color: rgba(246, 161, 154, 0.4);
    margin-left: 0.6em;
    font-variant: normal;
    text-transform: none;
    letter-spacing: 0.04em;
  }
  .ccl-essay-body {
    font-family: "Source Serif 4", "Source Serif Pro", Georgia, "Iowan Old Style", serif;
    font-size: clamp(1.15rem, 2.6vw, 1.85rem);
    line-height: 1.5;
    letter-spacing: 0.005em;
    margin: 0 auto;
    /* dark backdrop halo so prose lifts off the field underneath */
    text-shadow:
      0 0 6px #06080b, 0 0 14px #06080b, 0 0 28px #06080b,
      0 0 48px rgba(6, 8, 11, 0.85);
  }
  .ccl-essay-body em { font-style: italic; }
  .ccl-essay-progress {
    display: flex;
    gap: 0.5em;
    justify-content: center;
    margin-top: clamp(1.4rem, 4vh, 3rem);
  }
  .ccl-essay-progress .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: rgba(246, 161, 154, 0.22);
    transition: background 360ms ease-out;
  }
  .ccl-essay-progress .dot.is-current { background: rgba(246, 161, 154, 0.9); }
  .ccl-essay-progress .dot.is-past    { background: rgba(246, 161, 154, 0.5); }
  .ccl-essay-hint {
    position: absolute;
    bottom: clamp(50px, 7vh, 90px);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(135, 131, 122, 0.55);
    opacity: 0;
    transition: opacity 600ms ease-out;
    pointer-events: none;
  }
  .ccl-essay-hint.is-shown { opacity: 1; }
  @media (max-width: 720px) {
    .ccl-essay-body { font-size: clamp(1.05rem, 4.5vw, 1.45rem); }
    .ccl-essay-kicker { font-size: 0.6rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ccl-essay-card { transition: none; }
    .ccl-essay-progress .dot { transition: none; }
  }
  .ccl-bg         { color: #4a6478; opacity: 0.65; }
  .ccl-edges      { color: #3aa99f; opacity: 0.55; text-shadow: 0 0 4px rgba(58,169,159,.4); font-weight: 600; }
  .ccl-stars {
    color: #fffcf0; opacity: 1.0; font-weight: 900;
    /* dark backdrop punch only — knocks the busy bg back behind each star
     * so the constellation pops without a sci-fi glow halo */
    text-shadow:
      0 0 2px #06080b, 0 0 4px #06080b, 0 0 8px #06080b,
      1px 0 #06080b, -1px 0 #06080b, 0 1px #06080b, 0 -1px #06080b;
  }
  .ccl-stars.weight-black  { font-weight: 900; }
  .ccl-stars.weight-bold   { font-weight: 800; }
  .ccl-stars.weight-medium { font-weight: 600; }
  .ccl-stars.weight-light  { font-weight: 400; }
  .ccl-note-layer { color: #f6a19a; z-index: 2; }

  .ccl-cycle {
    position: absolute; left: 50%; bottom: 0.6rem; transform: translateX(-50%);
    display: flex; gap: 0.6rem; align-items: center;
    font-size: 0.7rem; color: #87837a;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    background: rgba(6,8,11,.55); padding: 0.25rem 0.7rem;
    border: 1px solid #1d1f23; border-radius: 2px;
    backdrop-filter: blur(2px); z-index: 5;
  }
  .ccl-cycle button { background: #14161a; color: #cecdc3; border: 1px solid #2a2c30; padding: 0.15rem 0.5rem; font: inherit; cursor: pointer; border-radius: 2px; }
  .ccl-cycle button:hover { background: #1d1f23; color: #fffcf0; }
  .ccl-cycle-label { min-width: 20ch; text-align: center; color: #cecdc3; font-variant: small-caps; letter-spacing: 0.04em; }
  .ccl-cycle-pause { margin-left: 0.4rem; }
  .ccl-cycle-pause.is-paused { color: #f6a19a; border-color: #6a3a36; }
  .ccl-cycle-autoplay { margin-left: 0.4rem; }
  .ccl-cycle-autoplay.is-on { color: #f6a19a; border-color: #6a3a36; }

  .ccl-knobs { position: absolute; top: 0.6rem; right: 0.6rem; width: 380px; max-height: 94vh; overflow-y: auto; font-size: 0.7rem; color: #87837a; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; z-index: 5; }
  .ccl-knobs summary { cursor: pointer; padding: 0.25rem 0.55rem; background: rgba(6,8,11,.7); border: 1px solid #1d1f23; border-radius: 2px; user-select: none; text-align: right; }
  .ccl-knobs summary:hover { color: #cecdc3; }
  .ccl-knobs-grid { display: grid; grid-template-columns: 1fr; gap: 0.3rem 1rem; margin-top: 0.35rem; padding: 0.6rem 0.8rem; background: rgba(6,8,11,.92); border: 1px solid #1d1f23; }
  .ccl-knobs-grid h3 { margin: 0.4rem 0 0.1rem; padding-top: 0.3rem; border-top: 1px dashed #1d1f23; font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; color: #5d5b56; font-weight: 500; }
  .ccl-knobs-grid h3:first-child { border-top: 0; padding-top: 0; margin-top: 0; }
  .ccl-knobs-grid label { display: grid; grid-template-columns: 1fr 110px 4ch; gap: 0.35rem; align-items: center; font-size: 0.6rem; letter-spacing: 0.06em; text-transform: uppercase; color: #87837a; }
  .ccl-knobs-grid input[type=range] { accent-color: #d14d41; width: 100%; }
  .ccl-knobs-grid select { background: #050608; color: #cecdc3; border: 1px solid #2a2c30; padding: 0.1rem; font: inherit; grid-column: 2 / 4; }
  .ccl-knobs-grid output { color: #cecdc3; font-variant-numeric: tabular-nums; text-align: right; }
  .ccl-hud { margin: 0.5rem 0 0; padding: 0.2rem 0.55rem; background: #0d0e10; border: 1px solid #1d1f23; color: #cecdc3; font-size: 0.6rem; text-align: right; }
</style>

<script src="/assets/js/constellations.js"></script>
<script src="/assets/nasa/agc-corpus.js"></script>
<script>
(function () {
  'use strict';

  const bgEl       = document.querySelector('[data-bg]');
  const edgesEl    = document.querySelector('[data-edges]');
  const starsEl    = document.querySelector('[data-stars]');
  const essayEl    = document.querySelector('[data-essay]');
  const essayCardEl   = document.querySelector('[data-essay-card]');
  const essayKickerEl = document.querySelector('[data-essay-kicker]');
  const essayBodyEl   = document.querySelector('[data-essay-body]');
  const essayProgEl   = document.querySelector('[data-essay-progress]');
  const essayHintEl   = document.querySelector('[data-essay-hint]');
  const watermarkEl   = document.querySelector('[data-watermark]');
  const cycleLabel = document.querySelector('[data-cycle-label]');
  const btnPrev    = document.querySelector('[data-prev]');
  const btnNext    = document.querySelector('[data-next]');
  const btnAutoplay = document.querySelector('[data-autoplay]');
  const hudEl      = document.querySelector('[data-hud]');

  const CONSTELLATIONS = window.CONSTELLATIONS;
  const CYCLE = window.CONSTELLATION_CYCLE;
  const CORPUS = (window.NASA_CORPUS || []).map(e => e.text).join('\n\n').replace(/\t/g, '  ');

  const STORE_KEY = 'ccl_v5_knobs';
  const defaults = {
    pattern: 'field', speed: 10, density: 55, scale: 100, falloff: 50, hgrav: 180, wash: 65,
    cellBg: 11, cellStar: 22, cellNote: 14, conScale: 100, conX: 50, conY: 30,
    palette: 'cool', hue: 50, bgcolor: 'palette', starcolor: 'cream', starGlow: 0,
    music: 'on', musicGain: 28,
    star: 'dot', highlight: 'star', twinkle: 55, pulse: 55, scatter: 55,
    edge: 'dot', edgeA: 55, starA: 92,
    notepos: 'bl', notew: 58, red: 'salmon', noteA: 100, noteGlow: 0,
    noteFont: 'typewriter', noteLS: 0, noteLH: 110,
