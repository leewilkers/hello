  const STAR_GLYPHS = { dot: '·', ast: '*', filled: '●', cross: '+', diamond: '◆' };
  const HIGHLIGHT_GLYPHS = { star: '★', circ: '◉', at: '@', o: 'O' };
  const EDGE_GLYPHS = { dot: '·', hyphen: '-', dash: '─', trace: '·', none: '' };
  const STAR_TWINKLE = { dot: ['·', '•', '∘', '*'], ast: ['*', '✦', '✧', '+'], filled: ['●', '⬤', '◉', '○'], cross: ['+', '✚', '✱', '×'], diamond: ['◆', '◇', '◈', '✦'] };
  const HIGHLIGHT_TWINKLE = { star: ['★', '✦', '✧', '✺'], circ: ['◉', '◎', '⊙', '☉'], at: ['@', '◉', '◎', '⊙'], o: ['O', '◯', '◉', '◎'] };
  const RAMP_FIELD = [' ', ' ', '.', '.', '·', '·', '\'', '`', '˜', '~', '-', '=', '≈', '∼', '+', '*', '°', 'o', 'O'];
  const RAMP_LENSING = ['@', '#', '%', '$', '*', '+', '=', '-', '~', '·', '.', ' ', ' ', ' '];
  const RAMP_RIPPLE = [' ', ' ', '.', '·', '·', '~', '~', '*', '*', '●', '·', '~'];
  const RAMP_WAVES = ['  ', ' ', '.', '·', '\'', '`', '˜', '~', '-', '=', '≈', '+', '*', '°', 'o'];
  const RAMP_TOPO = [' ', '.', '·', '─', '═', '━', '▔', '▀'];
