  /* ─── knob plumbing ─── */
  function applyKnobsToUI () {
    Object.keys(knobs).forEach(k => {
      const ctrl = document.querySelector(`[data-knob="${k}"]`);
      const out  = document.querySelector(`[data-out="${k}"]`);
      if (ctrl) ctrl.value = knobs[k];
      if (out) out.textContent = knobs[k];
    });
    const red = REDS[knobs.red] || REDS.salmon;
    if (essayCardEl) essayCardEl.style.color = red;

    const pal = PALETTES[knobs.palette] || PALETTES.cool;
    bgEl.style.color = (knobs.bgcolor === 'palette') ? pal.base : (BG_COLORS[knobs.bgcolor] || pal.base);
    bgEl.style.opacity = (knobs.wash / 100).toFixed(2);

    const starColor = STAR_COLORS[knobs.starcolor] || STAR_COLORS.cream;
    starsEl.style.color = starColor;
    starsEl.style.opacity = (knobs.starA / 100).toFixed(2);
    const STAR_DARK = '0 0 2px #06080b, 0 0 4px #06080b, 0 0 8px #06080b, 1px 0 #06080b, -1px 0 #06080b, 0 1px #06080b, 0 -1px #06080b';
    starsEl.style.textShadow = knobs.starGlow > 0
      ? `${STAR_DARK}, 0 0 ${4 + knobs.starGlow * 0.1}px ${starColor}, 0 0 ${10 + knobs.starGlow * 0.2}px ${starColor}55`
      : STAR_DARK;
    starsEl.classList.remove('weight-bold','weight-black','weight-medium','weight-light');
    starsEl.classList.add('weight-' + (knobs.starWeight || 'bold'));

    edgesEl.style.opacity = (knobs.edgeA / 100).toFixed(2);

    /* font sizes per layer (note layer is now the essay overlay — fluid via CSS) */
    bgEl.style.fontSize    = knobs.cellBg + 'px';
    edgesEl.style.fontSize = knobs.cellStar + 'px';
    starsEl.style.fontSize = knobs.cellStar + 'px';
  }
  document.querySelectorAll('[data-knob]').forEach(el => {
    el.addEventListener('input', () => {
      const k = el.dataset.knob;
      knobs[k] = (el.type === 'range') ? parseFloat(el.value) : el.value;
      const out = document.querySelector(`[data-out="${k}"]`);
      if (out) out.textContent = knobs[k];
      try { localStorage.setItem(STORE_KEY, JSON.stringify(knobs)); } catch (_) {}
      applyKnobsToUI();
      onLayoutOrPatternChange();
    });
  });

  /* ─── runtime font metrics — measure the actual character width for the
   * active font + size, so the note text and its black panel can't drift.
   * Cached by (font, size, letterSpacing) key. */
  const charWidthCache = new Map();
  function measureCharWidth (fontFamily, sizePx, letterSpacingEm) {
    const key = `${fontFamily}|${sizePx}|${letterSpacingEm}`;
    if (charWidthCache.has(key)) return charWidthCache.get(key);
    const probe = document.createElement('pre');
    probe.style.cssText = `position:absolute;visibility:hidden;left:-9999px;top:0;margin:0;padding:0;line-height:1;letter-spacing:${letterSpacingEm}em;font-family:${fontFamily};font-size:${sizePx}px;white-space:pre;`;
    probe.textContent = 'M'.repeat(100);
    document.body.appendChild(probe);
    const w = probe.getBoundingClientRect().width / 100;
    probe.remove();
    charWidthCache.set(key, w);
    return w;
  }

  /* ─── geometry — each layer has its own grid sized to its font ─── */
  const CHAR_W_RATIO = 0.6;   /* fallback for bg/edges/stars where small drift doesn't matter */
  function gridForCell (cellPx) {
    const cw = cellPx * CHAR_W_RATIO;
    return {
      cellPx, cw, ch: cellPx,
      cols: Math.max(20, Math.ceil(window.innerWidth / cw)),
      rows: Math.max(10, Math.ceil(window.innerHeight / cellPx))
    };
  }
  let gBg, gStar, gNote;
  function reflow () {
    gBg   = gridForCell(knobs.cellBg);
    gStar = gridForCell(knobs.cellStar);
    gNote = gridForCell(knobs.cellNote);
  }
  function onLayoutOrPatternChange () {
    reflow();
    if (currentCon) {
      computeStarFieldCache(currentCon);
      layoutNote(currentCon);
    }
  }

  /* ─── constellation projection ─── */
  /* Logical (px, py) in 60×30 → screen pixels, using user-controlled scale +
   * anchor knobs. This is the single source of truth: bg waves, edges, stars,
   * all consume star screen-px positions. */
  const SRC_W = 60, SRC_H = 30;
  function projectScreenPx (lx, ly) {
    const W = window.innerWidth, H = window.innerHeight;
    /* base scale: fit SRC into 70% of viewport */
    const padFactor = 0.70;
    const baseScale = Math.min(W * padFactor / SRC_W, H * padFactor / SRC_H);
    const sc = baseScale * (knobs.conScale / 100);
    const cx = W * (knobs.conX / 100);
    const cy = H * (knobs.conY / 100);
    return [cx + (lx - SRC_W / 2) * sc, cy + (ly - SRC_H / 2) * sc];
  }
  function gridFromScreenPx (g, sx, sy) {
    return [Math.round(sx / g.cw), Math.round(sy / g.ch)];
  }
  function screenPxFromGridCenter (g, col, row) {
    return [(col + 0.5) * g.cw, (row + 0.5) * g.ch];
  }

  /* Cached projected star info for the active constellation. */
  let starField = null; /* { points: [...], edges: [...], labels: [{text,sx,sy,primary}] } */
  function computeStarFieldCache (con) {
    const points = [];
    if (Array.isArray(con.points)) {
      con.points.forEach((p, i) => {
        const [sx, sy] = projectScreenPx(p[0], p[1]);
        const isHighlight = (i === con.highlightIndex);
        points.push({
          sx, sy,
          amp: isHighlight ? 1.8 : 1.0,
          phase: Math.random() * Math.PI * 2,
          freq: 0.35 + Math.random() * 0.25,
          twinkleRate: 0.4 + Math.random() * 1.5,
          twinklePhase: Math.random() * Math.PI * 2,
          isHighlight,
          isScatter: false
        });
      });
    }
    if (Array.isArray(con.stars)) {
      con.stars.forEach((s) => {
        const [sx, sy] = projectScreenPx(s[0], s[1]);
        /* magnitude is encoded in s[2] (smaller = brighter in mag-system, but
         * ascii-lab data uses it as raw radius — bigger = more prominent).
         * Scale to amp so visibly-bigger scatter stars also visibly ripple. */
        const rad = (s[2] !== undefined) ? s[2] : 1.5;
        points.push({
          sx, sy,
          amp: 0.55 + Math.min(1, rad / 3) * 0.4,    /* 0.55 - 0.95 */
          phase: Math.random() * Math.PI * 2,
          freq: 0.25 + Math.random() * 0.3,
          twinkleRate: 0.3 + Math.random() * 0.8,
          twinklePhase: Math.random() * Math.PI * 2,
          isHighlight: false,
          isScatter: true
        });
      });
    }
    const edges = [];
    if (Array.isArray(con.edges) && Array.isArray(con.points)) {
      con.edges.forEach(([a, b]) => {
        const pa = con.points[a], pb = con.points[b];
        if (!pa || !pb) return;
        const [sx0, sy0] = projectScreenPx(pa[0], pa[1]);
        const [sx1, sy1] = projectScreenPx(pb[0], pb[1]);
        edges.push({ sx0, sy0, sx1, sy1 });
      });
    }
    /* labels: dx/dy are in source-grid units. We project the star, then offset
     * the label by a *tighter* fraction of dx/dy so it sits adjacent to its
     * star rather than across the chart. Negative dx → right-anchor the text
     * so the end of the word kisses the star. */
    const labels = [];
    if (con.labels && typeof con.labels === 'object') {
      Object.values(con.labels).forEach((lbl) => {
        const pi = lbl.pointIndex;
        if (pi == null || !con.points || !con.points[pi]) return;
        const tightness = 0.45;  /* pull labels in toward their stars */
        const [sx, sy] = projectScreenPx(
          con.points[pi][0] + (lbl.dx || 0) * tightness,
          con.points[pi][1] + (lbl.dy || 0) * tightness
        );
        labels.push({
          text: lbl.text, sx, sy,
          primary: !!lbl.primary,
          anchor: (lbl.dx || 0) < 0 ? 'end' : 'start'
        });
      });
    }
    /* WAVE SOURCES — filter the points used as wave emitters in `field`/`orbit`/etc.
     * The full points array is still used for star+halo rendering; this filtered
     * subset is what the bg field samples from. */
    let wavePoints;
    const sources = knobs.sources || 'labeled';
    if (sources === 'all') {
      wavePoints = points;
    } else if (sources === 'main') {
      wavePoints = points.filter(p => !p.isScatter);
    } else if (sources === 'highlight') {
      wavePoints = points.filter(p => p.isHighlight);
    } else if (sources === 'labeled') {
      /* labeled stars only: use the pointIndex set from con.labels */
      const labeledIdx = new Set();
      if (con.labels) Object.values(con.labels).forEach(l => { if (l.pointIndex != null) labeledIdx.add(l.pointIndex); });
      /* primary labeled star gets full hgrav boost; others ride at amp=1.0 */
      wavePoints = points.filter((_, i) => labeledIdx.has(i)).map((p, i) => {
        return Object.assign({}, p, { amp: p.isHighlight ? 1.6 : 1.0 });
      });
      if (wavePoints.length === 0) wavePoints = points.filter(p => p.isHighlight);
    } else if (sources === 'centroid') {
      /* one source at the centroid of labeled stars (or main points if no labels) */
      const labeledIdx = new Set();
      if (con.labels) Object.values(con.labels).forEach(l => { if (l.pointIndex != null) labeledIdx.add(l.pointIndex); });
      const seeds = points.filter((_, i) => labeledIdx.has(i));
      const src = seeds.length ? seeds : points.filter(p => !p.isScatter);
      if (src.length) {
        const cx = src.reduce((s, p) => s + p.sx, 0) / src.length;
        const cy = src.reduce((s, p) => s + p.sy, 0) / src.length;
        wavePoints = [{
          sx: cx, sy: cy, amp: 1.5,
          phase: 0, freq: 0.35, twinkleRate: 0.5, twinklePhase: 0,
          isHighlight: true, isScatter: false
        }];
      } else wavePoints = [];
    } else if (sources === 'edges') {
      /* edges mode: leave wavePoints empty — bg field samples distance-to-segment
       * across `edges` instead of distance-to-point. Pattern code handles this. */
      wavePoints = [];
    } else {
      wavePoints = points;
    }
    starField = { points, wavePoints, edges, labels, conId: con.id };
  }

  /* ─── pattern renderers ─── */
  let agcOffset = 0;       /* integer-snapped position into corpus */
  let agcTarget = 0;        /* fractional accumulator */
  let agcLastText = '';
  let rainCols = null;
  let lastFrame = performance.now();
  function ensureRainCols (g) {
    if (!rainCols || rainCols.length !== g.cols) {
      rainCols = new Array(g.cols);
      for (let c = 0; c < g.cols; c++) rainCols[c] = Math.random() * g.rows * 1.5;
    }
  }
  function rampPickFromValue (v, ramp) {
    const rL = ramp.length;
    let n = (v + 1) / 2;
    return ramp[Math.min(rL - 1, Math.max(0, Math.floor(n * rL)))];
  }

  function renderBg (now) {
    const pattern = knobs.pattern;
    const speed = knobs.speed / 100;
    const density = knobs.density / 100;
    const scale = knobs.scale / 100;
    const dt = (now - lastFrame) / 1000;
    lastFrame = now;
    const g = gBg;

    if (pattern === 'void') { bgEl.textContent = ''; bgEl.style.filter = 'none'; return; }

    /* motif: tile the active constellation's themed sprite across the bg grid */
    if (pattern === 'motif') {
      const motif = (currentCon && MOTIFS[currentCon.id]) || null;
      if (!motif) { bgEl.textContent = ''; bgEl.style.filter = 'none'; return; }
      const frameIdx = Math.floor((now / 1000) * motif.fps) % motif.frames.length;
      const frame = motif.frames[frameIdx];
      const motifW = motif.w + 2;       /* horizontal padding between motifs */
      const motifH = motif.h + 2;       /* vertical padding */
      /* slow drift so the lattice breathes */
      const driftX = Math.floor((now * speed * 0.0008) % motifW);
      const driftY = Math.floor((now * speed * 0.0003) % motifH);
      let s2 = '';
      for (let y = 0; y < g.rows; y++) {
        let line = '';
        const yy = ((y + driftY) % motifH + motifH) % motifH;
        const inSpriteY = yy < motif.h;
        for (let x = 0; x < g.cols; x++) {
          const xx = ((x + driftX) % motifW + motifW) % motifW;
          if (inSpriteY && xx < motif.w) {
            line += (frame[yy][xx] || ' ');
          } else {
            line += ' ';
          }
        }
        s2 += line + '\n';
      }
      bgEl.textContent = s2;
      const pal = PALETTES[knobs.palette] || PALETTES.cool;
      if (pal.amp && knobs.hue > 0) {
        const shift = Math.sin(now / (knobs.hue * 1000)) * pal.amp + pal.off;
        bgEl.style.filter = `hue-rotate(${shift.toFixed(2)}deg)`;
      } else {
        bgEl.style.filter = 'none';
      }
      return;
    }

    let s = '';
    if (pattern === 'field' || pattern === 'orbit' || pattern === 'lensing' || pattern === 'ripple' ||
        pattern === 'schwarz' || pattern === 'geodesic' || pattern === 'doppler' || pattern === 'metric' || pattern === 'lightcone') {
      if (!starField) { bgEl.textContent = ''; return; }
      /* CHILL ART: phase advances ~0.1 Hz at speed=10, so the field breathes
       * over many seconds rather than churning */
      const t = now * speed * 0.0001;
      /* edges mode samples constellation edges as wave sources instead of points */
      const sourcesMode = knobs.sources || 'labeled';
      const useEdges = (sourcesMode === 'edges');
      const pts = useEdges ? [] : (starField.wavePoints || starField.points);
      const nPts = pts.length;
      const segments = useEdges ? starField.edges : [];
      const nSegs = segments.length;
      /* wavelength in screen px (knob scale × cell size) */
      const lambdaPx = scale * g.cellPx * 1.4;
      const hgrav = knobs.hgrav / 100;
      const falloffExp = knobs.falloff / 100;

      let ramp;
      if      (pattern === 'field')     ramp = RAMP_FIELD;
      else if (pattern === 'orbit')     ramp = RAMP_FIELD;
      else if (pattern === 'lensing')   ramp = RAMP_LENSING;
      else if (pattern === 'ripple')    ramp = RAMP_RIPPLE;
      else if (pattern === 'schwarz')   ramp = RAMP_LENSING;
      else if (pattern === 'geodesic')  ramp = RAMP_FIELD;
      else if (pattern === 'doppler')   ramp = RAMP_FIELD;
      else if (pattern === 'metric')    ramp = RAMP_LENSING;
      else if (pattern === 'lightcone') ramp = RAMP_RIPPLE;
      const rL = ramp.length;

      for (let y = 0; y < g.rows; y++) {
        for (let x = 0; x < g.cols; x++) {
          /* screen-px center of this cell */
          const px = (x + 0.5) * g.cw;
          const py = (y + 0.5) * g.ch;
          let v = 0;
          /* edges-as-sources: distance to nearest segment determines the wave */
          if (useEdges && nSegs > 0) {
            let minD = Infinity;
            for (let si = 0; si < nSegs; si++) {
              const e = segments[si];
              const dx = e.sx1 - e.sx0, dy = e.sy1 - e.sy0;
              const len2 = dx * dx + dy * dy;
              const tT = Math.max(0, Math.min(1, ((px - e.sx0) * dx + (py - e.sy0) * dy) / (len2 || 1)));
              const projX = e.sx0 + tT * dx;
              const projY = e.sy0 + tT * dy;
              const d = Math.hypot(px - projX, py - projY);
              if (d < minD) minD = d;
            }
            const d = minD + g.cellPx;
            const dNorm = d / lambdaPx;
            const dropoff = Math.pow(d / g.cellPx, falloffExp);
            v = 1.4 * Math.sin(dNorm * Math.PI * 2 - t * 2 * Math.PI * 0.4) / dropoff;
          }
          for (let i = 0; i < nPts; i++) {
            const p = pts[i];
            const dx = px - p.sx;
            const dy = py - p.sy;
            const d = Math.sqrt(dx * dx + dy * dy) + g.cellPx;  /* +cellPx softens singularity */
            const amp = p.isHighlight ? p.amp * hgrav : p.amp;
            const dNorm = d / lambdaPx;
            const dropoff = Math.pow(d / g.cellPx, falloffExp);
            if (pattern === 'field') {
              v += amp * Math.sin(dNorm * Math.PI * 2 - t * 2 * Math.PI * p.freq + p.phase) / dropoff;
            } else if (pattern === 'orbit') {
              const ang = Math.atan2(dy, dx);
              v += amp * Math.sin(dNorm * Math.PI * 2 + ang * 3 - t * 2 * Math.PI * p.freq) / dropoff;
            } else if (pattern === 'lensing') {
              v += amp / Math.max(0.5, dropoff * 0.5);
            } else if (pattern === 'ripple') {
              const phaseT = (t * p.freq + p.phase / (Math.PI * 2)) % 1;
              const ringR = phaseT * lambdaPx * 3;
              const ringW = lambdaPx * 0.5;
              const gauss = Math.exp(-Math.pow((d - ringR) / ringW, 2));
              v += amp * gauss * 1.5;
            }
          }
          /* physics patterns: replace v entirely with metric-specific math */
          if (pattern === 'schwarz') {
            /* Schwarzschild lensing: deflection ~ 4GM / (c² b). Render as
             * density falling off like 1/r with a tangential streak factor. */
            let acc = 0;
            for (let i = 0; i < nPts; i++) {
              const p = pts[i];
              const dx = px - p.sx, dy = py - p.sy;
              const r = Math.sqrt(dx * dx + dy * dy) + g.cellPx;
              const ang = Math.atan2(dy, dx);
              const ampi = (p.isHighlight ? p.amp * hgrav : p.amp);
              /* lensing: tangential streaks (sin(2*angle) ridges around mass) */
              acc += ampi * (1 + 0.6 * Math.sin(ang * 2 + t * p.freq * Math.PI)) / Math.pow(r / g.cellPx, 1.1);
            }
            v = acc;
          } else if (pattern === 'geodesic') {
            /* null geodesics: pick glyph based on (angle from nearest star + r),
             * giving curved-path families bending toward each mass. */
            let minR = Infinity, sumPhase = 0, totalAmp = 0;
            for (let i = 0; i < nPts; i++) {
              const p = pts[i];
              const dx = px - p.sx, dy = py - p.sy;
              const r = Math.sqrt(dx * dx + dy * dy) + g.cellPx;
              const ang = Math.atan2(dy, dx);
              const ampi = (p.isHighlight ? p.amp * hgrav : p.amp);
              const bend = ampi * 8 / Math.max(1, r / g.cellPx);  /* bigger near mass */
              sumPhase += (ang + bend) * ampi;
              totalAmp += ampi;
              if (r < minR) minR = r;
            }
            const phase = totalAmp > 0 ? sumPhase / totalAmp : 0;
            v = Math.sin(phase * 4 + t * 2 * Math.PI * 0.3);
          } else if (pattern === 'doppler') {
            /* radial bands of red/blueshift around each star */
            let acc = 0;
            for (let i = 0; i < nPts; i++) {
              const p = pts[i];
              const dx = px - p.sx, dy = py - p.sy;
              const r = Math.sqrt(dx * dx + dy * dy) + g.cellPx;
              const dNorm = r / lambdaPx;
              const ampi = (p.isHighlight ? p.amp * hgrav : p.amp);
              /* bands cycle with t — represents rotation/recession */
              acc += ampi * Math.sin(dNorm * Math.PI * 4 - t * 2 * Math.PI * p.freq + p.phase) / Math.pow(r / g.cellPx, 0.6);
            }
            v = acc;
          } else if (pattern === 'metric') {
            /* curvature density: ASCII gets denser where spacetime curves more
             * (∑ 1/r² near each mass). No temporal evolution — static metric. */
            let acc = 0;
            for (let i = 0; i < nPts; i++) {
              const p = pts[i];
              const dx = px - p.sx, dy = py - p.sy;
              const r = Math.sqrt(dx * dx + dy * dy) + g.cellPx;
              const ampi = (p.isHighlight ? p.amp * hgrav : p.amp);
              acc += ampi / Math.pow(r / g.cellPx, 1.4);
            }
            /* slight breathing — slow oscillation so it's not frozen */
            v = acc * (1 + 0.08 * Math.sin(t * 2 * Math.PI * 0.1));
          } else if (pattern === 'lightcone') {
            /* past/future light cones at 45° from each star, expanding with t */
            let acc = 0;
            for (let i = 0; i < nPts; i++) {
              const p = pts[i];
              const dx = px - p.sx, dy = py - p.sy;
              const r = Math.sqrt(dx * dx + dy * dy) + g.cellPx;
              const ampi = (p.isHighlight ? p.amp * hgrav : p.amp);
              const phaseT = (t * p.freq + p.phase / (Math.PI * 2)) % 1;
              /* expanding 45° cone — bright where |dx| ≈ |dy| at the right radius */
              const cone = Math.exp(-Math.pow((Math.abs(Math.abs(dx) - Math.abs(dy))) / (g.cellPx * 2), 2));
              const ring = Math.exp(-Math.pow((r - phaseT * lambdaPx * 3) / (lambdaPx * 0.6), 2));
              acc += ampi * cone * ring * 2;
            }
            v = acc;
          }

          v *= 0.5 + density * 1.4;
          let glyph;
          if (pattern === 'lensing' || pattern === 'schwarz' || pattern === 'metric') {
            const n = Math.min(1, Math.max(0, v * 0.3));
            glyph = ramp[Math.min(rL - 1, Math.floor(n * rL))];
          } else if (pattern === 'ripple' || pattern === 'lightcone') {
            const n = Math.min(1, Math.max(0, v * 0.7));
            glyph = ramp[Math.min(rL - 1, Math.floor(n * rL))];
          } else {
            glyph = rampPickFromValue(Math.tanh(v * 0.7), ramp);
          }
          s += glyph;
        }
        s += '\n';
      }
      bgEl.textContent = s;
    }

    else if (pattern === 'agc' || pattern === 'agc-jitter') {
      if (!CORPUS.length) { bgEl.textContent = '(corpus missing)'; return; }
      /* Stable readable scroll: integer-snap, slow cadence. speed=10 → roughly
       * one row of advance per second; speed=50 → ~5 rows/sec. */
      const cps = speed * g.cols * 0.10;
      agcTarget = (agcTarget + cps * dt);
      const newOffset = Math.floor(agcTarget) % CORPUS.length;
      const stale = (pattern === 'agc-jitter' || newOffset !== agcOffset || agcLastText.length === 0);
      if (stale) {
        agcOffset = newOffset;
        const jitterAmp = (pattern === 'agc-jitter') ? Math.floor(scale * 4) : 0;
        for (let r = 0; r < g.rows; r++) {
          let pos;
          if (jitterAmp > 0) {
            const lineJit = Math.floor(Math.sin(r * 0.7 + now * 0.0003) * jitterAmp);
            pos = ((agcOffset + r * g.cols + lineJit) % CORPUS.length + CORPUS.length) % CORPUS.length;
          } else {
            pos = (agcOffset + r * g.cols) % CORPUS.length;
          }
          let line = '';
          while (line.length < g.cols) {
            const ch = CORPUS.charCodeAt(pos);
            pos = (pos + 1) % CORPUS.length;
            if (ch === 10 || ch === 13) line += ' ';
            else line += String.fromCharCode(ch);
          }
          s += line + '\n';
        }
        agcLastText = s;
        bgEl.textContent = s;
      }
      /* else: leave bgEl.textContent unchanged — stable text between advances */
    }

    else if (pattern === 'waves') {
      const t = now * speed * 0.0005;
      const fx = 0.08 / scale, fy = 0.11 / scale;
      const ramp = RAMP_WAVES; const rL = ramp.length;
      for (let y = 0; y < g.rows; y++) {
        for (let x = 0; x < g.cols; x++) {
          const v = Math.sin(x * fx + t * 0.4)
                  + Math.sin(y * fy - t * 0.27)
                  + 0.6 * Math.sin((x + y) * (fx * 0.7) + t * 0.55);
          let n = (v + 2.6) / 5.2;
          n = Math.pow(n, 1.3 - density * 0.8);
          s += ramp[Math.min(rL - 1, Math.max(0, Math.floor(n * rL)))];
        }
        s += '\n';
      }
      bgEl.textContent = s;
    }

    else if (pattern === 'topo') {
      const t = now * speed * 0.0003;
      const fx = 0.06 / scale, fy = 0.09 / scale;
      const ramp = RAMP_TOPO; const rL = ramp.length;
      for (let y = 0; y < g.rows; y++) {
        for (let x = 0; x < g.cols; x++) {
          const v = Math.sin(x * fx + t * 0.3) + Math.sin(y * fy + t * 0.18)
                  + 0.5 * Math.sin((x * 0.5 - y * 0.5) * fx + t * 0.42);
          const n = (v + 2.5) / 5;
          const bands = 6 + Math.floor(density * 8);
          const q = Math.floor(n * bands) / bands;
          s += ramp[Math.min(rL - 1, Math.max(0, Math.floor(q * rL)))];
        }
        s += '\n';
      }
      bgEl.textContent = s;
    }

    else if (pattern === 'rain') {
      ensureRainCols(g);
      const fall = speed * 30 * dt;
      const ramp = RAMP_RAIN; const rL = ramp.length;
      const grid = new Array(g.rows);
      for (let y = 0; y < g.rows; y++) grid[y] = new Array(g.cols).fill(' ');
      for (let c = 0; c < g.cols; c++) {
        rainCols[c] = (rainCols[c] + fall * (0.6 + Math.random() * 0.8)) % (g.rows + 8);
        const head = Math.floor(rainCols[c]);
        const trail = 3 + Math.floor(density * 14);
        for (let tr = 0; tr < trail; tr++) {
          const y = head - tr;
          if (y < 0 || y >= g.rows) continue;
          const intensity = 1 - (tr / trail);
          grid[y][c] = ramp[Math.min(rL - 1, Math.floor(intensity * (rL - 1)))];
        }
      }
      for (let y = 0; y < g.rows; y++) s += grid[y].join('') + '\n';
      bgEl.textContent = s;
    }

    else if (pattern === 'noise') {
      const t = now * speed * 0.0008;
      const ramp = RAMP_NOISE; const rL = ramp.length;
      const sc = scale * 0.04;
      for (let y = 0; y < g.rows; y++) {
        for (let x = 0; x < g.cols; x++) {
          const v = Math.sin(x * 12.9898 * sc + y * 78.233 * sc + t) * 43758.5453;
          const n = (v - Math.floor(v));
          const w = Math.pow(n, 1.4 - density * 0.9);
          s += ramp[Math.min(rL - 1, Math.floor(w * rL))];
        }
        s += '\n';
      }
      bgEl.textContent = s;
    }

    const pal = PALETTES[knobs.palette] || PALETTES.cool;
    if (pal.amp && knobs.hue > 0) {
      const shift = Math.sin(now / (knobs.hue * 1000)) * pal.amp + pal.off;
      bgEl.style.filter = `hue-rotate(${shift.toFixed(2)}deg)`;
    } else {
      bgEl.style.filter = 'none';
    }
  }

  /* ─── animated stars + edges (rendered at gStar resolution) ─── */
  function buildEmptyG (g, fill) {
    const out = new Array(g.rows);
    for (let y = 0; y < g.rows; y++) out[y] = new Array(g.cols).fill(fill === undefined ? ' ' : fill);
    return out;
  }
  function gridToString (grid) {
    let s = '';
    for (let y = 0; y < grid.length; y++) s += grid[y].join('') + '\n';
    return s;
  }
  function plotG (grid, x, y, ch, g) {
    if (y < 0 || y >= g.rows || x < 0 || x >= g.cols) return;
    grid[y][x] = ch;
  }
  function drawLineG (grid, x0, y0, x1, y1, ch, g) {
    let dx = Math.abs(x1 - x0), sx = x0 < x1 ? 1 : -1;
    let dy = -Math.abs(y1 - y0), sy = y0 < y1 ? 1 : -1;
    let err = dx + dy;
    let x = x0, y = y0;
    while (true) {
      plotG(grid, x, y, ch, g);
      if (x === x1 && y === y1) break;
      const e2 = 2 * err;
      if (e2 >= dy) { err += dy; x += sx; }
      if (e2 <= dx) { err += dx; y += sy; }
    }
  }

  const highlightEl = document.querySelector('[data-highlight]');
  function renderConstellationAnim (now) {
    if (!starField) { edgesEl.textContent = ''; starsEl.textContent = ''; if (highlightEl) highlightEl.textContent = ''; return; }
    const g = gStar;
    const eGrid = buildEmptyG(g);
    const sGrid = buildEmptyG(g);
    const hGrid = buildEmptyG(g);
    const sGlyph = STAR_GLYPHS[knobs.star] || '·';
    const hGlyph = HIGHLIGHT_GLYPHS[knobs.highlight] || '★';
    const sTwinkleSet = STAR_TWINKLE[knobs.star] || [sGlyph];
    const hTwinkleSet = HIGHLIGHT_TWINKLE[knobs.highlight] || [hGlyph];
    const eGlyph = EDGE_GLYPHS[knobs.edge];
    const twinkleAmt = knobs.twinkle / 100;
    const pulseAmt = knobs.pulse / 100;
    const scatterAmt = knobs.scatter / 100;

    /* edges */
    if (eGlyph || knobs.edge === 'trace') {
      starField.edges.forEach((e, ei) => {
        const [ex0, ey0] = gridFromScreenPx(g, e.sx0, e.sy0);
        const [ex1, ey1] = gridFromScreenPx(g, e.sx1, e.sy1);
        if (knobs.edge === 'trace') {
          drawLineG(eGrid, ex0, ey0, ex1, ey1, '·', g);
          const period = 4 + ei * 0.3;
          const phase = ((now / 1000) / period + ei * 0.17) % 1;
          const px = Math.round(ex0 + (ex1 - ex0) * phase);
          const py = Math.round(ey0 + (ey1 - ey0) * phase);
          plotG(eGrid, px, py, '✦', g);
        } else if (eGlyph) {
          drawLineG(eGrid, ex0, ey0, ex1, ey1, eGlyph, g);
        }
      });
    }

    /* stars */
    starField.points.forEach((p) => {
      if (p.isScatter && Math.random() > scatterAmt) return;
      const [x, y] = gridFromScreenPx(g, p.sx, p.sy);
      const tw = Math.sin(now * 0.001 * p.twinkleRate + p.twinklePhase);
      const norm = (tw + 1) / 2;
      const baseGlyph = p.isScatter ? '·' : (p.isHighlight ? hGlyph : sGlyph);
      const twinkleSet = p.isScatter ? ['·', '∘', '·', '\''] : (p.isHighlight ? hTwinkleSet : sTwinkleSet);
      let glyph = baseGlyph;
      if (twinkleAmt > 0 && Math.random() < twinkleAmt * 0.6) {
        glyph = twinkleSet[Math.floor(norm * twinkleSet.length) % twinkleSet.length];
      } else if (norm > 0.85) {
        glyph = twinkleSet[Math.floor(norm * twinkleSet.length) % twinkleSet.length];
      }
      /* highlight star goes into its own layer so it gets its own color */
      if (p.isHighlight) {
        plotG(hGrid, x, y, glyph, g);
      } else {
        plotG(sGrid, x, y, glyph, g);
      }

      if (pulseAmt > 0 && norm > 0.7 && !p.isScatter) {
        const haloStrength = (norm - 0.7) / 0.3;
        if (Math.random() < haloStrength * pulseAmt * 0.5) {
          const ring = p.isHighlight ? 2 : 1;
          for (let dx = -ring; dx <= ring; dx++) {
            for (let dy = -ring; dy <= ring; dy++) {
              if (Math.abs(dx) + Math.abs(dy) !== ring) continue;
              plotG(eGrid, x + dx, y + dy, '·', g);
            }
          }
        }
      }
    });

    /* star labels — render into stars grid, anchored so end-of-word kisses
     * the star when label is to the left, and a thin leader is drawn back
     * to the star for that "scientifically labeled" star-atlas feel. */
    if (starField.labels && starField.labels.length && knobs.labels !== 'none') {
      starField.labels.forEach((lbl) => {
        if (knobs.labels === 'primary' && !lbl.primary) return;
        const [lx, ly] = gridFromScreenPx(g, lbl.sx, lbl.sy);
        const startCol = (lbl.anchor === 'end') ? (lx - lbl.text.length + 1) : lx;
        for (let ci = 0; ci < lbl.text.length; ci++) {
          plotG(sGrid, startCol + ci, ly, lbl.text[ci], g);
        }
      });
    }

    edgesEl.textContent = gridToString(eGrid);
    starsEl.textContent = gridToString(sGrid);
    if (highlightEl) {
      highlightEl.textContent = gridToString(hGrid);
      highlightEl.style.fontSize = knobs.cellStar + 'px';
    }
  }

  /* ─── notes (text into note grid) ─── */
  const parser = new DOMParser();
  function htmlToPlain (html) {
    const doc = parser.parseFromString('<!doctype html><body>' + html + '</body>', 'text/html');
    return doc.body.textContent;
  }
  function wordWrap (text, width) {
    const words = text.split(/\s+/);
    const lines = [];
    let line = '';
    for (const w of words) {
      if (!line.length) line = w;
      else if (line.length + 1 + w.length <= width) line += ' ' + w;
      else { lines.push(line); line = w; }
    }
    if (line.length) lines.push(line);
    return lines;
  }

  /* ─── tap-essay pagination (Robin Sloan "Fish" feel) ─────────────────── */
  let currentCon = null;
  let pages = [];            /* [{kicker, body}] */
  let pageIdx = 0;
  let pageTimer = null;
  let autoplayActive = (knobs.autoplay !== false);

  /* ─── per-constellation palette + speed cinema ─── */
  const CON_CINEMA = {
    lepus:          { palette: 'cool',       speed: 8  },
    polaris:        { palette: 'cool',       speed: 6  },
    bootes:         { palette: 'terraforms', speed: 9  },
    crux:           { palette: 'lagoon',     speed: 7  },
    sirius:         { palette: 'ember',      speed: 11 },
    pleiades:       { palette: 'dusk',       speed: 6  },
    mizarAlcor:     { palette: 'mono',       speed: 7  },
    vega:           { palette: 'dusk',       speed: 8  },
    reticulum:      { palette: 'mono',       speed: 5  },
    epsilonEridani: { palette: 'xalt',       speed: 10 }
  };

  /* ─── audio: ambient drone + transition bell ─── */
  const audio = (function () {
    let ctx = null, master = null, started = false, muted = false;
    let droneOscs = [], droneLfos = [];
    function ensureCtx () {
      if (ctx) return true;
      const AC = window.AudioContext || window.webkitAudioContext;
      if (!AC) return false;
      ctx = new AC();
      master = ctx.createGain();
      master.gain.value = 0.0;
      master.connect(ctx.destination);
      return true;
    }
    function startDrone () {
      if (droneOscs.length) return;
      /* A minor chord low — A2(110), C3(130.81), E3(164.81) + a low fifth */
      const tones = [55, 110, 130.81, 164.81];
      tones.forEach((freq, i) => {
        const osc = ctx.createOscillator();
        osc.type = i === 0 ? 'triangle' : 'sine';
        osc.frequency.value = freq;
        const g = ctx.createGain();
        g.gain.value = i === 0 ? 0.18 : 0.12;
        osc.connect(g).connect(master);
        osc.start();
        droneOscs.push({osc, g});
        /* slow LFO on detune for breathing */
        const lfo = ctx.createOscillator();
        lfo.frequency.value = 0.045 + i * 0.013;
        const lfoGain = ctx.createGain();
        lfoGain.gain.value = 7;  /* cents */
        lfo.connect(lfoGain).connect(osc.detune);
        lfo.start();
        droneLfos.push(lfo);
      });
    }
    function ramp (target, secs) {
      if (!master) return;
      const now = ctx.currentTime;
      master.gain.cancelScheduledValues(now);
      master.gain.setValueAtTime(master.gain.value, now);
      master.gain.linearRampToValueAtTime(target, now + secs);
    }
    function bell (freq) {
      if (!ctx || muted) return;
      const now = ctx.currentTime;
      const carrier = ctx.createOscillator();
      carrier.type = 'sine';
      carrier.frequency.value = freq;
      const modulator = ctx.createOscillator();
      modulator.type = 'sine';
      modulator.frequency.value = freq * 1.414;
      const modGain = ctx.createGain();
      modGain.gain.value = freq * 1.6;
      modulator.connect(modGain).connect(carrier.frequency);
      const env = ctx.createGain();
      env.gain.setValueAtTime(0, now);
      env.gain.linearRampToValueAtTime(0.18, now + 0.012);
      env.gain.exponentialRampToValueAtTime(0.0001, now + 1.4);
      carrier.connect(env).connect(master);
      carrier.start(now);
      modulator.start(now);
      carrier.stop(now + 1.5);
      modulator.stop(now + 1.5);
    }
    return {
      start: function () {
        if (started || !ensureCtx()) return;
        ctx.resume().then(() => {
          startDrone();
          ramp(muted ? 0 : 0.22, 2.6);
          started = true;
        });
      },
      bell: bell,
      mute: function () { muted = true; ramp(0, 0.8); },
      unmute: function () { muted = false; ramp(0.22, 1.2); },
      isMuted: function () { return muted; },
      isStarted: function () { return started; }
    };
  })();
  /* start audio on first user gesture */
  function audioStartOnce () {
    audio.start();
    window.removeEventListener('pointerdown', audioStartOnce, true);
    window.removeEventListener('keydown', audioStartOnce, true);
  }
  window.addEventListener('pointerdown', audioStartOnce, true);
  window.addEventListener('keydown', audioStartOnce, true);

  function buildPages (con) {
    const out = [];
    /* page 1: title screen */
    out.push({ kicker: '', body: con.note.title, idText: con.note.id, isTitle: true });
    /* pages 2..N: one paragraph each */
    con.note.paragraphs.forEach((html, i) => {
      out.push({ kicker: con.note.title, idText: con.note.id, body: htmlToPlain(html) });
    });
    return out;
  }

  function renderPage () {
    if (!pages.length) return;
    const p = pages[pageIdx];
    /* kicker */
    while (essayKickerEl.firstChild) essayKickerEl.removeChild(essayKickerEl.firstChild);
    if (p.isTitle) {
      essayKickerEl.appendChild(document.createTextNode(p.idText));
    } else {
      essayKickerEl.appendChild(document.createTextNode(p.kicker + ' '));
      const idSpan = document.createElement('span');
      idSpan.className = 'id';
      idSpan.textContent = p.idText;
      essayKickerEl.appendChild(idSpan);
    }
    /* body */
    essayBodyEl.textContent = p.body;
    if (p.isTitle) {
      essayBodyEl.style.fontFamily = '"Source Serif 4", "Source Serif Pro", Georgia, serif';
      essayBodyEl.style.fontSize = 'clamp(2rem, 5vw, 3.8rem)';
      essayBodyEl.style.letterSpacing = '0.03em';
      essayBodyEl.style.fontVariant = 'small-caps';
    } else {
      essayBodyEl.style.fontFamily = '';
      essayBodyEl.style.fontSize = '';
      essayBodyEl.style.letterSpacing = '';
      essayBodyEl.style.fontVariant = '';
    }
    /* progress dots */
    while (essayProgEl.firstChild) essayProgEl.removeChild(essayProgEl.firstChild);
    pages.forEach((_, i) => {
      const dot = document.createElement('span');
      dot.className = 'dot';
      if (i < pageIdx) dot.classList.add('is-past');
      if (i === pageIdx) dot.classList.add('is-current');
      essayProgEl.appendChild(dot);
    });
    /* trigger fade-in: remove visible class, force reflow, re-add */
    essayCardEl.classList.remove('is-visible');
    void essayCardEl.offsetWidth;
    requestAnimationFrame(() => essayCardEl.classList.add('is-visible'));
  }

  function advancePage (direction) {
    direction = direction || 1;
    if (!pages.length) return;
    /* on last page + forward + autoplay: advance to next constellation */
    if (direction > 0 && pageIdx >= pages.length - 1) {
      if (autoplayActive) {
        idx = (idx + 1) % CYCLE.length;
        showCurrent();
        return;
      }
      /* manual + last page: stay (or wrap to first) */
      pageIdx = 0;
    } else if (direction < 0 && pageIdx === 0) {
      pageIdx = 0;
    } else {
      pageIdx += direction;
      pageIdx = Math.max(0, Math.min(pages.length - 1, pageIdx));
    }
    renderPage();
    schedulePage();
  }

  function schedulePage () {
    if (pageTimer) { clearTimeout(pageTimer); pageTimer = null; }
    if (!autoplayActive) return;
    const dwellMs = (knobs.dwell || 6) * 1000;
    pageTimer = setTimeout(() => advancePage(1), dwellMs);
  }

  /* tap / key / autoplay interaction */
  essayEl.addEventListener('click', (ev) => {
    /* don't advance on knob-panel clicks */
    if (ev.target.closest('.ccl-knobs') || ev.target.closest('.ccl-cycle')) return;
    advancePage(+1);
  });
  document.addEventListener('keydown', (ev) => {
    if (ev.target.matches('input, select, textarea')) return;
    if (ev.code === 'Space' || ev.code === 'ArrowRight') {
      ev.preventDefault();
      idx = (idx + 1) % CYCLE.length; showCurrent();
    } else if (ev.code === 'ArrowLeft') {
      ev.preventDefault();
      idx = (idx - 1 + CYCLE.length) % CYCLE.length; showCurrent();
    } else if (ev.key === 'a' || ev.key === 'A') {
      autoplayActive = !autoplayActive;
      btnAutoplay.classList.toggle('is-on', autoplayActive);
      btnAutoplay.textContent = autoplayActive ? 'autoplay on' : 'autoplay';
      if (autoplayActive) showCurrent();
      else if (pageTimer) { clearTimeout(pageTimer); pageTimer = null; }
    } else if (ev.key === 'm' || ev.key === 'M') {
      if (audio.isMuted()) audio.unmute(); else audio.mute();
    }
  });

  /* unused stubs that the old code path called — keep as no-ops so callers don't break */
  function renderNotes () {}

  /* ─── cycle ─── */
  let idx = 0;
  let paused = false;
  let cycleTimer = null;
  /* cinematic crossfade: fade ASCII layers down, swap constellation, fade back */
  function setLayerOpacity (visible) {
    const target = visible ? null : 0;
    [bgEl, edgesEl, starsEl, highlightEl].forEach((el) => {
      if (!el) return;
      el.style.transition = 'opacity 900ms ease-out';
      el.style.opacity = visible ? '' : '0';
    });
  }

  function applyCinema (con) {
    const c = CON_CINEMA[con.id];
    if (!c) return;
    /* commit to the lab knob state so the renderers pick it up next frame */
    if (c.palette && PALETTES[c.palette]) {
      knobs.palette = c.palette;
      const sel = document.querySelector('[data-knob="palette"]');
      if (sel) sel.value = c.palette;
    }
    if (c.speed != null) {
      knobs.speed = c.speed;
      const range = document.querySelector('[data-knob="speed"]');
      const out = document.querySelector('[data-out="speed"]');
      if (range) range.value = c.speed;
      if (out) out.textContent = c.speed;
    }
    applyKnobsToUI();
  }

  /* pitch pool for transition bell — A minor pentatonic */
  const BELL_PITCHES = [220, 261.63, 329.63, 392, 440, 523.25];

  function showCurrent () {
    const id = CYCLE[idx];
    const con = CONSTELLATIONS[id];

    /* crossfade out */
    setLayerOpacity(false);

    setTimeout(() => {
      currentCon = con;
      cycleLabel.textContent = `${con.note.title} · ${con.note.id}`;
      applyCinema(con);
      computeStarFieldCache(con);
      audio.bell(BELL_PITCHES[Math.floor(Math.random() * BELL_PITCHES.length)]);
      /* fade back */
      setTimeout(() => setLayerOpacity(true), 80);
    }, 940);

    /* watermark fade-out → swap text → fade-in */
    watermarkEl.classList.remove('is-visible');
    setTimeout(() => {
      while (watermarkEl.firstChild) watermarkEl.removeChild(watermarkEl.firstChild);
      watermarkEl.appendChild(document.createTextNode(con.note.title));
      const idSpan = document.createElement('span');
      idSpan.className = 'id';
      /* split "common name / main star" — color star name red */
      const slash = con.note.id.indexOf('/');
      if (slash > 0) {
        idSpan.appendChild(document.createTextNode(con.note.id.slice(0, slash + 1) + ' '));
        const starSpan = document.createElement('span');
        starSpan.className = 'star';
        starSpan.textContent = con.note.id.slice(slash + 1).trim();
        idSpan.appendChild(starSpan);
      } else {
        idSpan.textContent = con.note.id;
      }
      watermarkEl.appendChild(idSpan);
      /* sync watermark star color to the highlight layer color */
      const red = REDS[knobs.red] || REDS.salmon;
      watermarkEl.style.setProperty('--ccl-watermark-star', red);
      if (highlightEl) highlightEl.style.color = red;
      requestAnimationFrame(() => watermarkEl.classList.add('is-visible'));
    }, 320);

    /* schedule the autoplay handoff to next constellation */
    if (pageTimer) { clearTimeout(pageTimer); pageTimer = null; }
    if (autoplayActive) {
      const dwellMs = (knobs.dwell || 18) * 1000;
      pageTimer = setTimeout(() => {
        idx = (idx + 1) % CYCLE.length;
        showCurrent();
      }, dwellMs);
    }
  }
  function scheduleNext () { /* legacy — autoplay drives pages now */ }
  /* prev/next now advance PAGES within the current essay; reaching the end
   * with autoplay on jumps to the next constellation. Shift+click jumps
   * directly to prev/next constellation. */
  btnPrev.addEventListener('click', () => {
    idx = (idx - 1 + CYCLE.length) % CYCLE.length;
    showCurrent();
  });
  btnNext.addEventListener('click', () => {
    idx = (idx + 1) % CYCLE.length;
    showCurrent();
  });
  btnAutoplay.addEventListener('click', () => {
    autoplayActive = !autoplayActive;
    btnAutoplay.classList.toggle('is-on', autoplayActive);
    btnAutoplay.textContent = autoplayActive ? 'autoplay on' : 'autoplay';
    if (autoplayActive) {
      schedulePage();
      essayHintEl.classList.remove('is-shown');
    } else {
      if (pageTimer) { clearTimeout(pageTimer); pageTimer = null; }
    }
  });

  /* ─── liveness ─── */
  let liveSnapshot = '';
  let liveChanged = 0;
  let liveLastSampleAt = performance.now();
  function sampleLiveness (now) {
    if (now - liveLastSampleAt < 500) return;
    const snap = bgEl.textContent.slice(0, 2000);
    if (liveSnapshot.length === snap.length) {
      let changed = 0;
      for (let i = 0; i < snap.length; i++) if (snap[i] !== liveSnapshot[i]) changed++;
      liveChanged = Math.round((changed / snap.length) * 1000) / 10;
    }
    liveSnapshot = snap;
    liveLastSampleAt = now;
    if (hudEl) hudEl.textContent = `${knobs.pattern} · ${liveChanged}% / 500ms · bg ${gBg.cols}×${gBg.rows} · stars ${gStar.cols}×${gStar.rows} · ${starField ? starField.points.length : 0} pts`;
  }

  /* ─── loop ─── */
  function tick (now) {
    renderBg(now);
    renderConstellationAnim(now);
    renderNotes(now);
    sampleLiveness(now);
    requestAnimationFrame(tick);
  }

  applyKnobsToUI();
  reflow();
  window.addEventListener('resize', () => { onLayoutOrPatternChange(); });
  /* reflect initial autoplay state on the button */
  if (btnAutoplay) {
    btnAutoplay.classList.toggle('is-on', autoplayActive);
    btnAutoplay.textContent = autoplayActive ? 'autoplay on' : 'autoplay';
  }
  showCurrent();
  requestAnimationFrame(tick);
})();
</script>
