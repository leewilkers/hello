  let knobs = Object.assign({}, defaults, JSON.parse(localStorage.getItem(STORE_KEY) || '{}'));

  const REDS = { salmon: '#f6a19a', signal: '#d14d41', ember: '#ff5a3c', deep: '#b03028' };
  const NOTE_FONTS = {
