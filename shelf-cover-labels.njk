---
permalink: /shelf-cover-labels/index.html
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="robots" content="noindex,nofollow">
<title>Shelf Cover Labels</title>
<style>
:root {
  color-scheme: dark;
  --bg: #100f0f;
  --surface: #1c1b1a;
  --surface-soft: #242321;
  --ink: #cecdc3;
  --ink-light: #b7b5ac;
  --ink-faint: #878580;
  --ink-muted: #575653;
  --rule: #343331;
  --rule-strong: #575653;
  --accent: #3aa99f;
  --yellow: #d0a215;
  --green: #879a39;
  --red: #d14d41;
  --serif: Georgia, "Times New Roman", serif;
  --mono: "IBM Plex Sans", ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  --sans: "IBM Plex Sans", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-family: var(--sans);
}

* { box-sizing: border-box; }
html { background: var(--bg); color: var(--ink); scroll-behavior: smooth; }
body { margin: 0; min-height: 100vh; background: var(--bg); line-height: 1.38; }
a { color: inherit; text-decoration: none; }
button,
input {
  font: inherit;
}

.app-header {
  position: sticky;
  top: 0;
  z-index: 40;
  border-bottom: 1px solid var(--rule);
  background: color-mix(in srgb, var(--bg) 92%, transparent);
  backdrop-filter: blur(18px);
}

.header-inner {
  max-width: 1540px;
  margin: 0 auto;
  padding: 1rem;
}

.title-row {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: flex-start;
}

h1 {
  margin: 0;
  font-family: var(--serif);
  font-size: clamp(1.58rem, 1.18rem + 1.22vw, 2.42rem);
  font-weight: 700;
  line-height: 0.98;
  letter-spacing: 0;
}

.subtitle {
  max-width: 58rem;
  margin: 0.32rem 0 0;
  color: var(--ink-faint);
  font-family: var(--serif);
  font-size: 0.92rem;
  font-style: italic;
}

.badge,
.status-line,
.filter-button,
.quiet-actions,
.toggle-label,
.item-meta,
.topic-label {
  font-family: var(--mono);
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.badge {
  display: inline-flex;
  align-items: center;
  border: 1px solid var(--rule-strong);
  border-radius: 999px;
  padding: 0.32rem 0.62rem;
  color: var(--yellow);
  white-space: nowrap;
}

.status-line {
  display: flex;
  flex-wrap: wrap;
  gap: 0.46rem 0.8rem;
  margin-top: 0.82rem;
  color: var(--ink-muted);
}
.status-line b { color: var(--ink-light); }
.status-line .on b { color: var(--green); }
.status-line .off b { color: var(--red); }
.status-line .changed b { color: var(--accent); }

.toolbar {
  display: grid;
  grid-template-columns: minmax(14rem, 1fr) auto;
  gap: 0.72rem 1rem;
  align-items: center;
  margin-top: 0.86rem;
}

.search-input {
  width: 100%;
  min-height: 2rem;
  border: 1px solid var(--rule);
  border-radius: 3px;
  background: color-mix(in srgb, var(--bg) 84%, var(--surface-soft));
  color: var(--ink);
  padding: 0.42rem 0.58rem;
}
.search-input:focus {
  outline: 1px solid var(--accent);
  outline-offset: 2px;
}

.filters {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 0.34rem;
}

.filter-button {
  border: 1px solid var(--rule);
  border-radius: 999px;
  background: transparent;
  color: var(--ink-faint);
  padding: 0.34rem 0.58rem;
  cursor: pointer;
}
.filter-button:hover,
.filter-button:focus-visible,
.filter-button[aria-pressed="true"] {
  border-color: var(--accent);
  color: var(--accent);
  outline: 0;
}

.quiet-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.42rem 0.8rem;
  margin-top: 0.58rem;
}
.quiet-actions a {
  color: var(--ink-faint);
  text-underline-offset: 0.16em;
}
.quiet-actions a:hover,
.quiet-actions a:focus-visible {
  color: var(--accent);
  outline: 0;
  text-decoration: underline;
}
.quiet-actions a[aria-disabled="true"] {
  color: var(--ink-muted);
  pointer-events: none;
  opacity: 0.48;
}

.library {
  max-width: 1540px;
  margin: 0 auto;
  padding: 1rem 1.25rem 3rem;
}

.topic-section {
  margin: 0 0 1.2rem;
  border-top: 1px solid var(--rule-strong);
}

.topic-heading {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: baseline;
  padding: 0.52rem 0 0.64rem;
}

.topic-label {
  color: var(--yellow);
}

.topic-count {
  color: var(--ink-muted);
}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(148px, 1fr));
  gap: 1.05rem 0.86rem;
}

.cover-card {
  display: grid;
  grid-template-rows: auto 1fr;
  gap: 0.48rem;
  min-width: 0;
  color: var(--ink-faint);
}

.cover-frame {
  position: relative;
  display: block;
  width: 100%;
  aspect-ratio: 2 / 3;
  border: 1px solid color-mix(in srgb, var(--rule) 70%, transparent);
  background: #0b0b0b;
  overflow: hidden;
}

.cover-frame img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

.cover-frame.no-image {
  display: grid;
  place-items: center;
  padding: 0.8rem;
  color: var(--ink-muted);
  font-family: var(--mono);
  font-size: 0.68rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.cover-overlay {
  position: absolute;
  inset: 0;
  display: grid;
  align-content: end;
  gap: 0.25rem;
  padding: 0.62rem;
  background:
    linear-gradient(to top, rgba(16, 15, 15, 0.88), rgba(16, 15, 15, 0.36) 48%, rgba(16, 15, 15, 0.08));
  color: #f2f0e5;
  opacity: 0;
  pointer-events: none;
}

.cover-card.is-on .cover-overlay {
  opacity: 1;
}

.cover-overlay-title {
  font-family: var(--serif);
  font-size: clamp(0.92rem, 0.62rem + 0.7vw, 1.24rem);
  font-weight: 700;
  line-height: 1.02;
  overflow-wrap: anywhere;
}

.cover-overlay-meta {
  color: color-mix(in srgb, #f2f0e5 76%, transparent);
  font-family: var(--mono);
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  line-height: 1.24;
}

.cover-card.is-changed .cover-frame {
  border-color: var(--accent);
  box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent) 48%, transparent);
}

.cover-card.is-off .cover-frame {
  opacity: 0.76;
}

.item-copy {
  display: grid;
  gap: 0.32rem;
  min-width: 0;
}

.item-title {
  color: var(--ink);
  font-family: var(--serif);
  font-size: 0.94rem;
  line-height: 1.14;
}

.item-meta {
  color: var(--ink-muted);
  line-height: 1.22;
}

.toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.48rem;
}

.toggle {
  position: relative;
  width: 2.35rem;
  height: 1.22rem;
  flex: 0 0 auto;
  border: 1px solid var(--rule-strong);
  border-radius: 999px;
  background: color-mix(in srgb, var(--surface) 78%, var(--bg));
  cursor: pointer;
}
.toggle::after {
  content: "";
  position: absolute;
  top: 0.17rem;
  left: 0.18rem;
  width: 0.78rem;
  height: 0.78rem;
  border-radius: 999px;
  background: var(--ink-faint);
  transition: transform 120ms ease, background 120ms ease;
}
.toggle[aria-pressed="true"] {
  border-color: color-mix(in srgb, var(--green) 78%, var(--rule-strong));
}
.toggle[aria-pressed="true"]::after {
  transform: translateX(1.06rem);
  background: var(--green);
}
.toggle:focus-visible {
  outline: 1px solid var(--accent);
  outline-offset: 3px;
}

.toggle-label {
  color: var(--ink-muted);
}
.cover-card.is-on .toggle-label { color: var(--green); }
.cover-card.is-off .toggle-label { color: var(--red); }

.empty {
  border: 1px dashed var(--rule);
  padding: 2rem;
  color: var(--ink-faint);
  font-family: var(--serif);
  font-style: italic;
}

.export-panel {
  position: fixed;
  left: max(1rem, 4vw);
  right: max(1rem, 4vw);
  bottom: 1rem;
  z-index: 80;
  max-width: 980px;
  margin: 0 auto;
  border: 1px solid var(--rule-strong);
  background: color-mix(in srgb, var(--bg) 94%, var(--surface-soft));
  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.52);
  padding: 1rem;
}

.export-panel.hidden {
  display: none;
}

.export-head {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: start;
  margin-bottom: 0.72rem;
}

.export-head h2 {
  margin: 0;
  font-family: var(--serif);
  font-size: 1.24rem;
  line-height: 1;
}

.export-head p {
  margin: 0.28rem 0 0;
  color: var(--ink-faint);
  font-family: var(--serif);
  font-size: 0.88rem;
  font-style: italic;
}

.export-output {
  width: 100%;
  min-height: min(46vh, 30rem);
  max-height: min(58vh, 34rem);
  overflow: auto;
  border: 1px solid var(--rule);
  background: color-mix(in srgb, var(--bg) 88%, var(--surface-soft));
  color: var(--ink);
  border-radius: 3px;
  padding: 0.72rem;
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  font-size: 0.82rem;
  line-height: 1.45;
  white-space: pre-wrap;
}

@media (max-width: 720px) {
  .title-row,
  .toolbar,
  .topic-heading {
    display: block;
  }
  .badge,
  .filters {
    margin-top: 0.58rem;
    justify-content: flex-start;
  }
  .grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
</style>
</head>
<body>
{%- set shelfItems = collections.items | where("dest", "shelf") -%}
<header class="app-header">
  <div class="header-inner">
    <div class="title-row">
      <div>
        <h1>Shelf Cover Labels</h1>
        <p class="subtitle">Switch text overlays on or off for Shelf covers. This only changes browser state until you export it.</p>
      </div>
      <span class="badge">{{ shelfItems | length }} Shelf items</span>
    </div>
    <div class="status-line" id="stats"></div>
    <div class="toolbar">
      <input class="search-input" id="searchInput" type="search" autocomplete="off" placeholder="Search title, author, topic">
      <nav class="filters" aria-label="Cover label filters">
        <button class="filter-button" type="button" data-filter="all" aria-pressed="true">All</button>
        <button class="filter-button" type="button" data-filter="on" aria-pressed="false">Overlay on</button>
        <button class="filter-button" type="button" data-filter="off" aria-pressed="false">Overlay off</button>
        <button class="filter-button" type="button" data-filter="no-image" aria-pressed="false">No image</button>
        <button class="filter-button" type="button" data-filter="changed" aria-pressed="false">Changed</button>
      </nav>
    </div>
    <nav class="quiet-actions" aria-label="Cover label actions">
      <a href="#export" id="exportLink">Export changes</a>
      <a href="#copy" id="copyLink" aria-disabled="true">Copy export</a>
      <a href="#reset" id="resetLink">Clear local changes</a>
    </nav>
  </div>
</header>

<main class="library" id="board" aria-label="Shelf cover label board"></main>

<section id="exportPanel" class="export-panel hidden" aria-live="polite">
  <div class="export-head">
    <div>
      <h2>Export Cover Label Changes</h2>
      <p>Paste this back when you want the overlay decisions applied to item frontmatter.</p>
    </div>
    <a href="#close" id="closeExportLink">Close</a>
  </div>
  <pre id="exportText" class="export-output" tabindex="0"></pre>
  <nav class="quiet-actions" aria-label="Export actions">
    <a href="#copy-export" id="copyExportLink">Copy export</a>
  </nav>
</section>

<script>
const STORAGE_KEY = "shelfCoverLabels.v1";
const TOPICS = {{ topics | toJson | safe }};
const ITEMS = [
{%- for topic in topics %}
  {%- set bucket = collections.items | where("dest", "shelf") | where("topic", topic) | sortForShelf %}
  {%- for item in bucket %}
  {
    path: {{ item.inputPath | replace("./", "") | toJson | safe }},
    title: {{ item.data.title | toJson | safe }},
    author: {{ item.data.author | toJson | safe }},
    topic: {{ topic | toJson | safe }},
    type: {{ item.data.type | toJson | safe }},
    image: {{ (item.data.image or "") | toJson | safe }},
    url: {{ (item.data.url or "") | toJson | safe }},
    coverLabel: {{ ((item.data.cover_label or item.data.cover_label_text) and true or false) | toJson | safe }},
    coverLabelText: {{ (item.data.cover_label_text or "") | toJson | safe }}
  },
  {%- endfor %}
{%- endfor %}
];

const itemByPath = new Map(ITEMS.map((item) => [item.path, item]));
const state = {
  coverLabelByPath: {},
  filter: "all",
  search: ""
};

const els = {
  board: document.getElementById("board"),
  stats: document.getElementById("stats"),
  searchInput: document.getElementById("searchInput"),
  exportPanel: document.getElementById("exportPanel"),
  exportText: document.getElementById("exportText"),
  copyLink: document.getElementById("copyLink")
};

function loadState() {
  try {
    const parsed = JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}");
    state.coverLabelByPath = parsed && parsed.coverLabelByPath ? parsed.coverLabelByPath : {};
    state.filter = parsed && parsed.filter ? parsed.filter : "all";
    state.search = parsed && parsed.search ? parsed.search : "";
  } catch (error) {
    state.coverLabelByPath = {};
    state.filter = "all";
    state.search = "";
  }
  sanitizeState();
  writeState();
}

function sanitizeState() {
  const clean = {};
  for (const [path, value] of Object.entries(state.coverLabelByPath || {})) {
    const item = itemByPath.get(path);
    if (!item) continue;
    const nextValue = value === true || value === "true";
    if (nextValue !== Boolean(item.coverLabel)) clean[path] = nextValue;
  }
  state.coverLabelByPath = clean;
  if (!["all", "on", "off", "no-image", "changed"].includes(state.filter)) state.filter = "all";
  state.search = String(state.search || "");
}

function saveState() {
  sanitizeState();
  writeState();
}

function writeState() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify({
    coverLabelByPath: state.coverLabelByPath,
    filter: state.filter,
    search: state.search,
    updatedAt: new Date().toISOString()
  }));
}

function hasOverride(item) {
  return Object.prototype.hasOwnProperty.call(state.coverLabelByPath, item.path);
}

function hasCoverLabel(item) {
  if (!item) return false;
  if (hasOverride(item)) return Boolean(state.coverLabelByPath[item.path]);
  return Boolean(item.coverLabel);
}

function setCoverLabel(path, value) {
  const item = itemByPath.get(path);
  if (!item) return;
  const nextValue = Boolean(value);
  if (nextValue === Boolean(item.coverLabel)) delete state.coverLabelByPath[path];
  else state.coverLabelByPath[path] = nextValue;
  saveState();
  render();
}

function exportDecisions() {
  return ITEMS.filter(hasOverride).map((item) => ({
    path: item.path,
    title: item.title,
    author: item.author,
    topic: item.topic,
    type: item.type,
    image: item.image,
    oldCoverLabel: Boolean(item.coverLabel),
    newCoverLabel: hasCoverLabel(item),
    coverLabelText: item.coverLabelText,
    removeCoverLabelText: Boolean(item.coverLabelText) && !hasCoverLabel(item)
  }));
}

function exportPayload() {
  const decisions = exportDecisions();
  return {
    exportedAt: new Date().toISOString(),
    source: "shelf-cover-labels",
    localStorageKey: STORAGE_KEY,
    counts: {
      totalShelfItems: ITEMS.length,
      changedItems: decisions.length,
      overlayOn: ITEMS.filter(hasCoverLabel).length,
      overlayOff: ITEMS.filter((item) => !hasCoverLabel(item)).length,
      noImage: ITEMS.filter((item) => !item.image).length
    },
    decisions
  };
}

function visibleItems() {
  const query = state.search.trim().toLowerCase();
  return ITEMS.filter((item) => {
    const on = hasCoverLabel(item);
    const changed = hasOverride(item);
    if (state.filter === "on" && !on) return false;
    if (state.filter === "off" && on) return false;
    if (state.filter === "no-image" && item.image) return false;
    if (state.filter === "changed" && !changed) return false;
    if (!query) return true;
    return [item.title, item.author, item.topic, item.type].join(" ").toLowerCase().includes(query);
  });
}

function render() {
  renderStats();
  renderFilters();
  els.searchInput.value = state.search;
  const items = visibleItems();
  const grouped = TOPICS.map((topic) => ({
    topic,
    items: items.filter((item) => item.topic === topic)
  })).filter((group) => group.items.length);
  els.board.innerHTML = grouped.length
    ? grouped.map(topicMarkup).join("")
    : `<p class="empty">No Shelf items match this view.</p>`;
  bindCards();
}

function renderStats() {
  const decisions = exportDecisions();
  const on = ITEMS.filter(hasCoverLabel).length;
  const off = ITEMS.length - on;
  const noImage = ITEMS.filter((item) => !item.image).length;
  els.stats.innerHTML = [
    `<span><b>${ITEMS.length}</b> total shelf</span>`,
    `<span class="on"><b>${on}</b> overlay on</span>`,
    `<span class="off"><b>${off}</b> overlay off</span>`,
    `<span><b>${noImage}</b> no image</span>`,
    `<span class="changed"><b>${decisions.length}</b> changed</span>`
  ].join("");
  els.copyLink.setAttribute("aria-disabled", decisions.length ? "false" : "true");
}

function renderFilters() {
  document.querySelectorAll("[data-filter]").forEach((button) => {
    button.setAttribute("aria-pressed", button.dataset.filter === state.filter ? "true" : "false");
  });
}

function topicMarkup(group) {
  return `
    <section class="topic-section" id="${topicSlug(group.topic)}">
      <header class="topic-heading">
        <h2 class="topic-label">${escapeHtml(group.topic)}</h2>
        <span class="topic-count">${group.items.length}</span>
      </header>
      <div class="grid">
        ${group.items.map(cardMarkup).join("")}
      </div>
    </section>
  `;
}

function cardMarkup(item) {
  const on = hasCoverLabel(item);
  const changed = hasOverride(item);
  const classes = [
    "cover-card",
    on ? "is-on" : "is-off",
    changed ? "is-changed" : "",
    item.image ? "" : "has-no-image"
  ].filter(Boolean).join(" ");
  const overlayText = item.coverLabelText || item.title || "Untitled";
  return `
    <article class="${classes}" data-path="${escapeAttr(item.path)}">
      <span class="cover-frame${item.image ? "" : " no-image"}">
        ${item.image ? `<img src="${escapeAttr(item.image)}" alt="">` : "No image"}
        <span class="cover-overlay" aria-hidden="true">
          <span class="cover-overlay-title">${escapeHtml(overlayText)}</span>
          <span class="cover-overlay-meta">${escapeHtml(item.author || "")}</span>
        </span>
      </span>
      <span class="item-copy">
        <span class="item-title">${escapeHtml(item.title || "Untitled")}</span>
        <span class="item-meta">${escapeHtml([item.author, item.type].filter(Boolean).join(" / "))}</span>
        <span class="toggle-row">
          <span class="toggle-label">${on ? "Overlay on" : "Overlay off"}${changed ? " / changed" : ""}</span>
          <button class="toggle" type="button" aria-pressed="${on ? "true" : "false"}" aria-label="${on ? "Turn overlay off" : "Turn overlay on"} for ${escapeAttr(item.title || "Untitled")}"></button>
        </span>
      </span>
    </article>
  `;
}

function bindCards() {
  document.querySelectorAll(".cover-card .toggle").forEach((button) => {
    button.addEventListener("click", () => {
      const card = button.closest("[data-path]");
      const item = card ? itemByPath.get(card.dataset.path) : null;
      if (!item) return;
      setCoverLabel(item.path, !hasCoverLabel(item));
    });
  });
}

function showExport() {
  els.exportText.textContent = JSON.stringify(exportPayload(), null, 2);
  els.exportPanel.classList.remove("hidden");
  els.exportText.focus();
}

async function copyExport() {
  const text = JSON.stringify(exportPayload(), null, 2);
  try {
    await navigator.clipboard.writeText(text);
  } catch (error) {
    showExport();
    els.exportText.textContent = text;
    els.exportText.focus();
  }
}

function resetChanges() {
  if (!window.confirm("Clear local cover-label decisions? This only resets browser state.")) return;
  state.coverLabelByPath = {};
  state.filter = "all";
  state.search = "";
  saveState();
  render();
}

function topicSlug(topic) {
  return topic.toLowerCase().replace(/&/g, "and").replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
}

function escapeHtml(value) {
  return String(value || "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function escapeAttr(value) {
  return escapeHtml(value).replace(/'/g, "&#39;");
}

function stopLink(event) {
  event.preventDefault();
}

loadState();
render();

els.searchInput.addEventListener("input", (event) => {
  state.search = event.currentTarget.value;
  saveState();
  render();
});

document.querySelectorAll("[data-filter]").forEach((button) => {
  button.addEventListener("click", () => {
    state.filter = button.dataset.filter;
    saveState();
    render();
  });
});

document.getElementById("exportLink").addEventListener("click", (event) => {
  stopLink(event);
  showExport();
});
document.getElementById("copyLink").addEventListener("click", (event) => {
  stopLink(event);
  if (event.currentTarget.getAttribute("aria-disabled") !== "true") copyExport();
});
document.getElementById("resetLink").addEventListener("click", (event) => {
  stopLink(event);
  resetChanges();
});
document.getElementById("closeExportLink").addEventListener("click", (event) => {
  stopLink(event);
  els.exportPanel.classList.add("hidden");
});
document.getElementById("copyExportLink").addEventListener("click", (event) => {
  stopLink(event);
  copyExport();
});
document.addEventListener("keydown", (event) => {
  if (event.key === "Escape") els.exportPanel.classList.add("hidden");
});
</script>
</body>
</html>
